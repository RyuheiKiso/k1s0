{
  "$schema": "https://k1s0.dev/schemas/manifest.json",
  "schema_version": "1.0.0",
  "k1s0_version": "{{ k1s0_version | default(value="0.1.0") }}",
  "template": {
    "name": "backend-python",
    "version": "{{ template_version | default(value="0.1.0") }}",
    "source": "local",
    "path": "CLI/templates/backend-python/feature",
    "fingerprint": "{{ fingerprint | default(value="") }}"
  },
  "service": {
    "service_name": "{{ feature_name }}",
    "language": "python",
    "type": "backend",
    "framework": "fastapi",
    "features": {
      "with_grpc": {{ with_grpc }},
      "with_rest": {{ with_rest }},
      "with_db": {{ with_db }},
      "with_cache": {{ with_cache }},
      "with_docker": {{ with_docker }}
    }
  },
  "layer": "feature",
  {% if has_domain | default(value=false) -%}
  "domain": "{{ domain_name }}",
  "domain_version": "{{ domain_version_constraint | default(value="^0.1.0") }}",
  {% else -%}
  "domain": null,
  "domain_version": null,
  {% endif -%}
  "generated_at": "{{ now | date(format="%Y-%m-%dT%H:%M:%SZ") }}",
  "managed_paths": [
    "deploy/",
    "proto/",
    "openapi/",
    "config/",
    "buf.yaml",
    "buf.gen.yaml",
    "pyproject.toml",
    "ruff.toml",
    "Dockerfile",
    "Dockerfile.monorepo",
    ".dockerignore",
    "compose.yaml",
    "compose.monorepo.yaml",
    "deploy/docker/"
  ],
  "protected_paths": [
    "src/{{ feature_name_snake }}/domain/",
    "src/{{ feature_name_snake }}/application/"
  ],
  "update_policy": {
    "deploy/": "auto",
    "config/": "suggest_only",
    "src/{{ feature_name_snake }}/domain/": "protected",
    "src/{{ feature_name_snake }}/application/": "protected",
    "src/{{ feature_name_snake }}/infrastructure/": "suggest_only",
    "src/{{ feature_name_snake }}/presentation/": "suggest_only",
    "tests/": "suggest_only",
    "Dockerfile": "auto",
    "Dockerfile.monorepo": "auto",
    ".dockerignore": "auto",
    "compose.yaml": "suggest_only",
    "compose.monorepo.yaml": "suggest_only",
    "deploy/docker/": "auto"
  },
  "checksums": {},
  "dependencies": {
    "framework": [
      "k1s0-error",
      "k1s0-config",
      "k1s0-observability"
    ],
    "framework_packages": [
      { "name": "k1s0-error", "version": "{{ k1s0_version | default(value="0.1.0") }}" },
      { "name": "k1s0-config", "version": "{{ k1s0_version | default(value="0.1.0") }}" },
      { "name": "k1s0-observability", "version": "{{ k1s0_version | default(value="0.1.0") }}" }
    ]{% if has_domain | default(value=false) %},
    "domain": {
      "{{ domain_name }}": "{{ domain_version_constraint | default(value="^0.1.0") }}"
    }{% endif %}
  }
}
