class Test{{ name_pascal }}Created:
    """Tests for {{ name_pascal }}Created domain event."""

    def test_create_event(self) -> None:
        event = {{ name_pascal }}Created(
            aggregate_id="test-id-001",
            {{ name_snake }}_name="Sample Name",
        )
        assert event.aggregate_id == "test-id-001"
        assert event.{{ name_snake }}_name == "Sample Name"
        assert event.occurred_at is not None
        assert event.event_id is not None

    def test_event_is_immutable(self) -> None:
        event = {{ name_pascal }}Created(
            aggregate_id="test-id-001",
            {{ name_snake }}_name="Sample Name",
        )
        with pytest.raises(AttributeError):
            event.aggregate_id = "changed"  # type: ignore[misc]
{% endif %}