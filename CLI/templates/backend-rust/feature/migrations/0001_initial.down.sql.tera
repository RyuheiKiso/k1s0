-- {{ feature_name }} 初期マイグレーション (ロールバック)
-- Generated at {{ now | date(format="%Y-%m-%d") }}

-- トリガーを削除
DROP TRIGGER IF EXISTS trigger_{{ feature_name | snake_case }}_updated_at ON {{ feature_name | snake_case }};

-- 関数を削除
DROP FUNCTION IF EXISTS update_{{ feature_name | snake_case }}_updated_at();

-- インデックスを削除
{% if has_name_field | default(value=true) -%}
DROP INDEX IF EXISTS idx_{{ feature_name | snake_case }}_name;
{% endif -%}
{% if has_status_field | default(value=true) -%}
DROP INDEX IF EXISTS idx_{{ feature_name | snake_case }}_status;
{% endif -%}
DROP INDEX IF EXISTS idx_{{ feature_name | snake_case }}_created_at;

-- テーブルを削除
DROP TABLE IF EXISTS {{ feature_name | snake_case }};
