# {{ service_name }} 設定ファイル（dev 環境）
#
# ローカル開発環境向けの設定。
# default.yaml を上書きする値のみ記載する。
#
# 規約:
# - 機密値（パスワード、APIキー等）は直接書かない
# - 機密値は *_file キーでファイルパスを参照する

# データベース設定（dev 環境）
db:
  host: "localhost"
  name: "{{ service_name | replace(from="-", to="_") }}_dev"
  # ローカル開発用の機密値ファイル
  password_file: "./secrets/dev/db_password"
  pool:
    min_connections: 1
    max_connections: 5

# キャッシュ設定（dev 環境）
cache:
  host: "localhost"

# 観測性設定（dev 環境）
observability:
  logging:
    level: "debug"
  tracing:
    # ローカルの OTel Collector
    endpoint: "http://localhost:4317"
    sample_rate: 1.0
