apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - ../../base

namespace: {{ feature_name }}-dev

commonLabels:
  env: dev

replicas:
  - name: {{ feature_name }}
    count: 1

configMapGenerator:
  - name: {{ feature_name }}-config
    behavior: merge
    files:
      - dev.yaml=config/dev.yaml
