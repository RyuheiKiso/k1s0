//! {{ name_title }} domain 統合テスト

use {{ name_snake }}::domain::entities::{{"{"}}{{ name_pascal }}, {{ name_pascal }}Id};
use {{ name_snake }}::domain::value_objects::{{ name_pascal }}Name;

#[test]
fn test_entity_creation() {
    let id = {{ name_pascal }}Id::new("test-id-1");
    let entity = {{ name_pascal }}::new(id.clone(), "Test Name");

    assert_eq!(entity.id(), &id);
    assert_eq!(entity.name(), "Test Name");
}

#[test]
fn test_entity_equality_by_id() {
    let id = {{ name_pascal }}Id::new("same-id");
    let entity1 = {{ name_pascal }}::new(id.clone(), "Name 1");
    let entity2 = {{ name_pascal }}::new(id, "Name 2");

    assert_eq!(entity1, entity2);
}

#[test]
fn test_entity_update_name() {
    let id = {{ name_pascal }}Id::new("test-id");
    let mut entity = {{ name_pascal }}::new(id, "Old Name");

    entity.update_name("New Name");
    assert_eq!(entity.name(), "New Name");
}

#[test]
fn test_value_object_name_valid() {
    let name = {{ name_pascal }}Name::new("Valid Name");
    assert!(name.is_ok());
    assert_eq!(name.unwrap().value(), "Valid Name");
}

#[test]
fn test_value_object_name_empty() {
    let name = {{ name_pascal }}Name::new("");
    assert!(name.is_err());
}

#[test]
fn test_id_display() {
    let id = {{ name_pascal }}Id::new("display-test");
    assert_eq!(format!("{}", id), "display-test");
}
