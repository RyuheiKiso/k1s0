apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {{ namespace | default(value="k1s0-dev") }}

resources:
  - ../../base

replicas:
  - name: {{ feature_name_kebab }}
    count: 1

configMapGenerator:
  - name: {{ feature_name_kebab }}-config
    behavior: merge
    literals:
      - APP_ENV=dev
      - API_BASE_URL={{ api_base_url_dev | default(value="http://api-gateway.k1s0-dev.svc.cluster.local:8080") }}
