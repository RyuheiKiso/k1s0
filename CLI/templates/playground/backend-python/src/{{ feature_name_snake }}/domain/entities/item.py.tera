"""Item domain entities."""

from datetime import datetime
from pydantic import BaseModel


class Item(BaseModel):
    id: int
    name: str
    description: str | None = None
    created_at: datetime


class CreateItem(BaseModel):
    name: str
    description: str | None = None


class UpdateItem(BaseModel):
    name: str | None = None
    description: str | None = None
