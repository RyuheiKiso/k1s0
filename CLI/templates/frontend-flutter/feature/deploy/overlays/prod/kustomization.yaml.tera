apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {{ namespace | default(value="k1s0-prod") }}

resources:
  - ../../base

replicas:
  - name: {{ feature_name_kebab }}
    count: 3

configMapGenerator:
  - name: {{ feature_name_kebab }}-config
    behavior: merge
    literals:
      - FLUTTER_ENV=prod
      - API_BASE_URL={{ api_base_url_prod | default(value="https://api.example.com") }}
