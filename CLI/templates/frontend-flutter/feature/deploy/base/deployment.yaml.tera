apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ feature_name_kebab }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ feature_name_kebab }}
  template:
    metadata:
      labels:
        app: {{ feature_name_kebab }}
    spec:
      containers:
        - name: {{ feature_name_kebab }}
          image: {{ feature_name_kebab }}
          ports:
            - name: http
              containerPort: {{ port | default(value=80) }}
              protocol: TCP
          envFrom:
            - configMapRef:
                name: {{ feature_name_kebab }}-config
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 200m
              memory: 256Mi
          livenessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
