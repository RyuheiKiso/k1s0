apiVersion: v1
kind: Service
metadata:
  name: {{ feature_name_kebab }}
spec:
  type: ClusterIP
  selector:
    app: {{ feature_name_kebab }}
  ports:
    - name: grpc
      port: {{ grpc_port | default(value=50051) }}
      targetPort: grpc
      protocol: TCP
{% if has_rest | default(value=false) %}
    - name: http
      port: {{ rest_port | default(value=8080) }}
      targetPort: http
      protocol: TCP
{% endif %}
