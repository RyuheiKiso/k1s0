apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {{ namespace | default(value="k1s0-stg") }}

resources:
  - ../../base

replicas:
  - name: {{ feature_name_kebab }}
    count: 2

configMapGenerator:
  - name: {{ feature_name_kebab }}-config
    behavior: merge
    literals:
      - ENV=stg
      - LOG_LEVEL=info
