apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {{ namespace | default(value="k1s0-dev") }}

resources:
  - ../../base

replicas:
  - name: {{ feature_name_kebab }}
    count: 1

patches:
  - patch: |-
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/cpu
        value: 50m
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/memory
        value: 64Mi
    target:
      kind: Deployment
      name: {{ feature_name_kebab }}

configMapGenerator:
  - name: {{ feature_name_kebab }}-config
    behavior: merge
    literals:
      - ENV=dev
      - LOG_LEVEL=debug
