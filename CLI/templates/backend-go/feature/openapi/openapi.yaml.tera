openapi: 3.0.3
info:
  title: {{ feature_name_title }} API
  description: {{ feature_description | default(value="k1s0 generated Go service API") }}
  version: {{ version | default(value="0.1.0") }}
  contact:
    name: k1s0 Team

servers:
  - url: http://localhost:{{ rest_port | default(value=8080) }}
    description: Local development server

paths:
  /v1/{{ feature_name_kebab }}:
    get:
      summary: List {{ feature_name }}
      operationId: list{{ feature_name_pascal }}
      tags:
        - {{ feature_name_pascal }}
      parameters:
        - name: page_size
          in: query
          schema:
            type: integer
            default: 100
        - name: page_token
          in: query
          schema:
            type: string
      responses:
        '200':
          description: List of {{ feature_name }}
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/List{{ feature_name_pascal }}Response'

    post:
      summary: Create {{ feature_name }}
      operationId: create{{ feature_name_pascal }}
      tags:
        - {{ feature_name_pascal }}
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Create{{ feature_name_pascal }}Request'
      responses:
        '201':
          description: Created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ feature_name_pascal }}'

  /v1/{{ feature_name_kebab }}/{id}:
    get:
      summary: Get {{ feature_name }}
      operationId: get{{ feature_name_pascal }}
      tags:
        - {{ feature_name_pascal }}
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
            format: uuid
      responses:
        '200':
          description: {{ feature_name_pascal }} found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ feature_name_pascal }}'
        '404':
          description: Not found

    put:
      summary: Update {{ feature_name }}
      operationId: update{{ feature_name_pascal }}
      tags:
        - {{ feature_name_pascal }}
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
            format: uuid
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Update{{ feature_name_pascal }}Request'
      responses:
        '200':
          description: Updated
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ feature_name_pascal }}'

    delete:
      summary: Delete {{ feature_name }}
      operationId: delete{{ feature_name_pascal }}
      tags:
        - {{ feature_name_pascal }}
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
            format: uuid
      responses:
        '204':
          description: Deleted

  /health:
    get:
      summary: Health check
      operationId: healthCheck
      tags:
        - Health
      responses:
        '200':
          description: Service is healthy

components:
  schemas:
    {{ feature_name_pascal }}:
      type: object
      properties:
        id:
          type: string
          format: uuid
        name:
          type: string
        status:
          type: integer
        created_at:
          type: string
          format: date-time
        updated_at:
          type: string
          format: date-time

    Create{{ feature_name_pascal }}Request:
      type: object
      required:
        - name
      properties:
        name:
          type: string

    Update{{ feature_name_pascal }}Request:
      type: object
      properties:
        name:
          type: string
        status:
          type: integer

    List{{ feature_name_pascal }}Response:
      type: object
      properties:
        {{ feature_name_snake }}s:
          type: array
          items:
            $ref: '#/components/schemas/{{ feature_name_pascal }}'
        next_page_token:
          type: string

tags:
  - name: {{ feature_name_pascal }}
    description: {{ feature_name_pascal }} operations
  - name: Health
    description: Health check operations
