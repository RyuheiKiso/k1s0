// Package usecases contains application use cases
package usecases

import (
	"context"

	"github.com/google/uuid"

	"{{ module_path | default(value="example.com") }}/{{ feature_name | snake_case }}/internal/domain/entities"
	"{{ module_path | default(value="example.com") }}/{{ feature_name | snake_case }}/internal/domain/errors"
	"{{ module_path | default(value="example.com") }}/{{ feature_name | snake_case }}/internal/domain/ports"
)

// {{ feature_name | pascal_case }}UseCase defines the use case interface.
type {{ feature_name | pascal_case }}UseCase interface {
	Get(ctx context.Context, id uuid.UUID) (*entities.{{ feature_name | pascal_case }}, error)
	List(ctx context.Context, pageSize int, pageToken string) ([]*entities.{{ feature_name | pascal_case }}, string, error)
	Create(ctx context.Context, name string) (*entities.{{ feature_name | pascal_case }}, error)
	Update(ctx context.Context, id uuid.UUID, name string, status *int) (*entities.{{ feature_name | pascal_case }}, error)
	Delete(ctx context.Context, id uuid.UUID) error
}

// {{ feature_name | pascal_case }}UseCaseImpl implements {{ feature_name | pascal_case }}UseCase.
type {{ feature_name | pascal_case }}UseCaseImpl struct {
	repo ports.{{ feature_name | pascal_case }}Repository
}

// New{{ feature_name | pascal_case }}UseCase creates a new use case.
func New{{ feature_name | pascal_case }}UseCase(repo ports.{{ feature_name | pascal_case }}Repository) *{{ feature_name | pascal_case }}UseCaseImpl {
	return &{{ feature_name | pascal_case }}UseCaseImpl{repo: repo}
}

// Get retrieves a {{ feature_name }} by ID.
func (uc *{{ feature_name | pascal_case }}UseCaseImpl) Get(ctx context.Context, id uuid.UUID) (*entities.{{ feature_name | pascal_case }}, error) {
	entity, err := uc.repo.FindByID(ctx, id)
	if err != nil {
		return nil, err
	}
	if entity == nil {
		return nil, errors.NewNotFoundError("{{ feature_name | pascal_case }}", id.String())
	}
	return entity, nil
}

// List retrieves all {{ feature_name }}s with pagination.
func (uc *{{ feature_name | pascal_case }}UseCaseImpl) List(ctx context.Context, pageSize int, pageToken string) ([]*entities.{{ feature_name | pascal_case }}, string, error) {
	if pageSize <= 0 || pageSize > 1000 {
		pageSize = 100
	}
	return uc.repo.FindAll(ctx, pageSize, pageToken)
}

// Create creates a new {{ feature_name }}.
func (uc *{{ feature_name | pascal_case }}UseCaseImpl) Create(ctx context.Context, name string) (*entities.{{ feature_name | pascal_case }}, error) {
	if name == "" {
		return nil, errors.NewValidationError("name is required")
	}

	entity := entities.New{{ feature_name | pascal_case }}(name)
	if err := uc.repo.Save(ctx, entity); err != nil {
		return nil, err
	}
	return entity, nil
}

// Update updates an existing {{ feature_name }}.
func (uc *{{ feature_name | pascal_case }}UseCaseImpl) Update(ctx context.Context, id uuid.UUID, name string, status *int) (*entities.{{ feature_name | pascal_case }}, error) {
	entity, err := uc.repo.FindByID(ctx, id)
	if err != nil {
		return nil, err
	}
	if entity == nil {
		return nil, errors.NewNotFoundError("{{ feature_name | pascal_case }}", id.String())
	}

	if name != "" {
		entity.Update(name)
	}
	if status != nil {
		entity.Status = *status
	}

	if err := uc.repo.Save(ctx, entity); err != nil {
		return nil, err
	}
	return entity, nil
}

// Delete deletes a {{ feature_name }} by ID.
func (uc *{{ feature_name | pascal_case }}UseCaseImpl) Delete(ctx context.Context, id uuid.UUID) error {
	return uc.repo.Delete(ctx, id)
}
