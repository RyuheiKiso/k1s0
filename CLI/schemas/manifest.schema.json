{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://k1s0.dev/schemas/manifest.schema.json",
  "title": "k1s0 Manifest",
  "description": "k1s0 によって生成されたサービスのメタ情報。CLI が管理し、手動編集は非推奨。",
  "type": "object",
  "required": [
    "schema_version",
    "k1s0_version",
    "template",
    "service",
    "generated_at",
    "managed_paths",
    "protected_paths"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "manifest スキーマのバージョン",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "k1s0_version": {
      "type": "string",
      "description": "生成時の k1s0 バージョン（SemVer）",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["0.1.0"]
    },
    "template": {
      "type": "object",
      "description": "生成元テンプレートの情報",
      "required": ["name", "version", "path", "fingerprint"],
      "properties": {
        "name": {
          "type": "string",
          "description": "テンプレート名",
          "examples": ["backend-rust", "frontend-react"]
        },
        "version": {
          "type": "string",
          "description": "テンプレートバージョン（= k1s0_version）",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "source": {
          "type": "string",
          "description": "テンプレートのソース（local / registry）",
          "enum": ["local", "registry"],
          "default": "local"
        },
        "path": {
          "type": "string",
          "description": "テンプレートのパス（k1s0 リポジトリ内の相対パス）",
          "examples": ["CLI/templates/backend-rust/feature"]
        },
        "revision": {
          "type": "string",
          "description": "テンプレートの Git リビジョン（コミットハッシュ）",
          "pattern": "^[a-f0-9]{40}$"
        },
        "fingerprint": {
          "type": "string",
          "description": "テンプレートの fingerprint（SHA-256 ハッシュ）",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "description": "生成されたサービスの情報",
      "required": ["service_name", "language", "type"],
      "properties": {
        "service_name": {
          "type": "string",
          "description": "サービス名（kebab-case）",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
          "examples": ["user-management", "order-processing"]
        },
        "language": {
          "type": "string",
          "description": "プログラミング言語",
          "enum": ["rust", "go", "csharp", "python", "typescript", "dart"]
        },
        "type": {
          "type": "string",
          "description": "サービスタイプ",
          "enum": ["backend", "frontend", "bff"]
        },
        "framework": {
          "type": "string",
          "description": "使用フレームワーク",
          "examples": ["axum", "react", "flutter"]
        }
      },
      "additionalProperties": false
    },
    "layer": {
      "type": "string",
      "description": "サービスが属する層。framework: 技術基盤層、domain: 業務領域共通層、feature: 個別機能層。未指定の場合は feature として扱う（後方互換性）",
      "enum": ["framework", "domain", "feature"],
      "default": "feature",
      "examples": ["feature", "domain", "framework"]
    },
    "domain": {
      "type": ["string", "null"],
      "description": "feature 層の場合に所属するドメイン名。domain 層および framework 層の場合は null。kebab-case で指定。",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "default": null,
      "examples": ["finance", "inventory", "customer", null]
    },
    "version": {
      "type": "string",
      "description": "domain 層のバージョン（SemVer 形式）。domain 層では必須。",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "examples": ["1.0.0", "0.1.0", "2.0.0-beta.1"]
    },
    "domain_version": {
      "type": "string",
      "description": "feature 層が依存する domain のバージョン制約。domain フィールドが指定されている場合に使用。",
      "examples": ["^1.2.0", ">=1.0.0 <2.0.0", "~1.2.0"]
    },
    "min_framework_version": {
      "type": "string",
      "description": "この domain が動作するために必要な最小の k1s0 framework バージョン。",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "examples": ["0.1.0", "1.0.0"]
    },
    "breaking_changes": {
      "type": "object",
      "description": "メジャーバージョンごとの破壊的変更の説明。キーはバージョン番号、値は変更内容。",
      "additionalProperties": {
        "type": "string"
      },
      "examples": [
        {
          "2.0.0": "EntityA のフィールド名を変更",
          "1.0.0": "初回リリース"
        }
      ]
    },
    "deprecated": {
      "oneOf": [
        {
          "type": "boolean",
          "description": "単純な非推奨フラグ"
        },
        {
          "type": "object",
          "description": "詳細な非推奨情報",
          "properties": {
            "since": {
              "type": "string",
              "description": "非推奨化されたバージョン",
              "examples": ["1.5.0"]
            },
            "migrate_to": {
              "type": "string",
              "description": "移行先の domain 名",
              "examples": ["finance-v2"]
            },
            "deadline": {
              "type": "string",
              "description": "削除予定日（ISO 8601 日付形式）",
              "format": "date",
              "examples": ["2026-06-01"]
            },
            "reason": {
              "type": "string",
              "description": "非推奨化の理由"
            }
          }
        }
      ],
      "description": "非推奨フラグまたは非推奨情報"
    },
    "generated_at": {
      "type": "string",
      "description": "生成日時（ISO 8601 形式）",
      "format": "date-time",
      "examples": ["2026-01-25T10:30:00Z"]
    },
    "managed_paths": {
      "type": "array",
      "description": "CLI が管理するパス（upgrade 時に自動更新される）",
      "items": {
        "type": "string"
      },
      "examples": [
        ["deploy/", "config/", ".github/"]
      ]
    },
    "protected_paths": {
      "type": "array",
      "description": "CLI が変更しないパス（ビジネスロジック領域）",
      "items": {
        "type": "string"
      },
      "examples": [
        ["src/domain/", "src/application/"]
      ]
    },
    "update_policy": {
      "type": "object",
      "description": "パス別の更新ポリシー",
      "additionalProperties": {
        "type": "string",
        "enum": ["auto", "suggest_only", "protected"],
        "description": "auto: 自動更新, suggest_only: 差分提示のみ, protected: 変更しない"
      },
      "examples": [
        {
          "src/main.rs": "suggest_only",
          "src/presentation/": "suggest_only",
          "src/infrastructure/": "suggest_only"
        }
      ]
    },
    "checksums": {
      "type": "object",
      "description": "managed_paths 内のファイルのチェックサム（変更検知用）",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "examples": [
        {
          "deploy/base/deployment.yaml": "abc123...",
          "config/default.yaml": "def456..."
        }
      ]
    },
    "template_snapshot": {
      "type": "object",
      "description": "生成時のテンプレートファイル一覧とハッシュ（差分計算用）",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "dependencies": {
      "type": "object",
      "description": "framework crate および domain への依存情報",
      "properties": {
        "framework_crates": {
          "type": "array",
          "description": "使用する framework クレート/パッケージ",
          "items": {
            "type": "object",
            "required": ["name", "version"],
            "properties": {
              "name": {
                "type": "string",
                "examples": ["k1s0-config", "k1s0-error"]
              },
              "version": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              }
            }
          }
        },
        "framework": {
          "type": "array",
          "description": "使用する framework クレート/パッケージ名（簡易形式）",
          "items": {
            "type": "string"
          },
          "examples": [["k1s0-error", "k1s0-config", "k1s0-grpc-server"]]
        },
        "domain": {
          "type": "object",
          "description": "使用する domain 名とバージョン制約",
          "additionalProperties": {
            "type": "string"
          },
          "examples": [
            {
              "manufacturing": "^1.2.0",
              "finance": ">=1.0.0 <2.0.0"
            }
          ]
        }
      }
    }
  },
  "additionalProperties": false
}
