// H-018 監査対応: main 関数の戻り値を anyhow::Result<()> にし、
// expect() による強制パニックを ? 演算子による適切なエラー伝播に置き換える。
// anyhow クレートを Cargo.toml の dependencies に追加すること。
use anyhow::Result;
use axum::{routing::get, Json, Router};
use serde_json::json;
use std::net::SocketAddr;
use tower_http::cors::CorsLayer;
use tower_http::trace::TraceLayer;

use k1s0_telemetry::TelemetryConfig;
use k1s0_auth::JwksVerifier;


mod adapter;
mod domain;
mod infra;
mod usecase;

use infra::config::Config;

// H-018 監査対応: 起動エラーを anyhow::Result で伝播する（expect パニック廃止）
#[tokio::main]
async fn main() -> Result<()> {

    // --- Config ---
    // H-018 監査対応: ? 演算子でエラーを上位に伝播する（expect パニック廃止）
    let config = Config::load("config/config.yaml")?;

    // --- Telemetry (k1s0-telemetry) ---
    k1s0_telemetry::init_telemetry(&TelemetryConfig {
        service_name: config.app.name.clone(),
        version: config.app.version.clone(),
        tier: config.app.tier.clone(),
        environment: config.app.environment.clone(),
        trace_endpoint: config.observability.trace.enabled
            .then(|| config.observability.trace.endpoint.clone()),
        sample_rate: config.observability.trace.sample_rate,
        log_level: config.observability.log.level.clone(),
        log_format: config.observability.log.format.clone(),
    })?;

    // --- Auth Verifier (k1s0-auth) ---
    let _verifier = JwksVerifier::new(
        config.auth.oidc.as_ref().map(|o| o.jwks_uri.as_str()).unwrap_or(""),
        &config.auth.jwt.issuer,
        &config.auth.jwt.audience,
        std::time::Duration::from_secs(600),
    )?;






    // --- DI: Repository → UseCase → Handler ---

    let uc = usecase::TaskApiUseCase::new(

    );
    let handler = adapter::handler::AppHandler::new(uc);



    // --- Router ---
    let app = Router::new()
        .route("/healthz", get(|| async { Json(json!({"status": "ok"})) }))
        .route("/readyz", get({

            move || async move {

                Json(json!({"status": "ready"}))

            }
        }))
        .merge(handler.routes())
        .layer(TraceLayer::new_for_http())
        // H-016 監査対応: 本番環境では ALLOWED_ORIGIN 環境変数から CORS 許可オリジンを設定する。
        // 未設定の場合は開発用のすべてオリジン許可（permissive）を使用する。
        .layer({
            let origin = std::env::var("ALLOWED_ORIGIN").ok();
            match origin {
                Some(origin) => CorsLayer::new()
                    .allow_origin(origin.parse::<axum::http::HeaderValue>().expect("Invalid ALLOWED_ORIGIN"))
                    .allow_methods(tower_http::cors::Any)
                    .allow_headers(tower_http::cors::Any),
                None => CorsLayer::permissive(),
            }
        });

    // --- Server ---
    // H-018 監査対応: アドレスパース失敗は ? で伝播する
    let addr: SocketAddr = format!("0.0.0.0:{}", config.server.port)
        .parse()?;
    tracing::info!("server starting on {}", addr);

    // H-018 監査対応: バインド失敗は ? で伝播する
    let listener = tokio::net::TcpListener::bind(addr)
        .await?;

    // --- Graceful Shutdown ---
    // H-018 監査対応: サーバーエラーは ? で伝播する
    axum::serve(listener, app)
        .with_graceful_shutdown(shutdown_signal())
        .await?;

    k1s0_telemetry::shutdown();

    Ok(())
}

async fn shutdown_signal() {
    let ctrl_c = async {
        tokio::signal::ctrl_c()
            .await
            // シャットダウンシグナルハンドラは ? が使用できないため expect を維持する
            .expect("Failed to install Ctrl+C handler");
    };

    #[cfg(unix)]
    let terminate = async {
        tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate())
            .expect("Failed to install signal handler")
            .recv()
            .await;
    };

    #[cfg(not(unix))]
    let terminate = std::future::pending::<()>();

    tokio::select! {
        _ = ctrl_c => {},
        _ = terminate => {},
    }
    tracing::info!("shutdown signal received");
}
