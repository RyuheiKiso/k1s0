package main

import (
	"context"
	"log/slog"

	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"github.com/gin-gonic/gin"
	"go.opentelemetry.io/contrib/instrumentation/github.com/gin-gonic/gin/otelgin"

	telemetry "github.com/k1s0-platform/system-library-go-telemetry"
	auth "github.com/k1s0-platform/system-library-go-auth"



	"github.com/org/k1s0/regions/service/task-api/server/go/internal/adapter/handler"
	"github.com/org/k1s0/regions/service/task-api/server/go/internal/infra/config"


	"github.com/org/k1s0/regions/service/task-api/server/go/internal/usecase"
)

func main() {
	// --- Config ---
	cfg, err := config.Load("config/config.yaml")
	if err != nil {
		slog.Error("failed to load config", "error", err)
		os.Exit(1)
	}


	// --- Telemetry (k1s0-telemetry) ---
	tel, err := telemetry.InitTelemetry(context.Background(), telemetry.TelemetryConfig{
		ServiceName:   cfg.App.Name,
		Version:       cfg.App.Version,
		Tier:          cfg.App.Tier,
		Environment:   cfg.App.Environment,
		TraceEndpoint: cfg.Observability.Trace.Endpoint,
		SampleRate:    cfg.Observability.Trace.SampleRate,
		LogLevel:      cfg.Observability.Log.Level,
		LogFormat:     cfg.Observability.Log.Format,
	})
	if err != nil {
		slog.Error("failed to init telemetry", "error", err)
		os.Exit(1)
	}
	defer tel.Shutdown(context.Background())
	slog.SetDefault(tel.Logger())

	// --- Auth Verifier (k1s0-auth) ---
	jwksURI := ""
	if cfg.Auth.OIDC != nil {
		jwksURI = cfg.Auth.OIDC.JWKSURI
	}
	_ = auth.NewJWKSVerifier(jwksURI, cfg.Auth.JWT.Issuer, cfg.Auth.JWT.Audience, 10*time.Minute)






	// --- DI: Repository → UseCase → Handler ---

	uc := usecase.NewTaskApiUseCase(

	)
	h := handler.NewHandler(uc)

	// --- Router ---
	r := gin.New()
	r.Use(gin.Recovery())
	r.Use(otelgin.Middleware("task-api"))

	// ヘルスチェック
	r.GET("/healthz", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{"status": "ok"})
	})
	r.GET("/readyz", func(c *gin.Context) {

		c.JSON(http.StatusOK, gin.H{"status": "ready"})
	})

	// API ルート登録
	h.RegisterRoutes(r)



	// --- HTTP Server ---
	srv := &http.Server{
		Addr:    ":" + cfg.Server.Port,
		Handler: r,
	}

	go func() {
		slog.Info("server starting", "port", cfg.Server.Port)
		if err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			slog.Error("server failed", "error", err)
			os.Exit(1)
		}
	}()

	// --- Graceful Shutdown ---
	quit := make(chan os.Signal, 1)
	signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)
	<-quit
	slog.Info("shutting down server...")

	ctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)
	defer cancel()

	if err := srv.Shutdown(ctx); err != nil {
		slog.Error("server forced to shutdown", "error", err)
	}
	slog.Info("server exited")
}
