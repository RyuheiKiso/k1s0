# Consul バックエンド設定 — Terraform State をConsulに保存する
# 本番環境では ACL ブートストラップが必要: consul acl bootstrap
# CONSUL_HTTP_TOKEN 環境変数に ACL トークンを設定すること
terraform {
  backend "consul" {
    address = "consul.k1s0-system.svc:8500"
    scheme  = "https"
    path    = "k1s0/{{ tier }}/{{ service_name }}/terraform.tfstate"
    lock    = true
    # ACLトークン: 環境変数 CONSUL_HTTP_TOKEN から自動取得される
    # 明示的に指定する場合は以下を有効化する:
    # token = var.consul_acl_token
  }
}
