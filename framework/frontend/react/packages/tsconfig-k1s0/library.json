{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_description": "@k1s0/tsconfig - TypeScript configuration for libraries/packages",
  "extends": "./base.json",
  "compilerOptions": {
    /* Language and Environment */
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    /* Emit - Libraries need declaration files */
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    /* Composite Projects */
    "composite": false,
    "incremental": true
  }
}
