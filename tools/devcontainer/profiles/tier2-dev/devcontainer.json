{
    "name": "k1s0 tier2-dev (Phase 2)",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "../../../.."
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest"
        }
    },
    "remoteUser": "vscode",
    "workspaceFolder": "/workspaces/k1s0",
    "postCreateCommand": "bash tools/devcontainer/postCreate.sh",
    "containerEnv": {
        "K1S0_DEV_ROLE": "tier2-dev"
    },
    "mounts": [
        "source=k1s0-nuget,target=/home/vscode/.nuget/packages,type=volume",
        "source=k1s0-go-mod-tier2,target=/go/pkg/mod,type=volume"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "eamodio.gitlens",
                "EditorConfig.EditorConfig",
                "tamasfe.even-better-toml",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker",
                "ms-dotnettools.csharp",
                "ms-dotnettools.csdevkit",
                "golang.go",
                "zxh404.vscode-proto3",
                "bufbuild.vscode-buf",
                "ms-kubernetes-tools.vscode-kubernetes-tools"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.rulers": [120],
                "files.insertFinalNewline": true,
                "files.trimTrailingWhitespace": true,
                "dotnet.defaultSolution": "disable",
                "omnisharp.useModernNet": true,
                "go.useLanguageServer": true,
                "go.formatTool": "goimports",
                "[csharp]": {
                    "editor.defaultFormatter": "ms-dotnettools.csharp"
                },
                "[go]": {
                    "editor.defaultFormatter": "golang.go"
                }
            }
        }
    }
}
