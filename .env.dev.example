# =============================================================================
# k1s0 開発環境設定ファイルのテンプレート
# =============================================================================
# 使用方法:
#   1. このファイルをコピー: cp .env.dev.example .env.dev
#   2. 各値を実際の値に変更してください
#   3. セキュリティキーの生成: openssl rand -hex 32
#
# 警告: .env.dev は本番環境では絶対に使用しないこと。
#       本番の秘密情報は Vault / Kubernetes Secrets で管理してください。
# =============================================================================

# ============================================================
# PostgreSQL
# ============================================================
# PostgreSQL スーパーユーザーのパスワード（docker-compose.yaml の POSTGRES_PASSWORD）
POSTGRES_PASSWORD=<change-me>
# INFRA-HIGH-003 対応: dev スーパーユーザーの認証情報を変数として一元管理する
# docker-compose.dev.yaml の DATABASE_URL から直接パスワードを除去し、この変数を参照する
DEV_DB_USER=dev
DEV_DB_PASSWORD=<change-me>
# k1s0 アプリケーションユーザーのパスワード（infra/docker/init-db/00-create-app-user.sh で参照）
K1S0_DB_PASSWORD=<change-me>

# ============================================================
# Redis（キャッシュ用）
# ============================================================
# Redis キャッシュのパスワード
REDIS_PASSWORD=<change-me>

# ============================================================
# Redis（セッション用）
# ============================================================
# Redis セッションのパスワード（キャッシュ用と独立して設定すること）
REDIS_SESSION_PASSWORD=<change-me>

# ============================================================
# Keycloak
# ============================================================
# Keycloak が内部で使用する PostgreSQL データベースのパスワード
KC_DB_PASSWORD=<change-me>
# Keycloak 管理者アカウントのパスワード
KEYCLOAK_ADMIN_PASSWORD=<change-me>
# BFF クライアントの OAuth2 シークレット（Keycloak で生成した値を使用すること）
KC_BFF_CLIENT_SECRET=<change-me>
# サービスアカウント用クライアントシークレット
KC_SERVICE_CLIENT_SECRET=<change-me>
# H-015 監査対応: auth-rust-admin クライアントのシークレット変数を追加
# realm-k1s0.json の ${KC_AUTH_ADMIN_SECRET:-dev-service-secret} で参照される
KC_AUTH_ADMIN_SECRET=<change-me>
# ローカル開発用テストアカウントのパスワード（本番環境では使用しないこと）
KC_TEST_ADMIN_PASSWORD=<change-me>
KC_TEST_USER_PASSWORD=<change-me>
KC_TEST_TASK_MGR_PASSWORD=<change-me>

# ============================================================
# Vault（dev モード: インメモリ。本番では絶対使用不可）
# ============================================================
# Vault dev モードのルートトークン（本番では必ず Vault の自動アンシール・Raft HA を使用すること）
VAULT_DEV_ROOT_TOKEN_ID=<change-me>

# M-001 監査対応: Vault マスターキー（未設定の場合、再起動でシークレットが失われます）
# 生成方法: openssl rand -hex 32
VAULT_MASTER_KEY=<generate: openssl rand -hex 32 の出力を使用すること>

# ============================================================
# Grafana
# ============================================================
# Grafana 管理者パスワード
GF_SECURITY_ADMIN_PASSWORD=<change-me>

# ============================================================
# Docker Compose ビルド設定（C-7 監査対応）
# ============================================================
# Docker 並列ビルド数を制限してメモリ不足（OOM）によるクラッシュを防ぐ
# デフォルトでは CPU コア数に比例するが、大規模モノリポでは OOM になりやすいため制限する
# 注意: COMPOSE_PARALLEL_LIMIT は `up` のみに効果があり `build` には効果がない（HIGH-2 監査対応）
#      ビルド時は `just docker-build-safe` (--parallel 2) を使用すること
COMPOSE_PARALLEL_LIMIT=4

# ============================================================
# BFF セッション暗号化設定（MED-8 監査対応）
# ============================================================
# bff-proxy はこの値が設定されていない場合、セッションデータを Redis に平文で保存する。
# 本番環境では必ず openssl rand -hex 32 で生成したランダム値に変更すること
# 生成コマンド: openssl rand -hex 32
# H-06 監査対応: オールゼロキーを開発用固定値に変更（本番では必ずランダム値を使用すること）
# L-01 監査対応: パターン値から openssl rand -hex 32 生成のランダム値に変更する
SESSION_ENCRYPTION_KEY=<generate: openssl rand -hex 32 の出力を使用すること>

# ============================================================
# notification ポート設定（MED-15 監査対応）
# ============================================================
# デフォルト 8100 は macOS の XGRID サービス（ポート 8100）と衝突する可能性があるため、
# ローカル開発では 8122 に明示設定してポート競合を解消する。
NOTIFICATION_REST_HOST_PORT=8122

# ============================================================
# API Key ペッパー（HIGH-02 監査対応）
# ============================================================
# auth-rust の API キー HMAC-SHA256 ハッシュに使用するペッパー値。
# 本番環境では Vault から注入し、openssl rand -hex 32 で生成した値を使用すること。
# 以下はローカル開発専用の固定値であり、本番環境では絶対に使用しないこと。
API_KEY_PEPPER=<generate: openssl rand -hex 32 の出力を使用すること>
