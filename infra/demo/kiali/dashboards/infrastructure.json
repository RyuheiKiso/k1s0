  "panels": [
    {
      "title": "Node CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{id=\"/\",image=\"\"}[5m])) by (instance)", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "cores" } }
    },
    {
      "title": "Node Memory Working Set",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(container_memory_working_set_bytes{id=\"/\",image=\"\"}) by (instance)", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Namespace CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"k1s0-.*|messaging|observability|service-mesh\",container!=\"\",image!=\"\"}[5m])) by (namespace)", "legendFormat": "{{namespace}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "cores" } }
    },
    {
      "title": "Namespace Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(container_memory_working_set_bytes{namespace=~\"k1s0-.*|messaging|observability|service-mesh\",container!=\"\",image!=\"\"}) by (namespace)", "legendFormat": "{{namespace}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Pod Count by Namespace",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(container_last_seen{namespace=~\"k1s0-.*|messaging|observability|service-mesh\",container!=\"POD\",container!=\"\"}) by (namespace)", "legendFormat": "{{namespace}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
