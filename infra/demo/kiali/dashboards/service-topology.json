{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Communication Paths by Request Rate",
      "description": "Source-to-destination paths ranked by current traffic",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(sum(rate(istio_requests_total{reporter=\"destination\"}[5m])) by (source_workload, destination_workload) > 0)",
          "legendFormat": "{{source_workload}} -> {{destination_workload}}",
          "format": "time_series",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "xTickLabelSpacing": 100,
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "title": "Communication Paths by Error Rate",
      "description": "Non-2xx rate for each source-to-destination path",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc((sum(rate(istio_requests_total{reporter=\"destination\",response_code!~\"2..\"}[5m])) by (source_workload, destination_workload) / sum(rate(istio_requests_total{reporter=\"destination\"}[5m])) by (source_workload, destination_workload)) * 100)",
          "legendFormat": "{{source_workload}} -> {{destination_workload}}",
          "format": "time_series",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "xTickLabelSpacing": 100,
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "title": "Path Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(istio_request_duration_milliseconds_bucket{reporter=\"destination\"}[5m])) by (le, source_workload, destination_workload))",
          "legendFormat": "{{source_workload}} -> {{destination_workload}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Traffic by Namespace",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(istio_requests_total{reporter=\"destination\"}[5m])) by (destination_workload_namespace)",
          "legendFormat": "{{destination_workload_namespace}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k1s0", "istio", "topology"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "k1s0 Service Topology",
  "uid": "k1s0-service-topology",
  "version": 8
}
