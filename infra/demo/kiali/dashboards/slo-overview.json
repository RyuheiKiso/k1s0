{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Availability",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status!~\"5..\"}[30m])) / clamp_min(sum(rate(http_requests_total[30m])), 0.0001) * 100", "legendFormat": "availability" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Error Budget Remaining",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "clamp_min(100 - (((sum(rate(http_requests_total{status=~\"5..\"}[6h])) / clamp_min(sum(rate(http_requests_total[6h])), 0.0001)) / 0.01) * 100), 0)", "legendFormat": "remaining" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Burn Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(sum(rate(http_requests_total{status=~\"5..\"}[1h])) / clamp_min(sum(rate(http_requests_total[1h])), 0.0001)) / 0.01", "legendFormat": "1h burn rate" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "5xx Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service)", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k1s0", "slo"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
