{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Mesh Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(istio_requests_total{reporter=\"source\"}[5m])) by (destination_workload)", "legendFormat": "{{destination_workload}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Mesh Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(istio_requests_total{reporter=\"source\",response_code!~\"2..\"}[5m])) by (destination_workload) / clamp_min(sum(rate(istio_requests_total{reporter=\"source\"}[5m])) by (destination_workload), 0.0001) * 100", "legendFormat": "{{destination_workload}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Mesh P95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(istio_request_duration_milliseconds_bucket{reporter=\"source\"}[5m])) by (destination_workload, le))", "legendFormat": "{{destination_workload}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Active Upstream Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(envoy_cluster_upstream_cx_active) by (cluster_name)", "legendFormat": "{{cluster_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k1s0", "istio", "service-mesh"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
