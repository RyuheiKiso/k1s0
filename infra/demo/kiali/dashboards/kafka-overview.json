      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"task-events\"}[5m]))", "legendFormat": "offset rate" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Consumer Offset Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(kafka_consumergroup_current_offset{topic=\"task-events\",consumergroup=\"project-master-processor\"}[5m]))", "legendFormat": "consumer offset rate" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(kafka_consumergroup_lag{topic=\"task-events\",consumergroup=\"project-master-processor\"})", "legendFormat": "lag" }
