# infra/ansible/inventory/.env.ansible.example
#
# M-019 監査対応: Ansible インベントリのホスト IP を環境変数で管理するためのテンプレート。
# このファイルをコピーして .env.ansible を作成し、実際の IP アドレスを記入すること。
#
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# !! .env.ansible は絶対にリポジトリにコミットしないこと。              !!
# !! .gitignore に追加済み。                                             !!
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#
# 使用方法:
#   cp infra/ansible/inventory/.env.ansible.example infra/ansible/inventory/.env.ansible
#   # .env.ansible に実際の IP を記入する
#   export $(cat infra/ansible/inventory/.env.ansible | grep -v '^#' | xargs)
#   ansible-playbook -i infra/ansible/inventory/hosts.yaml ...
#
# CI/CD（GitHub Actions）の場合:
#   GitHub Secrets に各変数を登録し、ワークフローで `env:` ブロックに設定すること。
#   例: ANSIBLE_PROD_MASTER_01_IP: ${{ secrets.ANSIBLE_PROD_MASTER_01_IP }}
#
# 本番環境の IP は Vault（HashiCorp Vault）で管理し、CI/CD から動的に取得することを推奨する。
# 参照: docs/architecture/adr/0086-ansible-inventory-vault.md

# ============================================================
# dev 環境
# ============================================================
ANSIBLE_DEV_MASTER_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_DEV_WORKER_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_DEV_WORKER_02_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_DEV_CEPH_01_IP=REPLACE_WITH_ACTUAL_IP

# ============================================================
# staging 環境
# ============================================================
ANSIBLE_STAGING_MASTER_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_MASTER_02_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_MASTER_03_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_WORKER_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_WORKER_02_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_WORKER_03_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_CEPH_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_CEPH_02_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_STAGING_CEPH_03_IP=REPLACE_WITH_ACTUAL_IP

# ============================================================
# prod 環境（本番。HashiCorp Vault から自動取得推奨）
# ============================================================
ANSIBLE_PROD_MASTER_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_MASTER_02_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_MASTER_03_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_WORKER_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_WORKER_02_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_WORKER_03_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_WORKER_04_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_WORKER_05_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_CEPH_01_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_CEPH_02_IP=REPLACE_WITH_ACTUAL_IP
ANSIBLE_PROD_CEPH_03_IP=REPLACE_WITH_ACTUAL_IP
