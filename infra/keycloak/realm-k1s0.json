{
  "realm": "k1s0",
  "enabled": true,
  "displayName": "k1s0",
  "sslRequired": "all",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 300,
  "ssoSessionIdleTimeout": 1800,
  "refreshTokenLifespan": 1800,
  "ssoSessionMaxLifespan": 28800,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5,
  "defaultSignatureAlgorithm": "RS256",
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and specialChars(1) and digits(1) and notUsername() and passwordHistory(12)",
  "roles": {
    "realm": [
      {
        "name": "biz_admin",
        "description": "Business tier full access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "biz_operator",
        "description": "Business tier read/write access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "biz_auditor",
        "description": "Business tier read-only access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "user",
        "description": "Default user role",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "sys_admin",
        "description": "System administrator - full access to all resources across all tiers",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "sys_operator",
        "description": "System operator - monitoring, log viewing, configuration changes",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "sys_auditor",
        "description": "System auditor - read-only access to all resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "biz_taskmanagement_admin",
        "description": "Task management domain administrator - full access to project-master resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "biz_taskmanagement_manager",
        "description": "Task management domain manager - read/write access to project-master resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "biz_taskmanagement_viewer",
        "description": "Task management domain viewer - read-only access to project-master resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_task_admin",
        "description": "Task service administrator - full access to task resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_task_user",
        "description": "Task service user - create and update tasks",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_task_viewer",
        "description": "Task service viewer - read-only access to task resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_board_admin",
        "description": "Board service administrator - full access to board resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_board_user",
        "description": "Board service user - increment/decrement columns",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_activity_admin",
        "description": "Activity service administrator - full access to activity resources including approve/reject",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_activity_user",
        "description": "Activity service user - create and submit activities",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_activity_viewer",
        "description": "Activity service viewer - read-only access to activity resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "svc_internal",
        "description": "Service-to-service internal role - minimal privileges for inter-service communication",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "react-spa",
      "name": "React SPA Client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "_comment_redirectUris": "localhost URI は開発環境専用（http://localhost:3000, http://localhost:5173）。本番環境では explicit ドメインのみを使用すること（HIGH-SEC-04 監査対応）",
      "redirectUris": [
        "https://app.k1s0.internal.example.com/callback",
        "http://localhost:3000/callback",
        "http://localhost:5173/callback"
      ],
      "_comment_webOrigins": "*.k1s0.internal.example.com ワイルドカードは内部ドメイン限定。本番環境では明示的なドメインリスト（例: https://app.k1s0.internal.example.com）に変更すること（HIGH-SEC-06 監査対応）",
      "webOrigins": [
        "https://*.k1s0.internal.example.com",
        "http://localhost:3000",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "tier-access-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "tier_access",
            "claim.value": "[\"service\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "k1s0-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "k1s0-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "flutter-mobile",
      "name": "Flutter Mobile Client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "com.example.k1s0://callback"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "tier-access-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "tier_access",
            "claim.value": "[\"service\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "k1s0-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "k1s0-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "k1s0-cli",
      "name": "k1s0 CLI Client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "oauth2.device.polling.interval": "5"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "tier-access-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "tier_access",
            "claim.value": "[\"system\", \"business\", \"service\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "k1s0-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "k1s0-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "k1s0-bff",
      "name": "k1s0 BFF Proxy Client",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "${KEYCLOAK_BFF_CLIENT_SECRET}",
      "redirectUris": [
        "https://app.k1s0.internal.example.com/callback",
        "http://localhost:3000/callback"
      ],
      "webOrigins": [
        "https://*.k1s0.internal.example.com",
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "tier-access-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "tier_access",
            "claim.value": "[\"service\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "k1s0-service",
      "name": "k1s0 Service-to-Service Client",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "${KEYCLOAK_SERVICE_CLIENT_SECRET}",
      "defaultClientScopes": [
        "openid"
      ],
      "protocolMappers": [
        {
          "name": "tier-access-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "tier_access",
            "claim.value": "[\"system\", \"business\", \"service\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "k1s0-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "k1s0-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "defaultRoles": ["svc_internal"]
    },
    {
      "clientId": "auth-server",
      "name": "AuthServer",
      "enabled": true,
      "protocol": "openid-connect",
      "bearerOnly": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    },
    {
      "clientId": "auth-rust-admin",
      "name": "AuthRustAdmin",
      "description": "DOCKER-HIGH-003 対応: auth サービスが Keycloak から RBAC ロールマッピングを取得するためのサービスアカウント。Client Credentials Grant を使用して realm-management ロールを付与する（ADR-0061 準拠）。",
      "enabled": true,
      "protocol": "openid-connect",
      "bearerOnly": false,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "${KC_AUTH_ADMIN_SECRET:-dev-service-secret}",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "realm-management-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "realm-management",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "config-server",
      "name": "ConfigServer",
      "enabled": true,
      "protocol": "openid-connect",
      "bearerOnly": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "openid",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "k1s0-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "k1s0-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "components": {
    "org.keycloak.keys.KeyProvider": [
      {
        "name": "rsa-generated",
        "providerId": "rsa-generated",
        "config": {
          "keySize": ["3072"],
          "algorithm": ["RS256"],
          "priority": ["100"]
        }
      }
    ]
  },
  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "smtpServer": {},
  "eventsEnabled": true,
  "eventsListeners": ["jboss-logging"],
  "enabledEventTypes": [
    "LOGIN",
    "LOGIN_ERROR",
    "LOGOUT",
    "REGISTER",
    "REGISTER_ERROR",
    "CODE_TO_TOKEN",
    "CODE_TO_TOKEN_ERROR",
    "CLIENT_LOGIN",
    "CLIENT_LOGIN_ERROR",
    "REFRESH_TOKEN",
    "REFRESH_TOKEN_ERROR",
    "REVOKE_GRANT",
    "UPDATE_PROFILE",
    "UPDATE_PASSWORD",
    "SEND_RESET_PASSWORD",
    "RESET_PASSWORD"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "defaultRequiredActions": ["UPDATE_PASSWORD"],
  "users": [
    {
      "username": "service-account-auth-rust-admin",
      "enabled": true,
      "serviceAccountClientId": "auth-rust-admin",
      "clientRoles": {
        "realm-management": [
          "view-users",
          "query-groups",
          "view-clients",
          "view-realm"
        ]
      }
    }
  ]
}
