{
  "title": "tier1 SLO Overview",
  "uid": "tier1-slo-overview",
  "schemaVersion": 39,
  "refresh": "30s",
  "tags": ["k1s0", "tier1"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "tier1 API Availability (5m)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "1 - (sum(rate(grpc_server_handled_total{grpc_code!=\"OK\",app_kubernetes_io_part_of=\"k1s0\"}[5m])) / sum(rate(grpc_server_handled_total{app_kubernetes_io_part_of=\"k1s0\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.99},
              {"color": "green", "value": 0.999}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    }
  ]
}
