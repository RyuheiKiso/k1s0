<mxfile host="draw.io">
  <diagram name="Config Editor UI" id="config-editor-ui">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="550" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Outer window frame -->
        <mxCell id="window" value="" style="rounded=1;strokeColor=#333333;fillColor=#FFFFFF;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="700" height="450" as="geometry"/>
        </mxCell>

        <!-- Title bar -->
        <mxCell id="titlebar" value="" style="fillColor=#E8E8E8;strokeColor=#CCCCCC;fontStyle=1;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="700" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="titlebar-text" value="⚙ task-server 設定" style="text;align=left;verticalAlign=middle;fontStyle=1;fontSize=13;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="30" y="22" width="200" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="titlebar-badge" value="[変更 2件あり]" style="text;align=right;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;fontColor=#CC6600;" vertex="1" parent="1">
          <mxGeometry x="430" y="22" width="110" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="btn-discard" value="破棄" style="rounded=1;fillColor=#F0F0F0;strokeColor=#AAAAAA;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="550" y="26" width="60" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="btn-save" value="保存" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="620" y="26" width="60" height="24" as="geometry"/>
        </mxCell>

        <!-- Left navigation panel -->
        <mxCell id="left-panel" value="" style="fillColor=#F5F5F5;strokeColor=#DDDDDD;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="56" width="160" height="414" as="geometry"/>
        </mxCell>
        <mxCell id="nav-db" value="&gt; データベース" style="text;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fillColor=#E0E8F0;strokeColor=none;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="24" y="66" width="152" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="nav-msg" value="  メッセージ" style="text;align=left;verticalAlign=middle;fontSize=12;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="24" y="96" width="152" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="nav-flags" value="  機能フラグ" style="text;align=left;verticalAlign=middle;fontSize=12;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="24" y="126" width="152" height="30" as="geometry"/>
        </mxCell>

        <!-- Right content panel: section title -->
        <mxCell id="section-title" value="データベース" style="text;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="66" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="section-divider" value="" style="line;strokeColor=#DDDDDD;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="96" width="500" height="1" as="geometry"/>
        </mxCell>

        <!-- Field 1: 最大接続数 -->
        <mxCell id="label-max-conn" value="最大接続数" style="text;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="110" width="120" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="slider1-track" value="" style="rounded=1;fillColor=#E0E0E0;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="200" y="140" width="380" height="8" as="geometry"/>
        </mxCell>
        <mxCell id="slider1-fill" value="" style="rounded=1;fillColor=#6c8ebf;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="140" width="38" height="8" as="geometry"/>
        </mxCell>
        <mxCell id="slider1-thumb" value="" style="ellipse;fillColor=#FFFFFF;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="232" y="137" width="14" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="slider1-value" value="25 connections" style="rounded=1;fillColor=#F9F9F9;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="132" width="110" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="slider1-range" value="1 - 1000" style="text;align=right;verticalAlign=middle;fontSize=9;fontColor=#999999;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="500" y="150" width="80" height="16" as="geometry"/>
        </mxCell>

        <!-- Field 2: SSL モード -->
        <mxCell id="label-ssl" value="SSL モード" style="text;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="180" width="120" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="dropdown-ssl" value="require ▼" style="rounded=1;fillColor=#F9F9F9;strokeColor=#CCCCCC;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="200" y="208" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Field 3: 接続タイムアウト -->
        <mxCell id="label-timeout" value="接続タイムアウト" style="text;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="256" width="160" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="slider2-track" value="" style="rounded=1;fillColor=#E0E0E0;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="200" y="286" width="380" height="8" as="geometry"/>
        </mxCell>
        <mxCell id="slider2-fill" value="" style="rounded=1;fillColor=#6c8ebf;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="286" width="62" height="8" as="geometry"/>
        </mxCell>
        <mxCell id="slider2-thumb" value="" style="ellipse;fillColor=#FFFFFF;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="256" y="283" width="14" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="slider2-value" value="5000 ms" style="rounded=1;fillColor=#F9F9F9;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="278" width="110" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="slider2-range" value="100 - 30000" style="text;align=right;verticalAlign=middle;fontSize=9;fontColor=#999999;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="490" y="296" width="90" height="16" as="geometry"/>
        </mxCell>

        <!-- Default button -->
        <mxCell id="btn-default" value="デフォルトに戻す" style="rounded=1;fillColor=#F0F0F0;strokeColor=#AAAAAA;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="200" y="340" width="130" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
