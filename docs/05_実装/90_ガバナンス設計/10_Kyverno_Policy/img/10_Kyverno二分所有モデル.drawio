        </mxCell>
        <mxCell id="title" value="Kyverno 二分所有: validate=Security 承認 / mutate + generate=Platform/SRE 実装 (IMP-POL-KYV-010〜022)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1660" height="30" as="geometry" />
        </mxCell>

        <mxCell id="own_sec" value="Security (D) 所有&#xa;CODEOWNERS: @k1s0/security-team&#xa;拒否する権限 = 統制側" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="own_plat" value="Platform/SRE (A/B) 所有&#xa;CODEOWNERS: @k1s0/platform-team&#xa;補助する権限 = 運用側" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="60" width="960" height="70" as="geometry" />
        </mxCell>

        <mxCell id="val_dir" value="deploy/kyverno/validate/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="440" height="40" as="geometry" />
        </mxCell>
        <mxCell id="mut_dir" value="deploy/kyverno/mutate/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="gen_dir" value="deploy/kyverno/generate/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="150" width="480" height="40" as="geometry" />
        </mxCell>

        <mxCell id="val_title" value="validate 10 本 (拒否系, リリース時点 初期セット)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="440" height="25" as="geometry" />
        </mxCell>
        <mxCell id="v01" value="verify-image-signatures (IMP-SUP-COS-013)&#xa;cosign keyless 署名必須 release.yml ref 固定" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="440" height="40" as="geometry" />
        </mxCell>
        <mxCell id="v02" value="require-runasnonroot / root UID 拒否" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="275" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v03" value="disallow-privileged-containers (privileged:true 禁止)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v04" value="require-networkpolicy (NFR-E-NW-002, 全 ns default deny)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="345" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v05" value="disallow-hostpath-hostnetwork (外部連携 ns のみ例外)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v06" value="require-resource-limits (requests/limits 両方必須)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="415" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v07" value="disallow-latest-tag (digest/version tag のみ)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v08" value="require-labels (NFR-H-AUD-001, name/team/tier 3 label)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="485" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v09" value="verify-attestations (IMP-SUP-COS-010, SBOM+SLSA 必須)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="v10" value="disallow-default-serviceaccount (NFR-G-AC-001)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="555" width="440" height="30" as="geometry" />
        </mxCell>

        <mxCell id="mut_title" value="mutate 6 本 (補助系)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="200" width="460" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="inject-default-labels (part-of/team 推定注入)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="230" width="460" height="40" as="geometry" />
