        <mxCell id="f11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;dashed=1;" edge="1" parent="1" source="d_ng" target="d_dx">
          <mxGeometry relative="1" as="geometry" />
