        <mxCell id="crt_title" value="cert-manager 配置: 3 ClusterIssuer + Certificate CR + istio-csr SVID 統合 + 監視 / アラート" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1" vertex="1" parent="1">
