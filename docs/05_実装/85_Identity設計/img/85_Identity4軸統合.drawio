        <mxCell id="leg_narrative" value="退職時 revoke 5 ステップ: [1] Keycloak disable + LogoutAll → [2] OpenBao token revoke → [3] cert-manager CRL 追加 → [4] Istio JWTRule jwks 更新 → [5] SPIRE operator entry 削除。起点は HR 通知、ops/scripts/offboard.sh が idempotent に連鎖し、所要時間 SLI 15 分 99% を守る。監査ログは MinIO Object Lock で 7 年 WORM 保存。" style="text;html=1;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="735" width="1280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="leg_axis" value="4 軸構成: Keycloak (人間 ID / ADR-SEC-001) / SPIRE-SPIFFE (ワークロード ID / ADR-SEC-003) / OpenBao (Secret / ADR-SEC-002) / cert-manager (証明書)。Keycloak の 1 アカウント無効化を契機に全経路が chain revoke されるのが設計意図である。" style="text;html=1;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="830" width="1280" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
