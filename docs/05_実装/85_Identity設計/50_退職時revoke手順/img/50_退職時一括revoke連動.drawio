          <mxGeometry x="240" y="75" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="script" value="ops/scripts/offboard.sh &lt;username&gt;&#10;set -euo pipefail / idempotent / --dry-run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="420" height="70" as="geometry" />
        </mxCell>
