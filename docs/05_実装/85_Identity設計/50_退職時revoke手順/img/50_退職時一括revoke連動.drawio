          <mxGeometry x="960" y="75" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="Step 1: Keycloak&#10;user disable + LogoutAll&#10;refresh token 一括失効" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Step 2: OpenBao&#10;identity entity token revoke&#10;vault token revoke --accessor" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="210" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="Step 3: cert-manager&#10;client 証明書 CRL 追加&#10;OCSP responder 即時配信" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="210" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="Step 4: Istio JWTRule&#10;revoke list → jwks 更新&#10;既発行 JWT 検証強制" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="850" y="210" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="Step 5: SPIRE Server&#10;human operator entry 削除&#10;次回 rotation で失敗" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="210" width="240" height="90" as="geometry" />
