        </mxCell>

        <mxCell id="rbt_cmd_title" value="Phase 2-3 の 1 コマンド化（ops/scripts/rollback.sh）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="rbt_cmd" value="$ ./ops/scripts/rollback.sh \&#xa;    --app tier1-workflow \&#xa;    --revision &lt;prev-sha&gt; \&#xa;    --reason &quot;canary AT error-rate fail&quot;&#xa;&#xa;# 内部実行:&#xa;# 1. git revert &lt;merge-sha&gt; → PR 生成&#xa;# 2. SRE オンコール approval 検証&#xa;# 3. argocd app sync tier1-workflow --revision &lt;prev-sha&gt;&#xa;# 4. kubectl argo rollouts undo workflow-rollout&#xa;# 5. PagerDuty incident に実行ログ自動添付" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="500" height="220" as="geometry" />
        </mxCell>

