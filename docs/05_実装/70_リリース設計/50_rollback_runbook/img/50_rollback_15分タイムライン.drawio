        <mxCell id="rbt_e_alt2" style="edgeStyle=none;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#b85450;endArrow=classic;dashed=1" edge="1" parent="1" source="rbt_alt1" target="rbt_alt2">
