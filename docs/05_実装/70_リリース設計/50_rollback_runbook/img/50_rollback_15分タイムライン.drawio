        <mxCell id="rbt_phase1" value="Phase 1: 検知 / 起動 (2 分)&#xa;・PagerDuty Sev2 通知&#xa;・Incident Commander 立ち上げ&#xa;・Slack #k1s0-incidents 招集&#xa;・自動 / 手動 rollback 判定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="220" height="160" as="geometry" />
        </mxCell>
        <mxCell id="rbt_phase2" value="Phase 2: Git revert (3 分)&#xa;・ops/scripts/rollback.sh 起動&#xa;・対象 Application を特定&#xa;・git revert &lt;merge-sha&gt;&#xa;・自動生成 PR を SRE 承認&#xa;・main マージ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="320" y="140" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="rbt_phase3" value="Phase 3: Argo CD sync (5 分)&#xa;・argocd app sync &lt;app&gt;&#xa;・prev-sha への巻き戻し&#xa;・Helm chart 再展開&#xa;・Pod 入替（Rollout undo）&#xa;・kubectl argo rollouts undo（並列）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="580" y="140" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="rbt_phase4" value="Phase 4: AnalysisTemplate (5 分)&#xa;・5 本共通テンプレ評価&#xa;・error rate / latency / cpu&#xa;・dependency / EB burn&#xa;・全 pass = 安定化 OK&#xa;・任意 fail = 第二経路へ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="840" y="140" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="rbt_phase5" value="Phase 5: 安定化観測 (5 分)&#xa;・post-rollback ダッシュボード&#xa;・SLI 5 分連続 GREEN 確認&#xa;・PagerDuty resolve&#xa;・Postmortem PR テンプレ生成&#xa;・15 分以内完了 SLO 計測" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="1100" y="140" width="240" height="160" as="geometry" />
        </mxCell>

        <mxCell id="rbt_alt1" value="第二経路: Forward fix&#xa;AT fail 時に 5 分以内で hot-patch&#xa;（CVSS 9.0+ 限定、SRE 承認必須）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="840" y="340" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rbt_alt2" value="第三経路: 全停止 (kill)&#xa;tier1 = 業務影響極大時のみ&#xa;Maintenance Page へ切替" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
