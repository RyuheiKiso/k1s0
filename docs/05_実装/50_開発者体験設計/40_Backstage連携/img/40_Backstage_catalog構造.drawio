        <mxCell id="bsn_lg_l1" value="Component entity（5 種別: service / website / native-app / library / template）— 各 src/{tier}/{component}/ 配下に同居配置" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
