        </mxCell>
        <mxCell id="bsn_lg_l2" value="API entity（grpc / openapi）— src/contracts/ 配下に同居。Component が providesApis / consumesApis で参照" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="608" width="1040" height="22" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_c3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="55" y="636" width="22" height="14" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_l3" value="Group / System entity — リポジトリ直下 catalog/ に集約配置（owner team / system 名は組織横断のため component 別配置にしない）" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="631" width="1040" height="22" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_c4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="55" y="659" width="22" height="14" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_l4" value="Backstage 内部処理（GitHub provider polling / Catalog Processor / UI 表示）— infra/data/backstage/ で運用" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="654" width="1040" height="22" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_c5" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="55" y="682" width="22" height="14" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_l5" value="検証エラー出力（Catalog Errors ダッシュボード）— @k1s0/platform-dx が日次で監視。リリース時点は Slack 通知なし、目視運用" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="677" width="1040" height="22" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_n1" value="① Component の分散配置 vs Group / System の集約配置は意図的に分けている。Component は path 直下のため誰でも触る一方、Group / System は組織変更時のみ触り、変更頻度が異なる。" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="704" width="1080" height="22" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_n2" value="② 5 分間隔の polling は Backstage 標準。Webhook 連動も可能だが、リリース時点では polling のみ採用（webhook 失敗時のリカバリが polling で代替できるため）。" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="724" width="1080" height="22" as="geometry" />
        </mxCell>
        <mxCell id="bsn_lg_n3" value="③ catalog-info.yaml の lint は CI 段で `backstage-cli catalog:validate` を必須化（IMP-CI-PF-034 への path-filter 連動）。本番 Backstage に到達してから検証されるのを防ぐ。" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="744" width="1080" height="22" as="geometry" />
        </mxCell>
      </root>
