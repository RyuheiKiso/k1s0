<mxfile host="docs.k1s0">
  <diagram id="ci-quality-gate" name="ci-quality-gate">
    <mxGraphModel dx="1200" dy="780" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1240" height="780" as="geometry" />
        </mxCell>

        <mxCell id="title" value="quality gate 4 段（fmt → lint → unit → coverage）と段階導入カレンダー" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="15" width="1100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="qg_g1" value="第 1 段: fmt&#xa;rustfmt / gofmt /&#xa;prettier / dotnet format" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="qg_g2" value="第 2 段: lint&#xa;clippy / golangci-lint /&#xa;eslint / Roslyn analyzer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="qg_g3" value="第 3 段: unit-test&#xa;cargo nextest / go test /&#xa;vitest / dotnet test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="qg_g4" value="第 4 段: coverage&#xa;cargo-llvm-cov / go cover /&#xa;c8 / coverlet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="80" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="qg_e1" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;" edge="1" parent="1" source="qg_g1" target="qg_g2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qg_e2" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;" edge="1" parent="1" source="qg_g2" target="qg_g3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qg_e3" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;" edge="1" parent="1" source="qg_g3" target="qg_g4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="qg_fail" value="いずれか fail&#xa;→ PR merge ブロック&#xa;（必須 status check &#xa; ci-overall への伝搬）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="200" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="qg_ef1" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.2;entryDx=0;entryDy=0;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="qg_g1" target="qg_fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qg_ef2" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="qg_g2" target="qg_fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qg_ef3" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.8;entryY=0;entryDx=0;entryDy=0;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="qg_g3" target="qg_fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qg_ef4" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.2;entryDx=0;entryDy=0;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="qg_g4" target="qg_fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="qg_cal_hdr" value="段階導入カレンダー（IMP-CI-RWF-018 と整合）" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="800" height="30" as="geometry" />
        </mxCell>

        <mxCell id="qg_cal_h1" value="段階" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="qg_cal_h2" value="fmt" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="140" y="360" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="qg_cal_h3" value="lint" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="340" y="360" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="qg_cal_h4" value="unit-test" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="580" y="360" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="qg_cal_h5" value="coverage 閾値" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="820" y="360" width="380" height="30" as="geometry" />
        </mxCell>

        <mxCell id="qg_r1_a" value="リリース時点（OSS リリース）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r1_b" value="必須（即 fail）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="140" y="390" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r1_c" value="必須（warning は accept、error は fail）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="340" y="390" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r1_d" value="必須（タイムアウト 60s 超は fail）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="580" y="390" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r1_e" value="計測のみ（warning 表示、fail せず）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="820" y="390" width="380" height="50" as="geometry" />
        </mxCell>

        <mxCell id="qg_r2_a" value="採用初期（PoC 後）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r2_b" value="必須" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="140" y="440" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r2_c" value="必須（warning も fail に昇格）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="340" y="440" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r2_d" value="必須（flaky 検出ジョブ追加）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="580" y="440" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r2_e" value="80% 必須（差分カバレッジ）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="820" y="440" width="380" height="50" as="geometry" />
        </mxCell>

        <mxCell id="qg_r3_a" value="運用拡大（採用後 1 年）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r3_b" value="必須" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="140" y="490" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r3_c" value="必須（カスタム lint 追加）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="340" y="490" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r3_d" value="必須 + mutation testing 追加" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="580" y="490" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qg_r3_e" value="90% 必須（全体カバレッジ）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="820" y="490" width="380" height="50" as="geometry" />
        </mxCell>

        <mxCell id="qg_legendbox" value="凡例 / 設計ノート" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="1180" height="160" as="geometry" />
        </mxCell>

        <mxCell id="qg_lg_a" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="612" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="qg_lg_atxt" value="quality gate 段（reusable workflow 内 step）" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="609" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="qg_lg_b" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="370" y="612" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="qg_lg_btxt" value="fail 時の merge ブロックゲート" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="395" y="609" width="280" height="20" as="geometry" />
        </mxCell>

        <mxCell id="qg_lg_n1" value="quality gate は IMP-CI-POL-002（reusable workflow で統制）の 1 実装。4 段は順序固定で fmt → lint → unit → coverage、前段が fail なら後段 step を skip して fail 伝搬する。" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="1140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="qg_lg_n2" value="coverage の段階導入は IMP-CI-RWF-018 と完全整合。リリース時点 で 90% 強制すると初期 commit 速度が破壊されるため、計測 → 80% → 90% の 3 段階で導入する。" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="1140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="qg_lg_n3" value="lint の warning → fail 昇格は採用初期 で実施。OSS リリース直後は新規実装が多く warning がノイズになりやすいが、コードベース安定後は全 warning を fail 化することで品質劣化を構造的に防ぐ。" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="1140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="qg_lg_n4" value="例外（特定 PR で gate を一時無効化）は ADR 必須。PR 単位の `gate-bypass` ラベルでの無効化は明示的に禁止し、IMP-CI-POL-006（branch protection）で物理的にも塞ぐ。" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="1140" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
