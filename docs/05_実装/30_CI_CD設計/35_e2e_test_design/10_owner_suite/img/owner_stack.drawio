        <mxCell id="l7_vm" value="VM: multipass × 5（k1s0-cp-1/2/3 + k1s0-w-1/2、各 6GB / 2vCPU）&#10;計 30GB RAM / 10vCPU / 100GB disk（host 48GB に対し約 47GB 占有）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
