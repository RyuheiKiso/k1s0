        <mxCell id="l6_k8s" value="K8s: kubeadm (control-plane 3 HA + worker 2)&#10;multi-AZ topology label {a, b}（疑似分散）— ADR-INFRA-001" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
