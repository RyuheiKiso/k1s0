          <mxGeometry x="1330" y="510" width="270" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gate-note" value="これらは reusable workflow 側で定義され、個別リポジトリ (tier1/tier2/tier3 のワークフロー) が caller として呼び出す。quality gate は 80 章 (サプライチェーン) と結合。" style="text;html=1;fontSize=11;align=center;" vertex="1" parent="1">
