<mxfile host="app.diagrams.net">
  <diagram name="cicd-7stages" id="cicd-7stages-1">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
