        <mxCell id="title" value="CI/CD 7 段階パイプライン (GitHub Actions reusable workflow + self-hosted runner)" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="20" width="1540" height="30" as="geometry" />
