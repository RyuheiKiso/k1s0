        <mxCell id="eb_lg_l2" value="WARNING: 観測強化 + Canary 慎重化、開発は自由" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="606" width="450" height="22" as="geometry" />
