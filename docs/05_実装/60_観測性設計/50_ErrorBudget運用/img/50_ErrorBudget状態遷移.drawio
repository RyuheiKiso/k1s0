        <mxCell id="eb_lg_l3" value="ALERT: PagerDuty で人間関与、auto-merge 停止 (人手 review 強制)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="629" width="500" height="22" as="geometry" />
