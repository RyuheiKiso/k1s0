        <mxCell id="eb_recover_lbl" value="点線: 28日 rolling window で budget 回復 (自動)" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="430" y="245" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="eb_calc" value="Budget 計算式 (28 日 rolling window)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="1060" height="30" as="geometry" />
        </mxCell>
        <mxCell id="eb_formula" value="Budget(t) = (1 - SLO_target) * 総リクエスト数(t-28d, t)&#xa;Consumed(t) = エラーリクエスト数(t-28d, t)&#xa;Remaining(t) = 1 - Consumed(t) / Budget(t)&#xa;例: SLO=99.9%, 7日間で総 100M req → 28日 budget 400K, 消費 200K → Remaining=50% (WARNING 境界)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="325" width="1060" height="100" as="geometry" />
        </mxCell>
        <mxCell id="eb_actor_title" value="状態別の自動アクション主体" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="445" width="1060" height="30" as="geometry" />
        </mxCell>
        <mxCell id="eb_actor1" value="Mimir Alertmanager → Slack / PagerDuty 通知" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="485" width="280" height="40" as="geometry" />
