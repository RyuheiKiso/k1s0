        </mxCell>
        <mxCell id="rb_15box" value="Identity (3): keycloak-503 / openbao-seal / spire-bundle-rotation-fail&#xa;Edge (3): istio-ingress-503 / cert-expiry-warning / ratelimit-burst&#xa;Data (3): postgres-failover / redis-eviction-spike / kafka-isr-shrink&#xa;App (3): tier1-grpc-deadline / tier3-bff-5xx / dapr-sidecar-restart&#xa;Platform (3): argocd-sync-fail / prometheus-rule-load-fail / otel-gateway-queue-overflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
