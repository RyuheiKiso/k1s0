<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram name="pyroscope_integration" id="pyr_diagram">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
