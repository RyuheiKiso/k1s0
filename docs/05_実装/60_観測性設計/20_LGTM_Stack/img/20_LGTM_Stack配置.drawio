          <mxGeometry x="55" y="661" width="22" height="14" as="geometry" />
        </mxCell>
        <mxCell id="lgt_lg_l3" value="インフラ層: S3 互換オブジェクトストレージ (リリース時点 MinIO / 採用初期 で外部 S3 移行)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="656" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_lg_lsolid" value="—" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="610" width="22" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_lg_lsolid_t" value="実線太: テレメトリ送信経路 (アプリ → Agent → Gateway)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="610" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_lg_ldashed" value="- - -" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="633" width="22" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_lg_ldashed_t" value="点線: Grafana の datasource 接続 (UI 起点の read 経路)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="633" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_n1" value="① AGPL 分離は ADR-0003 を物理化したもの。Loki / Mimir / Tempo / Grafana は別プロセス・別 namespace・別 ServiceAccount で動かし、tier1 バイナリと dynamic linking しない。" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="685" width="1130" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_n2" value="② OTel Gateway が単一接続点。Grafana から各 backend を直接見る設計を選ばず、Collector を経由させない理由は「データソース読込に Collector を介在させると read レイテンシが悪化」するため (read は datasource 直接 / write は Collector 集約)。" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="705" width="1130" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_n3" value="③ オブジェクトストレージは リリース時点 で同一クラスタ MinIO に配置、採用初期 で AWS S3 / GCS / Azure Blob などへ移行。S3 互換 API を採用することで、移行は datasource URL 変更と secret rotate のみで完了させる。" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="725" width="1130" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgt_n4" value="④ 保持期間 (Loki 30 日 / Mimir 13 ヶ月 / Tempo 14 日) は Google SRE Book と CNCF Observability WG の典型例に揃え、コスト試算は 99 章索引 + 70 章リリースと結合する。" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="745" width="1130" height="22" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
