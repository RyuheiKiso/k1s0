          <mxGeometry x="670" y="90" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lgt_mimir" value="Mimir (AGPL v3) — Metrics (Prometheus 互換)&#xa;namespace=observability-lgtm&#xa;StatefulSet (3 replicas) + S3 互換&#xa;保持: 30 日 hot / 13 ヶ月 long-term" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="670" y="190" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lgt_tempo" value="Tempo (AGPL v3) — Traces (OTLP)&#xa;namespace=observability-lgtm&#xa;StatefulSet (2 replicas) + S3 互換&#xa;保持: 14 日 (tail sampling 後)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="670" y="290" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lgt_grafana" value="Grafana (AGPL v3) — UI / Dashboard / Alert&#xa;namespace=observability-lgtm&#xa;Deployment (2 replicas) + Postgres for state&#xa;Keycloak OIDC SSO 必須 (匿名閲覧禁止)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="670" y="390" width="500" height="80" as="geometry" />
