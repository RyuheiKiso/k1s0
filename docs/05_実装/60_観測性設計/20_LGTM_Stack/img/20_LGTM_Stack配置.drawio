        </mxCell>
        <mxCell id="lgt_lg_l1" value="Apache 2.0 ゾーン: アプリと OTel Collector の同居許容 (プロセス共有 OK)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="610" width="500" height="22" as="geometry" />
        </mxCell>
