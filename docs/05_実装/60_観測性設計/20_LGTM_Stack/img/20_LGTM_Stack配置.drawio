          <mxGeometry x="55" y="638" width="22" height="14" as="geometry" />
        </mxCell>
        <mxCell id="lgt_lg_l2" value="AGPL v3 ゾーン: 別 namespace / 別 NetworkPolicy / プロセス境界共有禁止" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="633" width="500" height="22" as="geometry" />
        </mxCell>
