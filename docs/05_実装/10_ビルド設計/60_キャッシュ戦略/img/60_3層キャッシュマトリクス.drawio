        <mxCell id="leg_note" value="セル内のキー欄は actions/cache の `key:` 式パターン。${hashFiles ...} は GitHub Actions の組み込み関数で lockfile 内容のハッシュを返す。" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
