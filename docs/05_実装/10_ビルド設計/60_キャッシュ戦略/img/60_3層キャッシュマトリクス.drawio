<mxfile host="docs.k1s0">
  <diagram id="cache-matrix" name="cache-matrix">
    <mxGraphModel dx="1200" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="640" as="geometry" />
        </mxCell>

        <mxCell id="title" value="3 層キャッシュマトリクス（4 言語 × ローカル / CI / リモート）" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="15" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="h_layer" value="Layer ＼ Language" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h_rust" value="Rust (Cargo)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="60" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h_go" value="Go" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h_ts" value="TypeScript (pnpm)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="60" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h_dotnet" value=".NET (NuGet)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="60" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_local" value="第 1 層: ローカル&#xa;(開発者端末)&#xa;&#xa;ライフタイム&#xa;1 週間以上" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_rust_local" value="~/.cargo/registry/&#xa;~/.cargo/git/&#xa;target/&#xa;&#xa;キー: Cargo.lock 全体" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="110" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_go_local" value="$GOMODCACHE&#xa;$GOCACHE&#xa;&#xa;キー: go.sum 全体" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="110" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_ts_local" value="~/.local/share/pnpm/store/v3/&#xa;node_modules/.cache/&#xa;.turbo/&#xa;&#xa;キー: pnpm-lock.yaml" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="110" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_dotnet_local" value="~/.nuget/packages/&#xa;obj/&#xa;&#xa;キー: packages.lock.json" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="110" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="r_ci" value="第 2 層: CI&#xa;(GitHub Actions cache)&#xa;&#xa;ライフタイム&#xa;7 日 (LRU)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_rust_ci" value="actions/cache@v4&#xa;path: ~/.cargo + target/&#xa;&#xa;キー: rust-${hashFiles}&#xa;     -${{ runner.os }}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="230" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_go_ci" value="actions/cache@v4&#xa;path: ${GOMODCACHE} + ${GOCACHE}&#xa;&#xa;キー: go-${hashFiles 'go.sum'}&#xa;     -${{ runner.os }}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="230" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_ts_ci" value="actions/cache@v4&#xa;path: pnpm store + .turbo/&#xa;&#xa;キー: pnpm-${hashFiles 'pnpm-lock'}&#xa;     -${{ runner.os }}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="230" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_dotnet_ci" value="actions/cache@v4&#xa;path: ~/.nuget/packages + obj/&#xa;&#xa;キー: nuget-${hashFiles&#xa;     'Directory.Packages.props'}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="230" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="r_remote" value="第 3 層: リモート&#xa;(分散キャッシュ)&#xa;&#xa;ライフタイム&#xa;30 日 (S3 lifecycle)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_rust_remote" value="sccache + S3/MinIO&#xa;(リリース時点 導入)&#xa;&#xa;対象: rustc 結果&#xa;キー: source hash + flags" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="350" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_go_remote" value="（公式リモートなし）&#xa;&#xa;リリース時点 で再評価&#xa;ビルド時間 SLI 観測後に判断" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#999999;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="350" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_ts_remote" value="Turbo Remote Cache&#xa;(self-hosted、リリース時点 ADR)&#xa;&#xa;対象: pnpm task 出力&#xa;キー: input hash + env" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="350" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c_dotnet_remote" value="（公式リモートなし）&#xa;&#xa;BuildXL 自前運用は&#xa;ROI が薄く保留" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#999999;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="960" y="350" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="legendbox" value="凡例" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="1120" height="120" as="geometry" />
