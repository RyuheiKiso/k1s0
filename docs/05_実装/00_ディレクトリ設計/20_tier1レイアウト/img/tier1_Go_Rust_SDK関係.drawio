        <mxCell id="t1-go" value="tier1-Go ファサード層（3 Pod / Dapr Go SDK / DS-SW-COMP-124）&#10;&#10;  cmd/state/     → t1-state Pod（State + PubSub API）&#10;  cmd/secret/    → t1-secret Pod（Secrets + Binding API）&#10;  cmd/workflow/  → t1-workflow Pod（Workflow API）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;spacingTop=8;verticalAlign=top;" vertex="1" parent="1">
