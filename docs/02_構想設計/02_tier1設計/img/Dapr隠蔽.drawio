          <mxGeometry x="0" y="0" width="1400" height="900" as="geometry" />
        </mxCell>
        <mxCell id="title" value="tier1 による Dapr 隠蔽構造" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="tier2/3 は tier1 公開 API のみを見る。tier1 内部の Dapr / Go ファサード / Rust 自作の存在は tier2/3 から完全に隠蔽される。すべて「アプリ層」に属するが、抽象レベルで区別する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="layer1" value="tier2 / tier3 コード (C# / Go / TS)&#xa;→ tier1 公開 API のみを import / 呼び出し" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="hide_line" value="── 隠蔽境界 (tier2/3 からは下層が見えない) ──" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#8b6508;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="1280" height="24" as="geometry" />
        </mxCell>
        <mxCell id="layer2" value="tier1 公開 API (多言語クライアントライブラリ)&#xa;k1s0 固有の統一 API: log / telemetry / state / pub-sub / secrets / workflow / auth / audit / decision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="235" width="1280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="layer3" value="tier1 内部実装 (Go + Rust ハイブリッド, tier2/3 からは不可視)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d79b00;strokeWidth=2;fontSize=13;fontStyle=1;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="355" width="1280" height="250" as="geometry" />
        </mxCell>
        <mxCell id="goSvc" value="Go サービス (Dapr ファサード)&#xa;stable Dapr Go SDK を直接利用&#xa;state / pub-sub / secrets / workflow /&#xa;bindings / 認証プロキシ / OTel 集約" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="90" y="405" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="rustSvc" value="Rust サービス (自作領域)&#xa;ZEN Engine in-process&#xa;JTC 固有機能 / 監査改ざん防止&#xa;雛形生成 CLI / Component バリデータ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="500" y="405" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="dapr" value="Dapr Control Plane + daprd サイドカー&#xa;(Pod に自動注入)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=1.5;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
