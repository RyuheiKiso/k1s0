        <mxCell id="ll2" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#d79b00;strokeWidth=1;dashed=1;dashPattern=2 2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="220" as="sourcePoint" />
