        </mxCell>
        <mxCell id="ll3" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#d79b00;strokeWidth=1;dashed=1;dashPattern=2 2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="820" y="220" as="sourcePoint" />
            <mxPoint x="820" y="920" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ll4" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#d79b00;strokeWidth=1;dashed=1;dashPattern=2 2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1140" y="220" as="sourcePoint" />
            <mxPoint x="1140" y="920" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ll5" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#d79b00;strokeWidth=1;dashed=1;dashPattern=2 2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1460" y="220" as="sourcePoint" />
            <mxPoint x="1460" y="920" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ll6" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#9673a6;strokeWidth=1;dashed=1;dashPattern=2 2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1780" y="220" as="sourcePoint" />
            <mxPoint x="1780" y="920" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m1" value="① k1s0.State.Save(key, value)" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#d79b00;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="280" as="sourcePoint" />
            <mxPoint x="500" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="② gRPC SaveRequest" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#d79b00;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="350" as="sourcePoint" />
            <mxPoint x="820" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="③ HTTP POST /v1.0/state/valkey" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#d79b00;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="820" y="420" as="sourcePoint" />
            <mxPoint x="1140" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="④ internal dispatch (config で選択)" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#d79b00;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1140" y="490" as="sourcePoint" />
            <mxPoint x="1460" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m5" value="⑤ SET key value" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#9673a6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1460" y="560" as="sourcePoint" />
            <mxPoint x="1780" y="560" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r1" value="OK" style="endArrow=open;html=1;rounded=0;strokeWidth=1;strokeColor=#666666;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1780" y="630" as="sourcePoint" />
            <mxPoint x="1460" y="630" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r2" value="ACK" style="endArrow=open;html=1;rounded=0;strokeWidth=1;strokeColor=#666666;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1460" y="690" as="sourcePoint" />
            <mxPoint x="1140" y="690" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r3" value="200 OK" style="endArrow=open;html=1;rounded=0;strokeWidth=1;strokeColor=#666666;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1140" y="750" as="sourcePoint" />
            <mxPoint x="820" y="750" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r4" value="gRPC response" style="endArrow=open;html=1;rounded=0;strokeWidth=1;strokeColor=#666666;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="820" y="810" as="sourcePoint" />
            <mxPoint x="500" y="810" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="r5" value="Result&lt;(), k1s0.Error&gt;" style="endArrow=open;html=1;rounded=0;strokeWidth=1;strokeColor=#666666;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="870" as="sourcePoint" />
            <mxPoint x="180" y="870" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="note1" value="特徴: すべての矢印の出発点がアプリコードから辿れる。tier3 のソースを読むと ①②③④⑤ の呼び出しチェーンが完全に追える。&#10;これが「アプリ層」の定義 ― アプリから明示的に呼び出す抽象。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=11;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="940" width="1840" height="60" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="比較: もし同じ Pod 内で ztunnel が動いていたら、Pod から外へ出る全パケットが ztunnel に透過的に捕捉される。しかしアプリコードには ztunnel の名前は 1 度も出てこない。これが「ネットワーク層」の定義 ― アプリから透過的に効く機構。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1020" width="1840" height="60" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="凡例" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingTop=8;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1940" y="140" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="lgA" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1955" y="175" width="28" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lgAT" value="アプリ層 (明示呼び出し)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1990" y="170" width="180" height="24" as="geometry" />
