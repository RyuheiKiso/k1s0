<mxfile host="app.diagrams.net" modified="2026-04-19T00:00:00.000Z" agent="Claude Code" version="24.8.8">
  <diagram id="app-dapr-flow" name="アプリ層_Dapr呼び出しフロー">
    <mxGraphModel dx="2200" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="2200" height="1100" as="geometry" />
        </mxCell>
        <mxCell id="title" value="アプリ層の Dapr 呼び出しフロー ― 明示呼び出しチェーン" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="30" width="1400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="tier3 アプリが k1s0.State.Save() を呼んだ瞬間に、tier1 ファサード → daprd → Dapr Component → Valkey まで明示的に呼び出される。すべてアプリコードに表現される層 = アプリ層。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="1700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="tier3 アプリ&#10;&#10;k1s0.State.Save(key, value)&#10;が書かれるコード" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="k1s0 Client SDK&#10;&#10;Rust / Go / TypeScript&#10;(アプリに組み込む薄い SDK)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="140" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="tier1 Go ファサード&#10;&#10;Dapr Go SDK +&#10;採用側組織のポリシー適用" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="140" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="daprd サイドカー&#10;&#10;Pod 内 localhost:3500&#10;(明示呼び出し先)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="140" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a5" value="Dapr Component&#10;&#10;state.valkey /&#10;pubsub.kafka / 等" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d79b00;strokeWidth=1;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1340" y="140" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a6" value="データストア&#10;&#10;Valkey / Postgres /&#10;Kafka / MinIO" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1660" y="140" width="240" height="80" as="geometry" />
