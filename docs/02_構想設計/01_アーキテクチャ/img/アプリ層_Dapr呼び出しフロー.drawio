        <mxCell id="lgL1T" value="実線太 = 明示呼び出し" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1995" y="228" width="180" height="24" as="geometry" />
