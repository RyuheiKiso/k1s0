        <mxCell id="lgL2T" value="実線細 = 戻り値" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1995" y="258" width="180" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lgLLT" value="(戻り矢印の細線は本図の&#10;sequence 表記専用。規約の&#10;点線=透過捕捉 とは別。)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontColor=#555555;" vertex="1" parent="1">
