<mxfile host="draw.io">
  <diagram name="deps" id="deps">
    <mxGraphModel dx="1200" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t3" value="tier3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="tier2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="260" y="120" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="tier1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="460" y="120" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="inf" value="infra" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="660" y="120" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="t3" target="t2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="t2" target="t1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="t1" target="inf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="tier2 が無い場合のみ許容" style="endArrow=classic;html=1;strokeWidth=1;dashed=1;curved=1;exitX=0.5;exitY=0;entryX=0.5;entryY=0;" edge="1" parent="1" source="t3" target="t1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="120" y="40" />
              <mxPoint x="520" y="40" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="note" value="依存は 1 方向のみ。infra への直接依存は tier1 のみ許可" style="text;html=1;align=center;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="160" y="240" width="560" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
