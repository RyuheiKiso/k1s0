<mxfile host="app.diagrams.net" modified="2026-04-19T00:00:00.000Z" agent="Claude Code" version="24.8.8">
  <diagram id="net-ambient-path" name="ネットワーク層_Ambientパケット経路">
    <mxGraphModel dx="2000" dy="1150" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="2000" height="1150" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ネットワーク層の Ambient パケット経路 ― 透過捕捉チェーン" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="30" width="1400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="アプリは素の HTTP を相手 Pod に投げているつもり。実際は Node 上の iptables/eBPF が捕捉し、ztunnel が HBONE (mTLS) で対向 Node の ztunnel へ運び、(必要なら) waypoint を経由して相手 Pod に配送する。アプリコードに経路上のコンポーネントは 1 つも出てこない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="1570" height="50" as="geometry" />
        </mxCell>
        <mxCell id="top_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d79b00;dashed=1;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="140" width="1900" height="280" as="geometry" />
        </mxCell>
        <mxCell id="top_lbl" value="① アプリから見えている世界 (ソースコードに書かれる対象)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#8b6508;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="1100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tpa" value="Pod A&#10;&#10;app container&#10;(注文サービス)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="180" y="220" width="300" height="140" as="geometry" />
        </mxCell>
        <mxCell id="tpb" value="Pod B&#10;&#10;app container&#10;(決済サービス)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1520" y="220" width="300" height="140" as="geometry" />
        </mxCell>
        <mxCell id="tpa_tpb" value="POST http://pay-service/api/pay" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#d79b00;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="290" as="sourcePoint" />
            <mxPoint x="1520" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tpa_note" value="アプリコード側に書かれるのはこの 1 本のみ。&#10;経路上のコンポーネント名 (ztunnel / waypoint / iptables / HBONE) は 1 度も登場しない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="70" y="370" width="1860" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bot_lbl" value="② 実際のパケット経路 (ネットワーク層が透過的に処理)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#1a4e7a;" vertex="1" parent="1">
          <mxGeometry x="50" y="440" width="1100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nodeA" value="Node A (インフラ層)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;fontSize=12;verticalAlign=top;align=left;spacingTop=10;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="860" height="430" as="geometry" />
        </mxCell>
        <mxCell id="podA" value="Pod A&#10;&#10;app container&#10;(アプリから見える唯一)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="90" y="540" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="iptablesA" value="iptables / eBPF&#10;&#10;Pod out を :15001 に&#10;redirect (透過捕捉点)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="540" width="180" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ztunA" value="ztunnel (Node A)&#10;&#10;DaemonSet&#10;HBONE proxy :15008&#10;mTLS 暗号化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="570" y="540" width="310" height="150" as="geometry" />
        </mxCell>
        <mxCell id="nodeA_note" value="重要: Pod A のマニフェストに iptables や ztunnel の記述は無い。&#10;Node が Ambient Mesh 配下にあれば、Pod 作成時点で自動的に透過捕捉配下に入る。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="90" y="720" width="790" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nodeB" value="Node B (インフラ層)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;fontSize=12;verticalAlign=top;align=left;spacingTop=10;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="1080" y="480" width="860" height="430" as="geometry" />
        </mxCell>
        <mxCell id="ztunB" value="ztunnel (Node B)&#10;&#10;DaemonSet&#10;HBONE terminate&#10;mTLS 復号" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1110" y="540" width="280" height="150" as="geometry" />
        </mxCell>
        <mxCell id="waypoint" value="waypoint&#10;&#10;Envoy L7&#10;(AuthZ / RateLimit /&#10;HTTP retry 等)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1430" y="540" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="podB" value="Pod B&#10;&#10;app container&#10;(アプリから見える唯一)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1690" y="540" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="nodeB_note" value="waypoint は L7 policy (認可/レート制限/retry 等) が必要な対象 Pod に対してのみ経由。&#10;L4 のみで足りる場合は ztunnel (Node B) が直接 Pod B に配送する (iptables 側から透過的に Pod に戻る)。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="1110" y="720" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="① 透過捕捉" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;dashPattern=1 2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="310" y="615" as="sourcePoint" />
            <mxPoint x="350" y="615" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e2" value="② 内部" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="530" y="615" as="sourcePoint" />
            <mxPoint x="570" y="615" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e3" value="③ HBONE (mTLS tunnel)" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="880" y="615" as="sourcePoint" />
            <mxPoint x="1110" y="615" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" value="④ L7 経由" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1390" y="615" as="sourcePoint" />
            <mxPoint x="1430" y="615" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" value="⑤ 透過配送" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;dashPattern=1 2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1650" y="615" as="sourcePoint" />
            <mxPoint x="1690" y="615" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="key" value="特徴: 経路上の iptables / ztunnel / HBONE / waypoint はすべて Node レベルの DaemonSet や Gateway リソースで、Pod 側の YAML には現れない。&#10;アプリから「見えない」=「呼び出していない」のに「効いている」= ネットワーク層 (アプリから透過的に効く機構)。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=11;verticalAlign=middle;align=left;spacingLeft=15;spacingRight=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="940" width="1560" height="80" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="凡例" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingTop=8;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1650" y="940" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="lgA" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1665" y="972" width="28" height="16" as="geometry" />
        </mxCell>
