        </mxCell>
        <mxCell id="lgLDT" value="点線細 = 透過捕捉/配送" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1705" y="1026" width="180" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lgLS" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
