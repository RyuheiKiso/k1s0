        <mxCell id="93" value="&lt;b&gt;BFF&lt;/b&gt; = ウェイター（注文を受けてキッチンに伝える）" style="text;html=1;fontSize=13;fontFamily=Helvetica;align=left;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
