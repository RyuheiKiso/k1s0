        <!-- BFF downward branch: System Server -->
        <mxCell id="70" value="&lt;b&gt;System Server&lt;/b&gt;&lt;br&gt;認証 / ログ / 設定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E53935;strokeColor=#C62828;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
