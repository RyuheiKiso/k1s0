<mxfile host="draw.io">
  <diagram name="Request Flow" id="request-flow-1">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Service Tier リクエストフロー" style="text;html=1;fontSize=22;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Step 1: User -->
        <mxCell id="10" value="ユーザー" style="shape=mxgraph.basic.smiley;dx=0.5;fillColor=#E3F2FD;strokeColor=#1565C0;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Step 2: React / Flutter -->
        <mxCell id="20" value="&lt;b&gt;React / Flutter&lt;/b&gt;&lt;br&gt;フロントエンド" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;strokeColor=#1565C0;fontColor=#FFFFFF;fontSize=13;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="155" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow User→React -->
        <mxCell id="21" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="10" target="20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: API Gateway -->
        <mxCell id="30" value="&lt;b&gt;API Gateway&lt;/b&gt;&lt;br&gt;ルーティング / レート制限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9E9E9E;strokeColor=#757575;fontColor=#FFFFFF;fontSize=13;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="155" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow React→Gateway -->
        <mxCell id="31" value="HTTP" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#2196F3;fontFamily=Helvetica;fontSize=11;fontColor=#2196F3;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="20" target="30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: BFF -->
        <mxCell id="40" value="&lt;b&gt;BFF&lt;/b&gt;&lt;br&gt;Go / Rust" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=#388E3C;fontColor=#FFFFFF;fontSize=13;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="155" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow Gateway→BFF -->
        <mxCell id="41" value="HTTP / GraphQL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#4CAF50;fontFamily=Helvetica;fontSize=11;fontColor=#4CAF50;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="30" target="40">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: Business Server -->
        <mxCell id="50" value="&lt;b&gt;業務サーバー&lt;/b&gt;&lt;br&gt;Rust (axum)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#F57C00;fontColor=#FFFFFF;fontSize=13;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="155" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow BFF→Business Server -->
        <mxCell id="51" value="gRPC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#FF9800;fontFamily=Helvetica;fontSize=11;fontColor=#FF9800;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="40" target="50">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6: DB -->
        <mxCell id="60" value="&lt;b&gt;DB&lt;/b&gt;&lt;br&gt;PostgreSQL" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#E0E0E0;strokeColor=#757575;fontColor=#333333;fontSize=13;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="145" width="120" height="90" as="geometry" />
        </mxCell>

        <!-- Arrow Business→DB -->
        <mxCell id="61" value="SQL (sqlx)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#757575;fontFamily=Helvetica;fontSize=11;fontColor=#757575;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="50" target="60">
          <mxGeometry relative="1" as="geometry" />
