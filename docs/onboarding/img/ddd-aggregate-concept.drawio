        <mxCell id="repo" value="&lt;b&gt;ProjectTypeRepository&lt;/b&gt; （trait）&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;async find_by_id(id) → Option&amp;lt;MasterProjectType&amp;gt;&lt;br&gt;async find_all() → Vec&amp;lt;MasterProjectType&amp;gt;&lt;br&gt;async save(project_type) → ()&lt;br&gt;async delete(id) → ()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
