        <mxCell id="status-def" value="&lt;b&gt;MasterStatusDefinition&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id: MasterStatusDefinitionId&lt;br&gt;project_type_id: ProjectTypeId &lt;b&gt;[ID参照]&lt;/b&gt;&lt;br&gt;code: String&lt;br&gt;name: String&lt;br&gt;display_order: i32&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6C8EBF;strokeColor=#4A7DB5;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="260" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="entity-note" value="集約間の参照は&lt;br&gt;ID参照のみ&lt;br&gt;（オブジェクト参照禁止）" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="400" width="80" height="60" as="geometry"/>
