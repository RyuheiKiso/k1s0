<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="ddd-agg-001" name="DDD集約・エンティティ・値オブジェクト">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="DDD — エンティティ・値オブジェクト・集約・リポジトリの関係" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1000" height="35" as="geometry"/>
        </mxCell>

        <!-- ===== 集約境界（破線枠） ===== -->
        <mxCell id="agg-border" value="" style="rounded=1;dashed=1;strokeWidth=3;strokeColor=#D79B00;fillColor=#FFFDE7;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="30" y="120" width="860" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="agg-label" value="集約（Aggregate）境界&lt;br&gt;─ 1トランザクションで整合性を保つ単位 ─" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#D79B00;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="125" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== 集約ルート（エンティティ） ===== -->
        <mxCell id="agg-root-bg" value="" style="rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="175" width="380" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="agg-root-tag" value="エンティティ（集約ルート）" style="text;html=1;fontSize=10;fontColor=#9673A6;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="55" y="178" width="200" height="15" as="geometry"/>
        </mxCell>

        <mxCell id="project-type" value="&lt;b&gt;MasterProjectType&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id: ProjectTypeId &lt;b&gt;[識別子]&lt;/b&gt;&lt;br&gt;name: String&lt;br&gt;description: Option&amp;lt;String&amp;gt;&lt;br&gt;is_system: bool&lt;br&gt;created_at / updated_at&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="root-note" value="★ 集約ルートを通じてのみ&lt;br&gt;内部エンティティを操作する" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#F3E5F5;strokeColor=#9673A6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="320" y="230" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 内部エンティティ ===== -->
        <mxCell id="entity-bg" value="" style="rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="365" width="380" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="entity-tag" value="エンティティ（集約内部）" style="text;html=1;fontSize=10;fontColor=#6C8EBF;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="55" y="368" width="200" height="15" as="geometry"/>
