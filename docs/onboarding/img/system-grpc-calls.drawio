<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="sys-grpc-calls-001" name="system tier gRPC呼出パターン">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="680" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="business サーバーから system tier への gRPC 呼び出しパターン" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="50" y="10" width="1100" height="30" as="geometry"/>
        </mxCell>

        <!-- business サーバー（中心） -->
        <mxCell id="biz-server" value="&lt;b&gt;business サーバー&lt;/b&gt;&lt;br&gt;（例: project-master）&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SystemClients で&lt;br&gt;接続を保持&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="480" y="245" width="220" height="110" as="geometry"/>
        </mxCell>

        <!-- ===== system サーバー群 ===== -->

        <!-- auth-server（左上） -->
        <mxCell id="sys-auth" value="&lt;b&gt;auth-server&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;AuthService.GetUser&lt;br&gt;トークン検証・ユーザー情報&lt;br&gt;エンドポイント: auth:50051&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="50" y="55" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- config-server（右上） -->
        <mxCell id="sys-config" value="&lt;b&gt;config-server&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ConfigService.GetConfig&lt;br&gt;設定値の動的取得&lt;br&gt;エンドポイント: config:50051&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="890" y="55" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- session-server（左中） -->
        <mxCell id="sys-session" value="&lt;b&gt;session-server&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SessionService.GetSession&lt;br&gt;セッション情報取得&lt;br&gt;エンドポイント: session:50051&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="50" y="250" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- tenant-server（右中） -->
        <mxCell id="sys-tenant" value="&lt;b&gt;tenant-server&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;TenantService.GetTenant&lt;br&gt;テナント情報取得&lt;br&gt;エンドポイント: tenant:50051&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="890" y="250" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- featureflag-server（下中） -->
        <mxCell id="sys-ff" value="&lt;b&gt;featureflag-server&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;FeatureFlagService.Evaluate&lt;br&gt;フィーチャーフラグ判定&lt;br&gt;エンドポイント: featureflag:50051&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="460" y="510" width="260" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== gRPC 接続の矢印 ===== -->

        <!-- → auth -->
        <mxCell id="e-auth" value="gRPC (TLS)&lt;br&gt;サービス間トークン付与" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=9;" edge="1" source="biz-server" target="sys-auth" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="300"/>
              <mxPoint x="170" y="300"/>
              <mxPoint x="170" y="155"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- → config -->
        <mxCell id="e-config" value="gRPC (TLS)&lt;br&gt;動的設定取得" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=9;" edge="1" source="biz-server" target="sys-config" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="280"/>
              <mxPoint x="1010" y="280"/>
              <mxPoint x="1010" y="155"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- → session -->
        <mxCell id="e-session" value="gRPC (TLS)&lt;br&gt;セッション確認" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=9;" edge="1" source="biz-server" target="sys-session" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="300"/>
              <mxPoint x="170" y="300"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- → tenant -->
        <mxCell id="e-tenant" value="gRPC (TLS)&lt;br&gt;テナント設定取得" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=9;" edge="1" source="biz-server" target="sys-tenant" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="300"/>
              <mxPoint x="1010" y="300"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- → featureflag -->
        <mxCell id="e-ff" value="gRPC (TLS)&lt;br&gt;フラグ評価" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=9;" edge="1" source="biz-server" target="sys-ff" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="355"/>
              <mxPoint x="590" y="510"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 実装注記 -->
        <mxCell id="impl-note" value="&lt;b&gt;実装（Rust）:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;use k1s0_authlib::AuthClient;&lt;br&gt;use k1s0_config::ConfigClient;&lt;br&gt;&lt;br&gt;pub struct SystemClients &#123;&lt;br&gt;&nbsp;&nbsp;auth: AuthClient,&lt;br&gt;&nbsp;&nbsp;config: ConfigClient, ...&lt;br&gt;&#125;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="50" y="440" width="350" height="145" as="geometry"/>
        </mxCell>

        <!-- 設定注記 -->
        <mxCell id="cfg-note" value="&lt;b&gt;接続先設定（config.yaml）:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;system:&lt;br&gt;&nbsp;&nbsp;auth_endpoint: &quot;auth:50051&quot;&lt;br&gt;&nbsp;&nbsp;config_endpoint: &quot;config:50051&quot;&lt;br&gt;&nbsp;&nbsp;session_endpoint: &quot;session:50051&quot;&lt;br&gt;&nbsp;&nbsp;tenant_endpoint: &quot;tenant:50051&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="780" y="440" width="360" height="145" as="geometry"/>
        </mxCell>

        <!-- 共通事項 -->
        <mxCell id="common-note" value="✓ 全通信にサービス間認証トークンを付与（k1s0_serviceauth）&nbsp;&nbsp;✓ Docker Compose: サービス名解決&nbsp;&nbsp;✓ K8s: Service DNS 名解決" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="625" width="1090" height="35" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
