<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="clean-arch-dep-001" name="サーバー4層依存図">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="クリーンアーキテクチャ 4層構成 — 依存の方向と責務" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1200" height="30" as="geometry"/>
        </mxCell>

        <!-- 依存方向の説明 -->
        <mxCell id="dep-rule" value="依存の方向: 外側 → 内側（一方向のみ）。内側の層は外側の層を知らない。" style="text;html=1;fontSize=12;fontStyle=2;fontColor=#555555;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="42" width="1200" height="18" as="geometry"/>
        </mxCell>

        <!-- ===== 同心円イメージ（左側）===== -->

        <!-- infrastructure（最外） -->
        <mxCell id="infra-outer" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=3;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="520" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="infra-label-top" value="infrastructure" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#6C8EBF;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="75" width="520" height="18" as="geometry"/>
        </mxCell>

        <!-- adapter -->
        <mxCell id="adapter-outer" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=3;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="90" y="130" width="400" height="440" as="geometry"/>
        </mxCell>
        <mxCell id="adapter-label-top" value="adapter" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#B85450;align=center;" vertex="1" parent="1">
          <mxGeometry x="90" y="135" width="400" height="18" as="geometry"/>
        </mxCell>

        <!-- usecase -->
        <mxCell id="usecase-outer" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=3;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="155" y="195" width="270" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="usecase-label-top" value="usecase" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#B8962E;align=center;" vertex="1" parent="1">
          <mxGeometry x="155" y="200" width="270" height="18" as="geometry"/>
        </mxCell>

        <!-- domain（中心） -->
        <mxCell id="domain-center" value="&lt;b&gt;domain&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;エンティティ&lt;br&gt;値オブジェクト&lt;br&gt;リポジトリ interface&lt;br&gt;ドメインサービス&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;strokeWidth=3;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="215" y="255" width="150" height="190" as="geometry"/>
        </mxCell>

        <!-- ===== 右側：ボックス形式の詳細 ===== -->

        <!-- adapter 層（右） -->
        <mxCell id="adapter-box" value="&lt;b&gt;adapter 層&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;src/adapter/ (Rust)&lt;br&gt;internal/adapter/ (Go)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• gRPC サービスハンドラー&lt;br&gt;• REST ハンドラー (axum/chi)&lt;br&gt;• リクエスト/レスポンス変換&lt;br&gt;• エラー変換&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B85450;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="75" width="280" height="140" as="geometry"/>
        </mxCell>

        <!-- usecase 層（右） -->
        <mxCell id="usecase-box" value="&lt;b&gt;usecase 層&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;src/usecase/ (Rust)&lt;br&gt;internal/usecase/ (Go)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• アプリケーションロジック&lt;br&gt;• トランザクション制御&lt;br&gt;• ドメインイベント発行&lt;br&gt;• バリデーション&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#D6B656;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="245" width="280" height="140" as="geometry"/>
        </mxCell>

        <!-- domain 層（右） -->
        <mxCell id="domain-box" value="&lt;b&gt;domain 層（核心）&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;src/domain/ (Rust)&lt;br&gt;internal/domain/ (Go)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• エンティティ（ID を持つ）&lt;br&gt;• 値オブジェクト（不変・ID なし）&lt;br&gt;• リポジトリ interface（trait/interface）&lt;br&gt;• ドメインサービス&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673A6;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="415" width="280" height="150" as="geometry"/>
        </mxCell>

        <!-- infrastructure 層（右） -->
        <mxCell id="infra-box" value="&lt;b&gt;infrastructure 層&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;src/infrastructure/ (Rust)&lt;br&gt;internal/infrastructure/ (Go)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• リポジトリ実装（DB アクセス）&lt;br&gt;• Kafka プロデューサー&lt;br&gt;• 外部 API クライアント&lt;br&gt;• 設定ロード&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C8EBF;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="585" width="280" height="150" as="geometry"/>
        </mxCell>

        <!-- 依存矢印 -->
        <!-- adapter → usecase -->
        <mxCell id="e-ad-uc" value="depends on" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;fontSize=10;" edge="1" source="adapter-box" target="usecase-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- usecase → domain -->
        <mxCell id="e-uc-dm" value="depends on" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;fontSize=10;" edge="1" source="usecase-box" target="domain-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- infrastructure → domain（interface 実装） -->
        <mxCell id="e-inf-dm" value="implements interface" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;fontSize=10;dashed=1;" edge="1" source="infra-box" target="domain-box" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1000" y="660"/>
              <mxPoint x="1050" y="660"/>
              <mxPoint x="1050" y="490"/>
              <mxPoint x="880" y="490"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- DI（依存性注入）の説明 -->
        <mxCell id="di-box" value="&lt;b&gt;DI（依存性注入）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;main.rs / main.go で&lt;br&gt;usecase に repository 実装を注入:&lt;br&gt;Arc&amp;lt;dyn Trait&amp;gt; (Rust)&lt;br&gt;interface 型 (Go)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="920" y="415" width="260" height="130" as="geometry"/>
        </mxCell>

        <!-- DI → infra/usecase -->
        <mxCell id="e-di-inf" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="di-box" target="infra-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-di-uc" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="di-box" target="usecase-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 同心円と右ボックスの対応線 -->
        <mxCell id="link-ad" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=1;fontSize=9;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="adapter-outer" target="adapter-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="link-uc" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=1;fontSize=9;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="usecase-outer" target="usecase-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="link-dm" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=1;fontSize=9;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="domain-center" target="domain-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="link-inf" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=1;fontSize=9;dashed=1;exitX=1;exitY=1;entryX=0;entryY=0.5;" edge="1" source="infra-outer" target="infra-box" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="555" y="620"/>
              <mxPoint x="600" y="660"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
