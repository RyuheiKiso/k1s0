          <mxGeometry x="880" y="90" width="165" height="90" as="geometry"/>
        </mxCell>

        <!-- ステップ6: アプリ組み立て（DI） -->
        <mxCell id="s6" value="&lt;b&gt;⑥ アプリ組み立て（DI）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;repo → usecase → handler&lt;br&gt;CorrelationLayer&lt;br&gt;AuthLayer / TraceLayer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
