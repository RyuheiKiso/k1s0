<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="server-startup-seq-001" name="サーバー初期化フロー">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="business サーバー — 起動時初期化フロー（main.rs / main.go）" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1200" height="30" as="geometry"/>
        </mxCell>

        <!-- 開始 -->
        <mxCell id="start" value="main()&lt;br&gt;起動" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="30" y="100" width="100" height="70" as="geometry"/>
        </mxCell>

        <!-- ステップ1: 設定読み込み -->
        <mxCell id="s1" value="&lt;b&gt;① 設定読み込み&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;Config::load(&quot;config.yaml&quot;)&lt;br&gt;k1s0_config&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="90" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- ステップ2: テレメトリ -->
