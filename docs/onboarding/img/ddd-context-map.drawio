<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="ddd-ctx-001" name="DDDコンテキストマップ">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="DDD — 境界づけられたコンテキストとコンテキストマップ" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="900" height="35" as="geometry"/>
        </mxCell>

        <!-- ===== system Tier（上位・外部コンテキスト） ===== -->
        <mxCell id="sys-ctx-bg" value="" style="rounded=1;dashed=1;strokeWidth=3;strokeColor=#9673A6;fillColor=#E1D5E7;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="1260" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="sys-ctx-label" value="system Tier（上流 / 外部コンテキスト）" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#9673A6;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="65" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- system各サービス -->
        <mxCell id="sys-auth" value="auth-server&lt;br&gt;ユーザー・ロール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="95" width="140" height="55" as="geometry"/>
