        <!-- fa コンテキスト -->
        <mxCell id="fa-ctx" value="" style="rounded=1;dashed=1;strokeWidth=3;strokeColor=#D6B656;fillColor=#FFF2CC;opacity=40;" vertex="1" parent="1">
