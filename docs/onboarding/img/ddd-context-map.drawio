        </mxCell>
        <mxCell id="rule1" value="✓ 同一コンテキスト（同じ業務領域）内: gRPC 同期通信 OK" style="text;html=1;fontSize=11;fontColor=#82B366;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="574" width="500" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule2" value="✓ 異なるコンテキスト間: Kafka 非同期メッセージングを使用" style="text;html=1;fontSize=11;fontColor=#B85450;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="596" width="500" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule3" value="✓ イベントスキーマは Schema Registry で管理し、後方互換性を保証する" style="text;html=1;fontSize=11;fontColor=#9673A6;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="574" width="450" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule4" value="✓ コンシューマーグループ: {領域名}.{サーバー名}  /  DLQ で失敗メッセージを保全" style="text;html=1;fontSize=11;fontColor=#D6B656;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="596" width="450" height="18" as="geometry"/>
