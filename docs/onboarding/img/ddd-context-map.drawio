          <mxGeometry x="20" y="210" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- taskmanagement コンテキスト -->
        <mxCell id="task-ctx" value="" style="rounded=1;dashed=1;strokeWidth=3;strokeColor=#82B366;fillColor=#D5E8D4;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="540" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="task-ctx-label" value="taskmanagement コンテキスト&lt;br&gt;（regions/business/taskmanagement/）" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#82B366;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="245" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- project-master -->
        <mxCell id="proj-master" value="&lt;b&gt;project-master&lt;/b&gt;&lt;br&gt;集約: MasterProjectType&lt;br&gt;集約: MasterStatusDefinition&lt;br&gt;ユビキタス言語:&lt;br&gt;プロジェクトタイプ・ステータス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="220" height="100" as="geometry"/>
