        <!-- fa-server -->
        <mxCell id="fa-server" value="&lt;b&gt;fa-server（例）&lt;/b&gt;&lt;br&gt;集約: FixedAsset&lt;br&gt;集約: DepreciationSchedule&lt;br&gt;ユビキタス言語:&lt;br&gt;固定資産・減価償却" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
