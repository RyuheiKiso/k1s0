        <!-- fa ACL -->
        <mxCell id="fa-acl" value="&lt;b&gt;Anti-Corruption Layer&lt;/b&gt;&lt;br&gt;taskmanagement のモデルを&lt;br&gt;fa のモデルに変換する変換層" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B85450;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="620" y="415" width="340" height="70" as="geometry"/>
        </mxCell>

        <!-- コンテキスト間 Kafka -->
        <mxCell id="e-task-fa" value="Kafka 非同期&lt;br&gt;（異コンテキスト間）" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;dashed=1;fontSize=9;" edge="1" source="task-events" target="fa-acl" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="450"/>
              <mxPoint x="620" y="450"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== コンテキスト関係パターン（右側） ===== -->
        <mxCell id="patterns-bg" value="" style="rounded=1;fillColor=#F5F5F5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="1000" y="240" width="280" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="patterns-title" value="コンテキスト関係パターン" style="text;html=1;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1010" y="245" width="260" height="20" as="geometry"/>
        </mxCell>

        <!-- Published Language -->
        <mxCell id="pat-pl" value="&lt;b&gt;Published Language&lt;/b&gt;&lt;br&gt;共有するイベントスキーマ&lt;br&gt;例: taskmanagement → fa への&lt;br&gt;プロジェクト完了イベント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="1010" y="270" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- Anti-Corruption Layer -->
        <mxCell id="pat-acl" value="&lt;b&gt;Anti-Corruption Layer&lt;/b&gt;&lt;br&gt;外部モデル → 自モデルへの変換&lt;br&gt;例: fa が taskmanagement の&lt;br&gt;プロジェクトデータを受け取る際" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="1010" y="360" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- Conformist -->
        <mxCell id="pat-conf" value="&lt;b&gt;Conformist&lt;/b&gt;&lt;br&gt;上流モデルをそのまま受け入れ&lt;br&gt;例: system tier のユーザーモデルを&lt;br&gt;business/service がそのまま利用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="1010" y="450" width="260" height="70" as="geometry"/>
