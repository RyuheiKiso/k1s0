        <mxCell id="sys-schema" value="Schema Registry&lt;br&gt;スキーマ管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="520" y="95" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- ===== business Tier コンテキスト群 ===== -->
