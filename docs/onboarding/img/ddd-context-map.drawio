        <mxCell id="sys-config" value="config-server&lt;br&gt;設定値" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
