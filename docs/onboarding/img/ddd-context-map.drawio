        <mxCell id="e-pm-task" value="gRPC（同期）&lt;br&gt;プロジェクトタイプ参照" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;fontSize=9;" edge="1" source="task-server" target="proj-master" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ドメインイベント（task） -->
        <mxCell id="task-events" value="&lt;b&gt;Published Events（Kafka）:&lt;/b&gt;&lt;br&gt;k1s0.service.task.created.v1&lt;br&gt;k1s0.service.task.updated.v1&lt;br&gt;k1s0.service.task.cancelled.v1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="415" width="500" height="70" as="geometry"/>
