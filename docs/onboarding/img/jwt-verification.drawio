<mxfile host="draw.io">
  <diagram name="JWT Verification Flow" id="jwt-flow-1">
    <mxGraphModel dx="900" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="1050" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="JWT 検証フロー" style="text;html=1;fontSize=20;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="175" y="20" width="350" height="40" as="geometry" />
        </mxCell>

        <!-- Step 1: Client -->
        <mxCell id="10" value="&lt;b&gt;1. クライアント&lt;/b&gt;&lt;br&gt;React / Flutter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;strokeColor=#1565C0;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="80" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 1→2 -->
        <mxCell id="11" value="Authorization: Bearer &lt;JWT&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeWidth=2;strokeColor=#666666;fontFamily=Helvetica;fontSize=11;fontColor=#666666;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="10" target="20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 2: API Gateway -->
        <mxCell id="20" value="&lt;b&gt;2. API Gateway&lt;/b&gt;&lt;br&gt;リクエスト受信・ルーティング" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9E9E9E;strokeColor=#757575;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="220" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 2→3 -->
        <mxCell id="21" value="リクエスト転送" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeWidth=2;strokeColor=#666666;fontFamily=Helvetica;fontSize=11;fontColor=#666666;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="20" target="30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Business Server -->
        <mxCell id="30" value="&lt;b&gt;3. Business Server&lt;/b&gt;&lt;br&gt;認証・認可ミドルウェア" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=#388E3C;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="360" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 3→4 -->
        <mxCell id="31" value="トークン抽出" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeWidth=2;strokeColor=#666666;fontFamily=Helvetica;fontSize=11;fontColor=#666666;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="30" target="40">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Processing detail annotation for step 3 -->
        <mxCell id="32" value="&lt;ol style='text-align:left;margin:4px;padding-left:16px;'&gt;&lt;li&gt;ヘッダーからJWT抽出&lt;/li&gt;&lt;li&gt;authlibに検証委譲&lt;/li&gt;&lt;li&gt;ユーザー情報をコンテキストに設定&lt;/li&gt;&lt;/ol&gt;" style="shape=note;size=12;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;fontFamily=Helvetica;align=left;verticalAlign=top;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="340" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="33" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#F9A825;strokeWidth=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="30" target="32">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: JWT Verification -->
        <mxCell id="40" value="&lt;b&gt;4. JWT 検証（authlib）&lt;/b&gt;&lt;br&gt;署名検証 / 有効期限チェック / クレーム検証" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFC107;strokeColor=#FFA000;fontColor=#333333;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="500" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow 4→5 -->
        <mxCell id="41" value="検証OK → ユーザー情報" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeWidth=2;strokeColor=#666666;fontFamily=Helvetica;fontSize=11;fontColor=#666666;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="40" target="50">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Rejection branch from JWT -->
        <mxCell id="42" value="&lt;b&gt;401 Unauthorized&lt;/b&gt;&lt;br&gt;検証失敗" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F44336;strokeColor=#D32F2F;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="510" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="43" value="検証NG" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#F44336;fontFamily=Helvetica;fontSize=11;fontColor=#F44336;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="40" target="42">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: RBAC Check -->
        <mxCell id="50" value="&lt;b&gt;5. RBAC チェック（authlib）&lt;/b&gt;&lt;br&gt;ロールベースのアクセス制御" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#F57C00;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="650" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow 5→6 -->
        <mxCell id="51" value="権限OK → 処理続行" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeWidth=2;strokeColor=#666666;fontFamily=Helvetica;fontSize=11;fontColor=#666666;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="50" target="60">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Rejection branch from RBAC -->
        <mxCell id="52" value="&lt;b&gt;403 Forbidden&lt;/b&gt;&lt;br&gt;権限不足" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F44336;strokeColor=#D32F2F;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="660" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="53" value="権限NG" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#F44336;fontFamily=Helvetica;fontSize=11;fontColor=#F44336;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="50" target="52">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6: Business Logic -->
        <mxCell id="60" value="&lt;b&gt;6. ビジネスロジック実行&lt;/b&gt;&lt;br&gt;サービス固有の処理を実行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;strokeColor=#1565C0;fontColor=#FFFFFF;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="800" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- Response arrow -->
        <mxCell id="61" value="&lt;b&gt;200 OK&lt;/b&gt; レスポンス返却" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;fontColor=#388E3C;fontSize=12;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="920" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="62" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#4CAF50;fontFamily=Helvetica;" edge="1" parent="1" source="60" target="61">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>