<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="server-add-flow-001" name="新規サーバー追加フロー">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="新規サーバー追加の手順フロー（10ステップ）" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1200" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== ステップ1: CLI雛形生成 ===== -->
        <mxCell id="s1" value="&lt;b&gt;① CLI で雛形生成&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;k1s0 generate&lt;br&gt;→ server &gt; business &gt; rust&lt;br&gt;&nbsp;&nbsp; 領域名・サーバー名を入力&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="30" y="65" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== ステップ2: proto定義 ===== -->
        <mxCell id="s2" value="&lt;b&gt;② proto ファイル定義&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;proto/k1s0/business/&lt;br&gt;{領域}/{サービス}/v1/&lt;br&gt;service.proto 作成&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;font-family:Courier New&quot;&gt;buf generate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="265" y="65" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== ステップ3: domain層 ===== -->
        <mxCell id="s3" value="&lt;b&gt;③ domain 層実装&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;エンティティ定義&lt;br&gt;値オブジェクト定義&lt;br&gt;リポジトリ interface（trait）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="65" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== ステップ4: usecase層 ===== -->
        <mxCell id="s4" value="&lt;b&gt;④ usecase 層実装&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;アプリケーションロジック&lt;br&gt;トランザクション制御&lt;br&gt;ドメインイベント発行組込&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="735" y="65" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== ステップ5: infrastructure層 ===== -->
        <mxCell id="s5" value="&lt;b&gt;⑤ infrastructure 層実装&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;リポジトリ DB 実装&lt;br&gt;Kafka プロデューサー&lt;br&gt;コンシューマー実装&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="970" y="65" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== ステップ6: adapter層 ===== -->
        <mxCell id="s6" value="&lt;b&gt;⑥ adapter 層実装&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;gRPC ハンドラー&lt;br&gt;REST ハンドラー&lt;br&gt;エラー変換&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1205" y="65" width="165" height="100" as="geometry"/>
        </mxCell>

        <!-- 上段の矢印 -->
        <mxCell id="e12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e23" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e34" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e45" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e56" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s5" target="s6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 下段（継続） ===== -->

        <!-- ステップ7: DB migration -->
        <mxCell id="s7" value="&lt;b&gt;⑦ DB マイグレーション作成&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;migrations/ に SQL 配置&lt;br&gt;{連番}_{説明}.up.sql&lt;br&gt;{連番}_{説明}.down.sql&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="340" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ステップ8: テスト -->
        <mxCell id="s8" value="&lt;b&gt;⑧ テスト記述&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;各層のユニットテスト&lt;br&gt;（モック活用）&lt;br&gt;結合テスト（テスト DB）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="265" y="340" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ステップ9: 設定ファイル -->
        <mxCell id="s9" value="&lt;b&gt;⑨ 設定ファイル作成&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;config/config.yaml&lt;br&gt;サーバー設定・Kafka&lt;br&gt;DB 接続情報等&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="340" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- ステップ10: Dockerfile/Helm -->
        <mxCell id="s10" value="&lt;b&gt;⑩ Dockerfile / Helm&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;コンテナ化&lt;br&gt;K8s Helm チャート作成&lt;br&gt;Namespace: k1s0-business&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="735" y="340" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- 完了 -->
        <mxCell id="done" value="&lt;b&gt;完成&lt;/b&gt;&lt;br&gt;PR レビュー&lt;br&gt;マージ" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="980" y="345" width="140" height="90" as="geometry"/>
        </mxCell>

        <!-- 折り返し矢印（s6 → s7） -->
        <mxCell id="e-turn" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s6" target="s7" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1287" y="220"/>
              <mxPoint x="1287" y="300"/>
              <mxPoint x="130" y="300"/>
              <mxPoint x="130" y="340"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 下段矢印 -->
        <mxCell id="e78" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s7" target="s8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e89" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s8" target="s9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e910" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="s9" target="s10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10done" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;" edge="1" source="s10" target="done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 注記 ===== -->
        <mxCell id="note-parallel" value="&lt;b&gt;並列実施可能:&lt;/b&gt; ③domain と ⑤infra の一部（スキーマ設計）は並行して進められる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="475" width="700" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="note-tdd" value="&lt;b&gt;TDD 推奨:&lt;/b&gt; ③～⑥の各層実装は「テストファースト」で進める（⑧と並行）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
