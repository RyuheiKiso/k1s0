          </mxGeometry>
        </mxCell>
        <mxCell id="sync_arrow_left" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#2E7D32;endArrow=block;endFill=1;" edge="1" source="journal_proc" target="domain_master" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="220" />
            </Array>
          </mxGeometry>
