        </mxCell>

        <!-- accounting → Kafka -->
        <mxCell id="async_e1" value="publish" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1565C0;fontFamily=Helvetica;fontSize=11;fontColor=#1565C0;" edge="1" source="acc_server" target="kafka" parent="1">
