        </mxCell>

        <mxCell id="sync_title" value="同一ドメインコンテキスト内（同期通信）" style="text;html=1;fontSize=15;fontStyle=1;fontFamily=Helvetica;align=left;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- accounting/domain-master -->
        <mxCell id="domain_master" value="&lt;b&gt;accounting/&lt;br&gt;domain-master&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E8B57;fontColor=#FFFFFF;strokeColor=#1E6B3F;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="170" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- accounting/journal-processor -->
        <mxCell id="journal_proc" value="&lt;b&gt;accounting/&lt;br&gt;journal-processor&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E8B57;fontColor=#FFFFFF;strokeColor=#1E6B3F;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="170" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- 双方向矢印 -->
        <mxCell id="sync_arrow_right" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#2E7D32;endArrow=block;endFill=1;" edge="1" source="domain_master" target="journal_proc" parent="1">
          <mxGeometry relative="1" as="geometry">
