        <!-- gRPC ラベル -->
        <mxCell id="grpc_label" value="&lt;b&gt;gRPC 直接通信&lt;/b&gt;" style="text;html=1;fontSize=13;fontFamily=Helvetica;align=center;fontColor=#2E7D32;fillColor=#C8E6C9;rounded=1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="410" y="260" width="140" height="30" as="geometry" />
        </mxCell>

        <!-- 下半分：非同期通信エリア（青背景） -->
        <mxCell id="async_area" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="840" height="280" as="geometry" />
        </mxCell>

