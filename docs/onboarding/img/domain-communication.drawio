        <!-- Kafka → fa -->
        <mxCell id="async_e2" value="consume" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1565C0;fontFamily=Helvetica;fontSize=11;fontColor=#1565C0;" edge="1" source="kafka" target="fa_server" parent="1">
