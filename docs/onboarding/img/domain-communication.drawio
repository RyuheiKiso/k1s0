          <mxGeometry x="100" y="390" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- accounting/server -->
        <mxCell id="acc_server" value="&lt;b&gt;accounting/&lt;br&gt;server&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4A90D9;fontColor=#FFFFFF;strokeColor=#3A70B0;fontSize=14;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="470" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Kafka -->
        <mxCell id="kafka" value="&lt;b&gt;Kafka&lt;/b&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFD54F;fontColor=#333333;strokeColor=#FFA000;fontSize=14;fontFamily=Helvetica;shadow=1;size=12;" vertex="1" parent="1">
