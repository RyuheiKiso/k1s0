<mxfile host="draw.io">
  <diagram name="UI Layout" id="ui-layout-1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="750" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Browser Window Frame -->
        <mxCell id="2" value="Web Application - UI Layout (3 Tier)" style="shape=mxgraph.mockup.containers.browserWindow;rSize=0;strokeColor=#666666;fillColor=#F5F5F5;align=center;verticalAlign=top;fontSize=14;fontFamily=Helvetica;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="1000" height="680" as="geometry" />
        </mxCell>

