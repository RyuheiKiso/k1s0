<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="biz-domain-struct-001" name="業務領域の構成図">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="720" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="業務「領域」の構成 — regions/business/{領域名}/ の内部構造" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1100" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== regions/business/ の2領域 ===== -->

        <!-- taskmanagement 領域 -->
        <mxCell id="task-ctx" value="" style="rounded=1;dashed=1;strokeWidth=3;strokeColor=#82B366;fillColor=#D5E8D4;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="55" width="560" height="460" as="geometry"/>
        </mxCell>
        <mxCell id="task-ctx-label" value="taskmanagement 領域&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;regions/business/taskmanagement/&lt;/font&gt;" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#5D9E4B;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="500" height="28" as="geometry"/>
        </mxCell>

        <!-- server -->
        <mxCell id="task-server" value="&lt;b&gt;server/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;rust/project-master&lt;br&gt;（ドメインサービス・CRUD API）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="105" width="240" height="80" as="geometry"/>
        </mxCell>
        <!-- client -->
        <mxCell id="task-client" value="&lt;b&gt;client/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;react/ 共通コンポーネント&lt;br&gt;flutter/ 共通ウィジェット&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="310" y="105" width="240" height="80" as="geometry"/>
        </mxCell>
        <!-- library -->
        <mxCell id="task-lib" value="&lt;b&gt;library/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;go/, rust/, typescript/, dart/&lt;br&gt;ドメインモデル・バリデーション&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="240" height="80" as="geometry"/>
        </mxCell>
        <!-- database -->
        <mxCell id="task-db" value="&lt;b&gt;database/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PostgreSQL&lt;br&gt;migrations/ マイグレーション&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="310" y="220" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- 4種別の関係説明 -->
        <mxCell id="task-note" value="&lt;b&gt;4種別の関係:&lt;/b&gt;&lt;br&gt;・server は library を import し、database を利用&lt;br&gt;・client は library を import して型定義を共有&lt;br&gt;・service tier は server へ gRPC で呼出&lt;br&gt;・service tier は library を import して利用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBE7;strokeColor=#82B366;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="335" width="510" height="90" as="geometry"/>
        </mxCell>

        <!-- server → library -->
        <mxCell id="e-srv-lib" value="import" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="task-server" target="task-lib" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- server → database -->
        <mxCell id="e-srv-db" value="sqlx" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="task-server" target="task-db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- client → library -->
        <mxCell id="e-cli-lib" value="import" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="task-client" target="task-lib" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== fa 領域 ===== -->
        <mxCell id="fa-ctx" value="" style="rounded=1;dashed=1;strokeWidth=3;strokeColor=#D6B656;fillColor=#FFF2CC;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="620" y="55" width="560" height="460" as="geometry"/>
        </mxCell>
        <mxCell id="fa-ctx-label" value="fa 領域（固定資産）&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;regions/business/fa/&lt;/font&gt;" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#B8962E;align=left;" vertex="1" parent="1">
          <mxGeometry x="630" y="60" width="500" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="fa-server" value="&lt;b&gt;server/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;rust/fa-server&lt;br&gt;（固定資産ドメインサービス）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="640" y="105" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="fa-client" value="&lt;b&gt;client/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;react/ FA共通コンポーネント&lt;br&gt;flutter/ FA共通ウィジェット&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="910" y="105" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="fa-lib" value="&lt;b&gt;library/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;go/, rust/, typescript/, dart/&lt;br&gt;固定資産モデル・計算ロジック&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="640" y="220" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="fa-db" value="&lt;b&gt;database/&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PostgreSQL（fa スキーマ）&lt;br&gt;migrations/ マイグレーション&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="910" y="220" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="fa-note" value="&lt;b&gt;ACL（Anti-Corruption Layer）:&lt;/b&gt;&lt;br&gt;fa 領域は taskmanagement のイベントを購読する際に&lt;br&gt;ACL で fa 独自のモデルに変換して利用する。&lt;br&gt;→ 他領域のモデルを直接参照しない設計" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#D6B656;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="640" y="335" width="510" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="e-fa-srv-lib" value="import" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="fa-server" target="fa-lib" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-fa-srv-db" value="sqlx" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="fa-server" target="fa-db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-fa-cli-lib" value="import" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=1;fontSize=9;dashed=1;" edge="1" source="fa-client" target="fa-lib" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 領域間 Kafka ===== -->
        <mxCell id="kafka-hub" value="Kafka&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;k1s0.business.*.*.v1&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="550" y="180" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- taskmanagement → Kafka（発行） -->
        <mxCell id="e-task-kafka" value="イベント発行" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;fontSize=9;" edge="1" source="task-server" target="kafka-hub" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="155"/>
              <mxPoint x="610" y="155"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Kafka → fa（購読） -->
        <mxCell id="e-kafka-fa" value="イベント購読（ACL変換）" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;fontSize=9;" edge="1" source="kafka-hub" target="fa-server" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="185"/>
              <mxPoint x="760" y="185"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 禁止バッジ -->
        <mxCell id="no-direct" value="× 直接 gRPC 通信禁止" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B85450;fontSize=11;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="500" y="280" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- ルールまとめ -->
        <mxCell id="rules-bg" value="" style="rounded=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;" vertex="1" parent="1">
          <mxGeometry x="20" y="540" width="1160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="rule1" value="✓ 各領域は互いに独立したディレクトリ・DB・ライブラリを持つ" style="text;html=1;fontSize=11;fontColor=#5D9E4B;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="545" width="500" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule2" value="✓ 領域間のデータ連携は Kafka 非同期メッセージング経由" style="text;html=1;fontSize=11;fontColor=#5D9E4B;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="567" width="500" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule3" value="✓ DB への直接アクセスは禁止 — 必ず server API 経由" style="text;html=1;fontSize=11;fontColor=#B85450;align=left;" vertex="1" parent="1">
          <mxGeometry x="560" y="545" width="480" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule4" value="✓ 他領域のモデルを直接参照しない — ACL で自領域モデルに変換" style="text;html=1;fontSize=11;fontColor=#B85450;align=left;" vertex="1" parent="1">
          <mxGeometry x="560" y="567" width="480" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
