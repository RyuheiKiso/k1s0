        <mxCell id="section2_title" value="Section 2: シークレット管理 (HashiCorp Vault 1.17)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="505" width="500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="vault_central" value="HashiCorp Vault 1.17&#xa;(中央シークレット管理)&#xa;&#xa;HA 構成 + Helm Chart&#xa;Vault Operator 管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="555" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="vault_kv" value="KV v2 エンジン&#xa;(マウント: secret/)&#xa;&#xa;・静的シークレット&#xa;・API キー、設定値&#xa;・OIDC Client Secret&#xa;・Redis AUTH パスワード&#xa;&#xa;パス: secret/data/k1s0/&#xa;  {tier}/{service}/{type}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="310" y="545" width="210" height="165" as="geometry" />
        </mxCell>

        <mxCell id="vault_db" value="Database エンジン&#xa;(マウント: database/)&#xa;&#xa;・動的 DB クレデンシャル&#xa;・TTL: 24h (default)&#xa;・Max TTL: 48h&#xa;・自動ローテーション&#xa;&#xa;パス: database/creds/&#xa;  {tier}-{service}-{rw|ro}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="540" y="545" width="210" height="165" as="geometry" />
        </mxCell>

        <mxCell id="vault_pki" value="PKI エンジン&#xa;(マウント: pki_int/)&#xa;&#xa;・内部 TLS 証明書発行&#xa;・Intermediate CA&#xa;・Root CA 直接利用禁止&#xa;・証明書ローテ: 90日&#xa;&#xa;パス: pki_int/issue/{tier}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="770" y="545" width="210" height="165" as="geometry" />
        </mxCell>

        <mxCell id="vault_auth_methods" value="Vault 認証方式&#xa;&#xa;┌───────────────────────────────┐&#xa;│ Kubernetes Auth              │&#xa;│  ServiceAccount → Vault Role │&#xa;│  (Pod からのアクセス)         │&#xa;├───────────────────────────────┤&#xa;│ AppRole                       │&#xa;│  (CI/CD パイプライン)         │&#xa;├───────────────────────────────┤&#xa;│ LDAP                          │&#xa;│  (人間のオペレーター)         │&#xa;└───────────────────────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="50" y="680" width="250" height="220" as="geometry" />
        </mxCell>

        <mxCell id="vault_injector" value="Vault Agent Injector パターン&#xa;&#xa;Pod annotations:&#xa;  vault.hashicorp.com/agent-inject: true&#xa;  vault.hashicorp.com/role: {service}&#xa;&#xa;マウントパス:&#xa;  /vault/secrets/db-password&#xa;  /vault/secrets/db-creds&#xa;  /vault/secrets/api-key&#xa;  /vault/secrets/redis-password&#xa;  /vault/secrets/kafka-sasl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="310" y="730" width="260" height="170" as="geometry" />
        </mxCell>

        <mxCell id="vault_rotation_flow" value="シークレットローテーションフロー&#xa;&#xa;┌─────────┐    ┌──────────┐    ┌──────┐&#xa;│ Vault   │───→│ Injector │───→│ Pod  │&#xa;│ 生成    │    │ 注入     │    │ 読取 │&#xa;└─────────┘    └──────────┘    └──────┘&#xa;     ↑                              │&#xa;     └──── TTL 期限切れ → 自動更新 ─┘&#xa;&#xa;ローテーション間隔:&#xa;  DB パスワード: 24h (自動)&#xa;  API キー: 90日 (手動)&#xa;  TLS 証明書: 90日 (自動)&#xa;  JWT 署名鍵: 90日 (Keycloak)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="590" y="730" width="310" height="190" as="geometry" />
        </mxCell>

        <mxCell id="vault_audit" value="監査ログ&#xa;&#xa;・全認証試行 (成功/失敗)&#xa;・全シークレット読取操作&#xa;・ポリシー変更&#xa;・設定変更&#xa;・シークレット値マスク&#xa;  (log_raw: false)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="730" width="190" height="140" as="geometry" />
        </mxCell>

        <mxCell id="vault_policy" value="Tier 別アクセスポリシー (最小権限)&#xa;&#xa;2階層構造:&#xa;  1. Bootstrap Tier ポリシー&#xa;     (k1s0-system.hcl 等)&#xa;  2. サービス固有ポリシー&#xa;     (auth-server.hcl 等)&#xa;&#xa;K8s Auth ロール:&#xa;  token_policies:&#xa;    [&quot;k1s0-system&quot;, &quot;auth-server&quot;]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1130" y="555" width="230" height="190" as="geometry" />
        </mxCell>

        <mxCell id="flow_vault_kv" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#D6B656;strokeWidth=1;" edge="1" source="vault_central" target="vault_kv" parent="1">
