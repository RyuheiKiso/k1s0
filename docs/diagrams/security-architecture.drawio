        <mxCell id="source_code" value="ソースコード&#xa;(GitHub リポジトリ)&#xa;&#xa;PR → CI トリガー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#339933;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1530" y="560" width="150" height="80" as="geometry" />
        </mxCell>

        <mxCell id="docker_build" value="Docker マルチステージビルド&#xa;&#xa;Build: rust:1.88-bookworm&#xa;       golang:1.24-bookworm&#xa;Runtime: distroless&#xa;  gcr.io/distroless/cc-debian12&#xa;  gcr.io/distroless/static-debian12&#xa;&#xa;・非 root 実行 (nonroot)&#xa;・攻撃面最小化&#xa;・不要ツール排除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#339933;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1530" y="670" width="230" height="190" as="geometry" />
        </mxCell>

        <mxCell id="trivy_scan" value="Trivy 脆弱性スキャン&#xa;&#xa;・CI: filesystem scan&#xa;・Push 時: Harbor 組込&#xa;・日次: image scan&#xa;&#xa;ポリシー:&#xa;  CRITICAL → push ブロック&#xa;  HIGH → push ブロック&#xa;  MEDIUM → 警告のみ&#xa;  LOW → 記録のみ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#339933;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1790" y="560" width="190" height="200" as="geometry" />
        </mxCell>

        <mxCell id="cosign_sign" value="Cosign Keyless 署名&#xa;&#xa;・GitHub OIDC Identity&#xa;・Sigstore Fulcio (証明書)&#xa;・Sigstore Rekor (透明性ログ)&#xa;・鍵管理不要&#xa;&#xa;cosign sign --yes \&#xa;  harbor.../image:tag&#xa;COSIGN_EXPERIMENTAL=1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#339933;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="2010" y="560" width="210" height="180" as="geometry" />
        </mxCell>

        <mxCell id="harbor" value="Harbor レジストリ&#xa;&#xa;プロジェクト構成:&#xa;  k1s0-system/&#xa;  k1s0-business/&#xa;  k1s0-service/&#xa;  k1s0-infra/&#xa;&#xa;・ロボットアカウント認証&#xa;・Trivy 自動スキャン&#xa;・タグ保持ポリシー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#339933;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="2250" y="560" width="200" height="200" as="geometry" />
        </mxCell>

        <mxCell id="admission_webhook" value="K8s Admission Webhook&#xa;&#xa;・Cosign 署名検証&#xa;・Kyverno / OPA Gatekeeper&#xa;・未署名イメージ拒否&#xa;&#xa;cosign verify \&#xa;  --certificate-oidc-issuer&#xa;  https://token.actions.&#xa;    githubusercontent.com&#xa;  --certificate-identity-regexp&#xa;  github.com/k1s0-org/k1s0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#339933;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="2480" y="560" width="230" height="200" as="geometry" />
        </mxCell>

        <mxCell id="deploy_target" value="デプロイ&#xa;(Helm upgrade)&#xa;&#xa;dev → staging → prod" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#339933;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2510" y="790" width="170" height="70" as="geometry" />
        </mxCell>

        <mxCell id="supply_chain_label" value="サプライチェーン: Source → Build → Scan → Sign → Store → Verify → Deploy" style="text;html=1;fontSize=11;fontStyle=3;align=center;verticalAlign=middle;fillColor=#E6FFE6;strokeColor=#339933;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1790" y="790" width="550" height="25" as="geometry" />
        </mxCell>

        <mxCell id="flow_src_build" value="Build" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#339933;strokeWidth=2;fontSize=9;" edge="1" source="source_code" target="docker_build" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_build_trivy" value="Scan" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#339933;strokeWidth=2;fontSize=9;" edge="1" source="docker_build" target="trivy_scan" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_trivy_cosign" value="Sign" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#339933;strokeWidth=2;fontSize=9;" edge="1" source="trivy_scan" target="cosign_sign" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_cosign_harbor" value="Push" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#339933;strokeWidth=2;fontSize=9;" edge="1" source="cosign_sign" target="harbor" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_harbor_verify" value="Pull" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#339933;strokeWidth=2;fontSize=9;" edge="1" source="harbor" target="admission_webhook" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_verify_deploy" value="Deploy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#339933;strokeWidth=2;fontSize=9;" edge="1" source="admission_webhook" target="deploy_target" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="section4_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="950" width="1460" height="520" as="geometry" />
        </mxCell>
        <mxCell id="section4_title" value="Section 4: ネットワークセキュリティ" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;fillColor=#DAE8FC;strokeColor=#6C8EBF;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="955" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="calico_cni" value="Calico CNI + NetworkPolicy&#xa;(L3/L4 ネットワーク制御)&#xa;&#xa;・Namespace 間の通信制御&#xa;・Pod レベルのファイアウォール&#xa;・IP ベースのアクセス制御&#xa;・Istio AuthorizationPolicy と連携&#xa;  (NetworkPolicy: L3/L4&#xa;   AuthorizationPolicy: L7)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="1000" width="280" height="160" as="geometry" />
        </mxCell>

        <mxCell id="ns_isolation" value="Namespace 分離&#xa;&#xa;┌─────────────────────────────────────┐&#xa;│ k1s0-system                         │&#xa;│  auth / config / saga / dlq-manager │&#xa;│  bff-proxy / vault / scheduler ...  │&#xa;├─────────────────────────────────────┤&#xa;│ k1s0-business                       │&#xa;│  ドメイン別ビジネスサーバー          │&#xa;├─────────────────────────────────────┤&#xa;│ k1s0-service                        │&#xa;│  BFF / エンドユーザー向けサービス    │&#xa;├─────────────────────────────────────┤&#xa;│ ingress / messaging / observability │&#xa;│ service-mesh / vault                │&#xa;└─────────────────────────────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="40" y="1180" width="320" height="270" as="geometry" />
        </mxCell>

        <mxCell id="authz_policy" value="Istio AuthorizationPolicy&#xa;(L7 Tier ベースアクセス制御)&#xa;&#xa;┌───────────────────────────────────┐&#xa;│ allow-from-lower-tiers (system)   │&#xa;│  FROM: k1s0-business, k1s0-service│&#xa;│  FROM: k1s0-system (同一Tier)     │&#xa;├───────────────────────────────────┤&#xa;│ allow-from-service-tier (business)│&#xa;│  FROM: k1s0-service               │&#xa;│  FROM: k1s0-business (同一Tier)   │&#xa;├───────────────────────────────────┤&#xa;│ allow-from-ingress (service)      │&#xa;│  FROM: ingress                    │&#xa;│  FROM: k1s0-service (同一Tier)    │&#xa;├───────────────────────────────────┤&#xa;│ deny-bff-to-bff (service)         │&#xa;│  DENY: *-bff-sa → BFF component  │&#xa;│  (BFF 間の直接通信を禁止)         │&#xa;└───────────────────────────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="380" y="1000" width="340" height="320" as="geometry" />
        </mxCell>

        <mxCell id="tier_flow" value="Tier 間通信ルール (一方向)&#xa;&#xa;service → business → system&#xa;(上位 Tier を呼び出し可能)&#xa;&#xa;system → business: 禁止&#xa;business → service: 禁止&#xa;BFF → BFF: 禁止" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="1340" width="280" height="120" as="geometry" />
        </mxCell>

        <mxCell id="kong_security" value="Kong セキュリティ機能&#xa;&#xa;・JWT 検証 (JWKS エンドポイント)&#xa;・レート制限 (IP / Consumer)&#xa;・CORS ポリシー制御&#xa;・Bot 検出&#xa;・リクエストサイズ制限&#xa;・IP ホワイトリスト" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="1000" width="250" height="155" as="geometry" />
        </mxCell>

        <mxCell id="redis_security" value="Redis セキュリティ (本番)&#xa;&#xa;・SASL/SCRAM 認証&#xa;・Vault 管理パスワード&#xa;・Redis Sentinel (HA)&#xa;・パス: secret/data/k1s0/&#xa;  system/redis/password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="1180" width="250" height="130" as="geometry" />
        </mxCell>

        <mxCell id="kafka_security" value="Kafka セキュリティ (本番)&#xa;&#xa;・SASL/SCRAM-SHA-512&#xa;・TLS 暗号化&#xa;・KRaft モード&#xa;・パス: secret/data/k1s0/&#xa;  system/kafka/sasl&#xa;  (username, password)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="1330" width="250" height="130" as="geometry" />
        </mxCell>

        <mxCell id="nw_defense" value="多層防御モデル&#xa;&#xa;L3/L4: Calico NetworkPolicy&#xa;  ↓&#xa;L7: Istio AuthorizationPolicy&#xa;  ↓&#xa;App: Kong JWT/Rate Limit&#xa;  ↓&#xa;App: サービス内 RBAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="1000" width="220" height="170" as="geometry" />
        </mxCell>

        <mxCell id="section5_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;strokeWidth=2;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="1500" y="950" width="1480" height="520" as="geometry" />
        </mxCell>
        <mxCell id="section5_title" value="Section 5: 暗号化とデータ保護" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1510" y="955" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="encrypt_transit" value="Encryption in Transit&#xa;(通信の暗号化)&#xa;&#xa;・TLS 1.3 (外部通信)&#xa;・mTLS (メッシュ内部)&#xa;  - Istio STRICT モード&#xa;  - 24h 証明書ローテーション&#xa;・Kafka TLS (本番)&#xa;・Redis TLS (本番)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1530" y="1000" width="250" height="175" as="geometry" />
        </mxCell>

        <mxCell id="encrypt_rest" value="Encryption at Rest&#xa;(保存時の暗号化)&#xa;&#xa;・PostgreSQL TDE&#xa;  (Transparent Data Encryption)&#xa;・Ceph RBD 暗号化&#xa;  (ストレージレベル)&#xa;・Vault KV v2&#xa;  (シークレット暗号化保管)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1810" y="1000" width="250" height="175" as="geometry" />
        </mxCell>

        <mxCell id="encrypt_app" value="アプリケーションレベル暗号化&#xa;(k1s0-encryption ライブラリ)&#xa;&#xa;対称暗号:&#xa;  ・AES-256-GCM&#xa;  ・generate_aes_key (32byte)&#xa;  ・aes_encrypt / aes_decrypt&#xa;  ・Base64 エンコード&#xa;&#xa;非対称暗号:&#xa;  ・RSA-OAEP-SHA256 (2048bit)&#xa;  ・PEM 形式鍵ペア生成&#xa;  ・rsa_encrypt / rsa_decrypt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="2090" y="1000" width="240" height="230" as="geometry" />
        </mxCell>

        <mxCell id="password_hash" value="パスワードハッシュ&#xa;&#xa;・Argon2id&#xa;  (メモリハード関数)&#xa;・hash_password()&#xa;・verify_password()&#xa;・argon2 crate v0.5&#xa;・golang.org/x/crypto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1530" y="1200" width="220" height="155" as="geometry" />
        </mxCell>

        <mxCell id="key_mgmt" value="鍵管理&#xa;&#xa;・Vault PKI エンジン&#xa;  (pki_int/ マウント)&#xa;・Intermediate CA 経由&#xa;・Root CA 直接利用禁止&#xa;・zeroize クレート&#xa;  (メモリ上の秘密鍵を&#xa;   確実にゼロ消去)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1810" y="1200" width="250" height="165" as="geometry" />
        </mxCell>

        <mxCell id="lang_support" value="多言語実装 (4言語対応)&#xa;&#xa;┌────────┬──────────────────────┐&#xa;│ Rust   │ k1s0-encryption crate│&#xa;│        │ aes-gcm / rsa / argon│&#xa;├────────┼──────────────────────┤&#xa;│ Go     │ encryption パッケージ │&#xa;│        │ golang.org/x/crypto  │&#xa;├────────┼──────────────────────┤&#xa;│ TS     │ crypto (Node.js 標準)│&#xa;│        │ argon2 パッケージ    │&#xa;├────────┼──────────────────────┤&#xa;│ Dart   │ pointycastle 3.9.1   │&#xa;│        │ convert 3.1.2        │&#xa;└────────┴──────────────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="2090" y="1250" width="280" height="210" as="geometry" />
        </mxCell>

        <mxCell id="data_protection_flow" value="データ保護フロー&#xa;&#xa;  PII データ     暗号化キー&#xa;     │              │&#xa;     ↓              ↓&#xa;k1s0-encryption   Vault&#xa;(AES-256-GCM)   (キー供給)&#xa;     │              │&#xa;     ↓              ↓&#xa;  暗号化保管     キーローテ&#xa;  (PostgreSQL)   (自動)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="2400" y="1000" width="220" height="200" as="geometry" />
        </mxCell>

