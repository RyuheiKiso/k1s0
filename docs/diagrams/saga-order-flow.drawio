        <mxCell id="es_append_title" value="&lt;b&gt;Append-Only 書き込み + 楽観的ロック&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="sec4">
          <mxGeometry x="30" y="275" width="350" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="es_append_box" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;POST /api/v1/events&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;&lt;b&gt;リクエスト:&lt;/b&gt;&lt;br&gt;{&lt;br&gt;  stream_id: &quot;order-ord-123&quot;,&lt;br&gt;  events: [{event_type, payload, metadata}],&lt;br&gt;  expected_version: 4  // 楽観的ロック&lt;br&gt;}&lt;br&gt;&lt;br&gt;&lt;b&gt;楽観的ロック:&lt;/b&gt;&lt;br&gt;- expected_version == current_version &amp;rarr; OK&lt;br&gt;- expected_version != current_version &amp;rarr; 409 VERSION_CONFLICT&lt;br&gt;- expected_version == -1 &amp;rarr; 新規ストリーム作成&lt;br&gt;&lt;br&gt;&lt;b&gt;保証:&lt;/b&gt;&lt;br&gt;- UPDATE/DELETE 禁止 (Append-Only)&lt;br&gt;- UNIQUE(stream_id, version) 制約&lt;br&gt;- sequence は IDENTITY (グローバル連番)&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" vertex="1" parent="sec4">
          <mxGeometry x="30" y="305" width="330" height="195" as="geometry"/>
        </mxCell>

        <mxCell id="es_snapshot_title" value="&lt;b&gt;スナップショット + Read Model 投影&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="sec4">
          <mxGeometry x="400" y="275" width="350" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="es_snapshot_flow" value="スナップショット &amp; Read Model 投影&#xa;Events → Snapshots (N件毎に作成)&#xa;→ Kafka (非同期転送) → Read Model (CQRS Projector)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="sec4">
          <mxGeometry x="400" y="305" width="540" height="195" as="geometry"/>
        </mxCell>

        <mxCell id="es_snap_ev" value="&lt;b&gt;Events&lt;/b&gt;&lt;br&gt;(Append-Only)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;size=10;" vertex="1" parent="sec4">
          <mxGeometry x="420" y="320" width="100" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="es_snap_snap" value="&lt;b&gt;Snapshots&lt;/b&gt;&lt;br&gt;(N件毎作成)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=9;size=10;" vertex="1" parent="sec4">
          <mxGeometry x="580" y="320" width="100" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="es_snap_kafka" value="&lt;b&gt;Kafka&lt;/b&gt;&lt;br&gt;(転送)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=9;size=10;" vertex="1" parent="sec4">
          <mxGeometry x="740" y="320" width="100" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="es_snap_read" value="&lt;b&gt;Read Model&lt;/b&gt;&lt;br&gt;(投影)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=9;size=10;" vertex="1" parent="sec4">
          <mxGeometry x="900" y="320" width="100" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="es_snap_a1" value="N件蓄積" style="endArrow=block;endFill=1;strokeColor=#6C8EBF;strokeWidth=1;fontSize=9;html=1;align=center;" edge="1" parent="sec4">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="345" as="sourcePoint"/>
            <mxPoint x="580" y="345" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="es_snap_a2" value="非同期転送" style="endArrow=block;endFill=1;strokeColor=#82B366;strokeWidth=1;fontSize=9;html=1;align=center;" edge="1" parent="sec4">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="365" as="sourcePoint"/>
            <mxPoint x="740" y="365" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="es_snap_a3" value="Projector" style="endArrow=block;endFill=1;strokeColor=#9673A6;strokeWidth=1;fontSize=9;html=1;align=center;" edge="1" parent="sec4">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="345" as="sourcePoint"/>
            <mxPoint x="900" y="345" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="es_snap_note1" value="&lt;font size=&quot;1&quot;&gt;&lt;b&gt;スナップショット作成&lt;/b&gt;&lt;br&gt;POST /api/v1/streams/:id/snapshot&lt;br&gt;{snapshot_version, aggregate_type, state}&lt;br&gt;&lt;br&gt;&lt;b&gt;状態復元の高速化:&lt;/b&gt;&lt;br&gt;最新 Snapshot + (snapshot_version 以降の Events)&lt;br&gt;&amp;rarr; 集約状態を再構築&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="sec4">
          <mxGeometry x="420" y="395" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="es_snap_note2" value="&lt;font size=&quot;1&quot;&gt;&lt;b&gt;Kafka 転送&lt;/b&gt;&lt;br&gt;Topic: k1s0.system.eventstore.event.published.v1&lt;br&gt;Key: stream_id (順序保証)&lt;br&gt;保証: at-least-once&lt;br&gt;&lt;br&gt;&lt;b&gt;Read Model 投影&lt;/b&gt;&lt;br&gt;Consumer が Kafka から読み取り&lt;br&gt;Read DB へ投影 (CQRS パターン)&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="sec4">
          <mxGeometry x="740" y="395" width="280" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="es_db_schema" value="&lt;b&gt;DB スキーマ: event_store&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font size=&quot;1&quot;&gt;&lt;b&gt;event_streams&lt;/b&gt; (id TEXT PK, aggregate_type, current_version)&lt;br&gt;&lt;b&gt;events&lt;/b&gt; (sequence IDENTITY PK, stream_id FK, version, event_type, payload JSONB, metadata JSONB)&lt;br&gt;&lt;b&gt;snapshots&lt;/b&gt; (id TEXT PK, stream_id FK, snapshot_version, state JSONB)&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="sec4">
          <mxGeometry x="780" y="70" width="470" height="90" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
