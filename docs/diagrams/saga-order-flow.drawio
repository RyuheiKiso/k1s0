        </mxCell>

        <mxCell id="s1_step2_label" value="&lt;b&gt;Step 1: 決済処理&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#4D4D4D;" vertex="1" parent="sec1">
          <mxGeometry x="450" y="295" width="130" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="s1_m4" value="6. gRPC: PaymentService.Charge&lt;br&gt;{order_id, amount}" style="endArrow=block;endFill=1;strokeColor=#FF6600;strokeWidth=1;dashed=1;dashPattern=5 3;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
