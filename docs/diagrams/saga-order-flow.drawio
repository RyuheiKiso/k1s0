          </mxGeometry>
        </mxCell>
        <mxCell id="s1_m3k" value="5. Kafka: k1s0.service.inventory.reserved.v1" style="endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=1;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
