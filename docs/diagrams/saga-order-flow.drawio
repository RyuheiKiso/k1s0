          </mxGeometry>
        </mxCell>
        <mxCell id="s1_m5k" value="11. Kafka: k1s0.service.order.shipping_arranged.v1 + SAGA_COMPLETED" style="endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=1;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
