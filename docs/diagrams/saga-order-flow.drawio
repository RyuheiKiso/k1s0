        <mxCell id="s2_inv" value="&lt;b&gt;InventoryService&lt;/b&gt;&lt;br&gt;(Business Tier)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;verticalAlign=middle;" vertex="1" parent="sec2">
