        <mxCell id="s1_m4r" value="OK {transaction_id: txn-001}" style="endArrow=open;endFill=0;dashed=1;strokeColor=#2D7600;strokeWidth=1;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1475" y="350" as="sourcePoint"/>
            <mxPoint x="440" y="350" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s1_m4e" value="7. AppendEvents&lt;br&gt;{event_type: PaymentCharged}" style="endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=1;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
