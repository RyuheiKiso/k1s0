        </mxCell>
        <mxCell id="s1_m3r" value="OK {reservation_id: res-001}" style="endArrow=open;endFill=0;dashed=1;strokeColor=#2D7600;strokeWidth=1;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1125" y="240" as="sourcePoint"/>
            <mxPoint x="440" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s1_m3e" value="4. AppendEvents&lt;br&gt;{event_type: InventoryReserved}" style="endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=1;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
