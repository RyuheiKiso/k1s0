          </mxGeometry>
        </mxCell>
        <mxCell id="s1_m5e" value="10. AppendEvents&lt;br&gt;{event_type: ShippingArranged}" style="endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=1;fontSize=10;html=1;align=center;" edge="1" parent="sec1">
