        <mxCell id="s4_verify" value="&lt;b&gt;トークン検証パラメータ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;アルゴリズム: RS256 (RSA-SHA256)&lt;br&gt;鍵長: 2048-bit RSA&lt;br&gt;検証項目: iss (発行者), aud (対象者), exp (有効期限)&lt;br&gt;ライブラリ: lestrrat-go/jwx/v2&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="lane4">
          <mxGeometry x="350" y="200" width="280" height="90" as="geometry"/>
