        <mxCell id="s4_cache" value="&lt;b&gt;JWKS キャッシュ戦略&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;JWKSVerifier: cacheTTL (デフォルト10分)&lt;br&gt;ダブルチェックロック (sync.RWMutex)&lt;br&gt;フェッチ失敗時は既存キャッシュにフォールバック&lt;br&gt;InvalidateCache() で手動無効化可能&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="lane4">
          <mxGeometry x="350" y="90" width="280" height="90" as="geometry"/>
