<mxfile host="app.diagrams.net">
  <diagram id="auth-flow" name="Authentication Flow">
    <mxGraphModel dx="2000" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title1" value="認証・認可フロー詳細図" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="20" width="600" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="title2" value="OAuth2 OIDC PKCE + JWT RS256 + RBAC + Istio mTLS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="900" y="60" width="600" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="lane1" value="&lt;b&gt;SECTION 1: Browser OIDC PKCE ログインフロー&lt;/b&gt;" style="shape=swimlane;startSize=30;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=14;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="2920" height="560" as="geometry"/>
        </mxCell>

        <mxCell id="s1_browser" value="&lt;b&gt;ブラウザ&lt;/b&gt;&lt;br&gt;(SPA クライアント)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontStyle=0;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="60" y="50" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s1_bff" value="&lt;b&gt;BFF Proxy&lt;/b&gt;&lt;br&gt;(Go / Gin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=12;fontStyle=0;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="560" y="50" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s1_keycloak" value="&lt;b&gt;Keycloak&lt;/b&gt;&lt;br&gt;(OIDC Provider)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;fontStyle=0;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="1060" y="50" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s1_redis" value="&lt;b&gt;Redis Session&lt;/b&gt;&lt;br&gt;(セッションストア)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=0;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="1560" y="50" width="160" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="s1_ll_browser" value="" style="endArrow=none;dashed=1;strokeColor=#6C8EBF;dashPattern=5 5;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="100" as="sourcePoint"/>
            <mxPoint x="140" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s1_ll_bff" value="" style="endArrow=none;dashed=1;strokeColor=#E65100;dashPattern=5 5;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="100" as="sourcePoint"/>
            <mxPoint x="640" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s1_ll_keycloak" value="" style="endArrow=none;dashed=1;strokeColor=#666666;dashPattern=5 5;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1140" y="100" as="sourcePoint"/>
            <mxPoint x="1140" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s1_ll_redis" value="" style="endArrow=none;dashed=1;strokeColor=#B85450;dashPattern=5 5;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1640" y="100" as="sourcePoint"/>
            <mxPoint x="1640" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_m1" value="① GET /auth/login&lt;br&gt;ログイン開始リクエスト" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="120" as="sourcePoint"/>
            <mxPoint x="640" y="120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_note1" value="② PKCE 生成&lt;br&gt;code_verifier (ランダム) →&lt;br&gt;code_challenge = SHA256(verifier)&lt;br&gt;state パラメータ生成 (CSRF防御)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="lane1">
          <mxGeometry x="480" y="135" width="230" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s1_m3" value="③ 302 Redirect → Keycloak /authorize&lt;br&gt;+ Set-Cookie: k1s0_oauth_state, k1s0_pkce_verifier (HttpOnly, 5min TTL)" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="220" as="sourcePoint"/>
            <mxPoint x="140" y="220" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_m4" value="④ 認可リクエスト&lt;br&gt;response_type=code &amp; code_challenge &amp; code_challenge_method=S256 &amp; state &amp; scope=openid" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="250" as="sourcePoint"/>
            <mxPoint x="1140" y="250" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_note2" value="⑤ ユーザーがログイン画面で&lt;br&gt;認証情報を入力" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="lane1">
          <mxGeometry x="1060" y="265" width="180" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="s1_m6" value="⑥ 302 Redirect → /auth/callback?code=AUTH_CODE&amp;state=STATE&lt;br&gt;認可コードとstate付きでコールバック" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1140" y="325" as="sourcePoint"/>
            <mxPoint x="140" y="325" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_m7" value="⑦ GET /auth/callback?code=X&amp;state=Y&lt;br&gt;+ Cookie: k1s0_oauth_state, k1s0_pkce_verifier" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="350" as="sourcePoint"/>
            <mxPoint x="640" y="350" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_note3" value="⑧ state パラメータ検証&lt;br&gt;Cookie state == Query state&lt;br&gt;不一致 → BFF_AUTH_STATE_MISMATCH" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="lane1">
          <mxGeometry x="480" y="360" width="220" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="s1_m9" value="⑨ POST /token (grant_type=authorization_code)&lt;br&gt;code=AUTH_CODE &amp; code_verifier=VERIFIER &amp; redirect_uri" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="430" as="sourcePoint"/>
            <mxPoint x="1140" y="430" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_m10" value="⑩ access_token + refresh_token + id_token (JWT RS256)&lt;br&gt;Claims: sub, realm_access, resource_access, tier_access" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1140" y="455" as="sourcePoint"/>
            <mxPoint x="640" y="455" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_m11" value="⑪ セッション作成 (SessionData)&lt;br&gt;AccessToken, RefreshToken, IDToken,&lt;br&gt;ExpiresAt, CSRFToken, Subject を保存" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="480" as="sourcePoint"/>
            <mxPoint x="1640" y="480" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_m12" value="⑫ Set-Cookie: k1s0_session (HttpOnly, Secure, SameSite=Lax)&lt;br&gt;+ JSON: {status: &quot;authenticated&quot;, csrf_token: &quot;...&quot;}&lt;br&gt;OAuth flow Cookie削除 (state, verifier)" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="515" as="sourcePoint"/>
            <mxPoint x="140" y="515" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s1_legend" value="&lt;b&gt;トークンはサーバーサイド保持&lt;/b&gt;&lt;br&gt;ブラウザにはセッションIDのみ&lt;br&gt;(BFF Pattern: Token Handler)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="lane1">
          <mxGeometry x="1800" y="50" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="lane2" value="&lt;b&gt;SECTION 2: API リクエスト認証フロー&lt;/b&gt;" style="shape=swimlane;startSize=30;fillColor=#E8F5E9;strokeColor=#388E3C;fontSize=14;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="700" width="2920" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="s2_browser" value="&lt;b&gt;ブラウザ&lt;/b&gt;&lt;br&gt;(リクエスト送信)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;verticalAlign=middle;" vertex="1" parent="lane2">
          <mxGeometry x="60" y="50" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s2_nginx" value="&lt;b&gt;Nginx&lt;/b&gt;&lt;br&gt;(TLS 終端)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;verticalAlign=middle;" vertex="1" parent="lane2">
          <mxGeometry x="340" y="50" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s2_kong" value="&lt;b&gt;Kong&lt;/b&gt;&lt;br&gt;(API Gateway)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;verticalAlign=middle;" vertex="1" parent="lane2">
          <mxGeometry x="620" y="50" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s2_istio" value="&lt;b&gt;Istio Sidecar&lt;/b&gt;&lt;br&gt;(サービスメッシュ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFFCC;strokeColor=#00994C;fontSize=12;verticalAlign=middle;" vertex="1" parent="lane2">
          <mxGeometry x="900" y="50" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s2_bff" value="&lt;b&gt;BFF Proxy&lt;/b&gt;&lt;br&gt;(Cookie→Bearer変換)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=12;verticalAlign=middle;" vertex="1" parent="lane2">
          <mxGeometry x="1220" y="50" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s2_backend" value="&lt;b&gt;バックエンドサービス&lt;/b&gt;&lt;br&gt;(Rust / Go)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=middle;" vertex="1" parent="lane2">
          <mxGeometry x="1560" y="50" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s2_redis" value="&lt;b&gt;Redis Session&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;verticalAlign=middle;" vertex="1" parent="lane2">
          <mxGeometry x="1220" y="350" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="s2_ll_browser" value="" style="endArrow=none;dashed=1;strokeColor=#6C8EBF;dashPattern=5 5;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="100" as="sourcePoint"/>
            <mxPoint x="130" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_ll_nginx" value="" style="endArrow=none;dashed=1;strokeColor=#82B366;dashPattern=5 5;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="100" as="sourcePoint"/>
            <mxPoint x="410" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_ll_kong" value="" style="endArrow=none;dashed=1;strokeColor=#82B366;dashPattern=5 5;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="690" y="100" as="sourcePoint"/>
            <mxPoint x="690" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_ll_istio" value="" style="endArrow=none;dashed=1;strokeColor=#00994C;dashPattern=5 5;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="980" y="100" as="sourcePoint"/>
            <mxPoint x="980" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_ll_bff" value="" style="endArrow=none;dashed=1;strokeColor=#E65100;dashPattern=5 5;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1300" y="100" as="sourcePoint"/>
            <mxPoint x="1300" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_ll_backend" value="" style="endArrow=none;dashed=1;strokeColor=#D6B656;dashPattern=5 5;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1640" y="100" as="sourcePoint"/>
            <mxPoint x="1640" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s2_m1" value="① HTTPS リクエスト&lt;br&gt;Cookie: k1s0_session + X-CSRF-Token ヘッダー" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="120" as="sourcePoint"/>
            <mxPoint x="410" y="120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s2_m2" value="② HTTP 転送 (TLS 終端済み)&lt;br&gt;SSL/TLS オフロード完了" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="155" as="sourcePoint"/>
            <mxPoint x="690" y="155" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s2_note1" value="③ Kong JWT プラグイン&lt;br&gt;RS256 署名検証 (JWKS エンドポイント)&lt;br&gt;iss / aud / exp クレーム検証&lt;br&gt;レートリミットチェック" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="lane2">
          <mxGeometry x="600" y="170" width="210" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s2_m4" value="④ レートリミットチェック通過&lt;br&gt;リクエスト転送" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="690" y="250" as="sourcePoint"/>
            <mxPoint x="980" y="250" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s2_note2" value="⑤ Istio サイドカー処理&lt;br&gt;mTLS 暗号化 (Pod間通信)&lt;br&gt;AuthorizationPolicy: tier_access クレーム検証&lt;br&gt;サービス間通信の認証" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#CCFFCC;strokeColor=#00994C;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="lane2">
          <mxGeometry x="880" y="265" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s2_m6" value="⑥ BFF Proxy: Cookie → Bearer 変換&lt;br&gt;Redis からセッション取得 → access_token 抽出" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="980" y="290" as="sourcePoint"/>
            <mxPoint x="1300" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s2_m_redis" value="セッション取得&lt;br&gt;GET session:{id}" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#B85450;fontSize=10;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1300" y="310" as="sourcePoint"/>
            <mxPoint x="1300" y="350" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s2_m7" value="⑦ Authorization: Bearer {access_token}&lt;br&gt;バックエンドサービスへ転送" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1300" y="320" as="sourcePoint"/>
            <mxPoint x="1640" y="320" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="s2_legend" value="&lt;b&gt;通信暗号化レイヤー&lt;/b&gt;&lt;br&gt;外部: HTTPS (Nginx TLS終端)&lt;br&gt;Gateway内部: HTTP&lt;br&gt;Pod間: Istio mTLS (自動)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="lane2">
          <mxGeometry x="1850" y="50" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="lane3" value="&lt;b&gt;SECTION 3: RBAC 権限解決フロー&lt;/b&gt;" style="shape=swimlane;startSize=30;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=14;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1150" width="2920" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="s3_jwt" value="&lt;b&gt;① JWT Claims 抽出&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;access_token から以下を取得:&lt;br&gt;- sub (ユーザーID)&lt;br&gt;- realm_access.roles (レルムロール)&lt;br&gt;- resource_access.{client}.roles (リソースロール)&lt;br&gt;- tier_access (Tierアクセス権)&lt;br&gt;- preferred_username&lt;br&gt;- email&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="lane3">
          <mxGeometry x="60" y="50" width="260" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="s3_role" value="&lt;b&gt;② ロール解決&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;HasRole(claims, role)&lt;br&gt;→ realm_access.roles にロールが含まれるか&lt;br&gt;&lt;br&gt;HasResourceRole(claims, resource, role)&lt;br&gt;→ resource_access[resource].roles にロールが含まれるか&lt;br&gt;&lt;br&gt;HasTierAccess(claims, tier)&lt;br&gt;→ tier_access に指定Tierが含まれるか&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="lane3">
          <mxGeometry x="380" y="50" width="300" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="s3_perm" value="&lt;b&gt;③ 権限チェック&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;CheckPermission(claims, resource, action)&lt;br&gt;&lt;br&gt;1. sys_admin ロール → 全権限 (bypass)&lt;br&gt;2. admin ロール → 全権限 (bypass)&lt;br&gt;3. resource_access[resource] に action or admin →許可&lt;br&gt;4. 上記以外 → 拒否 (deny by default)&lt;br&gt;&lt;br&gt;&lt;b&gt;ホワイトリストモデル: 明示的許可のみ&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="lane3">
          <mxGeometry x="740" y="50" width="320" height="170" as="geometry"/>
        </mxCell>

