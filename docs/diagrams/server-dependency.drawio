<mxfile host="draw.io">
  <diagram name="Server Dependency">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="827" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- タイトル -->
        <mxCell id="2" value="Server 間の依存イメージ" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="400" height="40" as="geometry"/>
        </mxCell>
        <!-- system層: 共通サーバー基盤 -->
        <mxCell id="10" value="system/server" style="swimlane;startSize=28;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;arcSize=8;fontStyle=1;fontSize=13;swimlaneLine=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="960" height="110" as="geometry"/>
        </mxCell>
        <!-- 認証・認可モジュール -->
        <mxCell id="11" value="認証・認可&#xa;JWT / OIDC" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="10">
          <mxGeometry x="20" y="38" width="200" height="58" as="geometry"/>
        </mxCell>
        <!-- APIゲートウェイモジュール -->
        <mxCell id="12" value="API ゲートウェイ&#xa;ルーティング&#xa;レート制限" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="10">
          <mxGeometry x="250" y="38" width="200" height="58" as="geometry"/>
        </mxCell>
        <!-- 可観測性モジュール -->
        <mxCell id="13" value="可観測性基盤&#xa;トレース&#xa;メトリクス" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="10">
          <mxGeometry x="480" y="38" width="200" height="58" as="geometry"/>
        </mxCell>
        <!-- 共通ミドルウェアモジュール -->
        <mxCell id="14" value="共通ミドルウェア&#xa;ログ&#xa;エラーハンドリング" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="10">
          <mxGeometry x="710" y="38" width="220" height="58" as="geometry"/>
