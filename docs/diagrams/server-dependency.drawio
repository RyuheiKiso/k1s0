        <!-- business層: 経理ドメイン共通サーバー -->
        <mxCell id="20" value="business/accounting/server" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;arcSize=8;fontStyle=1;fontSize=12;swimlaneLine=0;" vertex="1" parent="1">
