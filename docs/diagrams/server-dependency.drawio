        <!-- 凡例 -->
        <mxCell id="60" value="直線 = 直接依存&#xa;点線 = system への依存" style="text;fontSize=10;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="880" y="560" width="180" height="40" as="geometry"/>
