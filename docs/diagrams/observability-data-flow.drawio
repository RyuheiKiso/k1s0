<mxfile host="draw.io">
  <diagram name="Observability Data Flow">
    <mxGraphModel dx="2200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="2000" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="k1s0 Observability Data Flow (可観測性データフロー)" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="750" y="15" width="700" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="observability Namespace に全コンポーネントをデプロイ | Prometheus + Loki + Jaeger + Alertmanager → Grafana 統合" style="text;html=1;fontSize=12;align=center;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="650" y="55" width="900" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="sec1_bg" value="" style="rounded=1;arcSize=4;fillColor=#FFF8EE;strokeColor=#D79B00;strokeWidth=2;dashed=0;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="90" width="2960" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="sec1_title" value="Section 1: メトリクスパイプライン (Metrics Pipeline)" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;fontColor=#D79B00;" vertex="1" parent="1">
          <mxGeometry x="40" y="95" width="500" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="app_sys" value="Application Services&#xa;(system Tier)&#xa;&#xa;auth / config / saga&#xa;dlq-manager / bff-proxy&#xa;session / vault / ratelimit&#xa;&#xa;全サーバーが /metrics を公開" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=0;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="200" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="app_biz" value="Application Services&#xa;(business Tier)&#xa;&#xa;業務領域共通サーバー" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=0;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="295" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="app_svc" value="Application Services&#xa;(service Tier)&#xa;&#xa;個別業務サービス" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=0;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="385" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="otel_sdk_m" value="OTel SDK&#xa;(Metrics)&#xa;&#xa;prometheus/client_golang&#xa;prometheus crate&#xa;独自実装 (TS/Dart)&#xa;&#xa;Prometheus exposition format&#xa;で /metrics エンドポイント公開" style="rounded=1;whiteSpace=wrap;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="140" width="210" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="metrics_types" value="公開メトリクス:&#xa;&#xa;http_requests_total (counter)&#xa;http_request_duration_seconds (histogram)&#xa;grpc_server_handled_total (counter)&#xa;grpc_server_handling_seconds (histogram)&#xa;db_query_duration_seconds (histogram)&#xa;kafka_messages_produced_total (counter)&#xa;kafka_messages_consumed_total (counter)&#xa;cache_hits_total / cache_misses_total" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#8B6914;fillColor=#FFFBE6;strokeColor=#D79B00;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="305" width="210" height="155" as="geometry"/>
        </mxCell>

        <mxCell id="prometheus" value="Prometheus&#xa;(9090)&#xa;&#xa;ServiceMonitor で&#xa;15 秒間隔スクレイプ&#xa;&#xa;observability NS にデプロイ&#xa;Istio PERMISSIVE モード" style="rounded=1;whiteSpace=wrap;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="610" y="140" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="recording_rules" value="Recording Rules&#xa;(5m 集計)&#xa;&#xa;service:http_requests:rate5m&#xa;service:http_errors:rate5m&#xa;service:http_request_duration_seconds:p99&#xa;service:http_request_duration_seconds:p95&#xa;service:grpc_requests:rate5m&#xa;service:grpc_errors:rate5m&#xa;slo:availability:ratio&#xa;slo:error_budget:remaining" style="rounded=1;whiteSpace=wrap;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=9;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="610" y="295" width="220" height="165" as="geometry"/>
        </mxCell>

        <mxCell id="grafana_m" value="Grafana&#xa;(3200)&#xa;&#xa;Prometheus データソース&#xa;PromQL クエリ&#xa;&#xa;ダッシュボード自動プロビジョニング&#xa;(ConfigMap から)" style="rounded=1;whiteSpace=wrap;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="930" y="140" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="slo_box" value="SLO ターゲット&#xa;&#xa;system: 可用性 99.95% / P99 &lt; 200ms&#xa;business: 可用性 99.9% / P99 &lt; 500ms&#xa;service: 可用性 99.9% / P99 &lt; 1s&#xa;&#xa;エラーバジェット: 30日間&#xa;system: 21.6分 / business: 43.2分" style="rounded=1;whiteSpace=wrap;fillColor=#FFF8EE;strokeColor=#D79B00;fontSize=10;verticalAlign=top;spacingTop=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="300" width="220" height="145" as="geometry"/>
        </mxCell>

        <mxCell id="m_arrow1" value="OTel SDK 経由&#xa;メトリクス計測" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#D79B00;fontSize=9;fontColor=#D79B00;" edge="1" parent="1" source="app_sys" target="otel_sdk_m">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arrow1b" value="" style="endArrow=block;endFill=1;strokeWidth=1;strokeColor=#D79B00;" edge="1" parent="1" source="app_biz" target="otel_sdk_m">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arrow1c" value="" style="endArrow=block;endFill=1;strokeWidth=1;strokeColor=#D79B00;" edge="1" parent="1" source="app_svc" target="otel_sdk_m">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arrow2" value="scrape /metrics&#xa;(15s interval)" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#D79B00;fontSize=9;fontColor=#D79B00;dashed=1;" edge="1" parent="1" source="prometheus" target="otel_sdk_m">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arrow3" value="Recording Rules&#xa;事前集計" style="endArrow=block;endFill=1;strokeWidth=1;strokeColor=#D79B00;fontSize=9;fontColor=#D79B00;" edge="1" parent="1" source="prometheus" target="recording_rules">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arrow4" value="データソース接続" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#D79B00;fontSize=9;fontColor=#D79B00;" edge="1" parent="1" source="prometheus" target="grafana_m">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="sec2_bg" value="" style="rounded=1;arcSize=4;fillColor=#EEF5FF;strokeColor=#4A86C8;strokeWidth=2;dashed=0;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="1440" height="370" as="geometry"/>
        </mxCell>
        <mxCell id="sec2_title" value="Section 2: ログパイプライン (Logging Pipeline)" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;fontColor=#4A86C8;" vertex="1" parent="1">
          <mxGeometry x="40" y="495" width="450" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="app_log" value="Application Services&#xa;(全 Tier)&#xa;&#xa;JSON 構造化ログ → stdout&#xa;&#xa;Go: slog (JSONHandler)&#xa;Rust: tracing (json layer)&#xa;TS: structured logger&#xa;Dart: structured logger" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="200" height="155" as="geometry"/>
        </mxCell>

        <mxCell id="log_format" value="JSON ログフォーマット:&#xa;&#xa;{&#xa;  timestamp: ISO 8601 (UTC)&#xa;  level: debug|info|warn|error&#xa;  service: サービス名&#xa;  tier: system|business|service&#xa;  trace_id: トレースID&#xa;  span_id: スパンID&#xa;  request_id: リクエストID&#xa;  method: HTTP メソッド&#xa;  path: リクエストパス&#xa;  status: ステータスコード&#xa;  duration_ms: 処理時間&#xa;}" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#2C5F8C;fillColor=#E6F3FF;strokeColor=#4A86C8;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="710" width="200" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="promtail" value="Promtail&#xa;(DaemonSet)&#xa;&#xa;各ノードにデプロイ&#xa;Pod の stdout/stderr を収集&#xa;&#xa;kubernetes_sd_configs:&#xa;  - role: pod&#xa;&#xa;pipeline_stages:&#xa;  json → labels 抽出&#xa;  (level, trace_id, service)" style="rounded=1;whiteSpace=wrap;fillColor=#E6F3FF;strokeColor=#4A86C8;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="330" y="540" width="200" height="195" as="geometry"/>
        </mxCell>

        <mxCell id="loki" value="Loki&#xa;(3100)&#xa;&#xa;ログ集約・クエリエンジン&#xa;ラベルベースのインデックス&#xa;(全文インデックスなし = 低コスト)&#xa;&#xa;ラベル: service, tier,&#xa;environment, level, trace_id&#xa;&#xa;observability NS にデプロイ" style="rounded=1;whiteSpace=wrap;fillColor=#E6F3FF;strokeColor=#4A86C8;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="540" width="200" height="185" as="geometry"/>
        </mxCell>

        <mxCell id="log_retention" value="ログ保持期間:&#xa;&#xa;dev:     7日 (168h)&#xa;staging: 30日 (720h)&#xa;prod:    90日 (2160h)&#xa;&#xa;監査ログ: 1年 (8760h)&#xa;→ Ceph オブジェクトストレージ&#xa;   にアーカイブ" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#2C5F8C;fillColor=#E6F3FF;strokeColor=#4A86C8;rounded=1;dashed=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="630" y="740" width="200" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="grafana_l" value="Grafana&#xa;(Loki データソース)&#xa;&#xa;LogQL クエリ&#xa;&#xa;derivedFields:&#xa;trace_id → Jaeger 連携&#xa;(ログからトレースへ&#xa; ワンクリック遷移)" style="rounded=1;whiteSpace=wrap;fillColor=#E6F3FF;strokeColor=#4A86C8;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="930" y="540" width="200" height="155" as="geometry"/>
        </mxCell>

        <mxCell id="ceph" value="Ceph&#xa;オブジェクトストレージ&#xa;&#xa;監査ログ長期保管 (1年)&#xa;コンプライアンス対応" style="rounded=1;whiteSpace=wrap;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1230" y="540" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="l_arrow1" value="stdout&#xa;JSON ログ" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#4A86C8;fontSize=9;fontColor=#4A86C8;" edge="1" parent="1" source="app_log" target="promtail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l_arrow2" value="push&#xa;/loki/api/v1/push" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#4A86C8;fontSize=9;fontColor=#4A86C8;" edge="1" parent="1" source="promtail" target="loki">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l_arrow3" value="データソース接続" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#4A86C8;fontSize=9;fontColor=#4A86C8;" edge="1" parent="1" source="loki" target="grafana_l">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l_arrow4" value="監査ログ&#xa;アーカイブ" style="endArrow=block;endFill=1;strokeWidth=1;strokeColor=#666666;fontSize=9;fontColor=#666666;dashed=1;" edge="1" parent="1" source="loki" target="ceph">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="sec3_bg" value="" style="rounded=1;arcSize=4;fillColor=#F3EDF7;strokeColor=#9673A6;strokeWidth=2;dashed=0;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="1480" y="490" width="1500" height="370" as="geometry"/>
        </mxCell>
        <mxCell id="sec3_title" value="Section 3: トレーシングパイプライン (Tracing Pipeline)" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;fontColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="1500" y="495" width="500" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="app_trace" value="Application Services&#xa;(全 Tier)&#xa;&#xa;OTel SDK (tracing)&#xa;&#xa;Go: go.opentelemetry.io/otel&#xa;Rust: tracing-opentelemetry&#xa;TS: @opentelemetry/*&#xa;Dart: HTTP ヘッダのみ (制約)&#xa;&#xa;W3C TraceContext 伝搬&#xa;traceparent ヘッダ" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1500" y="540" width="200" height="195" as="geometry"/>
        </mxCell>

        <mxCell id="istio_envoy" value="Istio Envoy Sidecar&#xa;&#xa;自動スパン生成&#xa;サービス間通信の&#xa;トレースを自動取得&#xa;&#xa;全 Pod に注入" style="rounded=1;whiteSpace=wrap;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1500" y="750" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="otel_collector" value="OTel Collector&#xa;&#xa;Receivers:&#xa;  OTLP gRPC (4317)&#xa;  OTLP HTTP (4318)&#xa;&#xa;Processors:&#xa;  batch (5s / 512件)&#xa;  tail_sampling:&#xa;    ERROR → 100% 保持&#xa;    normal → 10% サンプリング&#xa;&#xa;observability NS にデプロイ" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1800" y="540" width="210" height="215" as="geometry"/>
        </mxCell>

        <mxCell id="sampling_table" value="サンプリング戦略:&#xa;&#xa;dev:     AlwaysOn (100%)&#xa;staging: TraceIDRatio (50%)&#xa;prod:    Tail-based (10%)&#xa;         + エラー 100% 保持" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#6A4C82;fillColor=#F3EDF7;strokeColor=#9673A6;rounded=1;dashed=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1800" y="770" width="210" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="jaeger" value="Jaeger&#xa;(OTLP Backend)&#xa;&#xa;Collector → Query → Storage&#xa;&#xa;トレースの保存・検索&#xa;サービスマップ可視化" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="2110" y="540" width="200" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="jaeger_ui" value="Jaeger UI&#xa;(16686)&#xa;&#xa;トレース検索・可視化&#xa;サービスマップ&#xa;依存関係分析" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="2110" y="690" width="200" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="grafana_t" value="Grafana&#xa;(Jaeger データソース)&#xa;&#xa;trace_id でログと相関&#xa;&#xa;Loki derivedFields:&#xa;trace_id → Jaeger 連携&#xa;ワンクリックドリルダウン" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="2420" y="540" width="210" height="145" as="geometry"/>
        </mxCell>

        <mxCell id="trace_correlation" value="ログ-トレース相関:&#xa;&#xa;trace_id をログに埋め込み&#xa;Grafana で統合表示&#xa;&#xa;Client → Kong → Service A → Service B&#xa;  └── trace_id: abc123 ──────┘&#xa;       span_id: A001  span_id: B001" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#6A4C82;fillColor=#F3EDF7;strokeColor=#9673A6;rounded=1;dashed=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="2420" y="700" width="250" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="t_arrow1" value="OTLP&#xa;gRPC/HTTP" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9673A6;fontSize=9;fontColor=#9673A6;" edge="1" parent="1" source="app_trace" target="otel_collector">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t_arrow1b" value="自動スパン" style="endArrow=block;endFill=1;strokeWidth=1;strokeColor=#666666;fontSize=9;fontColor=#666666;dashed=1;" edge="1" parent="1" source="istio_envoy" target="otel_collector">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t_arrow2" value="batch + sampling&#xa;→ OTLP export" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9673A6;fontSize=9;fontColor=#9673A6;" edge="1" parent="1" source="otel_collector" target="jaeger">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t_arrow3" value="UI" style="endArrow=block;endFill=1;strokeWidth=1;strokeColor=#9673A6;fontSize=9;fontColor=#9673A6;" edge="1" parent="1" source="jaeger" target="jaeger_ui">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t_arrow4" value="データソース接続" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9673A6;fontSize=9;fontColor=#9673A6;" edge="1" parent="1" source="jaeger" target="grafana_t">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="sec4_bg" value="" style="rounded=1;arcSize=4;fillColor=#FDF0F0;strokeColor=#B85450;strokeWidth=2;dashed=0;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="1200" y="90" width="1780" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="sec4_title" value="Section 4: アラートパイプライン (Alerting Pipeline)" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="1220" y="95" width="450" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="prom_alert" value="Prometheus&#xa;(アラート評価)&#xa;&#xa;recording_rules.yaml&#xa;alerting_rules.yaml&#xa;&#xa;15s 評価間隔" style="rounded=1;whiteSpace=wrap;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1220" y="140" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="alert_rules" value="アラートルール:&#xa;&#xa;SystemServiceErrorRateWarning&#xa;  → system 5xx &gt; 0.1% (5m) [warning]&#xa;SystemServiceHighErrorRate&#xa;  → system 5xx &gt; 1% (5m) [critical]&#xa;SystemServiceHighLatency&#xa;  → system P99 &gt; 500ms (5m) [warning]&#xa;ServiceErrorRateWarning&#xa;  → biz/svc 5xx &gt; 0.2% (5m) [warning]&#xa;ServiceHighErrorRate&#xa;  → biz/svc 5xx &gt; 5% (5m) [critical]&#xa;ServiceHighLatency&#xa;  → biz/svc P99 &gt; 1s (5m) [warning]&#xa;SLOBurnRateCritical&#xa;  → 14.4x (1h+5m窓) [critical]&#xa;SLOBurnRateWarning&#xa;  → 6x (6h+30m窓) [warning]" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#8B2020;fillColor=#FDF0F0;strokeColor=#B85450;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1220" y="275" width="230" height="185" as="geometry"/>
        </mxCell>

        <mxCell id="alertmanager" value="Alertmanager&#xa;&#xa;ルーティング:&#xa;group_by: [alertname, namespace, service]&#xa;group_wait: 30s&#xa;group_interval: 5m&#xa;&#xa;severity ベースルーティング:&#xa;critical → teams-critical (1h repeat)&#xa;warning → teams-warning (4h repeat)&#xa;&#xa;環境別抑制:&#xa;dev: 全無効&#xa;staging: warning 無効&#xa;prod: 全有効" style="rounded=1;whiteSpace=wrap;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1530" y="130" width="240" height="240" as="geometry"/>
        </mxCell>

        <mxCell id="tier_thresholds" value="Tier 別閾値:&#xa;&#xa;system (厳格):&#xa;  warning: error &gt; 0.1% / P99 &gt; 500ms&#xa;  critical: error &gt; 1%&#xa;&#xa;business/service (寛容):&#xa;  warning: error &gt; 0.2% / P99 &gt; 1s&#xa;  critical: error &gt; 5%" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#8B2020;fillColor=#FDF0F0;strokeColor=#B85450;rounded=1;dashed=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1530" y="380" width="240" height="80" as="geometry"/>
        </mxCell>

