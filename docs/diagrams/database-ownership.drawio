          <mxGeometry x="1490" y="1260" width="260" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="vault_consumers" value="&lt;b&gt;Vault 利用サービス&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;全サーバー: DB パスワード取得&lt;br&gt;Auth Server: JWT 署名鍵&lt;br&gt;Config Server: 暗号化キー&lt;br&gt;File Server: S3 シークレットキー&lt;br&gt;Search Server: OpenSearch パスワード&lt;br&gt;Quota Server: Redis パスワード&lt;br&gt;Vault Agent Injector 経由&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1500" y="1400" width="240" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="e_vault_consumers" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82B366;dashed=1;" edge="1" parent="1" source="vault_consumers" target="vault_secret_store">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="section4_title" value="&lt;b&gt;Section 4: データ分離ルール&lt;/b&gt;" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1830" y="1200" width="400" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="rules_box" value="&lt;b&gt;データ分離ルール&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;1. データベース所有権&lt;/b&gt;&lt;br&gt;各 Tier は独立したデータベースを所有する。&lt;br&gt;同一 PostgreSQL インスタンス上でもスキーマで分離。&lt;br&gt;&lt;br&gt;&lt;b&gt;2. Tier 間直接 DB アクセス禁止&lt;/b&gt;&lt;br&gt;下位層が上位層のデータを必要とする場合は、&lt;br&gt;上位層の server が提供する API（gRPC/REST）を経由。&lt;br&gt;直接的な SQL アクセスは一切禁止。&lt;br&gt;&lt;br&gt;&lt;b&gt;3. スキーママイグレーション&lt;/b&gt;&lt;br&gt;各サービスが独自にマイグレーションを管理。&lt;br&gt;Go: golang-migrate / Rust: sqlx-cli&lt;br&gt;マイグレーション配置: regions/system/database/{name}/migrations/&lt;br&gt;&lt;br&gt;&lt;b&gt;4. クレデンシャル管理&lt;/b&gt;&lt;br&gt;HashiCorp Vault による動的クレデンシャル生成。&lt;br&gt;静的パスワード: secret/data/k1s0/{tier}/{service}/database&lt;br&gt;動的RW: database/creds/{tier}-{service}-rw（TTL: 24時間）&lt;br&gt;動的RO: database/creds/{tier}-{service}-ro（TTL: 24時間）&lt;br&gt;&lt;br&gt;&lt;b&gt;5. バックアップポリシー&lt;/b&gt;&lt;br&gt;PostgreSQL: フルバックアップ 毎日（保持30日）+ WAL 継続アーカイブ&lt;br&gt;etcd: 日次バックアップ（保持30日）&lt;br&gt;Ceph: スナップショット 毎日（保持14日）&lt;br&gt;Kafka: トピック retention.ms によるセグメント管理&lt;br&gt;&lt;br&gt;&lt;b&gt;6. 接続設定&lt;/b&gt;&lt;br&gt;dev: ssl_mode=disable, max_conns=10&lt;br&gt;staging: ssl_mode=require, max_conns=25&lt;br&gt;prod: ssl_mode=verify-full, max_conns=50&lt;/font&gt;" style="shape=mxgraph.basic.rect;fillColor=#F5F5F5;strokeColor=#666666;rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="1830" y="1240" width="440" height="580" as="geometry"/>
        </mxCell>

        <mxCell id="legend_title" value="&lt;b&gt;凡例&lt;/b&gt;" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="2240" y="250" width="100" height="25" as="geometry"/>
