        <mxCell id="rule3" value="3. 並行稼働期間: 最低3ヶ月" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="590" y="130" width="260" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule4" value="4. 非推奨化: @deprecated アノテーション" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
