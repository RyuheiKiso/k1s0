        <mxCell id="leg" value="凡例: &lt;font color=&quot;#82B366&quot;&gt;■&lt;/font&gt; Active　&lt;font color=&quot;#6C8EBF&quot;&gt;■&lt;/font&gt; Development　&lt;font color=&quot;#D6B656&quot;&gt;■&lt;/font&gt; Deprecated　&lt;font color=&quot;#B85450&quot;&gt;■&lt;/font&gt; Removed　&lt;font color=&quot;#9673A6&quot;&gt;■&lt;/font&gt; System　&lt;font color=&quot;#82B366&quot;&gt;■&lt;/font&gt; Business　&lt;font color=&quot;#D6B656&quot;&gt;■&lt;/font&gt; Service" style="text;html=1;fontSize=10;" vertex="1" parent="1">
