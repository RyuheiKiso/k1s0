        </mxCell>
        <mxCell id="rule1" value="1. 後方互換の変更 → 同バージョン内" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="590" y="90" width="260" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="rule2" value="2. 破壊的変更 → 新バージョン作成" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
