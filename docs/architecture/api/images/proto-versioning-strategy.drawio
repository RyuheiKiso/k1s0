        </mxCell>
        <mxCell id="time_label" value="時間 →" style="text;html=1;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="900" y="525" width="50" height="15" as="geometry"/>
        </mxCell>

        <!-- フェーズラベル -->
        <mxCell id="phase1" value="Phase 1&lt;br&gt;v1のみ" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#82B366;align=center;" vertex="1" parent="1">
