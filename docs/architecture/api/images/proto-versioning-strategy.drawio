<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="proto-versioning" name="Protoパッケージバージョニング戦略">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="650" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="Proto パッケージバージョニング戦略" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- パッケージ階層 -->
        <mxCell id="pkg_title" value="パッケージ命名規約" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
