        <mxCell id="pkg3" value="&lt;b&gt;k1s0.service.notification.v1&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="180" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- パッケージ構造の説明 -->
        <mxCell id="pkg_desc" value="&lt;code&gt;k1s0.{tier}.{service}.{version}&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="120" width="250" height="35" as="geometry"/>
        </mxCell>

        <!-- バージョン移行タイムライン -->
        <mxCell id="timeline_title" value="バージョン移行ライフサイクル" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="250" height="20" as="geometry"/>
        </mxCell>

        <!-- 時間軸 -->
        <mxCell id="time_axis" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#666666;endArrow=classic;" edge="1" parent="1">
