<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="api-dec-001" name="APIプロトコル選定フロー">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="API プロトコル選定フロー" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="800" height="35" as="geometry"/>
        </mxCell>

        <!-- スタートノード -->
        <mxCell id="start" value="API を追加する" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=14;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- 質問1: 呼び出し元は？ -->
        <mxCell id="q1" value="&lt;b&gt;呼び出し元は？&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="430" y="160" width="300" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr-start-q1" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="q1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 分岐: クライアント（ブラウザ/モバイル） -->
        <mxCell id="branch-client" value="クライアント&lt;br&gt;（ブラウザ/モバイル）" style="text;html=1;fontSize=11;fontColor=#CC0000;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="150" height="40" as="geometry"/>
        </mxCell>

        <!-- 分岐: サービス間 -->
        <mxCell id="branch-service" value="サービス間&lt;br&gt;（内部通信）" style="text;html=1;fontSize=11;fontColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="520" y="270" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- q1 → クライアント左矢印 -->
        <mxCell id="arr-q1-client" value="クライアント" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;fontSize=9;fontStyle=1;" edge="1" source="q1" target="q2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="430" y="200"/>
              <mxPoint x="220" y="200"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- q1 → サービス間 下矢印 -->
        <mxCell id="arr-q1-svc" value="サービス間" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82B366;fontSize=9;fontStyle=1;" edge="1" source="q1" target="q3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 質問2: データ集約が必要か -->
        <mxCell id="q2" value="&lt;b&gt;複数バックエンドの&lt;br&gt;データ集約が必要？&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="300" height="90" as="geometry"/>
        </mxCell>

        <!-- 質問3: リアルタイムストリームが必要か -->
        <mxCell id="q3" value="&lt;b&gt;高速な内部 RPC?&lt;br&gt;（強い型保証・ストリーム）&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="570" y="310" width="300" height="90" as="geometry"/>
        </mxCell>

        <!-- ===== 結果ノード ===== -->

        <!-- GraphQL -->
        <mxCell id="result-graphql" value="&lt;b&gt;GraphQL&lt;/b&gt;&lt;br&gt;（オプション採用）&lt;br&gt;─&lt;br&gt;gqlgen（Go）&lt;br&gt;async-graphql（Rust）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8C00;strokeColor=#CC7000;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- REST -->
        <mxCell id="result-rest" value="&lt;b&gt;REST API&lt;/b&gt;&lt;br&gt;（外部公開）&lt;br&gt;─&lt;br&gt;Kong API GW 経由&lt;br&gt;OpenAPI スキーマ定義" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6C8EBF;strokeColor=#4A7DB5;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="280" y="470" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- gRPC -->
        <mxCell id="result-grpc" value="&lt;b&gt;gRPC&lt;/b&gt;&lt;br&gt;（標準・推奨）&lt;br&gt;─&lt;br&gt;protobuf 定義&lt;br&gt;buf によるリント&lt;br&gt;Istio mTLS で保護" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="575" y="470" width="200" height="110" as="geometry"/>
        </mxCell>

        <!-- gRPC + REST（両方） -->
        <mxCell id="result-both" value="&lt;b&gt;gRPC + REST（両方）&lt;/b&gt;&lt;br&gt;─&lt;br&gt;内部: gRPC（高速）&lt;br&gt;外部: REST（互換性）&lt;br&gt;system Tier の共通APIはこのパターン" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B39DDB;strokeColor=#9673A6;fontSize=12;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="810" y="470" width="220" height="110" as="geometry"/>
        </mxCell>

        <!-- ===== q2からの矢印 ===== -->
        <mxCell id="arr-q2-gql" value="YES" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF8C00;fontStyle=1;fontSize=10;" edge="1" source="q2" target="result-graphql" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="140" y="400"/>
              <mxPoint x="140" y="470"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="arr-q2-rest" value="NO" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6C8EBF;fontStyle=1;fontSize=10;" edge="1" source="q2" target="result-rest" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="300" y="400"/>
              <mxPoint x="380" y="400"/>
              <mxPoint x="380" y="470"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== q3からの矢印 ===== -->
        <mxCell id="arr-q3-grpc" value="YES" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82B366;fontStyle=1;fontSize=10;" edge="1" source="q3" target="result-grpc" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="675" y="400"/>
              <mxPoint x="675" y="470"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="arr-q3-both" value="外部公開も必要" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673A6;fontStyle=1;fontSize=10;" edge="1" source="q3" target="result-both" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="840" y="400"/>
              <mxPoint x="920" y="400"/>
              <mxPoint x="920" y="470"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== 採用基準メモ ===== -->
        <mxCell id="graphql-note" value="&lt;b&gt;GraphQL 導入基準:&lt;/b&gt;&lt;br&gt;• 異なる粒度でデータを取得したい&lt;br&gt;• N+1問題を解決したい&lt;br&gt;• フロントエンドが主導したいデータ取得&lt;br&gt;※ 全サービスへの一律適用はしない" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="600" width="240" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="rest-note" value="&lt;b&gt;REST 設計原則:&lt;/b&gt;&lt;br&gt;• リソース名は複数形名詞&lt;br&gt;• バージョニング: /api/v1/&lt;br&gt;• エラー: RFC 9457 Problem Details&lt;br&gt;• OpenAPI で自動コード生成" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#EBF5FB;strokeColor=#6C8EBF;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="600" width="240" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="grpc-note" value="&lt;b&gt;gRPC 設計原則:&lt;/b&gt;&lt;br&gt;• protobuf でスキーマ定義&lt;br&gt;• buf でリント・コード生成&lt;br&gt;• ストリーミング対応可能&lt;br&gt;• Istio mTLS で自動暗号化" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#E8F5E9;strokeColor=#82B366;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="555" y="610" width="240" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="both-note" value="&lt;b&gt;両対応の例（system Tier）:&lt;/b&gt;&lt;br&gt;• auth: REST + gRPC&lt;br&gt;• config: REST + gRPC&lt;br&gt;• notification: REST + gRPC&lt;br&gt;内部はgRPC、外部管理はREST" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#F3E5F5;strokeColor=#9673A6;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="810" y="610" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== Tier別採用一覧 ===== -->
        <mxCell id="tier-summary-bg" value="" style="rounded=1;fillColor=#F5F5F5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="20" y="730" width="1160" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="tier-summary-title" value="Tier 別の典型的な API パターン" style="text;html=1;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="735" width="300" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="tier-sys-row" value="&lt;b&gt;system Tier:&lt;/b&gt;  認証 (REST+gRPC) / config (REST+gRPC) / GraphQL Gateway / Saga/Workflow (REST+gRPC) / DLQ (REST)" style="text;html=1;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="760" width="1000" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="tier-biz-row" value="&lt;b&gt;business Tier:&lt;/b&gt;  ドメインCRUD (REST) / ドメインイベント配信 (gRPC Stream) / ドメイン操作 (gRPC)" style="text;html=1;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="782" width="1000" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="tier-svc-row" value="&lt;b&gt;service Tier:&lt;/b&gt;  BFF API (REST) / データ集約BFF (GraphQL・オプション) / 外部連携 (REST)" style="text;html=1;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="804" width="1000" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
