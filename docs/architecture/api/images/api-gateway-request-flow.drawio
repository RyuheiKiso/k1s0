<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="api-gw-flow-001" name="API Gateway リクエストフロー">
    <mxGraphModel dx="1600" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: API Gatewayリクエストフロー図 -->
        <mxCell id="title" value="API Gateway リクエストフロー" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="500" y="10" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- サブタイトル: リクエストが通過するレイヤーの説明 -->
        <mxCell id="subtitle" value="リクエストが通過する全レイヤーを示す" style="text;html=1;fontSize=14;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="550" y="45" width="500" height="20" as="geometry"/>
        </mxCell>

        <!-- コンポーネント1: ブラウザ/クライアント（リクエスト発信元） -->
        <mxCell id="client" value="ブラウザ /&lt;br&gt;クライアント" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="30" y="130" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- コンポーネント2: Nginx Ingress（TLS終端とIP制限） -->
        <mxCell id="nginx" value="Nginx Ingress&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(TLS終端, IP制限)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F5F5F5;strokeColor=#666666;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="270" y="130" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- コンポーネント3: Kong API Gateway（JWT検証、レート制限、CORS、ログ） -->
        <mxCell id="kong" value="Kong API Gateway&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(JWT検証, レート制限,&lt;br&gt;CORS, ログ)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="530" y="120" width="170" height="90" as="geometry"/>
        </mxCell>

        <!-- コンポーネント4: BFF Proxy（Goベース、セッション管理、CSRF検証） -->
        <mxCell id="bff" value="BFF Proxy&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(Go, セッション管理,&lt;br&gt;CSRF検証)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFE0B2;strokeColor=#E65100;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="800" y="120" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- コンポーネント5: Istio Gateway（mTLSとルーティング） -->
        <mxCell id="istio" value="Istio Gateway&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(mTLS, ルーティング)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1060" y="130" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- コンポーネント6: Backend Service（ビジネスロジックを処理） -->
        <mxCell id="backend" value="Backend Service&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(ビジネスロジック)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1330" y="130" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- プロトコル矢印: Client→Nginx (HTTPS) -->
        <mxCell id="e1" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="client" target="nginx" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- プロトコル矢印: Nginx→Kong (HTTP内部通信) -->
        <mxCell id="e2" value="HTTP (内部)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="nginx" target="kong" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- プロトコル矢印: Kong→BFF (HTTP + JWT) -->
        <mxCell id="e3" value="HTTP + JWT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="kong" target="bff" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- プロトコル矢印: BFF→Istio (mTLS自動) -->
        <mxCell id="e4" value="mTLS (自動)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="bff" target="istio" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- プロトコル矢印: Istio→Backend (mTLS) -->
        <mxCell id="e5" value="mTLS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="istio" target="backend" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- セキュリティレイヤーバー: 各ステージで適用されるセキュリティ対策 -->
        <mxCell id="sec-title" value="セキュリティレイヤー" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="30" y="270" width="200" height="20" as="geometry"/>
        </mxCell>

        <!-- セキュリティバー: クライアント側（TLS暗号化） -->
        <mxCell id="sec1" value="TLS暗号化" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="300" width="140" height="30" as="geometry"/>
        </mxCell>

        <!-- セキュリティバー: Nginx層（TLS終端 + IP制限） -->
        <mxCell id="sec2" value="TLS終端 + IP制限" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F5F5F5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="300" width="160" height="30" as="geometry"/>
        </mxCell>

        <!-- セキュリティバー: Kong層（JWT検証 + レート制限 + CORS） -->
        <mxCell id="sec3" value="JWT検証 + レート制限 + CORS" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="300" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- セキュリティバー: BFF層（セッション管理 + CSRF保護） -->
        <mxCell id="sec4" value="セッション管理 + CSRF保護" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFE0B2;strokeColor=#E65100;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="300" width="160" height="30" as="geometry"/>
        </mxCell>

        <!-- セキュリティバー: Istio層（mTLS相互認証） -->
        <mxCell id="sec5" value="mTLS相互認証" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E1D5E7;strokeColor=#9673A6;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="300" width="160" height="30" as="geometry"/>
        </mxCell>

        <!-- セキュリティバー: Backend層（認可 + ビジネスルール） -->
        <mxCell id="sec6" value="認可 + ビジネスルール" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1330" y="300" width="160" height="30" as="geometry"/>
        </mxCell>

        <!-- セキュリティバー下の接続線 -->
        <mxCell id="sec-line" value="" style="endArrow=none;strokeColor=#B85450;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="30" y="340" as="sourcePoint"/>
            <mxPoint x="1490" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- フロー方向ラベル -->
        <mxCell id="flow-label" value="リクエストの流れ →" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="30" y="95" width="200" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
