        <mxCell id="break-label" value="&lt;b&gt;破壊的変更が必要&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;buf breaking で検知&lt;br&gt;フィールド型変更・削除 等&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="1">
