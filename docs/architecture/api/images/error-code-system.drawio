        <mxCell id="http-map" value="&lt;table style=&quot;font-size:10px;border-collapse:collapse;width:100%;&quot;&gt;&lt;tr style=&quot;background:#E1D5E7;&quot;&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;400&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;バリデーション&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;401&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;認証エラー&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#D5E8D4;&quot;&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;403&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;認可エラー&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;404&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;Not Found&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF2CC;&quot;&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;409&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;楽観ロック&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;422&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;ビジネスルール&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F8CECC;&quot;&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;429&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;レート制限&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;&lt;b&gt;500/503&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px;border:1px solid #999;&quot;&gt;サーバーエラー&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
