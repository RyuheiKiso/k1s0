        <!-- セキュリティ注記 -->
        <mxCell id="security-note" value="&lt;b&gt;セキュリティポイント&lt;/b&gt;&lt;br&gt;・ブラウザに Bearer Token を保持しない&lt;br&gt;・HttpOnly Cookie でセッション管理&lt;br&gt;・BFF Proxy が Cookie ⇄ Bearer を双方向変換&lt;br&gt;・Backend 間は mTLS で暗号化" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;shadow=1;align=left;spacingLeft=8;spacingRight=8;" vertex="1" parent="1">
