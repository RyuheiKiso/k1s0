<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="tier-routing-001" name="Tier別ルーティングとレート制限">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: Tier別ルーティングとレート制限の全体図 -->
        <mxCell id="title" value="Tier別ルーティングとレート制限" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Nginx Ingress: 外部トラフィックの受け口 -->
        <mxCell id="nginx" value="Nginx Ingress&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(外部トラフィック受信)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Kong API Gateway: 中央のルーティングハブ -->
        <mxCell id="kong" value="Kong API Gateway" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="240" width="220" height="160" as="geometry"/>
        </mxCell>

        <!-- Nginx→Kong矢印 -->
        <mxCell id="e-nginx" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="nginx" target="kong" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Kongプラグイン: rate-limiting（上） -->
        <mxCell id="plugin-rate" value="rate-limiting" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="195" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- Kongプラグイン: jwt（左） -->
        <mxCell id="plugin-jwt" value="jwt" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="295" width="60" height="30" as="geometry"/>
        </mxCell>

        <!-- Kongプラグイン: cors（右） -->
        <mxCell id="plugin-cors" value="cors" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="295" width="60" height="30" as="geometry"/>
        </mxCell>

        <!-- Kongプラグイン: prometheus（下） -->
        <mxCell id="plugin-prom" value="prometheus" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="415" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- プラグイン接続線: rate-limiting→Kong -->
        <mxCell id="pl1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;dashed=1;dashPattern=4 4;" edge="1" source="plugin-rate" target="kong" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- プラグイン接続線: jwt→Kong -->
        <mxCell id="pl2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;dashed=1;dashPattern=4 4;" edge="1" source="plugin-jwt" target="kong" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- プラグイン接続線: cors→Kong -->
        <mxCell id="pl3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;dashed=1;dashPattern=4 4;" edge="1" source="plugin-cors" target="kong" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- プラグイン接続線: prometheus→Kong -->
        <mxCell id="pl4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;dashed=1;dashPattern=4 4;" edge="1" source="plugin-prom" target="kong" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== Path 1: System Tier（上部） ===== -->

        <!-- k1s0-system: システム層サービス群 -->
        <mxCell id="tier-system" value="k1s0-system" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Systemサービス一覧: auth-server, config-server -->
        <mxCell id="sys-services" value="auth-server&lt;br&gt;config-server" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E1D5E7;strokeColor=#9673A6;opacity=70;" vertex="1" parent="1">
          <mxGeometry x="1020" y="80" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Kong→System Tier矢印（ルートラベル付き） -->
        <mxCell id="e-sys" value="/api/v1/system/*" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="kong" target="tier-system" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="280"/>
              <mxPoint x="680" y="110"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- System Tier→サービス一覧矢印 -->
        <mxCell id="e-sys-svc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;" edge="1" source="tier-system" target="sys-services" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Systemレート制限注釈 -->
        <mxCell id="rate-sys" value="3000 req/min" style="text;html=1;fontSize=11;fontStyle=1;align=center;fontColor=#9673A6;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="100" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== Path 2: Business Tier（中央） ===== -->

        <!-- k1s0-business: ビジネス層サービス群 -->
        <mxCell id="tier-business" value="k1s0-business" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="290" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Businessサービス一覧: taskmanagement -->
        <mxCell id="biz-services" value="taskmanagement" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;opacity=70;" vertex="1" parent="1">
          <mxGeometry x="1020" y="290" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Kong→Business Tier矢印（ルートラベル付き） -->
        <mxCell id="e-biz" value="/api/v1/business/*" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="kong" target="tier-business" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Business Tier→サービス一覧矢印 -->
        <mxCell id="e-biz-svc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;" edge="1" source="tier-business" target="biz-services" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Businessレート制限注釈 -->
        <mxCell id="rate-biz" value="1000 req/min" style="text;html=1;fontSize=11;fontStyle=1;align=center;fontColor=#82B366;fillColor=#D5E8D4;strokeColor=#82B366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="360" width="100" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== Path 3: Service Tier（下部） ===== -->

        <!-- k1s0-service: サービス層サービス群 -->
        <mxCell id="tier-service" value="k1s0-service" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="500" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Serviceサービス一覧: task-bff, user-bff -->
        <mxCell id="svc-services" value="task-bff&lt;br&gt;user-bff" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;opacity=70;" vertex="1" parent="1">
          <mxGeometry x="1020" y="500" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Kong→Service Tier矢印（ルートラベル付き） -->
        <mxCell id="e-svc" value="/api/v1/service/*" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="kong" target="tier-service" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="360"/>
              <mxPoint x="680" y="530"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Service Tier→サービス一覧矢印 -->
        <mxCell id="e-svc-svc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;" edge="1" source="tier-service" target="svc-services" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Serviceレート制限注釈 -->
        <mxCell id="rate-svc" value="500 req/min" style="text;html=1;fontSize=11;fontStyle=1;align=center;fontColor=#D6B656;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="570" width="100" height="25" as="geometry"/>
        </mxCell>

        <!-- プラグインラベル: Kongに適用されるプラグインの説明 -->
        <mxCell id="plugin-label" value="Kongプラグイン" style="text;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="390" y="170" width="140" height="20" as="geometry"/>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend-bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#F5F5F5;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="30" y="530" width="350" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="legend-title" value="凡例" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="535" width="60" height="20" as="geometry"/>
        </mxCell>

        <!-- 凡例アイテム: System Tier -->
        <mxCell id="leg1" value="" style="rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="45" y="565" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg1t" value="System Tier — 認証・設定基盤 (高レート)" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="562" width="300" height="20" as="geometry"/>
        </mxCell>

        <!-- 凡例アイテム: Business Tier -->
        <mxCell id="leg2" value="" style="rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="45" y="590" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg2t" value="Business Tier — ビジネスロジック (中レート)" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="587" width="300" height="20" as="geometry"/>
        </mxCell>

        <!-- 凡例アイテム: Service Tier -->
        <mxCell id="leg3" value="" style="rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="45" y="615" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg3t" value="Service Tier — BFF/ユーザー向け (低レート)" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="612" width="300" height="20" as="geometry"/>
        </mxCell>

        <!-- 凡例アイテム: Kongプラグイン -->
        <mxCell id="leg4" value="" style="rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;dashed=1;dashPattern=4 4;" vertex="1" parent="1">
          <mxGeometry x="45" y="640" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg4t" value="Kong プラグイン" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="637" width="120" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
