<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="pagination-flow-001" name="ページネーション処理フロー">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="660" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="ページネーション 処理フロー — リクエストからレスポンスまで" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1200" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== レイヤーラベル（左側）===== -->
        <mxCell id="lbl-client" value="クライアント" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#9673A6;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="80" width="110" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lbl-adapter" value="adapter 層" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#B85450;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="175" width="110" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lbl-usecase" value="usecase 層" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#B8962E;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="285" width="110" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lbl-repo" value="repository 層" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#6C8EBF;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="435" width="110" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lbl-db" value="DB" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#555555;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="530" width="110" height="40" as="geometry"/>
        </mxCell>

        <!-- 水平区切り線 -->
        <mxCell id="line1" value="" style="line;strokeColor=#DDDDDD;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="155" width="1250" height="10" as="geometry"/>
        </mxCell>
        <mxCell id="line2" value="" style="line;strokeColor=#DDDDDD;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="260" width="1250" height="10" as="geometry"/>
        </mxCell>
        <mxCell id="line3" value="" style="line;strokeColor=#DDDDDD;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="415" width="1250" height="10" as="geometry"/>
        </mxCell>
        <mxCell id="line4" value="" style="line;strokeColor=#DDDDDD;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="510" width="1250" height="10" as="geometry"/>
        </mxCell>

        <!-- ===== クライアント層 ===== -->

        <!-- REST リクエスト -->
        <mxCell id="req-rest" value="REST リクエスト&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;GET /api/v1/tasks&lt;br&gt;?page=1&amp;amp;page_size=20&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="130" y="72" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- GraphQL リクエスト -->
        <mxCell id="req-gql" value="GraphQL リクエスト&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;tasks(page: 1,&lt;br&gt;&nbsp;&nbsp;pageSize: 20) &#123; ... &#125;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="72" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- gRPC リクエスト -->
        <mxCell id="req-grpc" value="gRPC リクエスト&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;ListTasksRequest &#123;&lt;br&gt;&nbsp;&nbsp;pagination: &#123;&lt;br&gt;&nbsp;&nbsp;&nbsp;&nbsp;page: 1, page_size: 20&lt;br&gt;&nbsp;&nbsp;&#125;&lt;br&gt;&#125;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="650" y="65" width="220" height="85" as="geometry"/>
        </mxCell>

        <!-- ===== adapter 層 ===== -->

        <!-- 共通 Pagination 変換 -->
        <mxCell id="adapter-conv" value="&lt;b&gt;Pagination パラメータ変換&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;各プロトコル → 共通の&lt;br&gt;Pagination proto 型に変換&lt;br&gt;page, page_size を抽出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="170" width="280" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== usecase 層 ===== -->

        <!-- バリデーション判定 -->
        <mxCell id="validate" value="&lt;b&gt;バリデーション&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;page &gt;= 1?&lt;br&gt;1 &lt;= page_size &lt;= 100?&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="270" width="180" height="130" as="geometry"/>
        </mxCell>

        <!-- エラーレスポンス -->
        <mxCell id="err-resp" value="ValidationError&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;400 Bad Request&lt;br&gt;エラーメッセージ返却&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="590" y="285" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- usecase → repo 呼出 -->
        <mxCell id="uc-call" value="&lt;b&gt;リポジトリ呼出&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;repo.list(page, page_size)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="350" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== repository 層 ===== -->

        <!-- OFFSET/LIMIT 計算 -->
        <mxCell id="offset-calc" value="&lt;b&gt;OFFSET / LIMIT 計算&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;offset = (page - 1) * page_size&lt;br&gt;limit = page_size&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="425" width="280" height="75" as="geometry"/>
        </mxCell>

        <!-- ===== DB 層 ===== -->

        <!-- SQL実行 -->
        <mxCell id="db-query" value="&lt;b&gt;SQL 実行&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;SELECT ... LIMIT $1 OFFSET $2&lt;br&gt;SELECT COUNT(*) ...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="520" width="280" height="70" as="geometry"/>
        </mxCell>

        <!-- ===== レスポンス生成（右側）===== -->

        <!-- PaginationResult 組み立て -->
        <mxCell id="result-build" value="&lt;b&gt;PaginationResult 生成&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;total_count: COUNT(*)&lt;br&gt;page: page&lt;br&gt;page_size: page_size&lt;br&gt;has_next: total &gt; offset+limit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="425" width="280" height="100" as="geometry"/>
        </mxCell>

        <!-- レスポンス -->
        <mxCell id="response" value="&lt;b&gt;レスポンス&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:Courier New&quot;&gt;&#123;&lt;br&gt;&nbsp;&nbsp;&quot;data&quot;: [...],&lt;br&gt;&nbsp;&nbsp;&quot;pagination&quot;: &#123;&lt;br&gt;&nbsp;&nbsp;&nbsp;&nbsp;&quot;total_count&quot;: 42,&lt;br&gt;&nbsp;&nbsp;&nbsp;&nbsp;&quot;page&quot;: 1,&lt;br&gt;&nbsp;&nbsp;&nbsp;&nbsp;&quot;page_size&quot;: 20,&lt;br&gt;&nbsp;&nbsp;&nbsp;&nbsp;&quot;has_next&quot;: true&lt;br&gt;&nbsp;&nbsp;&#125;&lt;br&gt;&#125;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="65" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== 矢印 ===== -->

        <!-- クライアント → adapter -->
        <mxCell id="e-rest-ad" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;" edge="1" source="req-rest" target="adapter-conv" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="240" y="155"/>
              <mxPoint x="390" y="155"/>
              <mxPoint x="390" y="170"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-gql-ad" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;" edge="1" source="req-gql" target="adapter-conv" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="155"/>
              <mxPoint x="450" y="155"/>
              <mxPoint x="450" y="170"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-grpc-ad" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;" edge="1" source="req-grpc" target="adapter-conv" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="155"/>
              <mxPoint x="520" y="155"/>
              <mxPoint x="520" y="170"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- adapter → validate -->
        <mxCell id="e-ad-val" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;" edge="1" source="adapter-conv" target="validate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- validate → エラー（NG） -->
        <mxCell id="e-val-err" value="NG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;fontSize=10;fontColor=#B85450;" edge="1" source="validate" target="err-resp" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="490" y="335"/>
              <mxPoint x="590" y="335"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- validate → uc-call（OK） -->
        <mxCell id="e-val-uc" value="OK" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;fontSize=10;fontColor=#5D9E4B;" edge="1" source="validate" target="uc-call" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="400"/>
              <mxPoint x="400" y="350"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- uc-call → offset-calc -->
        <mxCell id="e-uc-off" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;" edge="1" source="uc-call" target="offset-calc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- offset-calc → db-query -->
        <mxCell id="e-off-db" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="offset-calc" target="db-query" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- db-query → result-build（右へ） -->
        <mxCell id="e-db-res" value="結果・件数" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;fontSize=9;" edge="1" source="db-query" target="result-build" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="555"/>
              <mxPoint x="990" y="555"/>
              <mxPoint x="990" y="525"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- result-build → response（上へ） -->
        <mxCell id="e-res-resp" value="レスポンス生成" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=9;" edge="1" source="result-build" target="response" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="990" y="425"/>
              <mxPoint x="990" y="265"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
