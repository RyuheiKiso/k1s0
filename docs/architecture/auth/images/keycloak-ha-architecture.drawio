        <mxCell id="leg4" value="&lt;font color=&quot;#E1D5E7&quot;&gt;■&lt;/font&gt; Keycloak　&lt;font color=&quot;#DAE8FC&quot;&gt;■&lt;/font&gt; インフラ" style="text;html=1;fontSize=10;" vertex="1" parent="1">
