        </mxCell>
        <mxCell id="sync23" value="セッション同期" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#9673A6;dashed=1;dashPattern=4 4;fontSize=9;startArrow=classic;endArrow=classic;" edge="1" source="kc2" target="kc3" parent="1">
