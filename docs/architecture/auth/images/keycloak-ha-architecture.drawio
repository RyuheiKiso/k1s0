<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="keycloak-ha-arch" name="Keycloak HAクラスタ構成">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="Keycloak 3ノード HAクラスタ構成" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ロードバランサー -->
        <mxCell id="lb" value="&lt;b&gt;Load Balancer&lt;/b&gt;&lt;br&gt;(Nginx Ingress)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="380" y="70" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Keycloak クラスタ背景 -->
        <mxCell id="cluster_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;opacity=20;dashed=1;" vertex="1" parent="1">
