        <mxCell id="pg_primary" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;Primary" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="475" width="120" height="70" as="geometry"/>
