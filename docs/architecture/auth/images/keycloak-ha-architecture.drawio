        <!-- Keycloak ノード1 -->
        <mxCell id="kc1" value="&lt;b&gt;Keycloak Node 1&lt;/b&gt;&lt;br&gt;v26.0&lt;br&gt;Infinispan内蔵" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="110" y="220" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Keycloak ノード2 -->
        <mxCell id="kc2" value="&lt;b&gt;Keycloak Node 2&lt;/b&gt;&lt;br&gt;v26.0&lt;br&gt;Infinispan内蔵" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="390" y="220" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Keycloak ノード3 -->
        <mxCell id="kc3" value="&lt;b&gt;Keycloak Node 3&lt;/b&gt;&lt;br&gt;v26.0&lt;br&gt;Infinispan内蔵" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="670" y="220" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- ノード間セッション同期（双方向矢印） -->
        <mxCell id="sync12" value="セッション同期" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#9673A6;dashed=1;dashPattern=4 4;fontSize=9;startArrow=classic;endArrow=classic;" edge="1" source="kc1" target="kc2" parent="1">
