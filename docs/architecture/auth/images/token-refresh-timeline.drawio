<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="token-refresh-timeline" name="トークンリフレッシュタイムライン">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="トークンリフレッシュ タイムライン" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- 時間軸 -->
        <mxCell id="time_axis" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#666666;endArrow=classic;endSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="60" y="380" as="sourcePoint"/><mxPoint x="1060" y="380" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="time_label" value="時間 →" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1010" y="385" width="60" height="20" as="geometry"/>
        </mxCell>

        <!-- 時間マーカー -->
        <mxCell id="t0" value="0分" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="385" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t4" value="4分" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="260" y="385" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t5" value="5分" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="310" y="385" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t9" value="9分" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="480" y="385" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t10" value="10分" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="530" y="385" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t29" value="29分" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="860" y="385" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="t30" value="30分" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="920" y="385" width="40" height="20" as="geometry"/>
        </mxCell>

        <!-- Access Token ラベル -->
        <mxCell id="at_label" value="&lt;b&gt;Access Token&lt;/b&gt;&lt;br&gt;(有効期限: 5分)" style="text;html=1;fontSize=11;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="70" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Access Token 1（有効） -->
        <mxCell id="at1" value="AT #1 有効" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="70" width="180" height="30" as="geometry"/>
        </mxCell>
        <!-- Access Token 1（リフレッシュ閾値）-->
        <mxCell id="at1_warn" value="残り1分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="280" y="70" width="50" height="30" as="geometry"/>
        </mxCell>

        <!-- リフレッシュポイント1 -->
        <mxCell id="rp1" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="280" y="100" as="sourcePoint"/><mxPoint x="280" y="380" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="rp1_label" value="⟳ リフレッシュ" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#D6B656;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="230" y="220" width="100" height="20" as="geometry"/>
        </mxCell>

        <!-- Access Token 2（有効） -->
        <mxCell id="at2" value="AT #2 有効" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="70" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="at2_warn" value="残り1分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="50" height="30" as="geometry"/>
        </mxCell>

        <!-- リフレッシュポイント2 -->
        <mxCell id="rp2" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="500" y="100" as="sourcePoint"/><mxPoint x="500" y="380" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Access Token 3以降（省略） -->
        <mxCell id="at3" value="AT #3 有効" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="70" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="at_dots" value="..." style="text;html=1;fontSize=16;fontStyle=1;fontColor=#82B366;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="70" width="40" height="30" as="geometry"/>
        </mxCell>

        <!-- Refresh Token ラベル -->
        <mxCell id="rt_label" value="&lt;b&gt;Refresh Token&lt;/b&gt;&lt;br&gt;(有効期限: 30分)" style="text;html=1;fontSize=11;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="160" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Refresh Token（有効） -->
        <mxCell id="rt1" value="Refresh Token 有効" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="780" height="30" as="geometry"/>
        </mxCell>
        <!-- Refresh Token（残り1分） -->
        <mxCell id="rt1_warn" value="残り1分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="880" y="160" width="60" height="30" as="geometry"/>
        </mxCell>

        <!-- Refresh Token期限切れ -->
        <mxCell id="rt_expire" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#B85450;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="940" y="160" as="sourcePoint"/><mxPoint x="940" y="380" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="rt_expire_label" value="期限切れ→再認証" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#B85450;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="885" y="260" width="110" height="20" as="geometry"/>
        </mxCell>

        <!-- セッションライフサイクル説明 -->
        <mxCell id="desc" value="&lt;b&gt;セッション&lt;/b&gt;&lt;br&gt;ライフサイクル" style="text;html=1;fontSize=11;align=right;" vertex="1" parent="1">
          <mxGeometry x="0" y="250" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="session" value="Redis セッション (TTL = Refresh Token有効期限)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="250" width="840" height="30" as="geometry"/>
        </mxCell>

        <!-- プロアクティブリフレッシュ説明 -->
        <mxCell id="proactive" value="&lt;b&gt;プロアクティブリフレッシュ:&lt;/b&gt; Access Tokenの有効期限が残り1分になった時点でBFFが自動的にリフレッシュ&lt;br&gt;→ ユーザーは途切れないセッション体験を得る" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="560" height="40" as="geometry"/>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="420" width="700" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="leg" value="凡例: &lt;font color=&quot;#82B366&quot;&gt;■&lt;/font&gt; AT有効 &lt;font color=&quot;#6C8EBF&quot;&gt;■&lt;/font&gt; RT有効 &lt;font color=&quot;#D6B656&quot;&gt;■&lt;/font&gt; リフレッシュ閾値 &lt;font color=&quot;#B85450&quot;&gt;■&lt;/font&gt; セッション &lt;font color=&quot;#D6B656&quot;&gt;|&lt;/font&gt; リフレッシュポイント &lt;font color=&quot;#B85450&quot;&gt;|&lt;/font&gt; 期限切れ" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="110" y="428" width="680" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
