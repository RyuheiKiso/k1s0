        <mxCell id="leg3" value="&lt;font color=&quot;#6C8EBF&quot;&gt;■&lt;/font&gt;Client &lt;font color=&quot;#82B366&quot;&gt;■&lt;/font&gt;BFF &lt;font color=&quot;#9673A6&quot;&gt;■&lt;/font&gt;Auth &lt;font color=&quot;#B85450&quot;&gt;■&lt;/font&gt;Cache &lt;font color=&quot;#D6B656&quot;&gt;■&lt;/font&gt;API" style="text;html=1;fontSize=10;" vertex="1" parent="1">
