<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="bff-token-mgmt-seq" name="BFFトークン管理シーケンス">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="BFFパターン トークン管理シーケンス" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- 参加者: ライフライン -->
        <mxCell id="browser" value="&lt;b&gt;Browser&lt;/b&gt;&lt;br&gt;(SPA)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="bff" value="&lt;b&gt;BFF Proxy&lt;/b&gt;&lt;br&gt;(Go)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="70" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="keycloak" value="&lt;b&gt;Keycloak&lt;/b&gt;&lt;br&gt;(OIDC)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="70" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="redis" value="&lt;b&gt;Redis&lt;/b&gt;&lt;br&gt;(Session)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="830" y="70" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="api" value="&lt;b&gt;API Server&lt;/b&gt;&lt;br&gt;(Backend)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1030" y="70" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- ライフライン（縦線） -->
        <mxCell id="ll1" style="edgeStyle=none;dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="120" as="sourcePoint"/><mxPoint x="140" y="750" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ll2" style="edgeStyle=none;dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="120" as="sourcePoint"/><mxPoint x="390" y="750" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ll3" style="edgeStyle=none;dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="640" y="120" as="sourcePoint"/><mxPoint x="640" y="750" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ll4" style="edgeStyle=none;dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="890" y="120" as="sourcePoint"/><mxPoint x="890" y="750" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ll5" style="edgeStyle=none;dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1090" y="120" as="sourcePoint"/><mxPoint x="1090" y="750" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- フェーズ1: ログイン認証 -->
        <mxCell id="phase1" value="① ログイン認証" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="160" height="20" as="geometry"/>
        </mxCell>

        <!-- Browser → BFF: ログインリクエスト -->
        <mxCell id="m1" value="POST /auth/login" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="170" as="sourcePoint"/><mxPoint x="390" y="170" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- BFF → Keycloak: 認証コード要求 -->
        <mxCell id="m2" value="Authorization Code Request" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="200" as="sourcePoint"/><mxPoint x="640" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Keycloak → BFF: トークン返却 -->
        <mxCell id="m3" value="Access Token + Refresh Token" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#9673A6;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="640" y="230" as="sourcePoint"/><mxPoint x="390" y="230" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- BFF → Redis: トークン保存 -->
        <mxCell id="m4" value="トークンをセッションに保存" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="260" as="sourcePoint"/><mxPoint x="890" y="260" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- BFF → Browser: セッションIDのみ返却 -->
        <mxCell id="m5" value="Set-Cookie: session_id=xxx (HttpOnly)" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="290" as="sourcePoint"/><mxPoint x="140" y="290" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- 重要ポイント注記 -->
        <mxCell id="note1" value="&lt;b&gt;重要:&lt;/b&gt; ブラウザにはトークンを&lt;br&gt;一切渡さない（セッションIDのみ）" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;shadow=1;size=15;" vertex="1" parent="1">
          <mxGeometry x="20" y="300" width="110" height="70" as="geometry"/>
        </mxCell>

        <!-- フェーズ2: APIコール -->
        <mxCell id="phase2" value="② API呼び出し" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="20" y="390" width="160" height="20" as="geometry"/>
        </mxCell>

        <!-- Browser → BFF: APIリクエスト -->
        <mxCell id="m6" value="GET /api/resource (Cookie: session_id)" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="420" as="sourcePoint"/><mxPoint x="390" y="420" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- BFF → Redis: セッションからトークン取得 -->
        <mxCell id="m7" value="GET session:{id}" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="450" as="sourcePoint"/><mxPoint x="890" y="450" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Redis → BFF: トークン返却 -->
        <mxCell id="m8" value="Access Token" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="890" y="470" as="sourcePoint"/><mxPoint x="390" y="470" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- BFF → API: Bearer トークン付きリクエスト -->
        <mxCell id="m9" value="Authorization: Bearer {token}" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="500" as="sourcePoint"/><mxPoint x="1090" y="500" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- API → BFF: レスポンス -->
        <mxCell id="m10" value="200 OK (Response)" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1090" y="530" as="sourcePoint"/><mxPoint x="390" y="530" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- BFF → Browser: レスポンス転送 -->
        <mxCell id="m11" value="200 OK (Response)" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="550" as="sourcePoint"/><mxPoint x="140" y="550" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- フェーズ3: トークンリフレッシュ -->
        <mxCell id="phase3" value="③ トークンリフレッシュ（自動）" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="20" y="590" width="250" height="20" as="geometry"/>
        </mxCell>

        <!-- BFF → Keycloak: リフレッシュ -->
        <mxCell id="m12" value="Token Refresh (refresh_token)" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#9673A6;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="620" as="sourcePoint"/><mxPoint x="640" y="620" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Keycloak → BFF: 新トークン -->
        <mxCell id="m13" value="New Access Token + Refresh Token" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#9673A6;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="640" y="650" as="sourcePoint"/><mxPoint x="390" y="650" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- BFF → Redis: 新トークン保存 -->
        <mxCell id="m14" value="SET session:{id} (新トークン)" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="390" y="680" as="sourcePoint"/><mxPoint x="890" y="680" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- 注記: ブラウザ側は変更不要 -->
        <mxCell id="note2" value="&lt;b&gt;ポイント:&lt;/b&gt; リフレッシュは&lt;br&gt;BFF内部で自動実行&lt;br&gt;ブラウザ側は変更不要" style="shape=note;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;align=left;shadow=1;size=15;" vertex="1" parent="1">
          <mxGeometry x="20" y="640" width="110" height="70" as="geometry"/>
        </mxCell>

        <!-- 凡例 -->
