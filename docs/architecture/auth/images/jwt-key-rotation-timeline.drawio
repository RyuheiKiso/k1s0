<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="jwt-key-rotation" name="JWT 鍵ローテーションタイムライン">
    <mxGraphModel dx="1222" dy="462" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
