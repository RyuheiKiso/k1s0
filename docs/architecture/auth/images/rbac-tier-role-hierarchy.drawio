<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="rbac-tier-001" name="RBAC Tier別ロール階層">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="RBAC — Tier 別ロール階層と権限スコープ" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="35" as="geometry"/>
        </mxCell>

        <!-- ===== JWT tier_access 制御（最上段） ===== -->
        <mxCell id="jwt-bg" value="" style="rounded=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="1360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="jwt-title" value="JWT Claims — tier_access によるアクセス制御（Istio + アプリ二重検証）" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="65" width="1360" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="jwt-claims" value="{ &quot;tier_access&quot;: [&quot;system&quot;, &quot;business&quot;, &quot;service&quot;],  &quot;realm_access&quot;: { &quot;roles&quot;: [&quot;sys_admin&quot;, ...] },  &quot;resource_access&quot;: { &quot;task-server&quot;: { &quot;roles&quot;: [&quot;write&quot;] } } }" style="text;html=1;fontSize=11;fontFamily=Courier New;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="90" width="1360" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== system Tier ===== -->
        <mxCell id="sys-bg" value="" style="rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;strokeWidth=2;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="155" width="1360" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="sys-label" value="system Tier  ─  全プロジェクト共通基盤" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#9673A6;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="160" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- sys_admin -->
        <mxCell id="sys-admin" value="&lt;b&gt;sys_admin&lt;/b&gt;&lt;br&gt;システム全体管理者&lt;br&gt;─&lt;br&gt;全リソース: &lt;b&gt;RWD&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673A6;strokeColor=#7B4EA6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="180" height="90" as="geometry"/>
        </mxCell>

        <!-- sys_operator -->
        <mxCell id="sys-operator" value="&lt;b&gt;sys_operator&lt;/b&gt;&lt;br&gt;システム運用担当&lt;br&gt;─&lt;br&gt;users: R&lt;br&gt;auth_config: RW&lt;br&gt;monitoring: RW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B39DDB;strokeColor=#9673A6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="250" y="190" width="180" height="90" as="geometry"/>
        </mxCell>

        <!-- sys_auditor -->
        <mxCell id="sys-auditor" value="&lt;b&gt;sys_auditor&lt;/b&gt;&lt;br&gt;監査担当&lt;br&gt;─&lt;br&gt;全リソース: &lt;b&gt;R のみ&lt;/b&gt;&lt;br&gt;vault_secrets: 不可" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B39DDB;strokeColor=#9673A6;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="460" y="190" width="180" height="90" as="geometry"/>
        </mxCell>

        <!-- sys scope note -->
        <mxCell id="sys-scope" value="&lt;b&gt;スコープ:&lt;/b&gt; 全 Tier のリソースにアクセス可能（スーパーユーザー）&lt;br&gt;tier_access = [&quot;system&quot;, &quot;business&quot;, &quot;service&quot;]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="200" width="680" height="70" as="geometry"/>
        </mxCell>

        <!-- ===== business Tier ===== -->
        <mxCell id="biz-bg" value="" style="rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=2;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="360" width="1360" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="biz-label" value="business Tier  ─  業務領域（例: taskmanagement）" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#82B366;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="365" width="500" height="20" as="geometry"/>
        </mxCell>

        <!-- biz admin -->
        <mxCell id="biz-admin" value="&lt;b&gt;biz_{domain}_admin&lt;/b&gt;&lt;br&gt;領域管理者&lt;br&gt;─&lt;br&gt;領域内全リソース: &lt;b&gt;RWD&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82B366;strokeColor=#6B9A52;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="395" width="200" height="90" as="geometry"/>
        </mxCell>

        <!-- biz manager -->
        <mxCell id="biz-manager" value="&lt;b&gt;biz_{domain}_manager&lt;/b&gt;&lt;br&gt;領域マネージャー&lt;br&gt;─&lt;br&gt;領域内リソース: &lt;b&gt;RW&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#82B366;fontSize=11;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="270" y="395" width="200" height="90" as="geometry"/>
        </mxCell>

        <!-- biz viewer -->
        <mxCell id="biz-viewer" value="&lt;b&gt;biz_{domain}_viewer&lt;/b&gt;&lt;br&gt;領域閲覧者&lt;br&gt;─&lt;br&gt;領域内リソース: &lt;b&gt;R のみ&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#82B366;fontSize=11;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="500" y="395" width="200" height="90" as="geometry"/>
        </mxCell>

        <!-- biz scope note -->
        <mxCell id="biz-scope" value="&lt;b&gt;スコープ:&lt;/b&gt; 所属領域のリソースのみ&lt;br&gt;tier_access = [&quot;business&quot;, &quot;service&quot;]&lt;br&gt;&lt;b&gt;例:&lt;/b&gt; biz_taskmanagement_admin → project_types, project_status, master_data &lt;b&gt;RWD&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="730" y="400" width="630" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== service Tier ===== -->
        <mxCell id="svc-bg" value="" style="rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=2;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="585" width="1360" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="svc-label" value="service Tier  ─  個別サービス（例: task サービス）" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#D6B656;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="590" width="500" height="20" as="geometry"/>
        </mxCell>

        <!-- svc admin -->
        <mxCell id="svc-admin" value="&lt;b&gt;svc_{service}_admin&lt;/b&gt;&lt;br&gt;サービス管理者&lt;br&gt;─&lt;br&gt;サービス内全リソース: &lt;b&gt;RWD&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=11;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="200" height="90" as="geometry"/>
        </mxCell>

        <!-- svc user -->
        <mxCell id="svc-user" value="&lt;b&gt;svc_{service}_user&lt;/b&gt;&lt;br&gt;サービス利用者&lt;br&gt;─&lt;br&gt;tasks: RW&lt;br&gt;boards: R" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE082;strokeColor=#D6B656;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="270" y="620" width="200" height="90" as="geometry"/>
        </mxCell>

        <!-- svc viewer -->
        <mxCell id="svc-viewer" value="&lt;b&gt;svc_{service}_viewer&lt;/b&gt;&lt;br&gt;サービス閲覧者&lt;br&gt;─&lt;br&gt;全リソース: &lt;b&gt;R のみ&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE082;strokeColor=#D6B656;fontSize=11;fontColor=#5D4037;" vertex="1" parent="1">
          <mxGeometry x="500" y="620" width="200" height="90" as="geometry"/>
        </mxCell>

        <!-- svc scope note -->
        <mxCell id="svc-scope" value="&lt;b&gt;スコープ:&lt;/b&gt; 所属サービスのリソースのみ&lt;br&gt;tier_access = [&quot;service&quot;]&lt;br&gt;&lt;b&gt;例:&lt;/b&gt; svc_task_user → tasks &lt;b&gt;RW&lt;/b&gt;, task_items &lt;b&gt;RW&lt;/b&gt;, boards &lt;b&gt;R&lt;/b&gt;, activities &lt;b&gt;RW&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="730" y="625" width="630" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== パーミッション解決フロー（下段） ===== -->
        <mxCell id="resolve-bg" value="" style="rounded=1;fillColor=#F5F5F5;strokeColor=#999999;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="810" width="1360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="resolve-title" value="パーミッション解決フロー（リクエストごと）" style="text;html=1;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="815" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- ステップ1 -->
        <mxCell id="step1" value="① JWT取得&lt;br&gt;realm_access.roles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="838" width="150" height="35" as="geometry"/>
        </mxCell>

        <!-- 矢印1 -->
        <mxCell id="arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ステップ2 -->
        <mxCell id="step2" value="② ロール→権限変換&lt;br&gt;インメモリキャッシュ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="838" width="160" height="35" as="geometry"/>
        </mxCell>

        <!-- 矢印2 -->
        <mxCell id="arrow2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ステップ3 -->
        <mxCell id="step3" value="③ tier_access検証&lt;br&gt;Istio + ミドルウェア" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="838" width="160" height="35" as="geometry"/>
        </mxCell>

        <!-- 矢印3 -->
        <mxCell id="arrow3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="step3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ステップ4 -->
        <mxCell id="step4" value="④ permission+resource&lt;br&gt;チェック" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="838" width="160" height="35" as="geometry"/>
        </mxCell>

        <!-- 矢印4 -->
        <mxCell id="arrow4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="step4" target="step5ok" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ステップ5OK -->
        <mxCell id="step5ok" value="✓ 許可&lt;br&gt;200 OK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="828" width="120" height="55" as="geometry"/>
        </mxCell>

        <!-- ステップ5NG -->
        <mxCell id="step5ng" value="✗ 拒否&lt;br&gt;403 Forbidden" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="828" width="120" height="55" as="geometry"/>
        </mxCell>

        <!-- deny by default -->
        <mxCell id="deny-rule" value="deny by default：明示的に許可されていないパーミッションはすべて拒否" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1150" y="838" width="220" height="35" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
