<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="jwt-verification-flow" name="JWT 検証フロー">
    <mxGraphModel dx="1422" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="JWT 検証フロー" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="600" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Keycloak JWKS → auth-server → Kong / Service 二重検証" style="text;html=1;fontSize=14;fontColor=#999999;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="400" y="45" width="600" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== Top Section: JWKS 配布 ===== -->
        <mxCell id="jwks_section_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1100" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="jwks_section_label" value="JWKS 配布" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="55" y="85" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Keycloak -->
        <mxCell id="keycloak" value="Keycloak&#xa;&#xa;JWKS ソース&#xa;/realms/k1s0/&#xa;.../certs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="150" height="100" as="geometry"/>
        </mxCell>

        <!-- auth-server -->
        <mxCell id="auth_server" value="auth-server&#xa;&#xa;JWKS プロキシ/キャッシュ&#xa;/jwks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="120" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- Kong (JWKS取得先) -->
        <mxCell id="kong_jwks" value="Kong API Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="740" y="115" width="160" height="45" as="geometry"/>
        </mxCell>

        <!-- 各サービス (JWKS取得先) -->
        <mxCell id="services_jwks" value="各サービス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="740" y="180" width="160" height="45" as="geometry"/>
        </mxCell>

        <!-- Keycloak → auth-server -->
        <mxCell id="kc_to_auth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#9673A6;" edge="1" source="keycloak" target="auth_server" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="kc_to_auth_label" value="JWKS取得" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#9673A6;" vertex="1" connectable="0" parent="kc_to_auth">
          <mxGeometry x="-0.1" y="-1" relative="1" as="geometry">
            <mxPoint x="0" y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- auth-server → Kong -->
        <mxCell id="auth_to_kong" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82B366;" edge="1" source="auth_server" target="kong_jwks" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="auth_to_kong_label" value="JWKS取得" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#82B366;" vertex="1" connectable="0" parent="auth_to_kong">
          <mxGeometry x="-0.1" y="-1" relative="1" as="geometry">
            <mxPoint x="0" y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- auth-server → 各サービス -->
        <mxCell id="auth_to_svc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82B366;" edge="1" source="auth_server" target="services_jwks" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="auth_to_svc_label" value="JWKS取得" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#82B366;" vertex="1" connectable="0" parent="auth_to_svc">
          <mxGeometry x="-0.1" y="1" relative="1" as="geometry">
            <mxPoint x="0" y="10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== Bottom Section: 二重検証フロー ===== -->
        <mxCell id="dual_section_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="1320" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="dual_section_label" value="二重検証フロー" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="55" y="285" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- クライアント -->
        <mxCell id="client" value="クライアント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontStyle=1;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="70" y="360" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- Kong (二重検証) -->
        <mxCell id="kong_verify" value="Kong&#xa;API Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="360" y="350" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- Kong 検証ノート -->
        <mxCell id="kong_note" value="第1検証層&#xa;・JWT署名検証&#xa;・kid照合" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;align=left;spacingLeft=8;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="330" y="440" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- サービス (二重検証) -->
        <mxCell id="service_verify" value="サービス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontStyle=1;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="680" y="350" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- サービス検証ノート -->
        <mxCell id="service_note" value="第2検証層&#xa;・JWT署名再検証&#xa;・Claims検証&#xa;・RBAC判定" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="650" y="440" width="150" height="80" as="geometry"/>
        </mxCell>

        <!-- Client → Kong -->
        <mxCell id="c_to_k" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="client" target="kong_verify" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c_to_k_label" value="Bearer JWT" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontStyle=1;fontColor=#333333;" vertex="1" connectable="0" parent="c_to_k">
          <mxGeometry x="-0.1" y="-1" relative="1" as="geometry">
            <mxPoint x="0" y="-12" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Kong → サービス -->
        <mxCell id="k_to_s" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="kong_verify" target="service_verify" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="k_to_s_label" value="検証済みJWT転送" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontStyle=1;fontColor=#333333;" vertex="1" connectable="0" parent="k_to_s">
          <mxGeometry x="-0.1" y="-1" relative="1" as="geometry">
            <mxPoint x="0" y="-12" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 結果: OK -->
        <mxCell id="result_ok" value="200 OK&#xa;処理続行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="930" y="340" width="120" height="45" as="geometry"/>
        </mxCell>

        <!-- 結果: NG -->
        <mxCell id="result_ng" value="401 Unauthorized" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="930" y="400" width="140" height="45" as="geometry"/>
        </mxCell>

        <!-- Service → OK -->
        <mxCell id="s_to_ok" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82B366;" edge="1" source="service_verify" target="result_ok" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Service → NG -->
        <mxCell id="s_to_ng" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;dashed=1;" edge="1" source="service_verify" target="result_ng" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== Side note: kid不明時 ===== -->
        <mxCell id="kid_note" value="kid不明時:&#xa;キャッシュ強制更新&#xa;→ JWKS再取得&#xa;→ 再検証" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1130" y="310" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- kid note connector -->
        <mxCell id="kid_conn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1;strokeColor=#D6B656;dashed=1;endArrow=none;" edge="1" source="kid_note" target="service_verify" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1100" y="350"/>
              <mxPoint x="1100" y="385"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
