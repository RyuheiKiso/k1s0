<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="rbac-perm-resolution" name="パーミッション解決フロー">
    <mxGraphModel dx="1422" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="パーミッション解決フロー" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="700" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="JWT Claims → Role抽出 → Cache → Permission Check" style="text;html=1;fontSize=14;fontColor=#999999;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="350" y="45" width="700" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 1: JWT トークン受信 -->
        <mxCell id="step1" value="JWT トークン&#xa;受信" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="30" y="200" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 2: realm_access.roles / resource_access 取得 -->
        <mxCell id="step2" value="realm_access.roles&#xa;resource_access&#xa;取得" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="210" y="195" width="150" height="70" as="geometry"/>
        </mxCell>

        <!-- Step 3: ロール→パーミッション変換テーブル参照 -->
        <mxCell id="step3" value="ロール→パーミッション&#xa;変換テーブル参照" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="410" y="195" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Decision: キャッシュHit? -->
        <mxCell id="cache_decision" value="キャッシュ&#xa;Hit?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="185" width="110" height="90" as="geometry"/>
        </mxCell>

        <!-- Keycloak Admin API から再取得 (No path) -->
        <mxCell id="keycloak_fetch" value="Keycloak&#xa;Admin API&#xa;から再取得" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="610" y="360" width="140" height="65" as="geometry"/>
        </mxCell>

        <!-- Step 5: 要求パーミッションチェック -->
        <mxCell id="step5" value="要求パーミッション&#xa;チェック" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="790" y="195" width="150" height="70" as="geometry"/>
        </mxCell>

        <!-- Decision: 権限あり? -->
        <mxCell id="auth_decision" value="権限&#xa;あり?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="185" width="100" height="90" as="geometry"/>
        </mxCell>

        <!-- 200 OK (Yes) -->
        <mxCell id="result_ok" value="200 OK&#xa;リクエスト処理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="1170" y="140" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- 403 Forbidden (No) -->
        <mxCell id="result_deny" value="403 Forbidden&#xa;拒否 (deny by default)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="1170" y="270" width="170" height="55" as="geometry"/>
        </mxCell>

        <!-- ===== Arrows ===== -->

        <!-- Step1 → Step2 -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step2 → Step3 -->
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step3 → Cache Decision -->
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="step3" target="cache_decision" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Cache Decision → Step5 (Yes) -->
        <mxCell id="a4_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82B366;" edge="1" source="cache_decision" target="step5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4_yes_label" value="Yes" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontStyle=1;fontColor=#82B366;" vertex="1" connectable="0" parent="a4_yes">
          <mxGeometry x="-0.3" y="-1" relative="1" as="geometry">
            <mxPoint x="0" y="-10" as="offset"/>
          </mxGeometry>
