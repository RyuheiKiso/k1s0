          </mxGeometry>
        </mxCell>
        <mxCell id="a7_yes_label" value="Yes" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontStyle=1;fontColor=#82B366;" vertex="1" connectable="0" parent="a7_yes">
          <mxGeometry x="-0.5" y="-1" relative="1" as="geometry">
            <mxPoint x="0" y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Auth Decision → 403 Forbidden (No) -->
        <mxCell id="a7_no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;" edge="1" source="auth_decision" target="result_deny" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1140" y="250"/>
              <mxPoint x="1140" y="298"/>
