        <!-- Side note: キャッシュ設定 -->
        <mxCell id="cache_note" value="キャッシュ TTL: 5分&#xa;バックグラウンド更新&#xa;フォールバック: 既存キャッシュ継続" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="400" width="220" height="80" as="geometry"/>
