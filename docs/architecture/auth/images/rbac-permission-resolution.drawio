        <!-- Cache Decision → Keycloak (No) -->
        <mxCell id="a4_no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;" edge="1" source="cache_decision" target="keycloak_fetch" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4_no_label" value="No" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontStyle=1;fontColor=#B85450;" vertex="1" connectable="0" parent="a4_no">
          <mxGeometry x="-0.3" y="-1" relative="1" as="geometry">
            <mxPoint x="10" y="0" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Keycloak → Step5 -->
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#9673A6;" edge="1" source="keycloak_fetch" target="step5" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="865" y="393"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step5 → Auth Decision -->
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#333333;" edge="1" source="step5" target="auth_decision" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Auth Decision → 200 OK (Yes) -->
        <mxCell id="a7_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82B366;" edge="1" source="auth_decision" target="result_ok" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1140" y="230"/>
              <mxPoint x="1140" y="168"/>
