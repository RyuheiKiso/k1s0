        <mxCell id="a7_no_label" value="No" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontStyle=1;fontColor=#B85450;" vertex="1" connectable="0" parent="a7_no">
          <mxGeometry x="-0.5" y="1" relative="1" as="geometry">
