        <!-- トレースノート -->
        <mxCell id="trace-note" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;サンプリング率&lt;/b&gt;&lt;br&gt;dev: 100%&lt;br&gt;staging: 50%&lt;br&gt;prod: 10%+tail&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="swim-traces">
