<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="obs-stack-overview" name="可観測性スタック全体像">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: 可観測性スタック全体像 -->
        <mxCell id="title" value="可観測性スタック全体像" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 左列: データソース ===== -->
