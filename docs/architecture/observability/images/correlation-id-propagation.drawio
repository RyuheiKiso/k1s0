          <mxGeometry x="457" y="150" width="6" height="6" as="geometry"/>
        </mxCell>
        <mxCell id="anc-hdl-bot" value="" style="ellipse;fillColor=none;strokeColor=none;fontSize=0;" vertex="1" parent="1">
          <mxGeometry x="457" y="554" width="6" height="6" as="geometry"/>
