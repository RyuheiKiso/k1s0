<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="trace-001" name="Correlation ID伝搬シーケンス図とスパン階層">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="Correlation ID 伝搬シーケンス &amp; スパン階層" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 左側: シーケンス図 ===== -->
        <mxCell id="section-seq" value="リクエスト伝搬フロー" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="300" height="30" as="geometry"/>
        </mxCell>

        <!-- アクター: Client -->
        <mxCell id="client" value="&lt;b&gt;Client&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(React/Flutter)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- アクター: CorrelationLayer -->
        <mxCell id="corr-layer" value="&lt;b&gt;CorrelationLayer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(Rust Middleware)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="100" width="150" height="50" as="geometry"/>
        </mxCell>

        <!-- アクター: Handler -->
        <mxCell id="handler" value="&lt;b&gt;Handler&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(Business Logic)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- アクター: Backend Service -->
        <mxCell id="backend" value="&lt;b&gt;Backend&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(gRPC Service)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="100" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== ライフライン用の不可視アンカーポイント ===== -->
        <!-- Client ライフライン端点 -->
        <mxCell id="anc-cli-top" value="" style="ellipse;fillColor=none;strokeColor=none;fontSize=0;" vertex="1" parent="1">
          <mxGeometry x="92" y="150" width="6" height="6" as="geometry"/>
        </mxCell>
        <mxCell id="anc-cli-bot" value="" style="ellipse;fillColor=none;strokeColor=none;fontSize=0;" vertex="1" parent="1">
          <mxGeometry x="92" y="554" width="6" height="6" as="geometry"/>
        </mxCell>

        <!-- CorrelationLayer ライフライン端点 -->
        <mxCell id="anc-corr-top" value="" style="ellipse;fillColor=none;strokeColor=none;fontSize=0;" vertex="1" parent="1">
          <mxGeometry x="272" y="150" width="6" height="6" as="geometry"/>
        </mxCell>
        <mxCell id="anc-corr-bot" value="" style="ellipse;fillColor=none;strokeColor=none;fontSize=0;" vertex="1" parent="1">
          <mxGeometry x="272" y="554" width="6" height="6" as="geometry"/>
        </mxCell>

        <!-- Handler ライフライン端点 -->
