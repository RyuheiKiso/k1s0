<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="metrics-recording-rules" name="メトリクスRecording Rules集約DAG">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="メトリクス Recording Rules 集約DAG" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 上層: ダッシュボード / アラート ===== -->
        <mxCell id="layer3_bg" value="" style="rounded=1;fillColor=#F8CECC;strokeColor=#B85450;opacity=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="920" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="layer3_label" value="ダッシュボード / アラート" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="50" y="63" width="200" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="dash1" value="&lt;b&gt;SLO Dashboard&lt;/b&gt;&lt;br&gt;可用性・レイテンシ" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="dash2" value="&lt;b&gt;RED Dashboard&lt;/b&gt;&lt;br&gt;Rate/Error/Duration" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="90" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="alert1" value="&lt;b&gt;PagerDuty Alert&lt;/b&gt;&lt;br&gt;SLO burn rate" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="90" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="alert2" value="&lt;b&gt;Slack Alert&lt;/b&gt;&lt;br&gt;エラー率しきい値" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="90" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== 中間層: Recording Rules ===== -->
        <mxCell id="layer2_bg" value="" style="rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;opacity=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="920" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="layer2_label" value="Recording Rules（事前集約）" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="50" y="203" width="240" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="rr1" value="&lt;b&gt;job:http_requests:rate5m&lt;/b&gt;&lt;br&gt;sum(rate(http_requests_total[5m]))&lt;br&gt;by (job)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rr2" value="&lt;b&gt;job:http_errors:rate5m&lt;/b&gt;&lt;br&gt;sum(rate(http_requests_total{code=~&quot;5..&quot;}[5m]))&lt;br&gt;by (job)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="300" y="230" width="250" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="rr3" value="&lt;b&gt;job:http_latency:p99_5m&lt;/b&gt;&lt;br&gt;histogram_quantile(0.99,&lt;br&gt;sum(rate(http_request_duration_seconds_bucket[5m]))&lt;br&gt;by (le, job))" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="580" y="230" width="340" height="55" as="geometry"/>
        </mxCell>

        <!-- 二次集約 Recording Rules -->
        <mxCell id="rr4" value="&lt;b&gt;job:http_error_rate:ratio5m&lt;/b&gt;&lt;br&gt;job:http_errors:rate5m / job:http_requests:rate5m" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="120" y="310" width="300" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="rr5" value="&lt;b&gt;job:slo_burn_rate:1h&lt;/b&gt;&lt;br&gt;error_rate / (1 - slo_target)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="500" y="310" width="250" height="45" as="geometry"/>
        </mxCell>

        <!-- ===== 最下層: 生メトリクス ===== -->
        <mxCell id="layer1_bg" value="" style="rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;opacity=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="920" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="layer1_label" value="生メトリクス（Prometheus TSDB）" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="50" y="423" width="280" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="raw1" value="&lt;b&gt;http_requests_total&lt;/b&gt;&lt;br&gt;Counter" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="raw2" value="&lt;b&gt;http_request_duration&lt;br&gt;_seconds_bucket&lt;/b&gt;&lt;br&gt;Histogram" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="450" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="raw3" value="&lt;b&gt;grpc_server_handled_total&lt;/b&gt;&lt;br&gt;Counter" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="460" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="raw4" value="&lt;b&gt;process_cpu_seconds_total&lt;/b&gt;&lt;br&gt;Counter" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="460" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- 矢印: 生メトリクス → Recording Rules -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#6C8EBF;" edge="1" source="raw1" target="rr1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#6C8EBF;" edge="1" source="raw1" target="rr2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#6C8EBF;" edge="1" source="raw2" target="rr3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 矢印: 一次RR → 二次RR -->
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#D6B656;" edge="1" source="rr1" target="rr4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#D6B656;" edge="1" source="rr2" target="rr4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#D6B656;" edge="1" source="rr4" target="rr5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 矢印: Recording Rules → ダッシュボード/アラート -->
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#B85450;" edge="1" source="rr5" target="dash1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#B85450;" edge="1" source="rr1" target="dash2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#B85450;" edge="1" source="rr5" target="alert1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#B85450;" edge="1" source="rr4" target="alert2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="700" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg_t" value="凡例:" style="text;html=1;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="575" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="&lt;font color=&quot;#6C8EBF&quot;&gt;■&lt;/font&gt; 生メトリクス" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="575" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="&lt;font color=&quot;#D6B656&quot;&gt;■&lt;/font&gt; Recording Rules" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="575" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="&lt;font color=&quot;#B85450&quot;&gt;■&lt;/font&gt; ダッシュボード/アラート" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="575" width="180" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="↑ 集約方向（下→上）" style="text;html=1;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="560" y="575" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg_note" value="Recording Rules により PromQL の計算コストを削減し、ダッシュボードの応答速度を改善" style="text;html=1;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="50" y="595" width="500" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
