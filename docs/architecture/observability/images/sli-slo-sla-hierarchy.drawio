<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="slo-001" name="SLI/SLO/SLA階層図とバーンレートアラート">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="SLI / SLO / SLA 階層図 &amp; エラーバジェット運用" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 左側: SLI/SLO/SLA ピラミッド ===== -->
        <mxCell id="section-pyramid" value="階層構造" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- SLA: 最外側（顧客合意） -->
        <mxCell id="sla" value="&lt;b style=&quot;font-size:16px&quot;&gt;SLA（Service Level Agreement）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;チーム間合意 — 外部向け保証&lt;br&gt;SLO より緩い値で設定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="540" height="80" as="geometry"/>
        </mxCell>

        <!-- SLO: 中間層（内部目標） -->
        <mxCell id="slo" value="&lt;b style=&quot;font-size:14px&quot;&gt;SLO（Service Level Objective）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;内部目標 — エラーバジェットの基準値&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="460" height="70" as="geometry"/>
        </mxCell>

        <!-- SLI: 最内側（計測指標） -->
        <mxCell id="sli" value="&lt;b style=&quot;font-size:14px&quot;&gt;SLI（Service Level Indicator）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;計測指標 — 可用性・レイテンシ・エラー率&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="120" y="290" width="380" height="70" as="geometry"/>
        </mxCell>

        <!-- 矢印: SLI → SLO -->
        <mxCell id="e-sli-slo" value="計測" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="sli" target="slo" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 矢印: SLO → SLA -->
        <mxCell id="e-slo-sla" value="保証" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="slo" target="sla" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tier別SLO値テーブル -->
        <mxCell id="tier-table" value="&lt;table style=&quot;font-size:10px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#E1D5E7;&quot;&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;&lt;b&gt;system&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;可用性 99.95%&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;P99 &amp;lt; 200ms&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;21.6分/月&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#D5E8D4;&quot;&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;&lt;b&gt;business&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;可用性 99.9%&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;P99 &amp;lt; 500ms&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;43.2分/月&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF2CC;&quot;&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;&lt;b&gt;service&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;可用性 99.9%&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;P99 &amp;lt; 1s&lt;/td&gt;&lt;td style=&quot;padding:4px;border:1px solid #999;&quot;&gt;43.2分/月&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="440" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== 右側: エラーバジェット消費 & バーンレートアラート ===== -->
        <mxCell id="section-budget" value="エラーバジェット &amp; バーンレートアラート" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="660" y="60" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- エラーバジェット残量ゲージ（段階表示） -->
        <mxCell id="budget-100" value="&lt;b&gt;&gt; 50%&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;通常運用&lt;br&gt;新機能リリース可&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="100" width="150" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="budget-50" value="&lt;b&gt;25% - 50%&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;注意&lt;br&gt;リリース頻度低下&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="100" width="150" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="budget-25" value="&lt;b&gt;&lt; 25%&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;警告&lt;br&gt;リリース凍結&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="100" width="150" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="budget-0" value="&lt;b&gt;0%&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;凍結&lt;br&gt;ポストモーテム&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#B85450;strokeColor=#6C0000;fontColor=#FFFFFF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="100" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- 矢印: バジェット消費方向 -->
        <mxCell id="e-b100-b50" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="budget-100" target="budget-50" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-b50-b25" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="budget-50" target="budget-25" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-b25-b0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="budget-25" target="budget-0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- バーンレートアラート判定フロー -->
        <mxCell id="br-title" value="バーンレートアラート判定" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="660" y="210" width="300" height="25" as="geometry"/>
        </mxCell>

        <!-- エラー率計算 -->
        <mxCell id="br-calc" value="&lt;b&gt;バーンレート計算&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;実測エラー率 / エラーバジェット&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="250" width="220" height="50" as="geometry"/>
        </mxCell>

        <!-- 判定: 14.4x超過? -->
        <mxCell id="br-check-crit" value="&lt;b&gt;14.4x 超過？&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;1h窓 AND 5m窓&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="690" y="340" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e-calc-crit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="br-calc" target="br-check-crit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- critical アラート発火 -->
        <mxCell id="br-critical" value="&lt;b&gt;Critical&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;即時対応（ページ）&lt;br&gt;〜2日でバジェット枯渇&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#B85450;strokeColor=#6C0000;fontColor=#FFFFFF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="470" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e-crit-yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" source="br-check-crit" target="br-critical" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 判定: 6x超過? -->
        <mxCell id="br-check-warn" value="&lt;b&gt;6x 超過？&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;6h窓 AND 30m窓&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="910" y="340" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e-crit-no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" source="br-check-crit" target="br-check-warn" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- warning アラート発火 -->
        <mxCell id="br-warning" value="&lt;b&gt;Warning&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;計画対応（チケット）&lt;br&gt;〜5日でバジェット枯渇&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="470" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e-warn-yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" source="br-check-warn" target="br-warning" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 通常運用 -->
        <mxCell id="br-normal" value="&lt;b&gt;通常運用&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;アラートなし&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="470" width="130" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e-warn-no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" source="br-check-warn" target="br-normal" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Multi-windowノート -->
        <mxCell id="mw-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Multi-window, Multi-burn-rate&lt;/b&gt;&lt;br&gt;短期窓: 急激な劣化を即座に検知&lt;br&gt;長期窓: 緩やかな劣化を検知&lt;br&gt;両方の条件を AND で評価&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="660" y="560" width="230" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
