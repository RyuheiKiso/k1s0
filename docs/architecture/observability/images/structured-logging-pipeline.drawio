<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="log-pipeline-001" name="構造化ログパイプライン">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: 構造化ログパイプライン -->
        <mxCell id="title" value="&lt;b style=&quot;font-size:20px&quot;&gt;構造化ログパイプライン&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#666&quot;&gt;環境別のログ収集経路とデータストアへの流れ&lt;/font&gt;" style="text;html=1;fontSize=14;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="5" width="600" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== メインフロー: prod/staging ===== -->

        <!-- メインフローラベル -->
        <mxCell id="main-label" value="&lt;b style=&quot;font-size:12px&quot;&gt;staging / prod 環境&lt;/b&gt;" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- メインフロー背景 -->
        <mxCell id="main-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FAFAFA;strokeColor=#CCCCCC;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="85" width="1160" height="200" as="geometry"/>
        </mxCell>

        <!-- Service (ログ生成元) -->
        <mxCell id="service" value="&lt;b style=&quot;font-size:13px&quot;&gt;Service&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Go / Rust / TS / Dart&lt;br&gt;slog / tracing / pino&lt;br&gt;&lt;b&gt;JSON 構造化ログ&lt;/b&gt;&lt;br&gt;→ stdout&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="105" width="150" height="100" as="geometry"/>
        </mxCell>

        <!-- stdout 矢印 -->
        <mxCell id="arrow-stdout" value="&lt;font style=&quot;font-size:10px&quot;&gt;stdout&lt;br&gt;(JSON)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;fontColor=#666;" edge="1" parent="1" source="service" target="promtail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Promtail DaemonSet -->
        <mxCell id="promtail" value="&lt;b style=&quot;font-size:13px&quot;&gt;Promtail&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;DaemonSet&lt;br&gt;ラベル付与&lt;br&gt;(namespace, pod, container)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="280" y="105" width="150" height="100" as="geometry"/>
        </mxCell>

        <!-- Promtail → Loki 矢印 -->
        <mxCell id="arrow-loki" value="&lt;font style=&quot;font-size:10px&quot;&gt;Push API&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;fontColor=#666;" edge="1" parent="1" source="promtail" target="loki">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Loki -->
        <mxCell id="loki" value="&lt;b style=&quot;font-size:13px&quot;&gt;Loki&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ログストレージ&lt;br&gt;ラベルインデックス&lt;br&gt;LogQL クエリ&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;boundedLbl=1;size=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="100" width="150" height="110" as="geometry"/>
        </mxCell>

        <!-- Loki → Grafana 矢印 -->
        <mxCell id="arrow-grafana" value="&lt;font style=&quot;font-size:10px&quot;&gt;LogQL&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6C8EBF;fontColor=#4472C4;" edge="1" parent="1" source="loki" target="grafana">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Grafana -->
        <mxCell id="grafana" value="&lt;b style=&quot;font-size:13px&quot;&gt;Grafana&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ログ可視化&lt;br&gt;ダッシュボード&lt;br&gt;アラートルール&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="760" y="105" width="150" height="100" as="geometry"/>
        </mxCell>

        <!-- ===== 分岐: trace_id → Jaeger ===== -->

        <!-- Jaeger -->
        <mxCell id="jaeger" value="&lt;b style=&quot;font-size:13px&quot;&gt;Jaeger&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;分散トレーシング&lt;br&gt;trace_id で検索&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1000" y="105" width="150" height="100" as="geometry"/>
        </mxCell>

        <!-- Grafana → Jaeger: derivedFields リンク -->
        <mxCell id="arrow-jaeger" value="&lt;font style=&quot;font-size:9px&quot;&gt;derivedFields&lt;br&gt;trace_id → リンク&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#6C8EBF;fontColor=#4472C4;dashed=1;" edge="1" parent="1" source="grafana" target="jaeger">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- trace_id 説明 -->
        <mxCell id="trace-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;ログ内の &lt;b&gt;trace_id&lt;/b&gt; フィールドから&lt;br&gt;Jaeger UI へ直接遷移可能&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF;strokeColor=#6C8EBF;fontSize=9;verticalAlign=middle;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="215" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== dev 環境パス ===== -->

        <!-- dev ラベル -->
        <mxCell id="dev-label" value="&lt;b style=&quot;font-size:12px&quot;&gt;dev 環境&lt;/b&gt;" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="20" y="300" width="150" height="25" as="geometry"/>
        </mxCell>

        <!-- dev 背景 -->
        <mxCell id="dev-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFF9E6;strokeColor=#D6B656;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="325" width="540" height="110" as="geometry"/>
        </mxCell>

        <!-- dev: Service -->
        <mxCell id="dev-service" value="&lt;b&gt;Service&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;text format&lt;/b&gt;&lt;br&gt;人間が読みやすい形式&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="345" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- dev: stdout -->
        <mxCell id="dev-stdout" value="&lt;b&gt;stdout&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ターミナル直接確認&lt;br&gt;docker compose logs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="270" y="345" width="150" height="70" as="geometry"/>
        </mxCell>

        <!-- dev: Service → stdout -->
        <mxCell id="dev-arrow" value="&lt;font style=&quot;font-size:10px&quot;&gt;text&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;fontColor=#B8860B;" edge="1" parent="1" source="dev-service" target="dev-stdout">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- dev: 環境切替注釈 -->
        <mxCell id="dev-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;APP_ENV=dev のとき&lt;br&gt;text format を使用&lt;br&gt;（Loki 連携なし）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF;strokeColor=#D6B656;fontSize=9;verticalAlign=middle;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="350" width="110" height="55" as="geometry"/>
        </mxCell>

        <!-- ===== ログ保持期間テーブル ===== -->

        <!-- 保持期間ラベル -->
        <mxCell id="retention-label" value="&lt;b style=&quot;font-size:12px&quot;&gt;ログ保持期間&lt;/b&gt;" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="600" y="300" width="150" height="25" as="geometry"/>
        </mxCell>

        <!-- 保持期間背景 -->
        <mxCell id="retention-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#F0F4FA;strokeColor=#6C8EBF;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="325" width="580" height="110" as="geometry"/>
        </mxCell>

        <!-- dev: 7日 -->
        <mxCell id="ret-dev" value="&lt;b style=&quot;font-size:12px&quot;&gt;dev&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px;color:#D6B656&quot;&gt;&lt;b&gt;7日&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ローカルのみ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="620" y="340" width="110" height="80" as="geometry"/>
        </mxCell>

        <!-- staging: 30日 -->
        <mxCell id="ret-stg" value="&lt;b style=&quot;font-size:12px&quot;&gt;staging&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px;color:#6C8EBF&quot;&gt;&lt;b&gt;30日&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Loki 保持&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="750" y="340" width="110" height="80" as="geometry"/>
        </mxCell>

        <!-- prod: 90日 -->
        <mxCell id="ret-prod" value="&lt;b style=&quot;font-size:12px&quot;&gt;prod&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px;color:#6C8EBF&quot;&gt;&lt;b&gt;90日&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Loki 保持&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="880" y="340" width="110" height="80" as="geometry"/>
        </mxCell>

        <!-- audit: 1年 -->
        <mxCell id="ret-audit" value="&lt;b style=&quot;font-size:12px&quot;&gt;audit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px;color:#82B366&quot;&gt;&lt;b&gt;1年&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;コンプライアンス&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1010" y="340" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== ログフォーマット例 ===== -->

        <!-- JSON ログ例 -->
        <mxCell id="log-example" value="&lt;font style=&quot;font-size:9px;font-family:monospace&quot;&gt;&lt;b&gt;JSON ログ例 (staging/prod):&lt;/b&gt;&lt;br&gt;{&lt;br&gt;  &quot;level&quot;: &quot;info&quot;,&lt;br&gt;  &quot;msg&quot;: &quot;request completed&quot;,&lt;br&gt;  &quot;trace_id&quot;: &quot;abc123...&quot;,&lt;br&gt;  &quot;span_id&quot;: &quot;def456...&quot;,&lt;br&gt;  &quot;method&quot;: &quot;POST&quot;,&lt;br&gt;  &quot;path&quot;: &quot;/api/v1/orders&quot;,&lt;br&gt;  &quot;status&quot;: 200,&lt;br&gt;  &quot;duration_ms&quot;: 42&lt;br&gt;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="20" y="450" width="260" height="140" as="geometry"/>
        </mxCell>

        <!-- text ログ例 -->
        <mxCell id="text-example" value="&lt;font style=&quot;font-size:9px;font-family:monospace&quot;&gt;&lt;b&gt;text ログ例 (dev):&lt;/b&gt;&lt;br&gt;2024-01-15 10:30:42 INFO&lt;br&gt;  request completed&lt;br&gt;  trace_id=abc123...&lt;br&gt;  method=POST&lt;br&gt;  path=/api/v1/orders&lt;br&gt;  status=200&lt;br&gt;  duration=42ms&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#D6B656;fontSize=9;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="300" y="450" width="260" height="140" as="geometry"/>
        </mxCell>

        <!-- ===== 共通フィールド一覧 ===== -->

        <!-- 共通フィールド -->
        <mxCell id="fields" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;必須フィールド:&lt;/b&gt;&lt;br&gt;* level -- ログレベル (debug/info/warn/error)&lt;br&gt;* msg -- メッセージ本文&lt;br&gt;* trace_id -- 分散トレース ID (W3C Trace Context)&lt;br&gt;* span_id -- スパン ID&lt;br&gt;* service -- サービス名&lt;br&gt;* tenant_id -- テナント識別子 (マルチテナント)&lt;br&gt;* timestamp -- RFC3339 タイムスタンプ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F4FA;strokeColor=#6C8EBF;fontSize=9;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="600" y="450" width="300" height="140" as="geometry"/>
        </mxCell>

        <!-- 環境切替フロー -->
        <mxCell id="env-switch" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;環境による切替ロジック:&lt;/b&gt;&lt;br&gt;APP_ENV=dev → text format, stdout 直出力&lt;br&gt;APP_ENV=staging → JSON, Promtail → Loki&lt;br&gt;APP_ENV=prod → JSON, Promtail → Loki&lt;br&gt;&lt;br&gt;&lt;b&gt;設定:&lt;/b&gt; config-server が環境判定し&lt;br&gt;ログフォーマットを注入&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="920" y="450" width="260" height="140" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>