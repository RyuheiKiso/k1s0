<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="loki-jaeger-linking" name="Loki-Jaegerトレース連携">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="550" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="Loki-Jaeger トレース連携アーキテクチャ" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Application -->
        <mxCell id="app" value="&lt;b&gt;Application&lt;/b&gt;&lt;br&gt;(Go/Rust Server)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- OTel Collector -->
        <mxCell id="otel" value="&lt;b&gt;OpenTelemetry&lt;br&gt;Collector&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="340" y="200" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Loki (ログストレージ) -->
        <mxCell id="loki" value="&lt;b&gt;Grafana Loki&lt;/b&gt;&lt;br&gt;ログストレージ" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="100" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Jaeger (トレースストレージ) -->
        <mxCell id="jaeger" value="&lt;b&gt;Jaeger&lt;/b&gt;&lt;br&gt;トレースストレージ" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="290" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Grafana -->
        <mxCell id="grafana" value="&lt;b&gt;Grafana&lt;/b&gt;&lt;br&gt;統合ダッシュボード" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="860" y="200" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- App → OTel: ログ + トレース -->
        <mxCell id="e1" value="ログ + トレース&lt;br&gt;(OTLP)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#9673A6;fontSize=10;fontStyle=1;" edge="1" source="app" target="otel" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- OTel → Loki: ログ(traceID含む) -->
        <mxCell id="e2" value="ログ&lt;br&gt;(traceID含む)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontStyle=1;" edge="1" source="otel" target="loki" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- OTel → Jaeger: トレース -->
        <mxCell id="e3" value="トレース&lt;br&gt;スパン" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontStyle=1;" edge="1" source="otel" target="jaeger" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Loki → Grafana -->
        <mxCell id="e4" value="LogQL" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;" edge="1" source="loki" target="grafana" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Jaeger → Grafana -->
        <mxCell id="e5" value="Trace API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;" edge="1" source="jaeger" target="grafana" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Loki ↔ Jaeger: traceIDリンク -->
        <mxCell id="link" value="&lt;b&gt;traceID&lt;/b&gt;&lt;br&gt;リンク" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=3;strokeColor=#B85450;fontSize=11;fontStyle=1;dashed=1;dashPattern=8 4;startArrow=classic;endArrow=classic;" edge="1" source="loki" target="jaeger" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- traceID説明ノート -->
        <mxCell id="note" value="&lt;b&gt;traceID連携の仕組み:&lt;/b&gt;&lt;br&gt;1. ログに traceID を自動付与&lt;br&gt;2. Grafana で Loki → Jaeger リンクを設定&lt;br&gt;3. ログからワンクリックでトレース表示&lt;br&gt;4. トレースからログへの逆引きも可能" style="shape=note;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;shadow=1;size=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="260" height="90" as="geometry"/>
        </mxCell>

        <!-- ログフォーマット例 -->
        <mxCell id="format" value="&lt;b&gt;ログフォーマット例:&lt;/b&gt;&lt;br&gt;&lt;code&gt;{&quot;msg&quot;:&quot;...&quot;,&quot;traceID&quot;:&quot;abc123&quot;,&quot;spanID&quot;:&quot;def456&quot;}&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="220" height="50" as="geometry"/>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="440" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg_t" value="凡例:" style="text;html=1;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="448" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="&lt;font color=&quot;#82B366&quot;&gt;───&lt;/font&gt; ログフロー" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="448" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="&lt;font color=&quot;#D6B656&quot;&gt;───&lt;/font&gt; トレースフロー" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="448" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="&lt;font color=&quot;#B85450&quot;&gt;- - -&lt;/font&gt; traceID連携" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="448" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="&lt;font color=&quot;#6C8EBF&quot;&gt;■&lt;/font&gt;App &lt;font color=&quot;#9673A6&quot;&gt;■&lt;/font&gt;OTel &lt;font color=&quot;#82B366&quot;&gt;■&lt;/font&gt;Loki &lt;font color=&quot;#D6B656&quot;&gt;■&lt;/font&gt;Jaeger &lt;font color=&quot;#B85450&quot;&gt;■&lt;/font&gt;Grafana" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="468" width="460" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
