<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="otel-tail-sampling" name="テールベースサンプリング判定フロー">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="650" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="テールベースサンプリング判定フロー" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ルートノード: トレース完了 -->
        <mxCell id="start" value="&lt;b&gt;トレース完了&lt;/b&gt;&lt;br&gt;OTel Collectorで受信" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="330" y="70" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- 判定1: エラーあり？ -->
        <mxCell id="d1" value="エラーあり？" style="rhombus;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="160" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- 結果: 100%サンプリング（エラー） -->
        <mxCell id="r1" value="&lt;b&gt;100% サンプリング&lt;/b&gt;&lt;br&gt;全エラートレースを保持" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="620" y="170" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- 判定2: レイテンシ > しきい値？ -->
        <mxCell id="d2" value="レイテンシ &amp;gt;&lt;br&gt;しきい値？" style="rhombus;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="290" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- 結果: 100%サンプリング（高レイテンシ） -->
        <mxCell id="r2" value="&lt;b&gt;100% サンプリング&lt;/b&gt;&lt;br&gt;高レイテンシを保持" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="620" y="300" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- 判定3: 重要サービス？ -->
        <mxCell id="d3" value="重要サービス？" style="rhombus;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="420" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- 結果: 50%サンプリング -->
        <mxCell id="r3" value="&lt;b&gt;50% サンプリング&lt;/b&gt;&lt;br&gt;重要サービスは高確率" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="620" y="430" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- デフォルト結果: 5%確率的サンプリング -->
        <mxCell id="r4" value="&lt;b&gt;5% 確率的サンプリング&lt;/b&gt;&lt;br&gt;デフォルト保持率" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="330" y="560" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- 接続線 -->
        <mxCell id="e0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#6C8EBF;" edge="1" source="start" target="d1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- d1 → r1 (Yes) -->
        <mxCell id="e1y" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="d1" target="r1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- d1 → d2 (No) -->
        <mxCell id="e1n" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="d1" target="d2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- d2 → r2 (Yes) -->
        <mxCell id="e2y" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="d2" target="r2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- d2 → d3 (No) -->
        <mxCell id="e2n" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="d2" target="d3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- d3 → r3 (Yes) -->
        <mxCell id="e3y" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="d3" target="r3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- d3 → r4 (No) -->
        <mxCell id="e3n" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="d3" target="r4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- しきい値の説明ノート -->
        <mxCell id="note1" value="&lt;b&gt;しきい値:&lt;/b&gt;&lt;br&gt;・P99レイテンシの2倍&lt;br&gt;・サービス毎に設定可能" style="shape=note;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;shadow=1;size=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- 重要サービスの説明ノート -->
        <mxCell id="note2" value="&lt;b&gt;重要サービス:&lt;/b&gt;&lt;br&gt;・auth-server&lt;br&gt;・payment-server&lt;br&gt;・order-server" style="shape=note;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;align=left;shadow=1;size=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="540" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg_t" value="凡例:" style="text;html=1;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="545" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="&lt;font color=&quot;#D6B656&quot;&gt;◇&lt;/font&gt; 判定ノード" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="545" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="&lt;font color=&quot;#B85450&quot;&gt;■&lt;/font&gt; 高保持率" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="545" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="&lt;font color=&quot;#82B366&quot;&gt;■&lt;/font&gt; 低保持率" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="565" width="80" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
