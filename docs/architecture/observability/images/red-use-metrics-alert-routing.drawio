<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="alert-001" name="RED/USEメトリクス分類とアラートルーティング">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="RED / USE メトリクス分類 &amp; アラートルーティングフロー" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 左側: RED / USE メトリクス分類 ===== -->
        <mxCell id="section-metrics" value="メトリクス分類" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- RED メソッド（サービスメトリクス）スイムレーン -->
        <mxCell id="swim-red" value="RED メソッド（サービス）" style="shape=swimlane;startSize=30;rounded=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="100" width="320" height="350" as="geometry"/>
        </mxCell>

        <!-- Rate -->
        <mxCell id="red-r" value="&lt;b&gt;Rate（リクエスト率）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;http_requests_total&lt;br&gt;grpc_server_handled_total&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="swim-red">
          <mxGeometry x="20" y="50" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- Errors -->
        <mxCell id="red-e" value="&lt;b&gt;Errors（エラー率）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;http_requests_total{status=~&quot;5..&quot;}&lt;br&gt;grpc_server_handled_total{code!=&quot;OK&quot;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="swim-red">
          <mxGeometry x="20" y="130" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- Duration -->
        <mxCell id="red-d" value="&lt;b&gt;Duration（レイテンシ）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;http_request_duration_seconds&lt;br&gt;grpc_server_handling_seconds&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="swim-red">
          <mxGeometry x="20" y="210" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- カスタムメトリクスノート -->
        <mxCell id="custom-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;カスタムメトリクス&lt;/b&gt;&lt;br&gt;db_query_duration_seconds&lt;br&gt;kafka_messages_produced_total&lt;br&gt;cache_hits_total / cache_misses_total&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="swim-red">
          <mxGeometry x="30" y="280" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- USE メソッド（インフラメトリクス）スイムレーン -->
        <mxCell id="swim-use" value="USE メソッド（インフラ）" style="shape=swimlane;startSize=30;rounded=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="480" width="320" height="260" as="geometry"/>
        </mxCell>

        <!-- Utilization -->
        <mxCell id="use-u" value="&lt;b&gt;Utilization（使用率）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;container_cpu_usage_seconds_total&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="swim-use">
          <mxGeometry x="20" y="50" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- Saturation -->
        <mxCell id="use-s" value="&lt;b&gt;Saturation（飽和度）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;container_memory_working_set_bytes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="swim-use">
          <mxGeometry x="20" y="120" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- Errors (infra) -->
        <mxCell id="use-e" value="&lt;b&gt;Errors（エラー）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;node_disk_io_time_seconds_total&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="swim-use">
          <mxGeometry x="20" y="190" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== 右側: アラートルーティングフロー ===== -->
        <mxCell id="section-routing" value="アラートルーティングフロー" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="300" height="30" as="geometry"/>
        </mxCell>

        <!-- Prometheus: メトリクス収集 -->
        <mxCell id="prometheus" value="&lt;b&gt;Prometheus&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;メトリクス収集 (15s間隔)&lt;br&gt;Recording Rules で RED 集計&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- アラートルール評価 -->
        <mxCell id="alert-eval" value="&lt;b&gt;アラートルール評価&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="210" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e-prom-eval" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="prometheus" target="alert-eval" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tier別ルール分岐 -->
        <mxCell id="tier-check" value="&lt;b&gt;Tier判定&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="550" y="290" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e-eval-tier" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="alert-eval" target="tier-check" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- system Tier ルール -->
        <mxCell id="sys-rule" value="&lt;b&gt;system Tier&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;error &gt; 0.1%: warning&lt;br&gt;error &gt; 1%: critical&lt;br&gt;P99 &gt; 500ms: warning&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="410" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e-tier-sys" value="system" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;fontSize=9;fontStyle=1;" edge="1" source="tier-check" target="sys-rule" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- business/service Tier ルール -->
        <mxCell id="bizsvc-rule" value="&lt;b&gt;business/service Tier&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;error &gt; 0.2%: warning&lt;br&gt;error &gt; 5%: critical&lt;br&gt;P99 &gt; 1s: warning&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="410" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e-tier-biz" value="business/service" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;fontSize=9;fontStyle=1;" edge="1" source="tier-check" target="bizsvc-rule" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Alertmanager -->
        <mxCell id="alertmanager" value="&lt;b&gt;Alertmanager&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;group_by: alertname, namespace, service&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="530" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-sys-am" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="sys-rule" target="alertmanager" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-biz-am" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="bizsvc-rule" target="alertmanager" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- severity ルーティング分岐 -->
        <mxCell id="sev-check" value="&lt;b&gt;severity?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="555" y="620" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e-am-sev" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="alertmanager" target="sev-check" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- critical 通知先 -->
        <mxCell id="teams-crit" value="&lt;b&gt;Teams Critical&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;repeat: 1h&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#B85450;strokeColor=#6C0000;fontColor=#FFFFFF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="730" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-sev-crit" value="critical" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;fontSize=9;fontStyle=1;fontColor=#B85450;" edge="1" source="sev-check" target="teams-crit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- warning 通知先 -->
        <mxCell id="teams-warn" value="&lt;b&gt;Teams Warning&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;repeat: 4h&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="670" y="730" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-sev-warn" value="warning" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;fontSize=9;fontStyle=1;fontColor=#D6B656;" edge="1" source="sev-check" target="teams-warn" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 環境別抑制ノート -->
        <mxCell id="env-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;環境別アラート抑制&lt;/b&gt;&lt;br&gt;dev: 全無効&lt;br&gt;staging: critical のみ&lt;br&gt;prod: 全有効&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="870" y="620" width="170" height="80" as="geometry"/>
        </mxCell>

        <!-- Grafana: ダッシュボード -->
        <mxCell id="grafana" value="&lt;b&gt;Grafana&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ダッシュボード可視化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFE0B2;strokeColor=#E65100;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="100" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-prom-grafana" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="prometheus" target="grafana" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Grafana ダッシュボード一覧ノート -->
        <mxCell id="dash-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;ダッシュボード構成&lt;/b&gt;&lt;br&gt;Overview: 全サービス RED&lt;br&gt;Service Detail: 個別詳細&lt;br&gt;Infrastructure: USE メトリクス&lt;br&gt;Kafka: スループット・ラグ&lt;br&gt;SLO: バーンレート&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="810" y="170" width="190" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
