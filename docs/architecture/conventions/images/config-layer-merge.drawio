<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="config-001" name="設定レイヤーマージスタックとVault統合フロー">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="Config レイヤーマージスタック &amp; Vault 統合フロー" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 左側: マージスタック ===== -->
        <mxCell id="section-stack" value="設定マージスタック" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="250" height="30" as="geometry"/>
        </mxCell>

        <!-- Layer 1: config.yaml (ベース) -->
        <mxCell id="layer-base" value="&lt;b style=&quot;font-size:14px&quot;&gt;config.yaml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ベース設定（全環境共通のデフォルト値）&lt;br&gt;すべてのキーをデフォルト値付きで定義&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="380" height="70" as="geometry"/>
        </mxCell>

        <!-- 矢印: マージ方向 -->
        <mxCell id="merge-arrow-1" value="マージ（上書き）" style="text;html=1;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="180" y="185" width="120" height="20" as="geometry"/>
        </mxCell>

        <!-- Layer 2: config.{env}.yaml -->
        <mxCell id="layer-env" value="&lt;b style=&quot;font-size:14px&quot;&gt;config.{env}.yaml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;環境別オーバーレイ（差分のみ）&lt;br&gt;development / staging / production&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="380" height="70" as="geometry"/>
        </mxCell>

        <!-- 矢印: マージ方向 -->
        <mxCell id="merge-arrow-2" value="マージ（サーバーのみ）" style="text;html=1;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="170" y="285" width="150" height="20" as="geometry"/>
        </mxCell>

        <!-- Layer 3: Vault シークレット -->
        <mxCell id="layer-vault" value="&lt;b style=&quot;font-size:14px&quot;&gt;Vault シークレット&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;DB パスワード、API キー等&lt;br&gt;Vault Agent Injector 経由で注入&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="380" height="70" as="geometry"/>
        </mxCell>

        <!-- 最終的な設定値 -->
        <mxCell id="final-config" value="&lt;b style=&quot;font-size:14px&quot;&gt;最終設定値&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;アプリケーションが読み取る値&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFE0B2;strokeColor=#E65100;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="420" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-vault-final" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="layer-vault" target="final-config" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- マージルールノート -->
        <mxCell id="merge-rules" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;マージルール&lt;/b&gt;&lt;br&gt;マップ: 再帰マージ&lt;br&gt;配列: 完全置換&lt;br&gt;スカラー: 上書き&lt;br&gt;null: キー削除&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- 責務分離ノート -->
        <mxCell id="sep-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;責務分離&lt;/b&gt;&lt;br&gt;ConfigMap: 非シークレットのみ&lt;br&gt;Vault: シークレットのみ&lt;br&gt;重複キーは Vault 優先 + 警告ログ&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#B85450;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="240" y="500" width="210" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== 右側: Vault統合フロー ===== -->
        <mxCell id="section-vault" value="Kubernetes 上での Vault 統合フロー" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="560" y="60" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- Kubernetes Pod -->
        <mxCell id="pod-bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#F5F5F5;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="560" y="200" width="420" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="pod-label" value="Kubernetes Pod" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="570" y="205" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- ConfigMap Volume -->
        <mxCell id="configmap" value="&lt;b&gt;ConfigMap&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;config.yaml&lt;br&gt;config.{env}.yaml&lt;br&gt;→ /etc/app/&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="240" width="150" height="70" as="geometry"/>
        </mxCell>

        <!-- Vault Agent Injector -->
        <mxCell id="vault-agent" value="&lt;b&gt;Vault Agent&lt;br&gt;Injector&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;シークレット注入&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="340" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- App Container -->
        <mxCell id="app" value="&lt;b&gt;App Container&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;config ローダー&lt;br&gt;ファイルパスを引数で受け取り&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="280" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ConfigMap → App -->
        <mxCell id="e-cm-app" value="volume mount" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;fontSize=9;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="configmap" target="app" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Vault → App -->
        <mxCell id="e-vault-app" value="inject" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;fontSize=9;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="vault-agent" target="app" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 外部 Vault Server -->
        <mxCell id="vault-server" value="&lt;b&gt;HashiCorp Vault&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;シークレット管理&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="110" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-vault-inject" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;" edge="1" source="vault-server" target="vault-agent" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Helm Values -->
        <mxCell id="helm" value="&lt;b&gt;Helm Values&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;args でファイルパス指定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="110" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-helm-app" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;" edge="1" source="helm" target="app" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ファイル構成ノート -->
        <mxCell id="file-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;ファイル構成&lt;/b&gt;&lt;br&gt;config/&lt;br&gt;├── config.yaml&lt;br&gt;├── config.development.yaml&lt;br&gt;├── config.staging.yaml&lt;br&gt;├── config.production.yaml&lt;br&gt;├── config.dev.example.yaml&lt;br&gt;└── config.dev.yaml (.gitignore)&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="560" y="530" width="240" height="140" as="geometry"/>
        </mxCell>

        <!-- 環境変数ポリシーノート -->
        <mxCell id="env-note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;基本原則&lt;/b&gt;&lt;br&gt;① YAML 一元化&lt;br&gt;② ハードコード禁止&lt;br&gt;③ 環境変数直参照禁止&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;（例外: APP_ENV のみ）&lt;br&gt;④ 独自フォーマット禁止&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="830" y="530" width="180" height="110" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
