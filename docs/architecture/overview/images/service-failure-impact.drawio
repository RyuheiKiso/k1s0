        <mxCell id="leg-spof-t" value="SPOF（単一障害点）" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#B85450;align=left;" vertex="1" parent="1">
          <mxGeometry x="1138" y="156" width="200" height="18" as="geometry"/>
        </mxCell>

        <!-- ===== SPOF表示 ===== -->
        <mxCell id="spof-banner" value="⚠ 最大の単一障害点 (SPOF): Keycloak が停止すると全ユーザーのログインが不可になる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B85450;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="55" width="1060" height="35" as="geometry"/>
        </mxCell>

        <!-- ===== SEV1 グループ ===== -->
        <mxCell id="sev1-bg" value="" style="rounded=1;fillColor=#FFEBEE;strokeColor=#B85450;strokeWidth=2;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="20" y="115" width="1360" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="sev1-label" value="SEV 1 — システム全体に影響（全機能停止レベル）" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#B85450;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="120" width="600" height="20" as="geometry"/>
        </mxCell>

        <!-- Keycloak障害 -->
        <mxCell id="f-keycloak" value="&lt;b&gt;Keycloak 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: bff-proxy, auth-server&lt;br&gt;結果: &lt;b&gt;全ユーザーログイン不可&lt;/b&gt;&lt;br&gt;★ SPOF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B85450;strokeColor=#922B21;strokeWidth=3;fontSize=10;fontColor=#FFFFFF;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="190" height="90" as="geometry"/>
        </mxCell>

        <!-- auth_db障害 -->
        <mxCell id="f-auth-db" value="&lt;b&gt;PostgreSQL (auth_db) 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: auth-server&lt;br&gt;結果: 認証履歴・ロール管理不能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B85450;strokeColor=#922B21;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="240" y="150" width="190" height="90" as="geometry"/>
        </mxCell>

        <!-- saga_db障害 -->
        <mxCell id="f-saga-db" value="&lt;b&gt;PostgreSQL (saga_db) 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: saga-server&lt;br&gt;結果: 分散トランザクション停止" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B85450;strokeColor=#922B21;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="450" y="150" width="190" height="90" as="geometry"/>
        </mxCell>

        <!-- Kafka障害 -->
        <mxCell id="f-kafka" value="&lt;b&gt;Kafka 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: auth, config, saga,&lt;br&gt;dlq-manager, task等&lt;br&gt;結果: 非同期処理全停止" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B85450;strokeColor=#922B21;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="660" y="150" width="190" height="90" as="geometry"/>
        </mxCell>

        <!-- auth-server障害 -->
        <mxCell id="f-auth" value="&lt;b&gt;auth-server 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: 全サービス（認証必須EP）&lt;br&gt;結果: 認証・権限チェック不能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B85450;strokeColor=#922B21;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="870" y="150" width="190" height="90" as="geometry"/>
        </mxCell>

        <!-- graphql-gateway障害 -->
        <mxCell id="f-gql" value="&lt;b&gt;graphql-gateway 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: フロントエンド全操作&lt;br&gt;結果: GraphQL API全体停止" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B85450;strokeColor=#922B21;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="1080" y="150" width="210" height="90" as="geometry"/>
        </mxCell>

        <!-- Redis障害（SEV1/2） -->
        <mxCell id="f-redis" value="&lt;b&gt;Redis 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: bff-proxy, ratelimit&lt;br&gt;結果: セッション喪失&lt;br&gt;（SEV1 or SEV2）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D43900;strokeColor=#922B21;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="1300" y="150" width="60" height="90" as="geometry"/>
        </mxCell>

