        <!-- session-server障害 -->
        <mxCell id="f-session" value="&lt;b&gt;session-server 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: graphql-gw, bff-proxy&lt;br&gt;結果: セッション確認不能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8C00;strokeColor=#CC7000;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
