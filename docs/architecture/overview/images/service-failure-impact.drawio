        <mxCell id="f-notify" value="&lt;b&gt;notification-server 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: scheduler, 各サービス&lt;br&gt;結果: 通知送信不能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6B656;strokeColor=#B8962E;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
