        <mxCell id="f-saga" value="&lt;b&gt;saga-server 障害&lt;/b&gt;&lt;br&gt;&lt;hr&gt;影響: task, board, activity&lt;br&gt;結果: 分散Txが宙に浮く" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8C00;strokeColor=#CC7000;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
