      <mxGeometry x="830" y="494" width="60" height="16" as="geometry" />
    </mxCell>

    <!-- r=5%ライン（青）: 最楽観 -->
    <!-- 座標: (0,-3100)→(100,457), (1,-856)→(252,374), (2,1282)→(404,296), (3,3317)→(556,221), (4,5256)→(708,150), (5,7102)→(860,83) -->
    <mxCell id="line5" value="" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#0070c0;strokeWidth=2.5;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="457" as="sourcePoint" />
        <mxPoint x="860" y="83" as="targetPoint" />
        <Array as="points">
          <mxPoint x="252" y="374" />
          <mxPoint x="404" y="296" />
          <mxPoint x="556" y="221" />
          <mxPoint x="708" y="150" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- r=8%ライン（緑）: 標準 -->
    <!-- 座標: (0,-3100)→(100,457), (1,-919)→(252,377), (2,1101)→(404,303), (3,2971)→(556,234), (4,4703)→(708,171), (5,6307)→(860,112) -->
    <mxCell id="line8" value="" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#00AA44;strokeWidth=2.5;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="457" as="sourcePoint" />
        <mxPoint x="860" y="112" as="targetPoint" />
