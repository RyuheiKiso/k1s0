<mxGraphModel pageWidth="900" pageHeight="540" grid="0" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- タイトル: NPV分析でCFO・経営層向けの財務言語で説得力を持たせる -->
    <mxCell id="t1" value="NPV（正味現在価値）分析 — 割引率別の累積キャッシュフロー（5年間）" style="text;html=1;fontSize=15;fontStyle=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="8" width="860" height="24" as="geometry" />
    </mxCell>
    <mxCell id="t2" value="IRR（内部収益率）≈ 71%　　日本企業の標準ハードルレート（8〜12%）を大幅に超過　　全シナリオで5年後NPVは+5,831万円以上" style="text;html=1;fontSize=10;fontColor=#0070c0;fontStyle=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="32" width="860" height="16" as="geometry" />
    </mxCell>

    <!-- チャートエリア: x=100〜860(760px), y=50〜490(440px) -->
    <!-- X軸: Year 0〜5、152px/年 -->
    <!-- Y軸: -4,000万〜+8,000万 (range 12,000万, 440px) -->
    <!-- y(V万) = 343 - V * 0.03667   (0線はy=343) -->

    <!-- グリッド線（横）: Y軸目盛り -->
    <!-- +8000万 → y=83 -->
    <mxCell id="gy8" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#eeeeee;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="83" as="sourcePoint" />
        <mxPoint x="860" y="83" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <!-- +4000万 → y=343-147=196 wait, y(4000) = 343 - 4000*0.03667 = 343 - 147 = 196 -->
    <mxCell id="gy4" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#eeeeee;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="196" as="sourcePoint" />
        <mxPoint x="860" y="196" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <!-- +2000万 → y(2000) = 343 - 2000*0.03667 = 343-73 = 270 -->
    <mxCell id="gy2" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#eeeeee;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="270" as="sourcePoint" />
        <mxPoint x="860" y="270" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <!-- -2000万 → y(−2000) = 343 + 73 = 416 -->
    <mxCell id="gym2" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#eeeeee;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="416" as="sourcePoint" />
        <mxPoint x="860" y="416" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- ゼロライン（黒実線）: y=343 -->
    <mxCell id="zeroline" value="" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="343" as="sourcePoint" />
        <mxPoint x="860" y="343" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="zerolabel" value="NPV = 0" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#333333;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="40" y="335" width="56" height="16" as="geometry" />
    </mxCell>

    <!-- Y軸メモリラベル -->
    <mxCell id="yv8" value="+8,000万" style="text;html=1;fontSize=9;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="28" y="76" width="68" height="14" as="geometry" />
    </mxCell>
    <mxCell id="yv4" value="+4,000万" style="text;html=1;fontSize=9;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="28" y="189" width="68" height="14" as="geometry" />
    </mxCell>
    <mxCell id="yv2" value="+2,000万" style="text;html=1;fontSize=9;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
