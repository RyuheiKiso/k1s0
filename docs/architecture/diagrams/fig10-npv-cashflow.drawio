    <mxCell id="yvm2" value="−2,000万" style="text;html=1;fontSize=9;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="28" y="409" width="68" height="14" as="geometry" />
    </mxCell>

    <!-- X軸ラベル: Year 0〜5 -->
    <mxCell id="x0" value="Year 0&#xa;（初期投資）" style="text;html=1;fontSize=10;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="70" y="494" width="80" height="28" as="geometry" />
    </mxCell>
