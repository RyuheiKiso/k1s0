          <mxPoint x="556" y="234" />
          <mxPoint x="708" y="171" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- r=10%ライン（オレンジ）: 厳しい条件 -->
    <!-- 座標: (0,-3100)→(100,457), (1,-958)→(252,378), (2,990)→(404,307), (3,2760)→(556,242), (4,4369)→(708,183), (5,5832)→(860,129) -->
    <mxCell id="line10" value="" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#d79b00;strokeWidth=2.5;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="457" as="sourcePoint" />
        <mxPoint x="860" y="129" as="targetPoint" />
        <Array as="points">
          <mxPoint x="252" y="378" />
          <mxPoint x="404" y="307" />
          <mxPoint x="556" y="242" />
          <mxPoint x="708" y="183" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- 初期投資点（全ライン共通）: Year0 -3,100万 -->
    <mxCell id="dot0" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
      <mxGeometry x="95" y="452" width="10" height="10" as="geometry" />
    </mxCell>
    <mxCell id="dot0l" value="−3,100万円&#xa;（初期投資）" style="text;html=1;fontSize=9;fontColor=#333333;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="108" y="446" width="90" height="28" as="geometry" />
    </mxCell>

    <!-- 回収完了の注釈: Year 1.3付近でゼロラインと交差 -->
    <mxCell id="breakeven" value="回収完了（約1.3年）" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#0070c0;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="262" y="318" width="130" height="18" as="geometry" />
    </mxCell>
    <!-- 矢印: 回収完了点を指す -->
    <mxCell id="brarr" style="edgeStyle=none;html=1;endArrow=block;endFill=1;strokeColor=#0070c0;fontSize=9;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="318" y="338" as="sourcePoint" />
        <mxPoint x="318" y="344" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- 5年後の最終値ラベル -->
    <mxCell id="end5" value="+7,102万（5%）&#xa;+6,307万（8%）&#xa;+5,832万（10%）" style="text;html=1;fontSize=10;align=left;strokeColor=none;fillColor=none;fontColor=#333333;" vertex="1" parent="1">
