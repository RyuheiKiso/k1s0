<mxGraphModel pageWidth="900" pageHeight="500" grid="0" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- タイトル: 代替案との5年TCO比較で経済的優位性を示す -->
    <mxCell id="t1" value="5年間総所有コスト（TCO）比較 — k1s0 vs 代替選択肢" style="text;html=1;fontSize=15;fontStyle=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="8" width="860" height="24" as="geometry" />
    </mxCell>
    <mxCell id="t2" value="（初期コスト + 5年間のランニングコスト/ライセンス/技術的負債コストの合計）" style="text;html=1;fontSize=10;fontColor=#555555;fontStyle=2;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="32" width="860" height="16" as="geometry" />
    </mxCell>

    <!-- Y軸ラベル: 万円単位で示す -->
    <mxCell id="y0" value="0" style="text;html=1;fontSize=10;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="26" y="402" width="40" height="16" as="geometry" />
    </mxCell>
    <mxCell id="y5000" value="5,000万" style="text;html=1;fontSize=10;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="8" y="279" width="58" height="16" as="geometry" />
    </mxCell>
    <mxCell id="y10000" value="10,000万" style="text;html=1;fontSize=10;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="2" y="156" width="64" height="16" as="geometry" />
    </mxCell>
    <mxCell id="y15000" value="15,000万" style="text;html=1;fontSize=10;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="2" y="54" width="64" height="16" as="geometry" />
    </mxCell>

    <!-- 参考線: チャートエリアはx=80〜860, y=50〜410 -->
    <!-- 高さ360px, 最大15,000万 → 1万円=0.024px -->
    <!-- y(V) = 410 - V * 0.024 -->
    <!-- y=5000万 → 410-120=290, y=10000万 → 410-240=170, y=15000万 → 410-360=50 -->
    <!-- グリッド線 -->
    <mxCell id="g1" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#cccccc;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="80" y="290" as="sourcePoint" />
        <mxPoint x="860" y="290" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="g2" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#cccccc;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="80" y="170" as="sourcePoint" />
        <mxPoint x="860" y="170" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="g3" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#cccccc;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="80" y="50" as="sourcePoint" />
        <mxPoint x="860" y="50" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <!-- ベースライン -->
    <mxCell id="base" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#666666;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="80" y="410" as="sourcePoint" />
        <mxPoint x="860" y="410" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- 各オプションのバー幅: 130px、間隔30px -->
    <!-- バー中心X: 145, 305, 465, 625, 785 → バー左端: 80, 240, 400, 560, 720 -->

    <!-- k1s0（最小TCO・青系）: 初期3,100万=74px + ランニング250万=6px = 3,350万=80px -->
    <!-- ランニング（上部）: y=410-80=330, height=6 → y=330 to y=336 -->
    <mxCell id="k1s0_run" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6da8d8;strokeColor=#1e4d78;" vertex="1" parent="1">
      <mxGeometry x="80" y="330" width="130" height="6" as="geometry" />
    </mxCell>
    <!-- 初期コスト（下部）: y=336, height=74 → y=336 to y=410 -->
    <mxCell id="k1s0_ini" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1e4d78;strokeColor=#1e4d78;" vertex="1" parent="1">
      <mxGeometry x="80" y="336" width="130" height="74" as="geometry" />
    </mxCell>
    <!-- k1s0バー上部の合計ラベル -->
    <mxCell id="k1s0_val" value="3,350万" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#1e4d78;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="80" y="312" width="130" height="18" as="geometry" />
    </mxCell>
    <!-- バーラベル -->
    <mxCell id="k1s0_lbl" value="k1s0&#xa;（推奨）" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#1e4d78;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="80" y="414" width="130" height="30" as="geometry" />
    </mxCell>

    <!-- Backstage（OSS + 運用チーム）: 初期2,000万=48px + 人件費4,000万=96px = 6,000万=144px -->
    <mxCell id="bs_run" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#2d6a2d;" vertex="1" parent="1">
      <mxGeometry x="240" y="266" width="130" height="96" as="geometry" />
    </mxCell>
    <mxCell id="bs_ini" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2d6a2d;strokeColor=#2d6a2d;" vertex="1" parent="1">
      <mxGeometry x="240" y="362" width="130" height="48" as="geometry" />
    </mxCell>
    <mxCell id="bs_val" value="6,000万" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#2d6a2d;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="240" y="248" width="130" height="18" as="geometry" />
    </mxCell>
    <mxCell id="bs_lbl" value="Backstage&#xa;（OSS+運用）" style="text;html=1;fontSize=11;fontColor=#2d6a2d;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="240" y="414" width="130" height="30" as="geometry" />
    </mxCell>

    <!-- 商用IDP（ライセンス型）: 初期500万=12px + ライセンス9,000万=216px = 9,500万=228px -->
    <mxCell id="idb_run" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#7a4700;" vertex="1" parent="1">
      <mxGeometry x="400" y="194" width="130" height="216" as="geometry" />
    </mxCell>
    <mxCell id="idb_ini" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#7a4700;strokeColor=#7a4700;" vertex="1" parent="1">
      <mxGeometry x="400" y="398" width="130" height="12" as="geometry" />
    </mxCell>
    <mxCell id="idb_val" value="9,500万" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#7a4700;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="400" y="176" width="130" height="18" as="geometry" />
    </mxCell>
    <mxCell id="idb_lbl" value="商用IDP&#xa;（ライセンス型）" style="text;html=1;fontSize=11;fontColor=#7a4700;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="400" y="414" width="130" height="30" as="geometry" />
    </mxCell>

    <!-- 自作基盤: 初期8,000万=192px + ランニング5,000万=120px = 13,000万=312px -->
    <mxCell id="cst_run" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8a040;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="560" y="98" width="130" height="120" as="geometry" />
    </mxCell>
    <mxCell id="cst_ini" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b85450;strokeColor=#6a1c1c;" vertex="1" parent="1">
      <mxGeometry x="560" y="218" width="130" height="192" as="geometry" />
    </mxCell>
    <mxCell id="cst_val" value="13,000万" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#6a1c1c;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="560" y="80" width="130" height="18" as="geometry" />
    </mxCell>
    <mxCell id="cst_lbl" value="自作基盤&#xa;（完全内製）" style="text;html=1;fontSize=11;fontColor=#6a1c1c;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="560" y="414" width="130" height="30" as="geometry" />
    </mxCell>

    <!-- 現状維持（技術的負債）: 15,000万=360px -->
    <mxCell id="sqo_bar" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="720" y="50" width="130" height="360" as="geometry" />
    </mxCell>
    <mxCell id="sqo_val" value="15,000万" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#b85450;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="720" y="32" width="130" height="18" as="geometry" />
    </mxCell>
    <mxCell id="sqo_lbl" value="現状維持&#xa;（技術的負債累積）" style="text;html=1;fontSize=11;fontColor=#b85450;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="720" y="414" width="130" height="30" as="geometry" />
    </mxCell>

    <!-- 凡例 -->
    <mxCell id="leg1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1e4d78;strokeColor=#1e4d78;" vertex="1" parent="1">
      <mxGeometry x="100" y="454" width="16" height="12" as="geometry" />
    </mxCell>
    <mxCell id="leg1t" value="初期コスト" style="text;html=1;fontSize=10;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="122" y="452" width="80" height="16" as="geometry" />
    </mxCell>
    <mxCell id="leg2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6da8d8;strokeColor=#1e4d78;" vertex="1" parent="1">
      <mxGeometry x="220" y="454" width="16" height="12" as="geometry" />
    </mxCell>
    <mxCell id="leg2t" value="ランニング/ライセンス/負債コスト（5年）" style="text;html=1;fontSize=10;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="242" y="452" width="240" height="16" as="geometry" />
    </mxCell>

    <!-- k1s0は最安オプションであることを強調する矢印注釈 -->
    <mxCell id="ann" value="k1s0 は最安選択肢。現状維持比 −77%（約11,650万円の節約）" style="text;html=1;fontSize=11;fontColor=#1e4d78;fontStyle=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="478" width="860" height="18" as="geometry" />
    </mxCell>
  </root>
</mxGraphModel>
