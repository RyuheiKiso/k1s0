    <mxCell id="ph_si" value="推奨: 全Phase + 案件展開" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;align=center;" vertex="1" parent="1">
      <mxGeometry x="652" y="518" width="146" height="20" as="geometry" />
