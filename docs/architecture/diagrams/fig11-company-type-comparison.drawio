    <mxCell id="lb_major" value="大手企業&#xa;（100名以上）" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#7a4700;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="460" y="484" width="150" height="30" as="geometry" />
    </mxCell>
    <mxCell id="lb_si" value="SIer&#xa;（複数プロジェクト）" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#5a3a6a;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="650" y="484" width="150" height="30" as="geometry" />
    </mxCell>

    <!-- 推奨フェーズバッジ（最下部） -->
    <mxCell id="ph_sme" value="推奨: Phase 1-2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=center;" vertex="1" parent="1">
      <mxGeometry x="82" y="518" width="146" height="20" as="geometry" />
    </mxCell>
    <mxCell id="ph_large" value="推奨: Phase 1-3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=center;" vertex="1" parent="1">
