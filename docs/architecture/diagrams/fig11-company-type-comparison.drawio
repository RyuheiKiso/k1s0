<mxGraphModel pageWidth="900" pageHeight="562" grid="0" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- タイトル: 企業規模別の経済効果を一目で比較できる棒グラフ -->
    <mxCell id="t1" value="企業規模・業態別 k1s0 年間経済効果と投資回収期間" style="text;html=1;fontSize=15;fontStyle=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="8" width="860" height="24" as="geometry" />
    </mxCell>
    <mxCell id="t2" value="各棒の高さ = 年間経済効果の試算値。企業規模に応じた前提条件の詳細はセクション9を参照" style="text;html=1;fontSize=10;fontColor=#555555;fontStyle=2;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="32" width="860" height="16" as="geometry" />
    </mxCell>

    <!-- Y軸グリッド線: y(V万) = 480 - V*0.05 -->
    <!-- 2,000万 → y=380, 4,000万 → y=280, 6,000万 → y=180, 8,000万 → y=80 -->
    <mxCell id="g1" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#eeeeee;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="62" y="380" as="sourcePoint" />
        <mxPoint x="860" y="380" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="g2" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#eeeeee;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="62" y="280" as="sourcePoint" />
        <mxPoint x="860" y="280" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="g3" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#eeeeee;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="62" y="180" as="sourcePoint" />
        <mxPoint x="860" y="180" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="g4" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#dddddd;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="62" y="80" as="sourcePoint" />
        <mxPoint x="860" y="80" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <!-- ベースライン -->
    <mxCell id="base" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="62" y="480" as="sourcePoint" />
        <mxPoint x="860" y="480" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- Y軸目盛りラベル -->
    <mxCell id="y0" value="0" style="text;html=1;fontSize=9;align=right;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="22" y="474" width="36" height="14" as="geometry" />
