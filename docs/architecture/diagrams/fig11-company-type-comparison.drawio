    </mxCell>

    <!-- 中小企業バー（青）: 年間900万 → height=60px(min), y=420〜480 -->
    <mxCell id="bar_sme" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6da8d8;strokeColor=#1e4d78;" vertex="1" parent="1">
      <mxGeometry x="80" y="420" width="150" height="60" as="geometry" />
