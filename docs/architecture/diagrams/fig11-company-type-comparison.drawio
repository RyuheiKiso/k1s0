      <mxGeometry x="270" y="322" width="150" height="16" as="geometry" />
    </mxCell>

    <!-- 大手企業バー（オレンジ）: 年間7,200万 → height=360px, y=120〜480 -->
    <mxCell id="bar_major" value="約7,200万円/年&#xa;&#xa;回収: 約8ヶ月" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8a040;strokeColor=#7a4700;fontColor=#7a4700;fontSize=12;fontStyle=1;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
      <mxGeometry x="460" y="120" width="150" height="360" as="geometry" />
