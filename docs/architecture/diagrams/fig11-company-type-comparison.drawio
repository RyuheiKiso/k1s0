    <!-- 企業タイプラベル（バー下部） -->
    <mxCell id="lb_sme" value="中小企業&#xa;（5〜15名）" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#1e4d78;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="80" y="484" width="150" height="30" as="geometry" />
