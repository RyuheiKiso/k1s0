    <mxCell id="ph_major" value="推奨: Phase 1-4（全フェーズ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=9;align=center;" vertex="1" parent="1">
