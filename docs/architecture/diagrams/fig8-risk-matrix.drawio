<mxGraphModel pageWidth="800" pageHeight="560" grid="0" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- タイトル: リスク分析で経営層の信頼を高める -->
    <mxCell id="t1" value="k1s0 採用リスクマトリクス — 発生確率 × 影響度による分類" style="text;html=1;fontSize=15;fontStyle=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="8" width="760" height="24" as="geometry" />
    </mxCell>
    <mxCell id="t2" value="全リスクに軽減策あり。高リスク項目（右上）は Phase 1 の段階的アプローチにより回避可能" style="text;html=1;fontSize=10;fontColor=#555555;fontStyle=2;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="20" y="32" width="760" height="16" as="geometry" />
    </mxCell>

    <!-- Y軸ラベル: 影響度 -->
    <mxCell id="yax" value="影響度（高）" style="text;html=1;fontSize=11;fontStyle=1;align=center;strokeColor=none;fillColor=none;rotation=-90;" vertex="1" parent="1">
      <mxGeometry x="-20" y="240" width="120" height="20" as="geometry" />
    </mxCell>
    <mxCell id="yaxl" value="低　　　　　　　↑　　　　　　　高" style="text;html=1;fontSize=10;fontColor=#888888;align=center;strokeColor=none;fillColor=none;rotation=-90;" vertex="1" parent="1">
      <mxGeometry x="8" y="260" width="160" height="14" as="geometry" />
    </mxCell>

    <!-- X軸ラベル: 発生確率 -->
    <mxCell id="xax" value="発生確率:　　低　←　　　　　　　　　　　　　→　高" style="text;html=1;fontSize=10;fontColor=#888888;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="90" y="494" width="620" height="18" as="geometry" />
    </mxCell>
    <mxCell id="xaxl" value="発生確率" style="text;html=1;fontSize=11;fontStyle=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="90" y="514" width="620" height="18" as="geometry" />
    </mxCell>

    <!-- 4象限の背景: 各ゾーンの色でリスクレベルを示す -->
    <!-- 左下: 低確率・低影響（緑=安全） -->
    <mxCell id="q_ll" value="低リスクゾーン" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=60;fontSize=12;fontColor=#2d6a2d;fontStyle=3;align=right;verticalAlign=bottom;spacingRight=6;spacingBottom=4;" vertex="1" parent="1">
      <mxGeometry x="90" y="270" width="300" height="210" as="geometry" />
    </mxCell>
    <!-- 右下: 高確率・低影響（オレンジ=要注意） -->
    <mxCell id="q_hl" value="注意ゾーン" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;opacity=60;fontSize=12;fontColor=#7a4700;fontStyle=3;align=right;verticalAlign=bottom;spacingRight=6;spacingBottom=4;" vertex="1" parent="1">
      <mxGeometry x="390" y="270" width="320" height="210" as="geometry" />
    </mxCell>
    <!-- 左上: 低確率・高影響（黄色=要監視） -->
    <mxCell id="q_lh" value="監視ゾーン" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=60;fontSize=12;fontColor=#7a4700;fontStyle=3;align=right;verticalAlign=bottom;spacingRight=6;spacingBottom=4;" vertex="1" parent="1">
      <mxGeometry x="90" y="60" width="300" height="210" as="geometry" />
    </mxCell>
    <!-- 右上: 高確率・高影響（赤=高リスク） -->
    <mxCell id="q_hh" value="高リスクゾーン&#xa;（優先対応）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;opacity=60;fontSize=12;fontColor=#6a1c1c;fontStyle=3;align=right;verticalAlign=bottom;spacingRight=6;spacingBottom=4;" vertex="1" parent="1">
      <mxGeometry x="390" y="60" width="320" height="210" as="geometry" />
    </mxCell>

    <!-- 軸の区切り線 -->
    <mxCell id="vline" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#666666;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="390" y="60" as="sourcePoint" />
        <mxPoint x="390" y="480" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="hline" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#666666;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="90" y="270" as="sourcePoint" />
        <mxPoint x="710" y="270" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- リスク項目のプロット: 各リスクを楕円で表示 -->
    <!-- 座標計算: x = 90 + (prob%) * 6.2, y = 480 - (impact%) * 4.2 -->

    <!-- R1: 変革への抵抗（高確率70%・高影響80%）→ x=524, y=144 → 高リスクゾーン -->
    <mxCell id="r1" value="変革への&#xa;抵抗" style="ellipse;whiteSpace=wrap;html=1;fillColor=#b85450;fontColor=#ffffff;strokeColor=#6a1c1c;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="494" y="120" width="60" height="50" as="geometry" />
    </mxCell>

    <!-- R2: 移行バグ（高確率55%・高影響68%）→ x=431, y=194 → 高リスクゾーン -->
    <mxCell id="r2" value="移行バグ" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontColor=#6a1c1c;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="411" y="171" width="66" height="44" as="geometry" />
    </mxCell>

    <!-- R3: K8s学習曲線（中確率50%・高影響72%）→ x=400, y=158 → 高リスクゾーン境界 -->
    <mxCell id="r3" value="K8s&#xa;学習曲線" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontColor=#7a4700;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="345" y="136" width="66" height="46" as="geometry" />
    </mxCell>

    <!-- R4: キーパーソン依存（中確率40%・高影響68%）→ x=338, y=194 → 監視ゾーン -->
    <mxCell id="r4" value="キーパーソン&#xa;依存" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontColor=#7a4700;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="280" y="172" width="70" height="46" as="geometry" />
    </mxCell>

    <!-- R5: Rust採用難易度（中確率50%・中影響48%）→ x=400, y=278 → 境界付近 -->
    <mxCell id="r5" value="Rust&#xa;採用難易度" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;fontColor=#7a4700;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="394" y="256" width="70" height="46" as="geometry" />
    </mxCell>

    <!-- R6: ROI遅延（低確率25%・中影響52%）→ x=245, y=262 → 監視ゾーン -->
    <mxCell id="r6" value="ROI&#xa;遅延" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontColor=#2d6a2d;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="218" y="240" width="60" height="46" as="geometry" />
    </mxCell>

    <!-- R7: ベンダーロックイン（低確率18%・低影響22%）→ x=202, y=388 → 低リスクゾーン -->
    <mxCell id="r7" value="ベンダー&#xa;ロックイン" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontColor=#2d6a2d;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="173" y="366" width="70" height="46" as="geometry" />
    </mxCell>

    <!-- 軽減策の注釈: 高リスク項目への対応策 -->
    <mxCell id="mit1" value="【軽減策】変革への抵抗: Phase 1はゼロアーキテクチャ変更。CLI+DevContainerのみ → 抵抗なし" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
      <mxGeometry x="90" y="534" width="620" height="18" as="geometry" />
    </mxCell>
  </root>
</mxGraphModel>
