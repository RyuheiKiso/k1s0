<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="schema-ver-001" name="スキーマバージョン同期ルール">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: スキーマバージョン同期ルール -->
        <mxCell id="title" value="スキーマバージョン同期ルール" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- 中央: 同期の核（vN） -->
        <mxCell id="version-core" value="&lt;b style=&quot;font-size:20px&quot;&gt;vN&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;スキーマメジャーバージョン&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fontSize=14;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="280" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- 要素1: Kafka トピック名 -->
        <mxCell id="kafka-topic" value="&lt;b&gt;Kafka トピック名&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;k1s0.service.task.created.&lt;b&gt;v1&lt;/b&gt;&lt;/font&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="100" width="250" height="60" as="geometry"/>
        </mxCell>
        <!-- トピック補足 -->
        <mxCell id="kafka-detail" value="トピック末尾の .vN が&lt;br&gt;メジャーバージョンを示す" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="160" y="165" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- 要素2: Proto パッケージ -->
        <mxCell id="proto-pkg" value="&lt;b&gt;Proto パッケージ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;package k1s0.event.service.task.&lt;b&gt;v1&lt;/b&gt;;&lt;br&gt;ディレクトリ: .../&lt;b&gt;v1&lt;/b&gt;/&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="100" width="280" height="70" as="geometry"/>
        </mxCell>
        <!-- Proto補足 -->
        <mxCell id="proto-detail" value="パッケージ名とディレクトリ名の&lt;br&gt;メジャーバージョンを一致させる" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="740" y="175" width="240" height="30" as="geometry"/>
        </mxCell>

        <!-- 要素3: Schema Registry -->
        <mxCell id="schema-reg" value="&lt;b&gt;Schema Registry Subject&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;EventMetadata.schema_version = &lt;b&gt;N&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="500" width="300" height="60" as="geometry"/>
        </mxCell>
        <!-- Registry補足 -->
        <mxCell id="schema-detail" value="EventMetadata の整数値 N が&lt;br&gt;上記2つと同期" style="text;html=1;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="435" y="565" width="230" height="30" as="geometry"/>
        </mxCell>

        <!-- 同期矢印: Kafka ↔ vN -->
        <mxCell id="sync1" value="同期" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=3;fontSize=11;fontStyle=1;fontColor=#D6B656;endArrow=block;endFill=1;startArrow=block;startFill=1;" edge="1" source="kafka-topic" target="version-core" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 同期矢印: Proto ↔ vN -->
        <mxCell id="sync2" value="同期" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=3;fontSize=11;fontStyle=1;fontColor=#6C8EBF;endArrow=block;endFill=1;startArrow=block;startFill=1;" edge="1" source="proto-pkg" target="version-core" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 同期矢印: Schema Registry ↔ vN -->
        <mxCell id="sync3" value="同期" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=3;fontSize=11;fontStyle=1;fontColor=#82B366;endArrow=block;endFill=1;startArrow=block;startFill=1;" edge="1" source="schema-reg" target="version-core" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- v2移行例 -->
        <mxCell id="migration-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#B85450;dashed=1;dashPattern=8 4;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="620" width="1160" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="migration-title" value="v2 移行時の同期例" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#B85450;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="625" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- v1（現行） -->
        <mxCell id="v1-topic" value="k1s0.service.task.created.&lt;b&gt;v1&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="40" y="665" width="230" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="v1-proto" value="package ...task.&lt;b&gt;v1&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="40" y="695" width="230" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="v1-schema" value="schema_version = &lt;b&gt;1&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="40" y="725" width="230" height="25" as="geometry"/>
        </mxCell>

        <!-- 矢印 -->
        <mxCell id="mig-arrow" value="メジャー変更時" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;fontSize=10;fontColor=#B85450;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="280" y="710" as="sourcePoint"/>
            <mxPoint x="440" y="710" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- v2（移行後） -->
        <mxCell id="v2-topic" value="k1s0.service.task.created.&lt;b&gt;v2&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="450" y="665" width="230" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="v2-proto" value="package ...task.&lt;b&gt;v2&lt;/b&gt;  dir: .../&lt;b&gt;v2&lt;/b&gt;/" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="450" y="695" width="230" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="v2-schema" value="schema_version = &lt;b&gt;2&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="450" y="725" width="230" height="25" as="geometry"/>
        </mxCell>

        <!-- 結果説明 -->
        <mxCell id="result-note" value="&lt;b&gt;結果&lt;/b&gt;: 3要素が分岐せず一貫した運用が可能&lt;br&gt;トピック名・Proto パッケージ・Schema Registry Subject が&lt;br&gt;常に同じ vN を参照する" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;shadow=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="730" y="670" width="280" height="70" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
