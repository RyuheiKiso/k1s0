        <!-- Kafkaトピック: 在庫引当完了イベント -->
        <mxCell id="t2" value="k1s0.service.board&lt;br&gt;.card_created.v1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;" vertex="1" parent="lane-normal">
