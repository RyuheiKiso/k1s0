<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="saga-flow-001" name="Saga パターンフロー">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: Sagaパターンフロー図 -->
        <mxCell id="title" value="Saga パターンフロー" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="500" y="10" width="400" height="40" as="geometry"/>
