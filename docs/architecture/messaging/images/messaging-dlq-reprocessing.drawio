<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="dlq-reprocess-001" name="DLQ 再処理フロー">
    <mxGraphModel dx="1200" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: DLQ再処理フロー図 -->
        <mxCell id="title" value="DLQ 再処理フロー" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- メインフローセクションラベル -->
        <mxCell id="section1" value="メッセージ処理フロー" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="30" y="55" width="200" height="20" as="geometry"/>
        </mxCell>

        <!-- メインキュー: Kafka Topicシリンダー -->
        <mxCell id="main-topic" value="Kafka Topic&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;メインキュー&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontSize=12;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- Consumer: メッセージ消費コンポーネント -->
        <mxCell id="consumer" value="Consumer" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="220" y="100" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- 判定ダイヤモンド: 処理成功か失敗かの分岐 -->
        <mxCell id="decision1" value="処理成功?" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="85" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- 処理完了: 成功時のOffset Commit -->
        <mxCell id="success" value="処理完了&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Offset Commit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="580" y="60" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- リトライ: 失敗時の再試行処理 -->
        <mxCell id="retry" value="リトライ" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFE0B2;strokeColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="420" y="210" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- 判定ダイヤモンド: 最大リトライ回数超過の分岐 -->
        <mxCell id="decision2" value="最大リトライ&lt;br&gt;超過?" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="190" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- DLQ Topic: デッドレターキュー -->
        <mxCell id="dlq-topic" value="DLQ Topic&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;.dlq サフィックス&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- メインフロー矢印: Topic→Consumer -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;" edge="1" source="main-topic" target="consumer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- メインフロー矢印: Consumer→判定 -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;" edge="1" source="consumer" target="decision1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 成功パス矢印: 判定→処理完了 -->
        <mxCell id="e3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" source="decision1" target="success" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 失敗パス矢印: 判定→リトライ -->
        <mxCell id="e4" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;fontSize=10;fontColor=#B85450;" edge="1" source="decision1" target="retry" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- リトライ→リトライ回数判定 -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;" edge="1" source="retry" target="decision2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- リトライ回数未超過: Consumerへ戻るループ -->
        <mxCell id="e6" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;fontSize=10;fontColor=#E65100;" edge="1" source="decision2" target="consumer" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="125"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- リトライ回数超過: DLQへ送信 -->
        <mxCell id="e7" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;fontSize=10;fontColor=#B85450;" edge="1" source="decision2" target="dlq-topic" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DLQ再処理セクションラベル -->
        <mxCell id="section2" value="DLQ 再処理" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="580" y="215" width="150" height="20" as="geometry"/>
        </mxCell>

        <!-- 管理API: DLQメッセージの管理インターフェース -->
        <mxCell id="admin-api" value="管理API&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(Admin API)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E1D5E7;strokeColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="600" y="250" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- 判定ダイヤモンド: 再処理か破棄かの分岐 -->
        <mxCell id="decision3" value="再処理&lt;br&gt;or 破棄?" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="240" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- メインキューへの再投入 -->
        <mxCell id="reprocess" value="メインキュー&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;に再投入&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="960" y="200" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- アーカイブ: 破棄時のログ記録 -->
        <mxCell id="archive" value="アーカイブ&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ログ記録&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="960" y="290" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- DLQ→管理API -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;" edge="1" source="dlq-topic" target="admin-api" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="100" y="370"/>
              <mxPoint x="560" y="370"/>
              <mxPoint x="560" y="275"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 管理API→判定 -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;" edge="1" source="admin-api" target="decision3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 再処理パス: メインキューへ再投入 -->
        <mxCell id="e10" value="再処理" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" source="decision3" target="reprocess" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 破棄パス: アーカイブへ -->
        <mxCell id="e11" value="破棄" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;fontSize=10;fontColor=#666666;" edge="1" source="decision3" target="archive" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 再投入からメインキューへの戻り矢印 -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;dashed=1;dashPattern=8 4;" edge="1" source="reprocess" target="main-topic" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1100" y="225"/>
              <mxPoint x="1100" y="30"/>
              <mxPoint x="100" y="30"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- リトライ設定の注釈ノート -->
        <mxCell id="note" value="リトライ設定:&lt;br&gt;最大3回&lt;br&gt;バックオフ: 指数関数&lt;br&gt;初期間隔: 1秒" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fontSize=10;fillColor=#F5F5F5;strokeColor=#666666;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="540" y="140" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- 注釈ノートからリトライへの接続（破線） -->
        <mxCell id="note-link" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;dashed=1;dashPattern=4 4;" edge="1" source="note" target="retry" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
