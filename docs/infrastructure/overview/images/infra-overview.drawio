<mxfile host="draw.io">
  <diagram name="Infrastructure Overview" id="infra-overview">
    <mxGraphModel dx="900" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Outer container: on-premises data center -->
        <mxCell id="dc" value="オンプレミス データセンター" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;rounded=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="20" y="20" width="800" height="500" as="geometry"/>
        </mxCell>

        <!-- dev cluster -->
        <mxCell id="dev" value="dev クラスタ (Kubernetes)" style="swimlane;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="dc" connectable="0">
          <mxGeometry x="20" y="50" width="230" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="dev-master" value="Master x1" style="text;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="dev">
          <mxGeometry x="10" y="36" width="200" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="dev-worker" value="Worker x2" style="text;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="dev">
          <mxGeometry x="10" y="64" width="200" height="24" as="geometry"/>
        </mxCell>

        <!-- staging cluster -->
        <mxCell id="stg" value="staging クラスタ (Kubernetes)" style="swimlane;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="dc" connectable="0">
          <mxGeometry x="280" y="50" width="230" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="stg-master" value="Master x1" style="text;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="stg">
          <mxGeometry x="10" y="36" width="200" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="stg-worker" value="Worker x3" style="text;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="stg">
          <mxGeometry x="10" y="64" width="200" height="24" as="geometry"/>
        </mxCell>

        <!-- prod cluster -->
        <mxCell id="prod" value="prod クラスタ (Kubernetes)" style="swimlane;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="dc" connectable="0">
          <mxGeometry x="540" y="50" width="230" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="prod-master" value="Master x3" style="text;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="prod">
          <mxGeometry x="10" y="36" width="200" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="prod-worker" value="Worker x5+" style="text;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="prod">
          <mxGeometry x="10" y="64" width="200" height="24" as="geometry"/>
        </mxCell>

        <!-- Shared services group -->
        <mxCell id="shared" value="共有サービス" style="swimlane;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="dc" connectable="0">
          <mxGeometry x="20" y="240" width="370" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="svc-consul" value="Consul" style="text;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="shared">
          <mxGeometry x="10" y="36" width="340" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="svc-consul-desc" value="Terraform State 管理" style="text;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;fillColor=none;strokeColor=none;spacingLeft=28;" vertex="1" parent="shared">
          <mxGeometry x="10" y="58" width="340" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="svc-git" value="GitLab / GitHub Enterprise" style="text;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="shared">
          <mxGeometry x="10" y="86" width="340" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="svc-git-desc" value="ソースコード管理" style="text;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;fillColor=none;strokeColor=none;spacingLeft=28;" vertex="1" parent="shared">
          <mxGeometry x="10" y="108" width="340" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="svc-ceph" value="Ceph" style="text;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="shared">
          <mxGeometry x="10" y="136" width="340" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="svc-ceph-desc" value="分散ストレージ" style="text;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;fillColor=none;strokeColor=none;spacingLeft=28;" vertex="1" parent="shared">
          <mxGeometry x="10" y="158" width="340" height="20" as="geometry"/>
        </mxCell>

        <!-- Kubernetes in-cluster services group -->
        <mxCell id="k8s-svc" value="Kubernetes クラスタ内サービス" style="swimlane;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="dc" connectable="0">
          <mxGeometry x="410" y="240" width="360" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="svc-vault" value="Vault" style="text;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="k8s-svc">
          <mxGeometry x="10" y="36" width="330" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="svc-vault-desc" value="シークレット管理 — k1s0-system Namespace" style="text;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;fillColor=none;strokeColor=none;spacingLeft=28;" vertex="1" parent="k8s-svc">
          <mxGeometry x="10" y="58" width="330" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="svc-keycloak" value="Keycloak" style="text;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="k8s-svc">
          <mxGeometry x="10" y="86" width="330" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="svc-keycloak-desc" value="認証基盤 — k1s0-system Namespace" style="text;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;fillColor=none;strokeColor=none;spacingLeft=28;" vertex="1" parent="k8s-svc">
          <mxGeometry x="10" y="108" width="330" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="svc-harbor" value="Harbor" style="text;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fillColor=none;strokeColor=none;spacingLeft=8;" vertex="1" parent="k8s-svc">
          <mxGeometry x="10" y="136" width="330" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="svc-harbor-desc" value="コンテナレジストリ — harbor Namespace" style="text;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;fillColor=none;strokeColor=none;spacingLeft=28;" vertex="1" parent="k8s-svc">
          <mxGeometry x="10" y="158" width="330" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
