<mxfile host="draw.io">
  <diagram name="App Distribution Architecture" id="app-dist-arch">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="アプリ配布基盤 全体アーキテクチャ" style="text;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- User Layer -->
        <mxCell id="user-layer" value="ユーザー層" style="swimlane;startSize=28;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;rounded=1;pointerEvents=0;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="40" y="60" width="1120" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="user-browser" value="ブラウザ&#xa;(App Catalog)" style="shape=mxgraph.basic.rounded_frame;whiteSpace=wrap;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="user-layer">
          <mxGeometry x="120" y="36" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="user-desktop" value="デスクトップアプリ&#xa;(自動更新クライアント)" style="shape=mxgraph.basic.rounded_frame;whiteSpace=wrap;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="user-layer">
          <mxGeometry x="480" y="36" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="user-admin" value="管理者&#xa;(GitHub Actions)" style="shape=mxgraph.basic.rounded_frame;whiteSpace=wrap;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="user-layer">
          <mxGeometry x="860" y="36" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Application Layer -->
        <mxCell id="app-layer" value="アプリケーション層 (Kubernetes)" style="swimlane;startSize=28;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;rounded=1;pointerEvents=0;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="40" y="200" width="1120" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="catalog-ui" value="App Catalog UI&#xa;(React SPA)" style="rounded=1;whiteSpace=wrap;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="app-layer">
          <mxGeometry x="60" y="50" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="catalog-desc" value="- アプリ一覧・検索・フィルタ&#xa;- バージョン履歴表示&#xa;- ダウンロードリンク生成&#xa;- インストール手順表示" style="text;align=left;verticalAlign=top;fontSize=10;fillColor=none;strokeColor=none;spacingLeft=4;" vertex="1" parent="app-layer">
          <mxGeometry x="60" y="116" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="registry-server" value="App Registry Server&#xa;(Rust)" style="rounded=1;whiteSpace=wrap;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="app-layer">
          <mxGeometry x="380" y="50" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="registry-desc" value="- メタデータ CRUD API&#xa;- Presigned URL 生成&#xa;- バージョンチェック API&#xa;- RBAC 認可" style="text;align=left;verticalAlign=top;fontSize=10;fillColor=none;strokeColor=none;spacingLeft=4;" vertex="1" parent="app-layer">
          <mxGeometry x="380" y="116" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="keycloak" value="Keycloak&#xa;(認証・認可)" style="rounded=1;whiteSpace=wrap;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="app-layer">
          <mxGeometry x="700" y="50" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="bff" value="BFF Proxy" style="rounded=1;whiteSpace=wrap;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="app-layer">
          <mxGeometry x="920" y="50" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Storage Layer -->
        <mxCell id="storage-layer" value="ストレージ層" style="swimlane;startSize=28;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;rounded=1;pointerEvents=0;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="40" y="440" width="1120" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="ceph-rgw" value="PersistentVolume (PV)&#xa;(ローカルFS)" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=10;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="storage-layer">
          <mxGeometry x="80" y="46" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="ceph-desc" value="アプリバイナリ保存&#xa;(exe / dmg / AppImage)&#xa;AWS/S3依存なし" style="text;align=left;verticalAlign=top;fontSize=10;fillColor=none;strokeColor=none;spacingLeft=4;" vertex="1" parent="storage-layer">
          <mxGeometry x="80" y="130" width="180" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="harbor" value="Harbor&#xa;(OCI Registry)" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=10;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="storage-layer">
          <mxGeometry x="380" y="46" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="harbor-desc" value="Docker イメージ管理&#xa;脆弱性スキャン (Trivy)" style="text;align=left;verticalAlign=top;fontSize=10;fillColor=none;strokeColor=none;spacingLeft=4;" vertex="1" parent="storage-layer">
          <mxGeometry x="380" y="130" width="180" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="postgres" value="PostgreSQL&#xa;(メタデータDB)" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=10;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="storage-layer">
          <mxGeometry x="680" y="46" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="postgres-desc" value="アプリ情報・バージョン・&#xa;ダウンロード統計" style="text;align=left;verticalAlign=top;fontSize=10;fillColor=none;strokeColor=none;spacingLeft=4;" vertex="1" parent="storage-layer">
          <mxGeometry x="680" y="130" width="180" height="36" as="geometry"/>
        </mxCell>

        <!-- CI/CD box -->
        <mxCell id="cicd-layer" value="CI/CD" style="swimlane;startSize=28;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;rounded=1;pointerEvents=0;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="40" y="660" width="1120" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="gh-actions" value="GitHub Actions" style="rounded=1;whiteSpace=wrap;fontSize=12;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="cicd-layer">
          <mxGeometry x="140" y="36" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="cosign" value="Cosign&#xa;(署名)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="cicd-layer">
          <mxGeometry x="420" y="36" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="trivy" value="Trivy&#xa;(脆弱性スキャン)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="cicd-layer">
          <mxGeometry x="660" y="36" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- Edges: User to App layer -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;exitX=0.5;exitY=1;entryX=0.3;entryY=0;" edge="1" parent="1" source="user-browser" target="app-layer">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="user-desktop" target="app-layer">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edges: App layer to Storage layer -->
        <mxCell id="e3" value="Presigned URL" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;fontSize=10;" edge="1" parent="1" source="registry-server" target="storage-layer">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="420"/>
              <mxPoint x="210" y="420"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" value="メタデータ R/W" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontSize=10;" edge="1" parent="1" source="registry-server" target="postgres">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="430"/>
              <mxPoint x="810" y="430"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Edges: Catalog to Registry -->
        <mxCell id="e5" value="REST API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=10;" edge="1" parent="1" source="catalog-ui" target="registry-server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edges: Auth -->
        <mxCell id="e6" value="OIDC" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1;strokeColor=#d6b656;dashed=1;fontSize=10;" edge="1" parent="1" source="registry-server" target="keycloak">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edges: CI/CD to Storage -->
        <mxCell id="e7" value="バイナリ Upload" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="gh-actions" target="ceph-rgw">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="260" y="640"/>
              <mxPoint x="210" y="640"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e8" value="メタデータ登録" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;fontSize=10;" edge="1" parent="1" source="gh-actions" target="registry-server">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="260" y="640"/>
              <mxPoint x="520" y="640"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
