<mxfile host="draw.io">
  <diagram name="CI/CD Publish Pipeline" id="cicd-pipeline">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="CI/CD パブリッシュパイプライン" style="text;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- Trigger -->
        <mxCell id="trigger" value="Git Tag Push&#xa;(v1.0.0)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;fontSize=12;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;size=0.2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Pipeline container -->
        <mxCell id="pipeline" value="GitHub Actions ワークフロー" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;rounded=1;pointerEvents=0;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="40" y="180" width="1120" height="480" as="geometry"/>
        </mxCell>

        <!-- Stage 1: Build -->
        <mxCell id="stage1" value="1. ビルド" style="swimlane;startSize=24;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="pipeline" connectable="0">
          <mxGeometry x="20" y="50" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s1-checkout" value="ソースコード checkout" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="stage1">
          <mxGeometry x="20" y="34" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s1-deps" value="flutter pub get" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="stage1">
          <mxGeometry x="20" y="76" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s1-build" value="flutter build (windows/linux/macos)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="stage1">
          <mxGeometry x="20" y="118" width="200" height="34" as="geometry"/>
        </mxCell>

        <!-- Stage 2: Test & Scan -->
        <mxCell id="stage2" value="2. テスト・スキャン" style="swimlane;startSize=24;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="pipeline" connectable="0">
          <mxGeometry x="300" y="50" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s2-test" value="flutter test" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="stage2">
          <mxGeometry x="20" y="34" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s2-analyze" value="dart analyze (静的解析)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="stage2">
          <mxGeometry x="20" y="76" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s2-scan" value="Trivy バイナリスキャン" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="stage2">
          <mxGeometry x="20" y="118" width="200" height="34" as="geometry"/>
        </mxCell>

        <!-- Stage 3: Sign -->
        <mxCell id="stage3" value="3. 署名" style="swimlane;startSize=24;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="pipeline" connectable="0">
          <mxGeometry x="580" y="50" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s3-hash" value="SHA-256 チェックサム生成" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="stage3">
          <mxGeometry x="20" y="34" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s3-sign" value="Cosign 署名 (Keyless)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="stage3">
          <mxGeometry x="20" y="76" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s3-sbom" value="SBOM 生成 (CycloneDX)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="stage3">
          <mxGeometry x="20" y="118" width="200" height="34" as="geometry"/>
        </mxCell>

        <!-- Stage 4: Publish -->
        <mxCell id="stage4" value="4. パブリッシュ" style="swimlane;startSize=24;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="pipeline" connectable="0">
          <mxGeometry x="860" y="50" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s4-upload" value="Ceph RGW へバイナリ Upload" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="stage4">
          <mxGeometry x="20" y="34" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s4-meta" value="App Registry にメタデータ登録" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="stage4">
          <mxGeometry x="20" y="76" width="200" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="s4-notify" value="更新通知送信 (Webhook)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="stage4">
          <mxGeometry x="20" y="118" width="200" height="34" as="geometry"/>
        </mxCell>

        <!-- Stage arrows -->
        <mxCell id="sa1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;entryX=0;entryY=0.5;" edge="1" parent="pipeline" source="stage1" target="stage2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;" edge="1" parent="pipeline" source="stage2" target="stage3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;" edge="1" parent="pipeline" source="stage3" target="stage4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Artifact matrix -->
        <mxCell id="matrix" value="ビルドマトリクス" style="swimlane;startSize=24;fillColor=#f5f5f5;strokeColor=#999999;fontStyle=1;fontSize=12;rounded=1;pointerEvents=0;" vertex="1" parent="pipeline" connectable="0">
          <mxGeometry x="20" y="270" width="1080" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="m-win" value="Windows&#xa;(exe + MSIX)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#E6E6E6;strokeColor=#999999;fontStyle=1;" vertex="1" parent="matrix">
          <mxGeometry x="40" y="34" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="m-linux" value="Linux&#xa;(AppImage + tar.gz)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#E6E6E6;strokeColor=#999999;fontStyle=1;" vertex="1" parent="matrix">
          <mxGeometry x="260" y="34" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="m-macos" value="macOS&#xa;(dmg + pkg)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#E6E6E6;strokeColor=#999999;fontStyle=1;" vertex="1" parent="matrix">
          <mxGeometry x="480" y="34" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="m-web" value="Web&#xa;(Docker Image)" style="rounded=1;whiteSpace=wrap;fontSize=11;fillColor=#E6E6E6;strokeColor=#999999;fontStyle=1;" vertex="1" parent="matrix">
          <mxGeometry x="700" y="34" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Trigger arrow -->
        <mxCell id="ta" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;" edge="1" parent="1" source="trigger" target="pipeline">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
