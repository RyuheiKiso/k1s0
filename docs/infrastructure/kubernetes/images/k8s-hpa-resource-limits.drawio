<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="hpa-resource-001" name="HPA・リソース制限 環境別比較">
    <mxGraphModel dx="1200" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
