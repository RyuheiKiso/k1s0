        <mxCell id="tier-label-business" value="&lt;font color=&quot;#82B366&quot;&gt;Business Tier&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=0;" vertex="1" parent="1">
