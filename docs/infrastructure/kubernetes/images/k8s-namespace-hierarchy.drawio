          <mxGeometry x="0.3" relative="1" as="geometry"/>
        </mxCell>

        <!-- DENY: ingress方向への逆流を禁止するポリシー -->
        <mxCell id="deny-arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;dashed=1;fontSize=10;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=1;entryDx=0;entryDy=0;" edge="1" source="ns-service" target="ns-ingress" parent="1">
          <mxGeometry relative="1" as="geometry"/>
