        <mxCell id="arrow-obs-service" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=1;dashed=1;fontSize=10;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" edge="1" source="ns-observability" target="ns-service" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="123"/>
              <mxPoint x="720" y="238"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-obs-service-label" value="metrics scrape" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#6C8EBF;" vertex="1" connectable="0" parent="arrow-obs-service">
          <mxGeometry x="0.3" relative="1" as="geometry"/>
