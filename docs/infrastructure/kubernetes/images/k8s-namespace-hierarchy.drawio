        <!-- 注記: Kubernetesラベル規約 -->
        <mxCell id="bottom-note" value="ラベル規約: app.kubernetes.io/name, tier, domain" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="620" width="400" height="25" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
