        <mxCell id="arrow-obs-business" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=1;dashed=1;fontSize=10;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" edge="1" source="ns-observability" target="ns-business" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="140"/>
              <mxPoint x="700" y="388"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-obs-business-label" value="metrics scrape" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#6C8EBF;" vertex="1" connectable="0" parent="arrow-obs-business">
          <mxGeometry x="0.3" relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow-obs-system" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=1;dashed=1;fontSize=10;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" edge="1" source="ns-observability" target="ns-system" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="140"/>
              <mxPoint x="680" y="538"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-obs-system-label" value="metrics scrape" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#6C8EBF;" vertex="1" connectable="0" parent="arrow-obs-system">
          <mxGeometry x="0.5" relative="1" as="geometry"/>
        </mxCell>

        <!-- 全Tier → messaging: Kafkaによるイベント駆動通信 -->
        <mxCell id="arrow-service-msg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;fontSize=10;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ns-service" target="ns-messaging" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
