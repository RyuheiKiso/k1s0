        <mxCell id="arrow-business-msg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" edge="1" source="ns-business" target="ns-messaging" parent="1">
          <mxGeometry relative="1" as="geometry">
