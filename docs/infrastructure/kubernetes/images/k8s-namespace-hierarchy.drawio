        <mxCell id="arrow-business-system-label" value="ALLOW" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#82B366;fontStyle=1;" vertex="1" connectable="0" parent="arrow-business-system">
          <mxGeometry x="0.1" relative="1" as="geometry">
            <mxPoint x="15" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- k1s0-service → k1s0-system: サービス層から直接システム層への呼び出しを許可（認証等） -->
        <mxCell id="arrow-service-system" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;fontColor=#82B366;fontSize=10;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" source="ns-service" target="ns-system" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="410" y="310"/>
              <mxPoint x="260" y="310"/>
              <mxPoint x="260" y="510"/>
              <mxPoint x="410" y="510"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-service-system-label" value="ALLOW" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#82B366;fontStyle=1;" vertex="1" connectable="0" parent="arrow-service-system">
          <mxGeometry x="0.5" relative="1" as="geometry">
            <mxPoint x="-20" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- observability → 全Tier: メトリクス収集のためのスクレイピング通信 -->
        <mxCell id="arrow-obs-ingress" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=1;dashed=1;fontSize=10;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ns-observability" target="ns-ingress" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-obs-ingress-label" value="metrics scrape" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#6C8EBF;" vertex="1" connectable="0" parent="arrow-obs-ingress">
          <mxGeometry x="0.2" relative="1" as="geometry"/>
