        <mxCell id="tier-label-system" value="&lt;font color=&quot;#9673A6&quot;&gt;System Tier&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="140" y="540" width="120" height="30" as="geometry"/>
