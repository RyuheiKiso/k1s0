<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="canary-stages-001" name="カナリアリリース段階（Flagger）">
    <mxGraphModel dx="1400" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: カナリアリリースの段階的ロールアウト全体図 -->
        <mxCell id="title" value="カナリアリリース段階（Flagger）" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="450" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== Stage 1: デプロイ開始 — Canary 0%, Stable 100% ===== -->
        <mxCell id="stage1" value="&lt;b style=&quot;font-size:14px&quot;&gt;Stage 1&lt;/b&gt;&lt;br&gt;&lt;br&gt;Canary: 0%&lt;br&gt;Stable: 100%&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;デプロイ開始&lt;/font&gt;" style="rounded=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- ===== Stage 2: 初期トラフィック — Canary 10%, Stable 90% ===== -->
        <mxCell id="stage2" value="&lt;b style=&quot;font-size:14px&quot;&gt;Stage 2&lt;/b&gt;&lt;br&gt;&lt;br&gt;Canary: 10%&lt;br&gt;Stable: 90%&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;初期トラフィック&lt;/font&gt;" style="rounded=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="240" y="80" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- ===== Stage 3: 段階的増加 — Canary 30%, Stable 70% ===== -->
        <mxCell id="stage3" value="&lt;b style=&quot;font-size:14px&quot;&gt;Stage 3&lt;/b&gt;&lt;br&gt;&lt;br&gt;Canary: 30%&lt;br&gt;Stable: 70%&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;段階的増加&lt;/font&gt;" style="rounded=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="80" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- ===== Stage 4: 半数到達 — Canary 50%, Stable 50% ===== -->
        <mxCell id="stage4" value="&lt;b style=&quot;font-size:14px&quot;&gt;Stage 4&lt;/b&gt;&lt;br&gt;&lt;br&gt;Canary: 50%&lt;br&gt;Stable: 50%&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;半数到達&lt;/font&gt;" style="rounded=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="660" y="80" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- ===== Stage 5: ほぼ全量 — Canary 80%, Stable 20% ===== -->
        <mxCell id="stage5" value="&lt;b style=&quot;font-size:14px&quot;&gt;Stage 5&lt;/b&gt;&lt;br&gt;&lt;br&gt;Canary: 80%&lt;br&gt;Stable: 20%&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ほぼ全量&lt;/font&gt;" style="rounded=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="870" y="80" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- ===== Stage 6: 完全切替 — Canary 100%, Stable 0%, Promote完了 ===== -->
        <mxCell id="stage6" value="&lt;b style=&quot;font-size:14px&quot;&gt;Stage 6&lt;/b&gt;&lt;br&gt;&lt;br&gt;Canary: 100%&lt;br&gt;Stable: 0%&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;完全切替&lt;br&gt;Promote&lt;/font&gt;" style="rounded=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1080" y="80" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- ===== 段階間の遷移矢印: メトリクス正常時に次の段階へ進む ===== -->

        <!-- Stage 1 → Stage 2: メトリクス正常を確認して遷移 -->
        <mxCell id="arrow-1-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="stage1" target="stage2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-1-2-label" value="✓ メトリクス正常" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#82B366;" vertex="1" connectable="0" parent="arrow-1-2">
          <mxGeometry x="0.5" relative="1" as="geometry">
            <mxPoint y="-12" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 2 → Stage 3 -->
        <mxCell id="arrow-2-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="stage2" target="stage3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-2-3-label" value="✓" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#82B366;" vertex="1" connectable="0" parent="arrow-2-3">
          <mxGeometry x="0.5" relative="1" as="geometry">
            <mxPoint y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 3 → Stage 4 -->
        <mxCell id="arrow-3-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="stage3" target="stage4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-3-4-label" value="✓" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#82B366;" vertex="1" connectable="0" parent="arrow-3-4">
          <mxGeometry x="0.5" relative="1" as="geometry">
            <mxPoint y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 4 → Stage 5 -->
        <mxCell id="arrow-4-5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="stage4" target="stage5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-4-5-label" value="✓" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#82B366;" vertex="1" connectable="0" parent="arrow-4-5">
          <mxGeometry x="0.5" relative="1" as="geometry">
            <mxPoint y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 5 → Stage 6 -->
        <mxCell id="arrow-5-6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="stage5" target="stage6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-5-6-label" value="✓" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#82B366;" vertex="1" connectable="0" parent="arrow-5-6">
          <mxGeometry x="0.5" relative="1" as="geometry">
            <mxPoint y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== 失敗パス: メトリクス異常時のロールバック経路 ===== -->

        <!-- ロールバック先ボックス — 異常検知時に即座に切り戻し -->
        <mxCell id="rollback" value="&lt;b&gt;ロールバック&lt;/b&gt;" style="rounded=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="520" y="340" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- Stage 2からのロールバック矢印 -->
        <mxCell id="fail-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" edge="1" source="stage2" target="rollback" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="310" y="280"/>
              <mxPoint x="560" y="280"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Stage 3からのロールバック矢印 -->
        <mxCell id="fail-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.35;entryY=0;entryDx=0;entryDy=0;" edge="1" source="stage3" target="rollback" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="270"/>
              <mxPoint x="590" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Stage 4からのロールバック矢印 -->
        <mxCell id="fail-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="stage4" target="rollback" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="730" y="260"/>
              <mxPoint x="620" y="260"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Stage 5からのロールバック矢印 -->
        <mxCell id="fail-5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.8;entryY=0;entryDx=0;entryDy=0;" edge="1" source="stage5" target="rollback" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="940" y="270"/>
              <mxPoint x="680" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ロールバック条件ラベル — 失敗判定の閾値 -->
        <mxCell id="fail-label" value="エラー率 &gt; 1% or レイテンシ P99 &gt; 500ms" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#B85450;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="460" y="395" width="320" height="20" as="geometry"/>
        </mxCell>

        <!-- ===== Flagger メトリクスボックス: 判定基準の詳細 ===== -->
        <mxCell id="metrics-box" value="&lt;b&gt;判定メトリクス:&lt;/b&gt;&lt;br&gt;&lt;br&gt;リクエスト成功率 &gt; 99%&lt;br&gt;レイテンシ P99 &lt; 500ms&lt;br&gt;判定間隔: 60秒" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;fontColor=#333333;align=left;verticalAlign=top;shadow=1;rounded=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1080" y="280" width="200" height="110" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
