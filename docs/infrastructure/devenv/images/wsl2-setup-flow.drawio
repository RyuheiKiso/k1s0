        <mxCell id="c-done" value="&lt;b style=&quot;color:#9673A6&quot;&gt;開発開始&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1010" y="920" width="120" height="40" as="geometry"/>
