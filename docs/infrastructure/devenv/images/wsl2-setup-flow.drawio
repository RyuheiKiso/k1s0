        </mxCell>
        <mxCell id="e-c3-done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;" edge="1" source="c3" target="c-done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 分岐 → 各方法への矢印 -->
        <mxCell id="e-dec-a" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;A&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;fontStyle=1;" edge="1" source="decision" target="a1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
