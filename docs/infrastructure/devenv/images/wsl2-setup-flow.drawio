<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="wsl2-flow-001" name="WSL2 セットアップフロー">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="WSL2 開発環境セットアップフロー" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 共通セットアップ（左カラム） ===== -->
        <mxCell id="common-bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="340" height="920" as="geometry"/>
        </mxCell>
        <mxCell id="common-label" value="&lt;b style=&quot;font-size:14px&quot;&gt;共通セットアップ&lt;/b&gt;" style="text;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="65" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 1: WSL2 インストール -->
        <mxCell id="s1" value="&lt;b&gt;1. WSL2 インストール&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;wsl --install -d Ubuntu-24.04&lt;br&gt;（PowerShell 管理者権限）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="100" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 2: リソース設定 -->
        <mxCell id="s2" value="&lt;b&gt;2. リソース設定&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;.wslconfig: memory=8GB, processors=4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="190" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- Step 3: systemd 有効化 -->
        <mxCell id="s3" value="&lt;b&gt;3. systemd 有効化&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;/etc/wsl.conf: [boot] systemd=true&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="270" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- Step 4: Git 設定 -->
        <mxCell id="s4" value="&lt;b&gt;4. Git 設定&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;autocrlf=input, longpaths=true&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="350" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- Step 5: リポジトリクローン -->
        <mxCell id="s5" value="&lt;b&gt;5. リポジトリクローン&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;~/work/k1s0 （WSL2 FS 内、/mnt/c/ は NG）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="430" width="260" height="55" as="geometry"/>
        </mxCell>

        <!-- Step 6: Docker Engine -->
        <mxCell id="s6" value="&lt;b&gt;6. Docker Engine (CE) インストール&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;apt install docker-ce docker-compose-plugin&lt;br&gt;usermod -aG docker $USER&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="520" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 7: Docker 動作確認 -->
        <mxCell id="s7" value="&lt;b&gt;7. Docker 動作確認&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;docker run --rm hello-world&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="610" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- 分岐: 方法選択 -->
        <mxCell id="decision" value="&lt;b&gt;方法を選択&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="700" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- 共通フロー矢印 -->
        <mxCell id="e-s1-s2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-s2-s3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-s3-s4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-s4-s5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-s5-s6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="s5" target="s6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-s6-s7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="s6" target="s7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-s7-dec" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" source="s7" target="decision" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 方法 A: Dev Container（中央カラム） ===== -->
        <mxCell id="a-bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="410" y="680" width="240" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="a-label" value="&lt;b style=&quot;font-size:12px;color:#D6B656&quot;&gt;方法 A（推奨）&lt;/b&gt;" style="text;html=1;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="685" width="160" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="a1" value="&lt;b&gt;VS Code 拡張&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Remote WSL&lt;br&gt;Dev Containers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="435" y="715" width="190" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a2" value="&lt;b&gt;Reopen in Container&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;post-create.sh が自動実行&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="435" y="785" width="190" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a3" value="&lt;b&gt;docker compose up&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;--profile infra&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="435" y="855" width="190" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="a-done" value="&lt;b style=&quot;color:#D6B656&quot;&gt;開発開始&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="920" width="120" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="e-a1-a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;" edge="1" source="a1" target="a2" parent="1">
