        <mxCell id="c3" value="&lt;b&gt;ツールチェーン手動&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;方法 B と同様&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="985" y="845" width="170" height="40" as="geometry"/>
