        </mxCell>
        <mxCell id="e-a3-done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;strokeWidth=2;" edge="1" source="a3" target="a-done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 方法 B: ネイティブ（右カラム） ===== -->
        <mxCell id="b-bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#D5E8D4;strokeColor=#82B366;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="690" y="680" width="240" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="b-label" value="&lt;b style=&quot;font-size:12px;color:#82B366&quot;&gt;方法 B（上級者向け）&lt;/b&gt;" style="text;html=1;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="685" width="180" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="b1" value="&lt;b&gt;ツールチェーン手動&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Rust 1.93, Go 1.24&lt;br&gt;Node 22, Flutter 3.24&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="715" y="715" width="190" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="b2" value="&lt;b&gt;開発ツール&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;buf, protoc, just&lt;br&gt;golangci-lint, clippy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="715" y="790" width="190" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="b3" value="&lt;b&gt;docker compose up&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;--profile infra&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="715" y="865" width="190" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="b-done" value="&lt;b style=&quot;color:#82B366&quot;&gt;開発開始&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="920" width="120" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="e-b1-b2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;" edge="1" source="b1" target="b2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-b2-b3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;" edge="1" source="b2" target="b3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-b3-done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;" edge="1" source="b3" target="b-done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 方法 C: Podman（右端カラム） ===== -->
        <mxCell id="c-bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="970" y="680" width="200" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="c-label" value="&lt;b style=&quot;font-size:12px;color:#9673A6&quot;&gt;方法 C（制約あり）&lt;/b&gt;" style="text;html=1;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="990" y="685" width="160" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="c1" value="&lt;b&gt;Podman インストール&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;apt install podman&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="985" y="715" width="170" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="c2" value="&lt;b&gt;podman-compose&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pip install podman-compose&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="985" y="780" width="170" height="45" as="geometry"/>
