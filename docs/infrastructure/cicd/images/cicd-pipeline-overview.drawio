<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="cicd-pipeline-overview" name="CI/CD パイプライン全体像">
    <mxGraphModel dx="1422" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="CI/CD パイプライン全体像" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="10" width="560" height="40" as="geometry"/>
        </mxCell>

        <!-- サブタイトル -->
        <mxCell id="subtitle" value="GitHub Actions ベースのパイプライン" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="480" y="45" width="440" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== セクション1: トリガー (左側) ===== -->
        <!-- トリガーラベル -->
        <mxCell id="trigger-label" value="トリガー" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="90" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- Pull Request ボックス -->
        <mxCell id="pr-trigger" value="&lt;b&gt;Pull Request&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PR作成/更新&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- main マージボックス -->
        <mxCell id="merge-trigger" value="&lt;b&gt;main マージ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;CD トリガー&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="20" y="230" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== セクション2: CI パイプライン (中央・青スイムレーン) ===== -->
        <mxCell id="swim-ci" value="CI パイプライン" style="shape=swimlane;startSize=30;rounded=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=18;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="90" width="780" height="530" as="geometry"/>
        </mxCell>

        <!-- ── Stage 1: Lint ── -->
        <mxCell id="lint-label" value="Lint" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="swim-ci">
          <mxGeometry x="30" y="40" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="lint-rust" value="&lt;b&gt;Rustfmt / clippy&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="30" y="75" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="lint-go" value="&lt;b&gt;golangci-lint&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="30" y="125" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="lint-ts" value="&lt;b&gt;ESLint / Prettier&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="30" y="175" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="lint-dart" value="&lt;b&gt;dart analyze&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="30" y="225" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- ── Stage 2: Test ── -->
        <mxCell id="test-label" value="Test" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="swim-ci">
          <mxGeometry x="290" y="40" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="test-unit" value="&lt;b&gt;Unit Test&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="290" y="75" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="test-integ" value="&lt;b&gt;Integration Test&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(PostgreSQL, Kafka)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="290" y="125" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="test-proto" value="&lt;b&gt;Proto Validation&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="290" y="185" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- ── Stage 3: Build ── -->
        <mxCell id="build-label" value="Build" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="swim-ci">
          <mxGeometry x="550" y="40" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="build-docker" value="&lt;b&gt;Docker Build&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="550" y="75" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="build-trivy" value="&lt;b&gt;Trivy スキャン&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="550" y="125" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="build-cosign" value="&lt;b&gt;Cosign 署名&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="550" y="175" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="build-harbor" value="&lt;b&gt;Harbor Push&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="swim-ci">
          <mxGeometry x="550" y="225" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- ステージ間の矢印 (CI 内) -->
        <!-- Lint → Test -->
        <mxCell id="e-lint-test" value="&lt;font style=&quot;font-size:10px&quot;&gt;通過&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="lint-go" target="test-integ" parent="swim-ci">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Test → Build -->
        <mxCell id="e-test-build" value="&lt;font style=&quot;font-size:10px&quot;&gt;通過&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="test-integ" target="build-trivy" parent="swim-ci">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CI 内フッター情報 -->
        <mxCell id="ci-footer" value="&lt;font style=&quot;font-size:10px&quot;&gt;サービス検出: modules.yaml &amp;nbsp;|&amp;nbsp; レジストリ: Harbor &amp;nbsp;|&amp;nbsp; 署名: Cosign&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="swim-ci">
          <mxGeometry x="130" y="480" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== セクション3: CD パイプライン (右側・緑スイムレーン) ===== -->
        <mxCell id="swim-cd" value="CD パイプライン" style="shape=swimlane;startSize=30;rounded=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=18;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="90" width="200" height="530" as="geometry"/>
        </mxCell>

        <!-- Helm Deploy -->
        <mxCell id="cd-deploy" value="&lt;b&gt;Helm Deploy&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="swim-cd">
          <mxGeometry x="20" y="60" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Smoke Test -->
        <mxCell id="cd-smoke" value="&lt;b&gt;Smoke Test&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="swim-cd">
          <mxGeometry x="20" y="140" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- 通知 -->
        <mxCell id="cd-notify" value="&lt;b&gt;通知&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;" vertex="1" parent="swim-cd">
          <mxGeometry x="20" y="220" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- CD 内の矢印 -->
        <mxCell id="e-cd-deploy-smoke" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="cd-deploy" target="cd-smoke" parent="swim-cd">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e-cd-smoke-notify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="cd-smoke" target="cd-notify" parent="swim-cd">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== セクション間の矢印 ===== -->
        <!-- PR → CI -->
        <mxCell id="e-pr-ci" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="pr-trigger" target="lint-rust" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- main マージ → CD -->
        <mxCell id="e-merge-cd" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="merge-trigger" target="cd-deploy" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CI Build → CD Deploy -->
        <mxCell id="e-ci-cd" value="&lt;font style=&quot;font-size:10px&quot;&gt;ビルド成功&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="build-harbor" target="cd-deploy" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
