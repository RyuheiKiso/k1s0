<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="cicd-env-progression" name="環境別デプロイフロー">
    <mxGraphModel dx="1222" dy="520" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="環境別デプロイフロー" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== 環境ボックス 1: dev (緑) ===== -->
        <mxCell id="env-dev" value="&lt;b style=&quot;font-size:16px&quot;&gt;dev&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;開発環境&lt;/font&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;自動デプロイ&lt;/b&gt;&lt;br&gt;main マージで即時&lt;br&gt;&lt;br&gt;Replicas: 1&lt;br&gt;Resources: minimal&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="240" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== 矢印: dev → staging (自動昇格) ===== -->
        <mxCell id="e-dev-staging" value="&lt;font style=&quot;font-size:10px&quot;&gt;自動昇格&lt;br&gt;(CI テスト通過)&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="env-dev" target="env-staging" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 環境ボックス 2: staging (黄) ===== -->
        <mxCell id="env-staging" value="&lt;b style=&quot;font-size:16px&quot;&gt;staging&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;ステージング環境&lt;/font&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;自動デプロイ&lt;/b&gt;&lt;br&gt;結合テスト実行&lt;br&gt;&lt;br&gt;Replicas: 2&lt;br&gt;Resources: moderate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="460" y="80" width="240" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== 承認ゲート (ダイヤモンド) ===== -->
        <mxCell id="gate" value="&lt;font style=&quot;font-size:10px&quot;&gt;手動承認&lt;br&gt;本番承認者&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;shadow=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="790" y="130" width="120" height="100" as="geometry"/>
        </mxCell>

        <!-- 矢印: staging → gate -->
        <mxCell id="e-staging-gate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="env-staging" target="gate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 矢印: gate → prod -->
        <mxCell id="e-gate-prod" value="&lt;font style=&quot;font-size:10px&quot;&gt;承認済み&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="gate" target="env-prod" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 環境ボックス 3: prod (赤/オレンジ) ===== -->
        <mxCell id="env-prod" value="&lt;b style=&quot;font-size:16px&quot;&gt;prod&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;本番環境&lt;/font&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;承認後デプロイ&lt;/b&gt;&lt;br&gt;カナリアリリース&lt;br&gt;&lt;br&gt;Replicas: 3+&lt;br&gt;Resources: full&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="80" width="200" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== 下部タイムライン ===== -->
        <!-- タイムライン背景 -->
        <mxCell id="timeline-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="1100" height="60" as="geometry"/>
        </mxCell>

        <!-- タイムラインテキスト -->
        <mxCell id="timeline-text" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;main マージ&lt;/b&gt; → &lt;font color=&quot;#82B366&quot;&gt;dev (即時)&lt;/font&gt; → &lt;font color=&quot;#D6B656&quot;&gt;staging (自動)&lt;/font&gt; → &lt;font color=&quot;#9673A6&quot;&gt;承認ゲート&lt;/font&gt; → &lt;font color=&quot;#B85450&quot;&gt;prod (承認後)&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="355" width="900" height="50" as="geometry"/>
        </mxCell>

        <!-- タイムライン矢印 -->
        <mxCell id="timeline-arrow" value="" style="endArrow=block;html=1;strokeWidth=2;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="430" as="sourcePoint"/>
            <mxPoint x="1140" y="430" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- タイムライン矢印上のラベル -->
        <mxCell id="tl-start" value="&lt;font style=&quot;font-size:10px&quot;&gt;main マージ&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="435" width="90" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="tl-dev" value="&lt;font style=&quot;font-size:10px&quot;&gt;dev (即時)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="300" y="435" width="90" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="tl-staging" value="&lt;font style=&quot;font-size:10px&quot;&gt;staging (自動)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="560" y="435" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="tl-prod" value="&lt;font style=&quot;font-size:10px&quot;&gt;prod (承認後)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1040" y="435" width="100" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
