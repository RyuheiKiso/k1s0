<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="clean-arch-001" name="Clean Architecture 層構成">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: Clean Architecture 層構成図 -->
        <mxCell id="title" value="Clean Architecture 層構成" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- 最外層: infrastructure（インフラ層 — グレー） -->
        <mxCell id="layer-infra" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;opacity=60;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="70" width="800" height="700" as="geometry"/>
        </mxCell>
        <!-- インフラ層ラベル -->
        <mxCell id="label-infra" value="&lt;b&gt;infrastructure&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;startup.rs / persistence / kafka / grpc&lt;/font&gt;" style="text;html=1;fontSize=14;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="90" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- 第2層: adapter（アダプター層 — 青） -->
        <mxCell id="layer-adapter" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;opacity=60;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="160" width="600" height="520" as="geometry"/>
        </mxCell>
        <!-- アダプター層ラベル -->
        <mxCell id="label-adapter" value="&lt;b&gt;adapter&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;handler (REST/gRPC) / repository impl&lt;/font&gt;" style="text;html=1;fontSize=14;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="185" width="360" height="40" as="geometry"/>
        </mxCell>

        <!-- 第3層: usecase（ユースケース層 — 緑） -->
        <mxCell id="layer-usecase" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;opacity=60;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="260" width="400" height="340" as="geometry"/>
        </mxCell>
        <!-- ユースケース層ラベル -->
        <mxCell id="label-usecase" value="&lt;b&gt;usecase&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ビジネスロジック / trait 依存&lt;/font&gt;" style="text;html=1;fontSize=14;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="465" y="285" width="270" height="40" as="geometry"/>
        </mxCell>

        <!-- 最内層: domain（ドメイン層 — 黄） -->
        <mxCell id="layer-domain" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;opacity=70;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="350" width="220" height="170" as="geometry"/>
        </mxCell>
        <!-- ドメイン層ラベル -->
        <mxCell id="label-domain" value="&lt;b&gt;domain&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;entity / value object&lt;br&gt;repository trait&lt;/font&gt;" style="text;html=1;fontSize=14;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="520" y="390" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- 依存方向の矢印（外→内） -->
        <!-- infrastructure → adapter -->
        <mxCell id="dep1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="420" as="sourcePoint"/>
            <mxPoint x="300" y="420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 依存方向ラベル -->
        <mxCell id="dep-label" value="依存方向" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="395" width="80" height="20" as="geometry"/>
        </mxCell>

        <!-- 右側: ディレクトリ構造マッピング -->
        <mxCell id="mapping-title" value="&lt;b&gt;ディレクトリ構造&lt;/b&gt;" style="text;html=1;fontSize=14;align=left;" vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="160" height="30" as="geometry"/>
        </mxCell>

        <!-- src/domain/ -->
        <mxCell id="dir-domain" value="src/domain/" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1020" y="140" width="150" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="dir-domain-desc" value="entity/, model/, repository trait" style="text;html=1;fontSize=10;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1020" y="175" width="160" height="20" as="geometry"/>
        </mxCell>

        <!-- src/usecase/ -->
        <mxCell id="dir-usecase" value="src/usecase/" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1020" y="210" width="150" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="dir-usecase-desc" value="ビジネスロジック実装" style="text;html=1;fontSize=10;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1020" y="245" width="160" height="20" as="geometry"/>
        </mxCell>

        <!-- src/adapter/ -->
        <mxCell id="dir-adapter" value="src/adapter/" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1020" y="280" width="150" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="dir-adapter-desc" value="handler/, grpc/, repository impl" style="text;html=1;fontSize=10;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1020" y="315" width="160" height="20" as="geometry"/>
        </mxCell>

        <!-- src/infrastructure/ -->
        <mxCell id="dir-infra" value="src/infrastructure/" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F5F5F5;strokeColor=#666666;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1020" y="350" width="150" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="dir-infra-desc" value="startup.rs, persistence, kafka" style="text;html=1;fontSize=10;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1020" y="385" width="160" height="20" as="geometry"/>
        </mxCell>

        <!-- マッピング矢印: ディレクトリ→層 -->
        <mxCell id="map-domain" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;dashed=1;dashPattern=4 4;" edge="1" source="dir-domain" target="layer-domain" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="map-usecase" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;dashed=1;dashPattern=4 4;" edge="1" source="dir-usecase" target="layer-usecase" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="map-adapter" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;dashed=1;dashPattern=4 4;" edge="1" source="dir-adapter" target="layer-adapter" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="map-infra" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;dashed=1;dashPattern=4 4;" edge="1" source="dir-infra" target="layer-infra" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 依存ルール注記 -->
        <mxCell id="rule-note" value="&lt;b&gt;依存ルール&lt;/b&gt;&lt;br&gt;・外層は内層に依存できる&lt;br&gt;・内層は外層に依存しない&lt;br&gt;・domain は純粋な Rust 構造体と trait のみ&lt;br&gt;・usecase は domain の trait に依存&lt;br&gt;・adapter が trait を実装&lt;br&gt;・infrastructure が DI で結合" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;shadow=1;align=left;spacingLeft=8;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="430" width="170" height="140" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
