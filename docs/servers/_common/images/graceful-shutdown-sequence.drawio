        <mxCell id="ll1" style="dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="100" y="100" as="sourcePoint"/><mxPoint x="100" y="700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll2" style="dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="100" as="sourcePoint"/><mxPoint x="290" y="700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll3" style="dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="480" y="100" as="sourcePoint"/><mxPoint x="480" y="700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll4" style="dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="670" y="100" as="sourcePoint"/><mxPoint x="670" y="700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll5" style="dashed=1;strokeColor=#CCCCCC;endArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="860" y="100" as="sourcePoint"/><mxPoint x="860" y="700" as="targetPoint"/></mxGeometry></mxCell>

        <!-- ① SIGTERM受信 -->
