<mxfile host="draw.io">
  <diagram name="constraint-categories" id="constraint-categories">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="980" height="600" as="geometry" />
        </mxCell>
        <mxCell id="title" value="制約条件の 4 層構造 — 上位ほど交渉の余地がない" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="900" height="26" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="法令 / 環境 が技術 / 組織 の選択肢を制限し、技術 / 組織 が要件の実現手段を制限する" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="36" width="900" height="20" as="geometry" />
        </mxCell>
        <mxCell id="layer1" value="① 法令・コンプライアンス  (CON-040〜049)&#xa;個人情報保護法 / J-SOX / データ主権 — 交渉不能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="820" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer2" value="② 環境  (CON-050〜059)&#xa;オンプレ完結 / x86_64 / 閉域 / 社内プロキシ経由 — 物理・組織の実態" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="820" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer3" value="③ ライセンス・予算・人員  (CON-020〜029 / CON-030〜039)&#xa;商用 OSS のみ / MVP-0 単独 / MVP-1 二名体制 — 経営合意で動かせる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="820" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer4" value="④ 技術・言語  (CON-001〜019)&#xa;Kubernetes / CNCF 優先 / Go + Rust (tier1) / .NET Framework 共存 — 技術判断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="350" width="820" height="70" as="geometry" />
        </mxCell>
        <mxCell id="layer5" value="⑤ プロジェクト規約  (CON-060〜069)&#xa;drawio 図表 / 1 ファイル 300 行 / 日本語コメント / ADR — 運用で変えられる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="820" height="70" as="geometry" />
        </mxCell>
        <mxCell id="arrow1" value="上位制約が下位の選択肢を狭める" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#333333;fontSize=11;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="40" y="115" as="sourcePoint"/><mxPoint x="40" y="475" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="note" value="例: 「データ主権 (①)」→「オンプレ完結 (②)」→「クラウド専用 OSS は対象外 (④)」→「Terraform ではなく OpenTofu (⑤)」の連鎖。" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FAFAFA;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="40" y="530" width="900" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
