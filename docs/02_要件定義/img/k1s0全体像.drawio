<mxfile host="draw.io">
  <diagram name="overview" id="overview">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="680" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="680" as="geometry" />
        </mxCell>
        <mxCell id="title" value="k1s0 全体像 — 4 層 + 運用横断の依存構造" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="620" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="tier3 — エンドユーザー層&#xa;業務アプリ / アプリ配信ポータル / 端末管理&#xa;言語自由: C# / Go / TypeScript (React) / MAUI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="60" width="620" height="90" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="tier2 — ドメインサービス層&#xa;業務ドメインロジック (マイクロサービス群)&#xa;言語自由: C# / Go" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="620" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="tier1 — 共通基盤サービス層 (k1s0 の核心)&#xa;&#xa;公開 API: k1s0.Auth / Log / Telemetry / State / PubSub /&#xa;         Service / Audit / Decision / Workflow / Secrets&#xa;&#xa;内部実装 (tier2 / tier3 からは不可視):&#xa;Go ファサード (Dapr 隠蔽) + Rust 自作領域 + 多言語クライアント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="620" height="160" as="geometry" />
        </mxCell>
        <mxCell id="inf" value="infra — インフラ層&#xa;Kubernetes (kubeadm) / Istio (mTLS) / Envoy Gateway&#xa;Kafka (Strimzi) / PostgreSQL (CloudNativePG) / Valkey&#xa;Loki / Grafana Tempo / Prometheus / Grafana / Pyroscope" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="620" height="110" as="geometry" />
        </mxCell>
        <mxCell id="op" value="operation — 運用横断&#xa;&#xa;(全層を横断する)&#xa;&#xa;Argo CD&#xa;Backstage&#xa;Harbor&#xa;Renovate&#xa;OpenBao&#xa;Litmus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="60" width="180" height="500" as="geometry" />
        </mxCell>
        <mxCell id="a1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="t3" target="t2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="t2" target="t1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="t1" target="inf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="矢印: 依存方向 (上→下の一方向のみ許可)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#CCCCCC;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="580" width="620" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note" value="依存ルール: 上位層は 1 つ下の層にのみ依存する。tier3 から tier1 / infra への直接依存は不可。infra への直接依存は tier1 のみに許可。" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="610" width="840" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
