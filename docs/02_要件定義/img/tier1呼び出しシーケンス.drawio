<mxfile host="draw.io">
  <diagram name="tier1-sequence" id="tier1-sequence">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1040" height="640" as="geometry" />
        </mxCell>
        <mxCell id="title" value="代表シーケンス — tier2 サービスが k1s0.Auth と k1s0.Log を呼び出す" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="60" y="10" width="920" height="26" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="tier2 は k1s0.* のみを呼ぶ — 内部 OSS は tier1 ファサードが隠蔽" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
