          <mxGeometry x="40" y="80" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="actor_tier2" value="tier2 業務サービス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="80" width="160" height="40" as="geometry" />
