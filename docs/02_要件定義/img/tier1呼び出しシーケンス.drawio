        <mxCell id="lane_user" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999999;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110" y="125" as="sourcePoint"/><mxPoint x="110" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lane_tier2" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999999;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="125" as="sourcePoint"/><mxPoint x="300" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lane_tier1" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999999;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="130" as="sourcePoint"/><mxPoint x="510" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lane_kc" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999999;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="710" y="125" as="sourcePoint"/><mxPoint x="710" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lane_loki" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#999999;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="900" y="125" as="sourcePoint"/><mxPoint x="900" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg1" value="① HTTP リクエスト + Bearer トークン" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110" y="160" as="sourcePoint"/><mxPoint x="300" y="160" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg2" value="② k1s0.Auth.ValidateToken(token)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#2F5B8C;fontSize=11;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="205" as="sourcePoint"/><mxPoint x="510" y="205" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg3" value="③ JWKS 公開鍵 (初回のみ取得、以後キャッシュ)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#A93226;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="250" as="sourcePoint"/><mxPoint x="710" y="250" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg4" value="④ 署名検証 OK / クレーム返却" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#2F5B8C;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="295" as="sourcePoint"/><mxPoint x="300" y="295" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg5" value="⑤ 業務ロジック実行" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#4C8C4A;fontSize=11;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="340" as="sourcePoint"/><mxPoint x="300" y="380" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg5_label" value="(tier2 内で処理)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="130" y="345" width="150" height="20" as="geometry" /></mxCell>
        <mxCell id="msg6" value="⑥ k1s0.Log.Info(msg, ctx) + traceId" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#2F5B8C;fontSize=11;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="410" as="sourcePoint"/><mxPoint x="510" y="410" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg7" value="⑦ Loki / Tempo へ非同期送信 (呼び出し側ブロックしない)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#A93226;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="455" as="sourcePoint"/><mxPoint x="900" y="455" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="msg8" value="⑧ HTTP レスポンス 200 OK" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="500" as="sourcePoint"/><mxPoint x="110" y="500" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="note" value="青矢印 = tier2 が呼ぶ k1s0.* 公開 API  /  赤矢印 = tier1 ファサード内で完結する OSS 呼び出し (tier2 からは不可視)" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#FAFAFA;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="40" y="555" width="960" height="30" as="geometry" />
