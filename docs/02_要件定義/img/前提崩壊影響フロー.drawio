        <mxCell id="risk2" value="RISK-002 顕在化&#xa;バス係数 1 継続" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="170" width="220" height="54" as="geometry" />
