<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="event-driven-flow" name="イベント駆動アーキテクチャフロー">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="イベント駆動アーキテクチャフロー" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="450" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ========== correlation_id 伝播線（上部） ========== -->
        <mxCell id="correlation_line" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#82B366;dashed=1;dashPattern=12 4;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="80" as="sourcePoint"/>
            <mxPoint x="1340" y="80" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="correlation_label" value="correlation_id 伝播（全ステップで維持）" style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;fillColor=#D5E8D4;strokeColor=#82B366;rounded=1;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="530" y="65" width="280" height="24" as="geometry"/>
        </mxCell>

        <!-- ========== causation_id リンク線（上部、correlation下） ========== -->
        <mxCell id="causation_line" value="" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#9673A6;dashed=1;dashPattern=4 4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="100" as="sourcePoint"/>
            <mxPoint x="1340" y="100" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="causation_label" value="causation_id（親→子イベントリンク）" style="text;html=1;fontSize=10;fontStyle=2;align=center;verticalAlign=middle;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="95" width="260" height="20" as="geometry"/>
        </mxCell>

        <!-- ========== Step 1: Service（ドメインイベント発行） ========== -->
        <mxCell id="step1" value="&lt;b&gt;1. Service&lt;/b&gt;&lt;br&gt;&lt;br&gt;ドメインイベント発行" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="30" y="160" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- ========== Step 2: EventMetadata 付与 ========== -->
        <mxCell id="step2" value="&lt;b&gt;2. EventMetadata&lt;/b&gt;&lt;br&gt;&lt;br&gt;event_id&lt;br&gt;event_type&lt;br&gt;correlation_id&lt;br&gt;causation_id&lt;br&gt;timestamp" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="220" y="140" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 1 → Step 2 -->
        <mxCell id="e1_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== Step 3: OutboxMessage 永続化（DB transaction） ========== -->
        <mxCell id="step3" value="&lt;b&gt;3. OutboxMessage&lt;/b&gt;&lt;br&gt;&lt;br&gt;DB Transaction で永続化" style="shape=cylinder3;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;boundedLbl=1;backgroundOutline=1;size=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="140" width="140" height="110" as="geometry"/>
        </mxCell>

        <!-- Step 2 → Step 3 -->
        <mxCell id="e2_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6C8EBF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== Step 4: OutboxProcessor（batch processing） ========== -->
        <mxCell id="step4" value="&lt;b&gt;4. OutboxProcessor&lt;/b&gt;&lt;br&gt;&lt;br&gt;バッチ処理&lt;br&gt;Pending メッセージ取得" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="600" y="150" width="140" height="90" as="geometry"/>
        </mxCell>

        <!-- Step 3 → Step 4 -->
        <mxCell id="e3_4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== Step 5: Kafka topic（publish） ========== -->
        <mxCell id="step5" value="&lt;b&gt;5. Kafka Topic&lt;/b&gt;&lt;br&gt;&lt;br&gt;メッセージ発行" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="790" y="155" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Step 4 → Step 5 -->
        <mxCell id="e4_5" value="Publish" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step4" target="step5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== Step 6: Consumer Group（subscribe） ========== -->
        <mxCell id="step6" value="&lt;b&gt;6. Consumer Group&lt;/b&gt;&lt;br&gt;&lt;br&gt;トピック購読&lt;br&gt;パーティション割当" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="980" y="150" width="150" height="90" as="geometry"/>
        </mxCell>

        <!-- Step 5 → Step 6 -->
        <mxCell id="e5_6" value="Subscribe" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step5" target="step6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== Step 7: Handler（process event） ========== -->
        <mxCell id="step7" value="&lt;b&gt;7. Handler&lt;/b&gt;&lt;br&gt;&lt;br&gt;イベント処理&lt;br&gt;ビジネスロジック実行" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="1190" y="150" width="150" height="90" as="geometry"/>
        </mxCell>

        <!-- Step 6 → Step 7 -->
        <mxCell id="e6_7" value="Dispatch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step6" target="step7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== 下部の補足説明 ========== -->

        <!-- イベントメタデータ構造 -->
        <mxCell id="metadata_box" value="&lt;b&gt;EventMetadata 構造&lt;/b&gt;&lt;hr&gt;event_id: UUID（一意識別子）&lt;br&gt;event_type: String（イベント種別）&lt;br&gt;correlation_id: UUID（リクエストスコープ）&lt;br&gt;causation_id: UUID（親イベントID）&lt;br&gt;timestamp: DateTime（発生時刻）&lt;br&gt;source: String（発行元サービス）" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;spacingRight=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="310" width="280" height="150" as="geometry"/>
        </mxCell>

        <!-- Outbox テーブル構造 -->
        <mxCell id="outbox_table" value="&lt;b&gt;outbox_messages テーブル&lt;/b&gt;&lt;hr&gt;id: UUID&lt;br&gt;event_type: String&lt;br&gt;payload: JSONB&lt;br&gt;status: Pending | Delivered | Failed&lt;br&gt;retry_count: Integer&lt;br&gt;created_at / delivered_at: DateTime" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;spacingRight=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="310" width="280" height="150" as="geometry"/>
        </mxCell>

        <!-- 処理保証の説明 -->
        <mxCell id="guarantee_box" value="&lt;b&gt;処理保証&lt;/b&gt;&lt;hr&gt;Producer: At-least-once（Outbox + リトライ）&lt;br&gt;Consumer: Idempotent 処理&lt;br&gt;Ordering: パーティション内で保証&lt;br&gt;Delivery: correlation_id でトレース可能" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;spacingRight=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="310" width="280" height="130" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
