<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="outbox-flow-001" name="Outbox パターンフロー">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル: Outbox パターンフロー -->
        <mxCell id="title" value="Outbox パターンフロー（トランザクショナルアウトボックス）" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- フェーズ1: トランザクション内書き込み -->
        <mxCell id="phase1" value="フェーズ1: DB トランザクション（アトミック書き込み）" style="shape=swimlane;startSize=30;fontSize=16;fontStyle=1;fillColor=#D5E8D4;strokeColor=#82B366;rounded=1;shadow=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="680" height="300" as="geometry"/>
        </mxCell>

        <!-- アプリケーション -->
        <mxCell id="app" value="Application&lt;br&gt;(usecase)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="phase1">
          <mxGeometry x="30" y="60" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- BEGIN TX -->
        <mxCell id="tx-begin" value="BEGIN TX" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F5F5F5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="phase1">
          <mxGeometry x="200" y="50" width="80" height="30" as="geometry"/>
        </mxCell>

        <!-- ビジネスデータ書込み -->
        <mxCell id="biz-write" value="ビジネスデータ&lt;br&gt;INSERT/UPDATE" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontSize=11;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="phase1">
          <mxGeometry x="320" y="45" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- Outboxテーブル書込み -->
        <mxCell id="outbox-write" value="outbox_messages&lt;br&gt;INSERT" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="phase1">
          <mxGeometry x="320" y="140" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- COMMIT TX -->
        <mxCell id="tx-commit" value="COMMIT TX" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F5F5F5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="phase1">
          <mxGeometry x="480" y="95" width="80" height="30" as="geometry"/>
        </mxCell>

        <!-- トランザクション境界線（破線囲み） -->
        <mxCell id="tx-boundary" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82B366;dashed=1;dashPattern=8 4;strokeWidth=2;" vertex="1" parent="phase1">
          <mxGeometry x="190" y="35" width="390" height="195" as="geometry"/>
        </mxCell>
        <mxCell id="tx-boundary-label" value="DB トランザクション境界" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#82B366;align=center;" vertex="1" parent="phase1">
          <mxGeometry x="270" y="235" width="140" height="20" as="geometry"/>
        </mxCell>

        <!-- フェーズ1内の矢印 -->
        <mxCell id="pa1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;" edge="1" source="app" target="tx-begin" parent="phase1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pa2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;" edge="1" source="tx-begin" target="biz-write" parent="phase1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pa3" value="同一TX内" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;fontSize=10;fontColor=#D6B656;" edge="1" source="biz-write" target="outbox-write" parent="phase1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pa4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" source="outbox-write" target="tx-commit" parent="phase1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- フェーズ2: ポーリング＋Kafka発行 -->
        <mxCell id="phase2" value="フェーズ2: 非同期ポーリング＋イベント発行" style="shape=swimlane;startSize=30;fontSize=16;fontStyle=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;rounded=1;shadow=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="70" width="660" height="300" as="geometry"/>
        </mxCell>

        <!-- OutboxPoller -->
        <mxCell id="poller" value="OutboxPoller&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;定期ポーリング&lt;br&gt;(tokio interval)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;" vertex="1" parent="phase2">
          <mxGeometry x="30" y="60" width="130" height="70" as="geometry"/>
        </mxCell>

        <!-- outbox_messages 読取 -->
        <mxCell id="outbox-read" value="outbox_messages&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;status = 'pending'&lt;br&gt;SELECT FOR UPDATE&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;" vertex="1" parent="phase2">
          <mxGeometry x="200" y="50" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- KafkaProducer -->
        <mxCell id="kafka-pub" value="KafkaProducer&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;publish()&lt;/font&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;shadow=1;" vertex="1" parent="phase2">
          <mxGeometry x="390" y="65" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- Kafka Topic -->
        <mxCell id="kafka-topic" value="Kafka Topic&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;k1s0.service.*.v1&lt;/font&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFF2CC;strokeColor=#D6B656;rounded=1;shadow=1;" vertex="1" parent="phase2">
          <mxGeometry x="390" y="165" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- mark_published -->
        <mxCell id="mark-pub" value="mark_published&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;status = 'published'&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontSize=11;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;" vertex="1" parent="phase2">
          <mxGeometry x="200" y="165" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- フェーズ2内の矢印 -->
        <mxCell id="pb1" value="SELECT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;fontSize=10;fontColor=#D6B656;" edge="1" source="poller" target="outbox-read" parent="phase2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pb2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;" edge="1" source="outbox-read" target="kafka-pub" parent="phase2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pb3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D6B656;" edge="1" source="kafka-pub" target="kafka-topic" parent="phase2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pb4" value="UPDATE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;fontSize=10;fontColor=#82B366;" edge="1" source="kafka-pub" target="mark-pub" parent="phase2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="570" y="93"/>
              <mxPoint x="570" y="200"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 保証事項ノート -->
        <mxCell id="guarantee" value="&lt;b&gt;整合性保証&lt;/b&gt;&lt;br&gt;・ビジネスデータと Outbox は同一 TX でコミット&lt;br&gt;・TX 失敗時は両方ロールバック（不整合なし）&lt;br&gt;・ポーリングにより at-least-once 配信を保証&lt;br&gt;・idempotency_key で重複発行を防止" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;shadow=1;align=left;spacingLeft=8;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="400" width="320" height="100" as="geometry"/>
        </mxCell>

        <!-- エラー時フロー注記 -->
        <mxCell id="error-note" value="&lt;b&gt;エラー時&lt;/b&gt;&lt;br&gt;・Kafka 発行失敗 → status 据え置き → 次回ポーリングでリトライ&lt;br&gt;・リトライ上限超過 → DLQ Manager へ転送" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;align=left;spacingLeft=8;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="360" y="400" width="320" height="80" as="geometry"/>
        </mxCell>

        <!-- 並列処理注記 -->
        <mxCell id="parallel-note" value="&lt;b&gt;並列処理&lt;/b&gt;&lt;br&gt;・OutboxProcessor は JoinSet で並列実行&lt;br&gt;・デフォルト並列度: 4（with_concurrency(n) で変更可能）" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#999999;shadow=1;align=left;spacingLeft=8;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="300" height="70" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
