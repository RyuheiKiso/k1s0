<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="circuit-breaker-state-machine" name="サーキットブレーカー状態遷移">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="サーキットブレーカー状態遷移図" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- Closed状態（正常）- 左上 -->
        <mxCell id="closed" value="&lt;b&gt;Closed（正常）&lt;/b&gt;&lt;br&gt;&lt;br&gt;全リクエストを通過&lt;br&gt;failure_count を監視" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;verticalAlign=middle;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- Open状態（遮断中）- 右上 -->
        <mxCell id="open" value="&lt;b&gt;Open（遮断中）&lt;/b&gt;&lt;br&gt;&lt;br&gt;全リクエストを即座に拒否&lt;br&gt;timeout タイマー開始" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;verticalAlign=middle;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="500" y="90" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- HalfOpen状態（試行中）- 下中央 -->
        <mxCell id="halfopen" value="&lt;b&gt;HalfOpen（試行中）&lt;/b&gt;&lt;br&gt;&lt;br&gt;制限付きリクエストを許可&lt;br&gt;success_count を監視" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;verticalAlign=middle;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="290" y="340" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- 遷移: Closed → Open（failure_count >= threshold） -->
        <mxCell id="closed_to_open" value="failure_count &amp;gt;= threshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="closed" target="open" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 遷移: Open → HalfOpen（timeout経過） -->
        <mxCell id="open_to_halfopen" value="timeout 経過" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;curved=1;" edge="1" source="open" target="halfopen" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="290"/>
              <mxPoint x="510" y="290"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 遷移: HalfOpen → Open（単一の失敗で即座に遷移） -->
        <mxCell id="halfopen_to_open" value="単一の失敗で即座に遷移" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4;curved=1;" edge="1" source="halfopen" target="open" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="340"/>
              <mxPoint x="720" y="340"/>
              <mxPoint x="720" y="260"/>
              <mxPoint x="720" y="210"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 遷移: HalfOpen → Closed（success_count >= threshold） -->
        <mxCell id="halfopen_to_closed" value="success_count &amp;gt;= threshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;curved=1;" edge="1" source="halfopen" target="closed" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="290" y="290"/>
              <mxPoint x="190" y="290"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
