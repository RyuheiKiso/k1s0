<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="outbox-pattern-flow" name="トランザクショナルアウトボックスパターン">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="トランザクショナルアウトボックスパターン" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="350" y="15" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ========== アクター ========== -->

        <!-- App（アプリケーション） -->
        <mxCell id="app" value="&lt;b&gt;App&lt;/b&gt;&lt;br&gt;アプリケーション" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- DB（データベース） -->
        <mxCell id="db" value="&lt;b&gt;Database&lt;/b&gt;&lt;br&gt;PostgreSQL" style="shape=cylinder3;whiteSpace=wrap;html=1;shadow=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;boundedLbl=1;backgroundOutline=1;size=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="130" height="90" as="geometry"/>
        </mxCell>

        <!-- 同一トランザクション境界ボックス -->
        <mxCell id="tx_boundary" value="" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;strokeColor=#B85450;strokeWidth=2;fillColor=none;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="25" y="80" width="400" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="tx_label" value="同一トランザクション" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fillColor=#F8CECC;strokeColor=#B85450;rounded=1;spacingLeft=6;spacingRight=6;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="160" height="24" as="geometry"/>
        </mxCell>

        <!-- App → DB: エンティティ + OutboxMessage 保存 -->
        <mxCell id="app_to_db" value="INSERT ドメインエンティティ&lt;br&gt;+ OutboxMessage (Pending)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontStyle=0;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="app" target="db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- OutboxProcessor -->
        <mxCell id="processor" value="&lt;b&gt;OutboxProcessor&lt;/b&gt;&lt;br&gt;定期ポーリング" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="280" y="290" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Processor → DB: fetch_pending -->
        <mxCell id="processor_to_db" value="fetch_pending()&lt;br&gt;Pending メッセージ取得" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontStyle=0;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="processor" target="db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- OutboxPublisher -->
        <mxCell id="publisher" value="&lt;b&gt;OutboxPublisher&lt;/b&gt;&lt;br&gt;メッセージ発行" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="530" y="290" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Processor → Publisher -->
        <mxCell id="processor_to_publisher" value="メッセージ委譲" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;fontSize=10;fontStyle=0;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="processor" target="publisher" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Kafka -->
        <mxCell id="kafka" value="&lt;b&gt;Kafka&lt;/b&gt;&lt;br&gt;メッセージブローカー" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="780" y="290" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Publisher → Kafka -->
        <mxCell id="publisher_to_kafka" value="Publish" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#9673A6;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="publisher" target="kafka" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- mark_delivered: ステータス更新 -->
        <mxCell id="mark_delivered" value="&lt;b&gt;mark_delivered&lt;/b&gt;&lt;br&gt;ステータスを Delivered に更新" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="530" y="120" width="190" height="60" as="geometry"/>
        </mxCell>

        <!-- Publisher → mark_delivered -->
        <mxCell id="publisher_to_mark" value="発行成功" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;fontStyle=0;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="publisher" target="mark_delivered" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- mark_delivered → DB -->
        <mxCell id="mark_to_db" value="UPDATE status = Delivered" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6C8EBF;fontSize=10;fontStyle=0;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="mark_delivered" target="db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== Failure Path ========== -->

        <!-- Failure境界 -->
        <mxCell id="failure_boundary" value="" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;strokeColor=#B85450;strokeWidth=2;fillColor=none;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="400" width="400" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="failure_label" value="失敗パス" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fillColor=#F8CECC;strokeColor=#B85450;rounded=1;spacingLeft=6;spacingRight=6;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="535" y="380" width="80" height="24" as="geometry"/>
        </mxCell>

        <!-- リトライ -->
        <mxCell id="retry" value="&lt;b&gt;リトライ&lt;/b&gt;&lt;br&gt;最大3回&lt;br&gt;Exponential Backoff" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="555" y="430" width="150" height="70" as="geometry"/>
        </mxCell>

        <!-- Publisher → Retry（発行失敗） -->
        <mxCell id="publisher_to_retry" value="発行失敗" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=4 4;" edge="1" source="publisher" target="retry" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="605" y="380"/>
              <mxPoint x="630" y="380"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Failed -->
        <mxCell id="failed" value="&lt;b&gt;Failed&lt;/b&gt;&lt;br&gt;ステータス更新" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="740" y="430" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Retry → Failed -->
        <mxCell id="retry_to_failed" value="3回超過" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="retry" target="failed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DLQ -->
        <mxCell id="dlq" value="&lt;b&gt;DLQ&lt;/b&gt;&lt;br&gt;Dead Letter Queue" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="740" y="500" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Failed → DLQ -->
        <mxCell id="failed_to_dlq" value="転送" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B85450;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="failed" target="dlq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
