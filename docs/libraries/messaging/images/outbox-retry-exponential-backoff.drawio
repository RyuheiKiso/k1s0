<mxfile host="draw.io" agent="Claude Code" version="24.0" type="device">
  <diagram id="outbox-retry-backoff" name="リトライ指数バックオフタイムライン">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="450" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- タイトル -->
        <mxCell id="title" value="リトライ指数バックオフ タイムライン" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- 数式説明 -->
        <mxCell id="formula" value="&lt;b&gt;算出式:&lt;/b&gt; delay = base_delay × 2^(retry_count - 1)　(base_delay = 1s, max_retries = 5)" style="text;html=1;fontSize=11;fontColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="50" width="640" height="20" as="geometry"/>
        </mxCell>

        <!-- 時間軸 -->
        <mxCell id="time_axis" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#666666;endArrow=classic;endSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="60" y="200" as="sourcePoint"/><mxPoint x="1140" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="time_label" value="時間 →" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1090" y="205" width="50" height="20" as="geometry"/>
        </mxCell>

        <!-- 初回送信失敗 (t=0) -->
        <mxCell id="t0_line" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#B85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="100" y="120" as="sourcePoint"/><mxPoint x="100" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="t0_label" value="&lt;font color=&quot;#B85450&quot;&gt;✗&lt;/font&gt;&lt;br&gt;&lt;b&gt;初回失敗&lt;/b&gt;&lt;br&gt;t=0s" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="65" y="80" width="70" height="45" as="geometry"/>
        </mxCell>

        <!-- リトライ1 (t=1s) -->
        <mxCell id="wait1" value="1s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="180" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r1_line" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="200" y="120" as="sourcePoint"/><mxPoint x="200" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r1_label" value="&lt;font color=&quot;#B85450&quot;&gt;✗&lt;/font&gt;&lt;br&gt;&lt;b&gt;Retry #1&lt;/b&gt;&lt;br&gt;t=1s" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="165" y="80" width="70" height="45" as="geometry"/>
        </mxCell>

        <!-- リトライ2 (t=3s, wait=2s) -->
        <mxCell id="wait2" value="2s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="180" width="140" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r2_line" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="360" y="120" as="sourcePoint"/><mxPoint x="360" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r2_label" value="&lt;font color=&quot;#B85450&quot;&gt;✗&lt;/font&gt;&lt;br&gt;&lt;b&gt;Retry #2&lt;/b&gt;&lt;br&gt;t=3s" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="325" y="80" width="70" height="45" as="geometry"/>
        </mxCell>

        <!-- リトライ3 (t=7s, wait=4s) -->
        <mxCell id="wait3" value="4s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="180" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r3_line" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="580" y="120" as="sourcePoint"/><mxPoint x="580" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r3_label" value="&lt;font color=&quot;#B85450&quot;&gt;✗&lt;/font&gt;&lt;br&gt;&lt;b&gt;Retry #3&lt;/b&gt;&lt;br&gt;t=7s" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="545" y="80" width="70" height="45" as="geometry"/>
        </mxCell>

        <!-- リトライ4 (t=15s, wait=8s) -->
        <mxCell id="wait4" value="8s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="180" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r4_line" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="860" y="120" as="sourcePoint"/><mxPoint x="860" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r4_label" value="&lt;font color=&quot;#B85450&quot;&gt;✗&lt;/font&gt;&lt;br&gt;&lt;b&gt;Retry #4&lt;/b&gt;&lt;br&gt;t=15s" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="825" y="80" width="70" height="45" as="geometry"/>
        </mxCell>

        <!-- リトライ5 (t=31s, wait=16s) — 最後 -->
        <mxCell id="wait5" value="16s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="180" width="170" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r5_line" style="edgeStyle=none;html=1;strokeWidth=3;strokeColor=#B85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="120" as="sourcePoint"/><mxPoint x="1050" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r5_label" value="&lt;font color=&quot;#B85450&quot;&gt;✗&lt;/font&gt;&lt;br&gt;&lt;b&gt;Retry #5&lt;/b&gt;&lt;br&gt;t=31s" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1015" y="80" width="70" height="45" as="geometry"/>
        </mxCell>

        <!-- Dead Letter Queue行き -->
        <mxCell id="dlq_arrow" style="edgeStyle=none;html=1;strokeWidth=3;strokeColor=#B85450;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="200" as="sourcePoint"/><mxPoint x="1050" y="280" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="dlq" value="&lt;b&gt;Dead Letter Queue&lt;/b&gt;&lt;br&gt;手動対応が必要" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="960" y="280" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- 待機時間の増加を示す矢印 -->
        <mxCell id="growth_arrow" style="edgeStyle=none;html=1;strokeWidth=2;strokeColor=#D6B656;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="100" y="230" as="sourcePoint"/><mxPoint x="1050" y="230" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="growth_label" value="待機時間が指数的に増加: 1s → 2s → 4s → 8s → 16s" style="text;html=1;fontSize=10;fontStyle=1;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="350" y="235" width="350" height="20" as="geometry"/>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="600" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg_t" value="凡例:" style="text;html=1;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="285" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="&lt;font color=&quot;#B85450&quot;&gt;|&lt;/font&gt; 送信失敗" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="285" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="&lt;font color=&quot;#D6B656&quot;&gt;■&lt;/font&gt; バックオフ待機" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="210" y="285" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="&lt;font color=&quot;#B85450&quot;&gt;■&lt;/font&gt; Dead Letter Queue" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="285" width="140" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg_note" value="jitter を追加して thundering herd を防止" style="text;html=1;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="70" y="305" width="280" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
