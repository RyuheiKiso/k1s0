<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="Layered Architecture Layers">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="500" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="title" value="レイヤードアーキテクチャの 4 層構造" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="500" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="layer_pres" value="&lt;b style=&quot;font-size:14px&quot;&gt;Presentation Layer（プレゼンテーション層）&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;UI / Web Controller / API ハンドラ&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="60" width="600" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="layer_bus" value="&lt;b style=&quot;font-size:14px&quot;&gt;Business Layer（ビジネス層）&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;Service / Domain Logic / トランザクション境界&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="160" width="600" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="layer_pers" value="&lt;b style=&quot;font-size:14px&quot;&gt;Persistence Layer（永続化層）&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;Repository / DAO / ORM マッピング&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="260" width="600" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="layer_db" value="&lt;b style=&quot;font-size:14px&quot;&gt;Database Layer（データベース層）&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;RDBMS / NoSQL / 外部ストレージ&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="360" width="600" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_pb" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;endSize=8;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="140" as="sourcePoint"/>
            <mxPoint x="450" y="160" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow_bp" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;endSize=8;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="240" as="sourcePoint"/>
            <mxPoint x="450" y="260" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow_pd" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;endSize=8;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="340" as="sourcePoint"/>
            <mxPoint x="450" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="dep_arrow" value="" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#666666;endSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="820" y="80" as="sourcePoint"/>
            <mxPoint x="820" y="420" as="targetPoint"/>
