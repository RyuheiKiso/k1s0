        <mxCell id="dep_label" value="依存方向" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="770" y="20" width="100" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="上位レイヤは直下のレイヤだけを呼び出す（Closed Layer 既定）" style="text;html=1;fontSize=12;fontStyle=2;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
