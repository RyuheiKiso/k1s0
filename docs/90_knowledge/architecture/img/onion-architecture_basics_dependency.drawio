<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="Onion Architecture Dependency Inversion">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="540" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="title" value="依存性逆転による外側→内側依存の実現" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="170" y="10" width="560" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="app" value="&lt;b style=&quot;font-size:14px&quot;&gt;OrderApplicationService&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;ユースケース実装&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="70" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="app_layer" value="Application Services 層" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="630" y="90" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="port" value="&lt;b style=&quot;font-size:14px&quot;&gt;&amp;lt;&amp;lt;interface&amp;gt;&amp;gt;&lt;br&gt;IOrderRepository&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;ドメインの永続化抽象&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="240" width="320" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="port_layer" value="Domain Services 層（Port 定義）" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="630" y="270" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="impl" value="&lt;b style=&quot;font-size:14px&quot;&gt;PostgresOrderRepository&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;具象実装（DB アクセス）&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="430" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="impl_layer" value="Infrastructure 層（Adapter 実装）" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="630" y="450" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dep_arrow" value="" style="endArrow=open;html=1;strokeWidth=2;strokeColor=#333333;dashed=1;dashPattern=8 4;endSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="150" as="sourcePoint"/>
            <mxPoint x="450" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="dep_label" value="依存" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="465" y="180" width="50" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="impl_arrow" value="" style="endArrow=block;endFill=0;html=1;strokeWidth=2;strokeColor=#333333;dashed=1;dashPattern=8 4;endSize=12;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="430" as="sourcePoint"/>
            <mxPoint x="450" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="impl_label" value="実装" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="465" y="375" width="50" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="外側（Infrastructure）が内側（Domain Services）の抽象を実装し、&#xa;内側（Application Services）はその抽象にのみ依存する。&#xa;結果として「実行時の流れ」と「依存の向き」が逆転する。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#444444;whiteSpace=wrap;" vertex="1" parent="1">
