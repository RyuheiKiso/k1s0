            <mxPoint x="240" y="430" as="sourcePoint" />
            <mxPoint x="580" y="430" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="result (content[])" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="470" as="sourcePoint" />
            <mxPoint x="240" y="470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p4" value="④ 通知" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#5b9d61;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="525" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m8" value="notifications/tools/list_changed" style="endArrow=classic;html=1;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="540" as="sourcePoint" />
            <mxPoint x="240" y="540" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m9" value="tools/list (再取得)" style="endArrow=classic;html=1;rounded=0;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="580" as="sourcePoint" />
            <mxPoint x="580" y="580" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg" value="凡例: 実線 = request / notification、破線 = response (result)。notification は id を持たず応答不要。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=center;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="665" width="720" height="35" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
