<mxfile>
  <diagram name="RTT Measurement" id="rtt-measurement">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="560" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="560" as="geometry" />
        </mxCell>
        <mxCell id="title" value="RTT（Round Trip Time）の計測シーケンス" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="180" y="15" width="600" height="40" as="geometry" />
        </mxCell>

        <mxCell id="clientHeader" value="Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="70" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="clientLine" value="" style="endArrow=none;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="190" y="110" as="sourcePoint" />
            <mxPoint x="190" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="clientTimeLabel" value="時間軸 ↓" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="150" y="495" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="serverHeader" value="Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="70" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="serverLine" value="" style="endArrow=none;strokeColor=#82b366;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="770" y="110" as="sourcePoint" />
            <mxPoint x="770" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="serverTimeLabel" value="時間軸 ↓" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="730" y="495" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="t0Box" value="T₀" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="140" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t0Label" value="送信時刻を記録" style="text;html=1;fontSize=11;align=right;fillColor=none;strokeColor=none;fontColor=#7a5d00;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="130" height="20" as="geometry" />
        </mxCell>

        <mxCell id="fwdLabel" value="Request パケット送出" style="text;html=1;fontSize=11;align=center;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="165" width="360" height="20" as="geometry" />
        </mxCell>
        <mxCell id="fwdArrow" value="" style="endArrow=classic;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="215" y="195" as="sourcePoint" />
            <mxPoint x="765" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="fwdDelayLabel" value="片道伝送時間 ＝ 伝播遅延 ＋ 送信遅延 ＋ キューイング遅延" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="230" y="260" width="490" height="20" as="geometry" />
        </mxCell>

        <mxCell id="procBox" value="処理遅延" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5e6a3;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="280" width="60" height="50" as="geometry" />
        </mxCell>
        <mxCell id="procLabel" value="要求を解釈し&#xa;応答を組み立てる時間" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="810" y="285" width="140" height="40" as="geometry" />
        </mxCell>

        <mxCell id="retLabel" value="Response パケット（ACK）受信" style="text;html=1;fontSize=11;align=center;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="335" width="360" height="20" as="geometry" />
        </mxCell>
        <mxCell id="retArrow" value="" style="endArrow=classic;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="745" y="365" as="sourcePoint" />
            <mxPoint x="215" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="t1Box" value="T₁" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="420" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t1Label" value="受信時刻を記録" style="text;html=1;fontSize=11;align=right;fillColor=none;strokeColor=none;fontColor=#7a5d00;" vertex="1" parent="1">
          <mxGeometry x="30" y="430" width="130" height="20" as="geometry" />
        </mxCell>

        <mxCell id="rttFormula" value="RTT ＝ T₁ − T₀" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="410" width="260" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
