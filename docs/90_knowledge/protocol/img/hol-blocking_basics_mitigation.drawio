<mxfile>
  <diagram name="HOL Blocking Mitigation" id="hol-mitigation">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="760" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1100" height="760" as="geometry" />
        </mxCell>
        <mxCell id="title" value="HOL ブロッキングの解消アプローチ比較" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="36" as="geometry" />
        </mxCell>

        <mxCell id="h1Box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="h1Title" value="HTTP/1.1 (1997, RFC 2068)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#8a1a1a;" vertex="1" parent="1">
          <mxGeometry x="55" y="70" width="400" height="24" as="geometry" />
        </mxCell>
        <mxCell id="h1Desc" value="単一 TCP 接続上で逐次リクエスト／レスポンス。&#xa;パイプラインを使っても応答は投入順 → アプリ層 HOL ブロックが顕在化。&#xa;実装では並列接続 (6 コネクション/ホスト) で回避する慣習に。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="100" width="470" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h1State" value="アプリ層 HOL: 発生&#xa;TCP 層 HOL: 発生" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;fontStyle=1;fontColor=#8a1a1a;" vertex="1" parent="1">
          <mxGeometry x="55" y="180" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="h2Box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="60" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="h2Title" value="HTTP/2 (2015, RFC 7540)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#7a5d00;" vertex="1" parent="1">
          <mxGeometry x="575" y="70" width="400" height="24" as="geometry" />
        </mxCell>
        <mxCell id="h2Desc" value="単一 TCP 接続にバイナリフレーム多重化。複数ストリームを Stream ID で識別し&#xa;インターリーブ送信 → アプリ層 HOL は解消。&#xa;ただし TCP 層では依然として 1 セグメント欠落で全ストリームが停止する。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="575" y="100" width="470" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h2State" value="アプリ層 HOL: 解消&#xa;TCP 層 HOL: 残存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;fontStyle=1;fontColor=#7a5d00;" vertex="1" parent="1">
          <mxGeometry x="575" y="180" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="h3Box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="h3Title" value="HTTP/3 over QUIC (2022, RFC 9114 / 9000)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#3a8a3a;" vertex="1" parent="1">
          <mxGeometry x="55" y="300" width="450" height="24" as="geometry" />
        </mxCell>
        <mxCell id="h3Desc" value="UDP 上に独立した複数ストリームを実装。各ストリームが独自にロス検出と再送を行い、&#xa;あるストリームのロスが他ストリームの配送順に影響しない。&#xa;トランスポート層レベルで HOL ブロックを構造的に排除。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="330" width="470" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h3State" value="アプリ層 HOL: 解消&#xa;TCP/QUIC 層 HOL: 解消" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;fontStyle=1;fontColor=#3a8a3a;" vertex="1" parent="1">
          <mxGeometry x="55" y="410" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="voqBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="290" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="voqTitle" value="スイッチ側: VOQ (Virtual Output Queuing)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#2e5cb8;" vertex="1" parent="1">
          <mxGeometry x="575" y="300" width="450" height="24" as="geometry" />
        </mxCell>
        <mxCell id="voqDesc" value="入力ポート毎に「出力ポート別の N 本のキュー」を持つ。&#xa;先頭が混雑出力 2 を待つ間も、出力 3 行きのキューは独立に発射可能。&#xa;Crossbar スケジューラ (iSLIP 等) と組み合わせ理論最大スループット 100% を達成。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="575" y="330" width="470" height="60" as="geometry" />
        </mxCell>
        <mxCell id="voqState" value="スイッチ層 HOL: 解消" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;fontColor=#2e5cb8;" vertex="1" parent="1">
          <mxGeometry x="575" y="410" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="lessonBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="1020" height="210" as="geometry" />
        </mxCell>
        <mxCell id="lessonTitle" value="共通する解消パターン" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#b45a00;" vertex="1" parent="1">
          <mxGeometry x="55" y="530" width="400" height="24" as="geometry" />
        </mxCell>

        <mxCell id="p1" value="① 単一 FIFO を分割する&#xa;独立に進行できる単位 (ストリーム / 出力別キュー) を分け、&#xa;先頭待ちの影響範囲を局所化する。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="55" y="560" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="② 順序保証の単位を縮小する&#xa;「全体で順序保証」から「ストリーム内のみ順序保証」へ縮約。&#xa;一部ロスの影響を他フローに伝搬させない。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="560" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="③ スケジューリングを賢くする&#xa;先頭固定 (FIFO) を捨て、進めるものから進めるマッチング規律 (iSLIP / 多重化) を採用する。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="725" y="560" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="caveat" value="トレードオフ: ストリーム独立化はコネクション状態管理コスト・暗号鍵管理 (QUIC は 1-RTT)、&#xa;VOQ は実装複雑度とメモリ帯域 (N×N キュー) を増やす。「解消した」のではなく「コストを移し替えた」と捉える。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="55" y="675" width="990" height="48" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
