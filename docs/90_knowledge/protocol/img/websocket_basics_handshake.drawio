<mxfile>
  <diagram name="WebSocket Handshake" id="handshake">
    <mxGraphModel dx="1200" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="560" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="560" as="geometry" />
        </mxCell>
        <mxCell id="title" value="WebSocket ハンドシェイク（RFC 6455）" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="230" y="15" width="500" height="40" as="geometry" />
        </mxCell>
        <!-- Client -->
        <mxCell id="client" value="クライアント&#xa;（ブラウザ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="clientLine" value="" style="endArrow=none;dashed=1;strokeColor=#999999;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="120" as="sourcePoint" />
            <mxPoint x="160" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Server -->
        <mxCell id="server" value="サーバー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="70" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="serverLine" value="" style="endArrow=none;dashed=1;strokeColor=#999999;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="120" as="sourcePoint" />
            <mxPoint x="800" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 1: HTTP Upgrade Request -->
        <mxCell id="step1arrow" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="170" y="160" as="sourcePoint" />
            <mxPoint x="790" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step1label" value="① HTTP Upgrade リクエスト&#xa;GET /chat HTTP/1.1&#xa;Upgrade: websocket&#xa;Connection: Upgrade&#xa;Sec-WebSocket-Key: ..." style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;spacingLeft=6;spacingRight=6;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="280" y="130" width="250" height="80" as="geometry" />
        </mxCell>
        <!-- Step 2: HTTP 101 Switching Protocols -->
        <mxCell id="step2arrow" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="790" y="260" as="sourcePoint" />
            <mxPoint x="170" y="260" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step2label" value="② HTTP 101 Switching Protocols&#xa;Upgrade: websocket&#xa;Connection: Upgrade&#xa;Sec-WebSocket-Accept: ..." style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;spacingLeft=6;spacingRight=6;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="280" y="225" width="260" height="75" as="geometry" />
        </mxCell>
        <!-- Step 3: WebSocket Connection Established -->
        <mxCell id="wsZone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="140" y="330" width="680" height="170" as="geometry" />
        </mxCell>
        <mxCell id="wsZoneLabel" value="WebSocket 接続確立（全二重通信）" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="330" y="335" width="300" height="30" as="geometry" />
        </mxCell>
        <!-- Bidirectional messages -->
        <mxCell id="msg1" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="170" y="390" as="sourcePoint" />
            <mxPoint x="790" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="msg1label" value="③ テキスト / バイナリメッセージ" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="370" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="msg2" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="790" y="420" as="sourcePoint" />
            <mxPoint x="170" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="msg2label" value="③ テキスト / バイナリメッセージ" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="330" y="422" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ping" value="" style="endArrow=classic;strokeColor=#d79b00;strokeWidth=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="170" y="462" as="sourcePoint" />
            <mxPoint x="790" y="462" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="pinglabel" value="④ Ping / Pong（死活監視）" style="text;html=1;fontSize=10;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="350" y="448" width="260" height="16" as="geometry" />
        </mxCell>
        <mxCell id="pong" value="" style="endArrow=classic;strokeColor=#d79b00;strokeWidth=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="790" y="480" as="sourcePoint" />
            <mxPoint x="170" y="480" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
