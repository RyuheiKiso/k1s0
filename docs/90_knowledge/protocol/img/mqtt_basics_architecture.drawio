          <mxGeometry x="730" y="75" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="sub1" value="ダッシュボード&#xa;Subscriber" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="115" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sub2" value="アラート通知&#xa;Subscriber" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="235" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sub3" value="時系列DB保存&#xa;Subscriber" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="355" width="170" height="55" as="geometry" />
        </mxCell>

        <mxCell id="pArr1" value="PUBLISH" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;fontColor=#2e5cb8;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="210" y="142" as="sourcePoint" />
            <mxPoint x="360" y="210" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="pArr2" value="PUBLISH" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;fontColor=#2e5cb8;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="210" y="262" as="sourcePoint" />
            <mxPoint x="360" y="250" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="pArr3" value="PUBLISH" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;fontColor=#2e5cb8;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="210" y="382" as="sourcePoint" />
            <mxPoint x="360" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="sArr1" value="SUBSCRIBE: home/#" style="endArrow=classic;strokeColor=#82b366;strokeWidth=2;fontSize=10;fontColor=#3a8a3a;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="210" as="sourcePoint" />
            <mxPoint x="750" y="142" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sArr2" value="SUBSCRIBE: home/temperature" style="endArrow=classic;strokeColor=#82b366;strokeWidth=2;fontSize=10;fontColor=#3a8a3a;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="250" as="sourcePoint" />
            <mxPoint x="750" y="262" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sArr3" value="SUBSCRIBE: home/+" style="endArrow=classic;strokeColor=#82b366;strokeWidth=2;fontSize=10;fontColor=#3a8a3a;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="290" as="sourcePoint" />
            <mxPoint x="750" y="382" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="noteTitle" value="MQTT Pub/Sub の特徴" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="400" height="22" as="geometry" />
        </mxCell>
        <mxCell id="noteBody" value="• Publisher と Subscriber は互いを直接知らず、Broker を介したトピック名だけで通信する&#xa;• 1 つのメッセージが複数の Subscriber に同時配信される（fan-out）&#xa;• ワイルドカード（`+` 単一階層 / `#` 複数階層）で柔軟な購読が可能&#xa;• TCP 上で軽量な 2 byte ヘッダの PUBLISH パケットを送受信（帯域効率が高い）" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="515" width="880" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
