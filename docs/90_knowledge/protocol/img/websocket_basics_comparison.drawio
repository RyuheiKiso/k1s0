<mxfile>
  <diagram name="HTTP vs WebSocket" id="comparison">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="640" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="640" as="geometry" />
        </mxCell>
        <mxCell id="title" value="HTTP ポーリング vs WebSocket 通信モデル比較" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="180" y="15" width="600" height="40" as="geometry" />
        </mxCell>
        <!-- HTTP Polling Section -->
        <mxCell id="httpSection" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="430" height="550" as="geometry" />
        </mxCell>
        <mxCell id="httpTitle" value="HTTP ポーリング" style="text;html=1;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="145" y="80" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="httpClient" value="クライアント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="httpServer" value="サーバー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="120" width="120" height="40" as="geometry" />
        </mxCell>
        <!-- HTTP Request/Response pairs -->
        <mxCell id="httpCL" value="" style="endArrow=none;dashed=1;strokeColor=#aaaaaa;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="160" as="sourcePoint" />
            <mxPoint x="120" y="590" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="httpSL" value="" style="endArrow=none;dashed=1;strokeColor=#aaaaaa;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="160" as="sourcePoint" />
            <mxPoint x="370" y="590" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Req 1 -->
        <mxCell id="hReq1" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="190" as="sourcePoint" />
            <mxPoint x="360" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hReq1L" value="GET（データある？）" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="170" y="172" width="150" height="18" as="geometry" />
        </mxCell>
        <mxCell id="hRes1" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="215" as="sourcePoint" />
            <mxPoint x="130" y="215" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hRes1L" value="200 OK（データなし）" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="170" y="217" width="150" height="18" as="geometry" />
        </mxCell>
        <!-- Req 2 -->
        <mxCell id="hReq2" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="270" as="sourcePoint" />
            <mxPoint x="360" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hReq2L" value="GET（データある？）" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="170" y="252" width="150" height="18" as="geometry" />
        </mxCell>
        <mxCell id="hRes2" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="295" as="sourcePoint" />
            <mxPoint x="130" y="295" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hRes2L" value="200 OK（データなし）" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="170" y="297" width="150" height="18" as="geometry" />
        </mxCell>
        <!-- Req 3 -->
        <mxCell id="hReq3" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="350" as="sourcePoint" />
            <mxPoint x="360" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hReq3L" value="GET（データある？）" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="170" y="332" width="150" height="18" as="geometry" />
        </mxCell>
        <mxCell id="hRes3" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="375" as="sourcePoint" />
            <mxPoint x="130" y="375" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hRes3L" value="200 OK（データあり!）" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="170" y="377" width="150" height="18" as="geometry" />
        </mxCell>
        <!-- Waste indicator -->
        <mxCell id="waste" value="無駄な通信が多い" style="text;html=1;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="420" width="200" height="30" as="geometry" />
        </mxCell>
        <!-- HTTP characteristics -->
        <mxCell id="httpChars" value="特徴:&#xa;• リクエスト/レスポンス型（半二重）&#xa;• 定期的にサーバーへ問い合わせが必要&#xa;• データがなくても通信が発生する&#xa;• レイテンシが高い（HTTP ヘッダの往復）&#xa;• サーバーからプッシュできない" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="465" width="380" height="130" as="geometry" />
        </mxCell>
        <!-- WebSocket Section -->
        <mxCell id="wsSection" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="430" height="550" as="geometry" />
        </mxCell>
        <mxCell id="wsTitle" value="WebSocket" style="text;html=1;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="615" y="80" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="wsClient" value="クライアント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="120" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="wsServer" value="サーバー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="120" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="wsCL" value="" style="endArrow=none;dashed=1;strokeColor=#aaaaaa;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="160" as="sourcePoint" />
            <mxPoint x="590" y="590" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsSL" value="" style="endArrow=none;dashed=1;strokeColor=#aaaaaa;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="160" as="sourcePoint" />
            <mxPoint x="840" y="590" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Handshake -->
        <mxCell id="wsHS1" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="190" as="sourcePoint" />
            <mxPoint x="830" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsHS1L" value="HTTP Upgrade" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="660" y="172" width="110" height="18" as="geometry" />
        </mxCell>
        <mxCell id="wsHS2" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="830" y="215" as="sourcePoint" />
            <mxPoint x="600" y="215" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsHS2L" value="101 Switching" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="660" y="217" width="110" height="18" as="geometry" />
        </mxCell>
        <!-- Persistent connection zone -->
        <mxCell id="persistZone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6f6;strokeColor=#9673a6;dashed=1;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="245" width="290" height="200" as="geometry" />
        </mxCell>
        <mxCell id="persistLabel" value="持続的な全二重接続" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="635" y="248" width="160" height="20" as="geometry" />
        </mxCell>
        <!-- WS messages - bidirectional -->
        <mxCell id="wsM1" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="290" as="sourcePoint" />
            <mxPoint x="830" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsM1L" value="メッセージ送信" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="660" y="274" width="110" height="16" as="geometry" />
        </mxCell>
        <mxCell id="wsM2" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="830" y="320" as="sourcePoint" />
            <mxPoint x="600" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsM2L" value="サーバープッシュ" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="655" y="322" width="120" height="16" as="geometry" />
        </mxCell>
        <mxCell id="wsM3" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="830" y="355" as="sourcePoint" />
            <mxPoint x="600" y="355" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsM3L" value="サーバープッシュ" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="655" y="357" width="120" height="16" as="geometry" />
        </mxCell>
        <mxCell id="wsM4" value="" style="endArrow=classic;strokeColor=#6c8ebf;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="390" as="sourcePoint" />
            <mxPoint x="830" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsM4L" value="メッセージ送信" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="660" y="392" width="110" height="16" as="geometry" />
        </mxCell>
        <mxCell id="wsM5" value="" style="endArrow=classic;strokeColor=#82b366;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="830" y="420" as="sourcePoint" />
            <mxPoint x="600" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wsM5L" value="サーバープッシュ" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="655" y="422" width="120" height="16" as="geometry" />
        </mxCell>
        <!-- Efficient indicator -->
        <mxCell id="efficient" value="必要な時だけ通信" style="text;html=1;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="615" y="455" width="200" height="30" as="geometry" />
        </mxCell>
        <!-- WS characteristics -->
        <mxCell id="wsChars" value="特徴:&#xa;• 全二重通信（同時に送受信可能）&#xa;• 1 回のハンドシェイクで持続的接続&#xa;• サーバーから任意のタイミングでプッシュ&#xa;• 低レイテンシ（フレームヘッダは 2〜14 bytes）&#xa;• リアルタイム通信に最適" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="525" y="500" width="380" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
