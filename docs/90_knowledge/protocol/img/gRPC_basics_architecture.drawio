<mxfile>
  <diagram name="gRPC Architecture" id="arch1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="600" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1100" height="600" as="geometry"/>
        </mxCell>
        <!-- Title -->
        <mxCell id="title" value="gRPC 通信アーキテクチャ" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        <!-- Client Side -->
        <mxCell id="client_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="400" height="480" as="geometry"/>
        </mxCell>
        <mxCell id="client_label" value="クライアント側" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="140" y="90" width="200" height="30" as="geometry"/>
        </mxCell>
        <!-- Client Application -->
        <mxCell id="client_app" value="クライアント&#xa;アプリケーション" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="140" width="220" height="60" as="geometry"/>
        </mxCell>
        <!-- Generated Stub -->
        <mxCell id="client_stub" value="自動生成スタブ&#xa;（クライアントライブラリ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="250" width="220" height="60" as="geometry"/>
        </mxCell>
        <!-- Serialization -->
        <mxCell id="client_serial" value="Protocol Buffers&#xa;シリアライズ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="360" width="220" height="50" as="geometry"/>
        </mxCell>
        <!-- HTTP/2 Client -->
        <mxCell id="client_http2" value="HTTP/2 トランスポート" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="460" width="220" height="50" as="geometry"/>
        </mxCell>
        <!-- Server Side -->
        <mxCell id="server_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="660" y="80" width="400" height="480" as="geometry"/>
        </mxCell>
        <mxCell id="server_label" value="サーバー側" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="760" y="90" width="200" height="30" as="geometry"/>
        </mxCell>
        <!-- Server Application -->
        <mxCell id="server_app" value="サーバー&#xa;アプリケーション" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="140" width="220" height="60" as="geometry"/>
        </mxCell>
        <!-- Server Skeleton -->
        <mxCell id="server_skel" value="自動生成スケルトン&#xa;（サーバーインターフェース）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="250" width="220" height="60" as="geometry"/>
        </mxCell>
        <!-- Deserialization -->
        <mxCell id="server_serial" value="Protocol Buffers&#xa;デシリアライズ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="750" y="360" width="220" height="50" as="geometry"/>
        </mxCell>
        <!-- HTTP/2 Server -->
        <mxCell id="server_http2" value="HTTP/2 トランスポート" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="460" width="220" height="50" as="geometry"/>
        </mxCell>
        <!-- Proto file -->
        <mxCell id="proto_file" value=".proto ファイル&#xa;（サービス定義 + メッセージ定義）" style="shape=document;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;size=0.15;" vertex="1" parent="1">
          <mxGeometry x="440" y="80" width="220" height="70" as="geometry"/>
        </mxCell>
        <!-- Arrows: App to Stub -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="client_app" target="client_stub">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a1_label" value="メソッド呼び出し" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#555555;" vertex="1" connectable="0" parent="a1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="client_stub" target="client_serial">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="client_serial" target="client_http2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Server arrows -->
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="server_app" target="server_skel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4_label" value="ハンドラ実装" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#555555;" vertex="1" connectable="0" parent="a4">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="server_skel" target="server_serial">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="server_serial" target="server_http2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Network arrow -->
        <mxCell id="net1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#B85450;strokeWidth=3;fillColor=#F8CECC;" edge="1" parent="1" source="client_http2" target="server_http2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="net1_label" value="HTTP/2 バイナリフレーム&#xa;（多重化・双方向ストリーミング）" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#B85450;fontStyle=1;" vertex="1" connectable="0" parent="net1">
          <mxGeometry x="-0.05" relative="1" as="geometry"><mxPoint y="-15" as="offset"/></mxGeometry>
        </mxCell>
        <!-- Proto to Stub -->
        <mxCell id="p1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;strokeColor=#D6B656;strokeWidth=2;dashed=1;" edge="1" parent="1" source="proto_file" target="client_stub">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="440" y="170"/>
              <mxPoint x="410" y="170"/>
              <mxPoint x="410" y="230"/>
              <mxPoint x="380" y="230"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p1_label" value="コード生成" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#D6B656;" vertex="1" connectable="0" parent="p1">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint x="-20" as="offset"/></mxGeometry>
        </mxCell>
        <!-- Proto to Skeleton -->
        <mxCell id="p2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;strokeColor=#D6B656;strokeWidth=2;dashed=1;" edge="1" parent="1" source="proto_file" target="server_skel">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="660" y="170"/>
              <mxPoint x="700" y="170"/>
              <mxPoint x="700" y="230"/>
              <mxPoint x="720" y="230"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p2_label" value="コード生成" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#D6B656;" vertex="1" connectable="0" parent="p2">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint x="20" as="offset"/></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>