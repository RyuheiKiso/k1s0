<mxfile>
  <diagram name="gRPC RPC Patterns" id="rpc1">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="750" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1100" height="750" as="geometry"/>
        </mxCell>
        <!-- Title -->
        <mxCell id="title" value="gRPC の 4 つの通信パターン" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="15" width="500" height="40" as="geometry"/>
        </mxCell>
        <!-- ===== Pattern 1: Unary ===== -->
        <mxCell id="p1_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="500" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="p1_title" value="① Unary RPC（単項 RPC）" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="50" y="75" width="300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1_desc" value="1 リクエスト → 1 レスポンス（最も基本的なパターン）" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="400" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p1_client" value="Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="135" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p1_server" value="Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="135" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p1_req" style="rounded=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=2;" edge="1" parent="1" source="p1_client" target="p1_server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_req_l" value="Request" style="edgeLabel;html=1;align=center;verticalAlign=bottom;fontSize=10;fontColor=#82B366;" vertex="1" connectable="0" parent="p1_req">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="-5" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="p1_res" style="rounded=1;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" parent="1" source="p1_server" target="p1_client">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_res_l" value="Response" style="edgeLabel;html=1;align=center;verticalAlign=top;fontSize=10;fontColor=#6C8EBF;" vertex="1" connectable="0" parent="p1_res">
          <mxGeometry x="0.1" relative="1" as="geometry"><mxPoint y="5" as="offset"/></mxGeometry>
        </mxCell>
        <!-- ===== Pattern 2: Server Streaming ===== -->
        <mxCell id="p2_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="570" y="70" width="500" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="p2_title" value="② Server Streaming RPC" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="590" y="75" width="300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p2_desc" value="1 リクエスト → 複数レスポンス（サーバーがストリームで返す）" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="590" y="100" width="450" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p2_client" value="Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="135" width="120" height="50" as="geometry"/>
