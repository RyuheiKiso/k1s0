        <mxCell id="p2_res1_l" value="Response 1, 2, 3 ..." style="edgeLabel;html=1;align=center;verticalAlign=top;fontSize=10;fontColor=#6C8EBF;" vertex="1" connectable="0" parent="p2_res1">
          <mxGeometry x="0.1" relative="1" as="geometry"><mxPoint y="5" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="p2_stream_icon" value="≋" style="text;html=1;fontSize=18;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="830" y="155" width="30" height="20" as="geometry"/>
