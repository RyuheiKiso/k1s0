        <mxCell id="p4_stream_icon1" value="≋" style="text;html=1;fontSize=18;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="795" y="305" width="30" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p4_stream_icon2" value="≋" style="text;html=1;fontSize=18;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="795" y="340" width="30" height="20" as="geometry"/>
        </mxCell>
        <!-- ===== Legend ===== -->
