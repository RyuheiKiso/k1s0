        <mxCell id="proto1_code" value="rpc GetUser(GetUserRequest) returns (User) {}" style="text;html=1;fontSize=12;fontFamily=Courier New;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
