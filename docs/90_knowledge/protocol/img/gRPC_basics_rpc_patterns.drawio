        <mxCell id="p2_req" style="rounded=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=2;" edge="1" parent="1" source="p2_client" target="p2_server">
          <mxGeometry relative="1" as="geometry"/>
