        </mxCell>
        <mxCell id="p4_desc" value="複数リクエスト ↔ 複数レスポンス（双方向ストリーム）" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
