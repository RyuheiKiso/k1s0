        </mxCell>
        <!-- ===== Pattern 4: Bidirectional Streaming ===== -->
        <mxCell id="p4_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="570" y="240" width="500" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="p4_title" value="④ Bidirectional Streaming RPC" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
