        <!-- ===== Pattern 3: Client Streaming ===== -->
        <mxCell id="p3_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="30" y="240" width="500" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="p3_title" value="③ Client Streaming RPC" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="50" y="245" width="300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p3_desc" value="複数リクエスト → 1 レスポンス（クライアントがストリームで送る）" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="50" y="270" width="450" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p3_client" value="Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="305" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p3_server" value="Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="305" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p3_req" style="rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=2;" edge="1" parent="1" source="p3_client" target="p3_server">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p3_req_l" value="Request 1, 2, 3 ..." style="edgeLabel;html=1;align=center;verticalAlign=bottom;fontSize=10;fontColor=#82B366;" vertex="1" connectable="0" parent="p3_req">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="-5" as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="p3_stream_icon" value="≋" style="text;html=1;fontSize=18;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="255" y="310" width="30" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p3_res" style="rounded=1;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" parent="1" source="p3_server" target="p3_client">
