        <mxCell id="q0title" value="QoS 0: At most once&#xa;（最大 1 回）" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#01579b;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="q0pub" value="Publisher" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="140" width="100" height="35" as="geometry" />
