        <mxCell id="q2use" value="用途: 課金・決済・制御命令&#xa;重複も欠損も許されない場合" style="text;html=1;fontSize=10;fontStyle=2;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#880e4f;spacingLeft=10;" vertex="1" parent="1">
