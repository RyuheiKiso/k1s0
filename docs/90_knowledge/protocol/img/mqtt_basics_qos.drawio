        <mxCell id="q0m1L" value="PUBLISH" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#2e5cb8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="125" y="198" width="90" height="18" as="geometry" />
        </mxCell>
        <mxCell id="q0note" value="• ACK なし&#xa;• 「投げっぱなし」方式&#xa;• ネットワーク障害時は&#xa;  メッセージが消失する&#xa;• 最も高速・軽量&#xa;• TCP レイヤの保証のみ" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="35" y="440" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="q0use" value="用途: センサーの定期送信など&#xa;多少の欠損を許容できる場合" style="text;html=1;fontSize=10;fontStyle=2;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#01579b;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="35" y="560" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="q1sec" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f9a825;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="330" y="70" width="300" height="550" as="geometry" />
        </mxCell>
        <mxCell id="q1title" value="QoS 1: At least once&#xa;（最低 1 回）" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="340" y="80" width="280" height="40" as="geometry" />
