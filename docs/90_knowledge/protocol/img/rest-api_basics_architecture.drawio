<mxfile>
  <diagram name="REST API 通信モデル">
    <mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="500">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="820" height="500" as="geometry" />
        </mxCell>
        <mxCell id="title" value="REST API リクエスト / レスポンスの流れ" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="210" y="15" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="client" value="&lt;b&gt;クライアント&lt;/b&gt;&lt;br&gt;ブラウザ / モバイル / 他サービス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="server" value="&lt;b&gt;REST API サーバー&lt;/b&gt;&lt;br&gt;リソースを管理・提供" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="reqArrow" value="" style="endArrow=classic;html=1;strokeColor=#B85450;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="210" y="100" as="sourcePoint" />
            <mxPoint x="600" y="100" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="reqLabel" value="HTTP リクエスト" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="72" width="130" height="24" as="geometry" />
        </mxCell>
        <mxCell id="resArrow" value="" style="endArrow=classic;html=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="127" as="sourcePoint" />
            <mxPoint x="210" y="127" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="resLabel" value="HTTP レスポンス" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="132" width="130" height="24" as="geometry" />
        </mxCell>
        <mxCell id="reqDetail" value="&lt;b&gt;リクエストの構成要素&lt;/b&gt;&lt;br&gt;● HTTP メソッド: GET / POST / PUT / DELETE&lt;br&gt;● URL: /users/123&lt;br&gt;● ヘッダー: Content-Type, Authorization&lt;br&gt;● ボディ: JSON データ（POST / PUT 時）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="185" width="350" height="100" as="geometry" />
        </mxCell>
        <mxCell id="resDetail" value="&lt;b&gt;レスポンスの構成要素&lt;/b&gt;&lt;br&gt;● ステータスコード: 200, 201, 404, 500&lt;br&gt;● ヘッダー: Content-Type, Cache-Control&lt;br&gt;● ボディ: JSON / XML（リソースの表現）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="185" width="350" height="100" as="geometry" />
        </mxCell>
        <mxCell id="principleTitle" value="REST の 6 つの制約（Fielding の定義）" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="220" y="310" width="380" height="25" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="&lt;b&gt;① クライアント・サーバー&lt;/b&gt;&lt;br&gt;UI とデータ管理を分離" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="350" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="&lt;b&gt;② ステートレス&lt;/b&gt;&lt;br&gt;各リクエストが完結" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="350" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="&lt;b&gt;③ キャッシュ可能&lt;/b&gt;&lt;br&gt;レスポンスのキャッシュ可否を明示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="350" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="&lt;b&gt;④ 統一インターフェース&lt;/b&gt;&lt;br&gt;HTTP メソッドで操作を統一" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="610" y="350" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="&lt;b&gt;⑤ 階層化システム&lt;/b&gt;&lt;br&gt;プロキシ・LB を透過的に配置可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="420" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c6" value="&lt;b&gt;⑥ コードオンデマンド（任意）&lt;/b&gt;&lt;br&gt;必要に応じて実行可能コードを転送" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="420" width="230" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
