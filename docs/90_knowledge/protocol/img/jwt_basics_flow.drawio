<mxfile host="Electron" modified="2026-04-28T00:00:00.000Z" agent="claude-code" version="24.0.0">
  <diagram id="jwt-flow" name="JWT の発行と検証フロー">
    <mxGraphModel dx="900" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="JWT の発行と検証フロー (JWS / RS256 を例に)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="認可サーバが秘密鍵で署名し、API サーバが公開鍵で検証する。鍵を共有しないため、API サーバの侵害がトークン偽造につながらない。" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="820" height="24" as="geometry" />
        </mxCell>
        <mxCell id="client" value="Client (利用側)&#10;&#10;・SPA / モバイル&#10;・別サービス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="auth" value="Authorization Server (認可サーバ)&#10;&#10;・資格情報を検証&#10;・秘密鍵で署名&#10;・JWT を発行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="120" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="api" value="API Server (リソースサーバ)&#10;&#10;・公開鍵で検証&#10;・exp / iss / aud を検査&#10;・許可された場合のみ応答" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="120" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="(1) ログイン: ID / パスワード等" style="endArrow=classic;html=1;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;strokeWidth=2;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="client" target="auth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="(2) JWT を返却" style="endArrow=classic;html=1;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;strokeWidth=2;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="auth" target="client">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="(3) Authorization: Bearer &lt;JWT&gt;" style="endArrow=classic;html=1;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;strokeWidth=2;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="220" y="225" as="sourcePoint" />
            <mxPoint x="700" y="225" as="targetPoint" />
            <Array as="points">
              <mxPoint x="450" y="305" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="step4" value="(4) JWKS で公開鍵を取得 (起動時 / TTL 付きキャッシュ)" style="endArrow=classic;html=1;rounded=0;strokeColor=#9673a6;fontSize=11;labelBackgroundColor=#FFFFFF;strokeWidth=2;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="api" target="auth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="verify" value="検証ステップ (API Server 側)&#10;&#10;1. 文字列を `.` で分割し Header / Payload / Signature を取り出す&#10;2. Header.alg が許可リストに含まれるか確認 (none は拒否)&#10;3. kid に対応する公開鍵を JWKS から取得&#10;4. 公開鍵で Signature を再計算し一致するか検証&#10;5. exp (期限切れでないか) と nbf (有効開始) を確認&#10;6. iss (発行者) と aud (受取人) が想定通りか確認&#10;7. 全て通った場合のみリクエストを受理" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="why_box" value="なぜ非対称鍵 (RS256 / ES256) が好まれるか&#10;&#10;・対称鍵 (HS256) では検証側にも秘密鍵が必要&#10;・検証側が複数サービスに分散すると鍵流出リスクが線形に増える&#10;・非対称鍵なら公開鍵だけ配ればよく、API サーバ侵害でも偽造されない&#10;・JWKS エンドポイントで kid 単位の鍵ローテーションが可能" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="380" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="凡例: 実線 = 同期リクエスト, 破線 = レスポンスまたは事前取得" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#f5f5f5;strokeColor=#666666;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="610" width="820" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
