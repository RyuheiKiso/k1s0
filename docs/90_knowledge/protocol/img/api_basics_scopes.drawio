        <mxCell id="lib_b" value="呼び出し範囲&#10;同一プロセス内&#10;&#10;通信形態&#10;関数 / メソッドの直接呼び出し&#10;&#10;典型例&#10;std::Vec::push&#10;tokio::spawn&#10;serde_json::to_string&#10;&#10;典型レイテンシ&#10;ナノ秒オーダー&#10;&#10;故障の中心&#10;引数不正・パニック・型違反" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#444444;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=12;" vertex="1" parent="1">
