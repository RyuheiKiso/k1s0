<mxfile>
  <diagram name="RTT Components" id="rtt-components">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="640" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="640" as="geometry" />
        </mxCell>
        <mxCell id="title" value="RTT を構成する 4 つの遅延要素" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="180" y="15" width="600" height="40" as="geometry" />
        </mxCell>

        <mxCell id="transBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="transTitle" value="① 送信遅延 (Transmission Delay)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#2e5cb8;" vertex="1" parent="1">
          <mxGeometry x="75" y="90" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="transFormula" value="時間 ＝ パケットサイズ ÷ 回線帯域" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="75" y="120" width="390" height="36" as="geometry" />
        </mxCell>
        <mxCell id="transDesc" value="NIC がパケットを最後のビットまで回線に押し出すのに要する時間。&#xa;1 Gbps の回線に 1500 byte のパケットを載せるなら約 12 µs。&#xa;帯域を増やすか、パケットを小さくすると短縮できる。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="75" y="165" width="395" height="100" as="geometry" />
        </mxCell>

        <mxCell id="propBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="propTitle" value="② 伝播遅延 (Propagation Delay)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#3a8a3a;" vertex="1" parent="1">
          <mxGeometry x="515" y="90" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="propFormula" value="時間 ＝ 距離 ÷ 伝送速度（≒ 光速の 2/3）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="515" y="120" width="390" height="36" as="geometry" />
        </mxCell>
        <mxCell id="propDesc" value="ビットが物理媒体上を移動する時間。地理距離に比例する物理下限。&#xa;東京 ↔ 大阪 (≒ 400 km) で往復 約 4 ms、東京 ↔ 米西海岸で約 100 ms。&#xa;回線を増速しても短縮できない（距離と光速は変わらない）。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="515" y="165" width="395" height="100" as="geometry" />
        </mxCell>

        <mxCell id="queueBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="queueTitle" value="③ キューイング遅延 (Queuing Delay)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#7a5d00;" vertex="1" parent="1">
          <mxGeometry x="75" y="320" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="queueFormula" value="時間 ＝ 経路上ルータの送信バッファで待つ時間の総和" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="75" y="350" width="390" height="36" as="geometry" />
        </mxCell>
        <mxCell id="queueDesc" value="ルータのバッファに先着のパケットが並んでいる場合、自分が送出されるまで&#xa;待機する時間。経路の混雑度に応じて変動し、RTT の揺らぎ（ジッタ）の&#xa;主要因となる。輻輳が深まるとパケット破棄（Tail Drop, AQM）も発生する。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="75" y="395" width="395" height="100" as="geometry" />
        </mxCell>

        <mxCell id="procBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="310" width="420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="procTitle" value="④ 処理遅延 (Processing Delay)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#b45a00;" vertex="1" parent="1">
          <mxGeometry x="515" y="320" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="procFormula" value="時間 ＝ ルータ・エンドポイント CPU での処理時間" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="515" y="350" width="390" height="36" as="geometry" />
        </mxCell>
        <mxCell id="procDesc" value="パケットの宛先を調べ転送経路を決定する時間（ルータ）、&#xa;あるいは上位プロトコルで要求を解釈し応答を組み立てる時間（サーバ）。&#xa;現代のハードウェアでは µs オーダーが一般的だが、TLS 復号や重い処理で伸びる。" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="515" y="395" width="395" height="100" as="geometry" />
        </mxCell>

        <mxCell id="sumBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="860" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sumTitle" value="RTT の合計式" style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#8a1a1a;" vertex="1" parent="1">
          <mxGeometry x="75" y="548" width="200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="sumFormula" value="RTT ≈ 2 × ( 送信遅延 ＋ 伝播遅延 ＋ キューイング遅延 ) ＋ 処理遅延（両端）" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="75" y="575" width="830" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
