        </mxCell>
        <mxCell id="vm" value="VM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="655" y="525" width="60" height="40" as="geometry" />
        </mxCell>
        <mxCell id="db" value="DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="525" width="60" height="40" as="geometry" />
        </mxCell>
        <mxCell id="net" value="Network" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="805" y="525" width="60" height="40" as="geometry" />
        </mxCell>
        <!-- Arrows -->
        <!-- User -> HCL: writes -->
        <mxCell id="e1" value="記述する" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;fontColor=#333333;fontSize=11;" edge="1" parent="1" source="user" target="hcl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- User -> Core: コマンド実行 -->
        <mxCell id="e2" value="terraform コマンド" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333333;fontColor=#333333;fontSize=11;" edge="1" parent="1" source="user" target="core">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Core -> HCL: reads -->
        <mxCell id="e3" value="読み込む" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333333;fontColor=#333333;fontSize=11;" edge="1" parent="1" source="core" target="hcl">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="250" y="380" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Core -> State: 同期 -->
        <mxCell id="e4" value="状態を記録" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;fontColor=#333333;fontSize=11;" edge="1" parent="1" source="core" target="state">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Core -> Providers: API呼び出し -->
        <mxCell id="e5" value="API 呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333333;fontColor=#333333;fontSize=11;" edge="1" parent="1" source="core" target="providers_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Providers -> Cloud Resources -->
        <mxCell id="e6" value="リソースを&#xa;作成・変更・削除" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;fontColor=#333333;fontSize=11;" edge="1" parent="1" source="providers_group" target="cloud_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Legend -->
