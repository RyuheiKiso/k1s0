<mxfile host="draw.io">
  <diagram name="Terraform Architecture" id="terraform-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="640" as="geometry" />
        </mxCell>
        <!-- Title -->
        <mxCell id="title" value="Terraform アーキテクチャ" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="340" y="20" width="280" height="40" as="geometry" />
        </mxCell>
        <!-- User -->
        <mxCell id="user" value="開発者" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="80" height="80" as="geometry" />
        </mxCell>
        <!-- HCL Config -->
        <mxCell id="hcl" value="HCL 設定ファイル&#xa;(.tf)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="120" height="80" as="geometry" />
        </mxCell>
        <!-- Terraform Core -->
        <mxCell id="core" value="Terraform Core&#xa;（CLI / エンジン）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="180" width="180" height="70" as="geometry" />
        </mxCell>
        <!-- State File -->
        <mxCell id="state" value="State ファイル&#xa;(.tfstate)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="340" width="120" height="80" as="geometry" />
        </mxCell>
        <!-- Providers -->
        <mxCell id="providers_group" value="Providers（プラグイン）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;verticalAlign=top;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="620" y="100" width="280" height="300" as="geometry" />
        </mxCell>
        <!-- AWS Provider -->
        <mxCell id="aws" value="AWS&#xa;Provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="650" y="150" width="100" height="50" as="geometry" />
        </mxCell>
        <!-- Azure Provider -->
        <mxCell id="azure" value="Azure&#xa;Provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="150" width="100" height="50" as="geometry" />
        </mxCell>
        <!-- GCP Provider -->
        <mxCell id="gcp" value="GCP&#xa;Provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="650" y="230" width="100" height="50" as="geometry" />
        </mxCell>
        <!-- K8s Provider -->
        <mxCell id="k8s" value="Kubernetes&#xa;Provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="230" width="100" height="50" as="geometry" />
        </mxCell>
        <!-- Other Provider -->
        <mxCell id="other" value="その他&#xa;1000+ Providers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="710" y="310" width="120" height="50" as="geometry" />
        </mxCell>
        <!-- Cloud Resources -->
        <mxCell id="resources_label" value="クラウドリソース&#xa;（実インフラ）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="690" y="470" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="cloud_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
