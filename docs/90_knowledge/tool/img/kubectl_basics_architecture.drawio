<mxfile>
  <diagram name="kubectl Architecture" id="ka">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="500" background="#FFFFFF">
      <root>
