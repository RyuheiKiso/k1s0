<mxfile>
  <diagram name="GitHub Actions 実行フロー" id="flow">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="600" pageHeight="510" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="600" height="510" as="geometry"/>
        </mxCell>
        <mxCell id="f1" value="1. 開発者がコードを push" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="30" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f2" value="2. GitHub がイベントを検出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="130" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f3" value="3. ワークフローファイルを検索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="230" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f4" value="4. Runner を割り当て" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="330" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f5" value="5. ステップを順次実行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="430" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t1" value="git push / PR 作成" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="430" y="70" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="on: セクション照合" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="430" y="170" width="130" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value=".github/workflows/*.yml" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="430" y="270" width="160" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t4" value="runs-on: で指定" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="430" y="370" width="110" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t5" value="uses: / run: で定義" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="430" y="470" width="130" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="fa1" style="rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="f1" target="f2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="fa2" style="rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="f2" target="f3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="fa3" style="rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="f3" target="f4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="fa4" style="rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="f4" target="f5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
