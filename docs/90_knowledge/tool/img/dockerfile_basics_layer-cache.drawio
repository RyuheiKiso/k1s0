<mxfile>
  <diagram name="Layer Cache" id="lc">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="540" background="#FFFFFF">
      <root>
