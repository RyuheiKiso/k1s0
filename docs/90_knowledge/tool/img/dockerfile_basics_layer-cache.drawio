        </mxCell>
        <mxCell id="title" value="レイヤキャッシュの仕組み（app.py だけを変更した場合）" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="800" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="df-title" value="&lt;b&gt;Dockerfile&lt;/b&gt;" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="df" value="FROM python:3.12-slim&#10;COPY requirements.txt .&#10;RUN pip install -r requirements.txt&#10;COPY app.py ." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;verticalAlign=middle;fontFamily=Courier New;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="280" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="b1-title" value="&lt;b&gt;1 回目のビルド&lt;/b&gt;&lt;br&gt;(全レイヤを新規生成)" style="text;html=1;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
