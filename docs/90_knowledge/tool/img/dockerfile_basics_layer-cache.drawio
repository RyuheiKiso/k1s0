        <mxCell id="b1l4" value="Layer 4: COPY app.py" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="370" y="270" width="260" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="b2-title" value="&lt;b&gt;2 回目のビルド&lt;/b&gt;&lt;br&gt;(app.py 変更後)" style="text;html=1;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
