<mxfile>
  <diagram name="Kustomize Build Pipeline" id="kustomize-build-pipeline">
    <mxGraphModel dx="1200" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="440" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="440" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Kustomize: ビルドパイプラインの処理フロー" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="15" width="560" height="40" as="geometry" />
        </mxCell>
        <!-- Step 1: リソース読み込み -->
        <mxCell id="step1" value="1. リソース読み込み" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step1-desc" value="resources に指定された&#xa;YAML ファイルを収集" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE599;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="145" width="180" height="50" as="geometry" />
        </mxCell>
        <!-- Step 2: ジェネレータ -->
        <mxCell id="step2" value="2. ジェネレータ実行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="80" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step2-desc" value="configMapGenerator&#xa;secretGenerator で&#xa;リソースを自動生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B6D7A8;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="145" width="180" height="55" as="geometry" />
        </mxCell>
        <!-- Step 3: トランスフォーマー -->
        <mxCell id="step3" value="3. トランスフォーマー適用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step3-desc" value="namePrefix / namespace&#xa;labels / annotations&#xa;images / replicas を変換" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B4C7E7;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="145" width="200" height="55" as="geometry" />
        </mxCell>
        <!-- Step 4: パッチ適用 -->
        <mxCell id="step4" value="4. パッチ適用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="80" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step4-desc" value="Strategic Merge Patch&#xa;JSON 6902 Patch で&#xa;リソースを部分変更" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D7CDE2;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="145" width="170" height="55" as="geometry" />
        </mxCell>
        <!-- Step 5: 最終出力 -->
        <mxCell id="step5" value="5. 最終 YAML 出力" style="shape=document;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="290" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step5-desc" value="kubectl apply -f - で&#xa;クラスタに適用可能" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="370" y="360" width="220" height="35" as="geometry" />
        </mxCell>
        <!-- Arrows between steps -->
        <mxCell id="arrow-1-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-2-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-3-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Arrow from step4 down to output -->
        <mxCell id="arrow-4-5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="835" y="250" />
              <mxPoint x="620" y="250" />
              <mxPoint x="620" y="305" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-4-5-label" value="kustomize build" style="edgeLabel;html=1;fontSize=12;fontColor=#B85450;fontStyle=1;" vertex="1" connectable="0" parent="arrow-4-5">
          <mxGeometry x="-0.3" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- kubectl apply -->
        <mxCell id="kubectl" value="kubectl apply -k ./" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;fontStyle=2;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="kubectl-desc" value="kubectl に統合済み&#xa;kustomize build を内部で実行" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="30" y="350" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="arrow-kubectl" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=1;endArrow=block;endFill=1;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="kubectl" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Legend -->
        <mxCell id="legend-1" value="■ 読み込み" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="40" y="410" width="90" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-2" value="■ ジェネレータ" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="150" y="410" width="110" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-3" value="■ トランスフォーマー" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="280" y="410" width="140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-4" value="■ パッチ" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="440" y="410" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-5" value="■ 出力" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="540" y="410" width="60" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>