<mxfile>
  <diagram name="Kustomize Workflow" id="kustomize-workflow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="540" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Kustomize: Base / Overlay ワークフロー" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="230" y="20" width="500" height="40" as="geometry" />
        </mxCell>
        <!-- Base グループ -->
        <mxCell id="base-group" value="base/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;verticalAlign=top;fontStyle=1;fontSize=14;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="240" height="280" as="geometry" />
        </mxCell>
        <mxCell id="base-kustomization" value="kustomization.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE599;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="140" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="base-deploy" value="deployment.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE599;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="200" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="base-svc" value="service.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE599;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="260" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="base-label" value="共通リソース定義" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="70" y="320" width="180" height="30" as="geometry" />
        </mxCell>
        <!-- Overlay Dev -->
        <mxCell id="dev-group" value="overlays/dev/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;verticalAlign=top;fontStyle=1;fontSize=14;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="360" y="90" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="dev-kustomization" value="kustomization.yaml&#xa;(resources: ../../base)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B6D7A8;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="140" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="dev-patch" value="replica-patch.yaml&#xa;(replicas: 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B6D7A8;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="200" width="180" height="40" as="geometry" />
        </mxCell>
        <!-- Overlay Prod -->
        <mxCell id="prod-group" value="overlays/prod/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;verticalAlign=top;fontStyle=1;fontSize=14;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="360" y="290" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="prod-kustomization" value="kustomization.yaml&#xa;(resources: ../../base)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B4C7E7;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="340" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="prod-patch" value="replica-patch.yaml&#xa;(replicas: 10)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B4C7E7;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="400" width="180" height="40" as="geometry" />
        </mxCell>
        <!-- kustomize build -->
        <mxCell id="build-dev" value="kustomize build&#xa;overlays/dev" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="build-prod" value="kustomize build&#xa;overlays/prod" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="310" width="200" height="60" as="geometry" />
        </mxCell>
        <!-- Output -->
        <mxCell id="output-dev" value="dev 用&#xa;最終 YAML" style="shape=document;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="735" y="200" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="output-prod" value="prod 用&#xa;最終 YAML" style="shape=document;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="735" y="400" width="130" height="60" as="geometry" />
        </mxCell>
        <!-- Arrows: base to overlays -->
        <mxCell id="arrow-base-dev" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="base-group" target="dev-group">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="160" />
              <mxPoint x="320" y="175" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-base-dev-label" value="参照" style="edgeLabel;html=1;fontSize=11;fontColor=#82B366;fontStyle=1;" vertex="1" connectable="0" parent="arrow-base-dev">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-base-prod" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="base-group" target="prod-group">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="300" />
              <mxPoint x="320" y="375" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-base-prod-label" value="参照" style="edgeLabel;html=1;fontSize=11;fontColor=#6C8EBF;fontStyle=1;" vertex="1" connectable="0" parent="arrow-base-prod">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- Arrows: overlays to build -->
        <mxCell id="arrow-dev-build" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="dev-group" target="build-dev">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-prod-build" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="prod-group" target="build-prod">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Arrows: build to output -->
        <mxCell id="arrow-build-dev-out" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="build-dev" target="output-dev">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-build-dev-out-label" value="生成" style="edgeLabel;html=1;fontSize=11;fontColor=#B85450;fontStyle=1;" vertex="1" connectable="0" parent="arrow-build-dev-out">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow-build-prod-out" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="build-prod" target="output-prod">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-build-prod-out-label" value="生成" style="edgeLabel;html=1;fontSize=11;fontColor=#B85450;fontStyle=1;" vertex="1" connectable="0" parent="arrow-build-prod-out">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- Legend -->
        <mxCell id="legend-base" value="■ Base（共通定義）" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="legend-dev" value="■ Overlay/dev（開発環境）" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="220" y="490" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="legend-prod" value="■ Overlay/prod（本番環境）" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="440" y="490" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="legend-build" value="■ ビルド処理" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="660" y="490" width="120" height="25" as="geometry" />
        </mxCell>
        <mxCell id="legend-output" value="■ 出力" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="800" y="490" width="120" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>