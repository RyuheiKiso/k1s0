<mxfile host="app.diagrams.net">
  <diagram name="kubeadm クラスタ構築フロー" id="kubeadm-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1100" height="700" as="geometry" />
        </mxCell>

        <!-- タイトル -->
        <mxCell id="title" value="kubeadm によるクラスタ構築フロー" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="15" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- ===== 左側: kubeadm init フェーズ ===== -->
        <mxCell id="init-group" value="kubeadm init（Control Plane ノード）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=5;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="480" height="580" as="geometry" />
        </mxCell>

        <!-- Phase 1: Preflight -->
        <mxCell id="phase1" value="1. Preflight Checks&#xa;（前提条件の検証）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAEEF3;strokeColor=#5B9BD5;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="400" height="45" as="geometry" />
        </mxCell>

        <!-- Phase 2: Certificates -->
        <mxCell id="phase2" value="2. 証明書の生成&#xa;（CA, API Server, kubelet 等の TLS 証明書）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAEEF3;strokeColor=#5B9BD5;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="400" height="45" as="geometry" />
        </mxCell>

        <!-- Phase 3: kubeconfig -->
        <mxCell id="phase3" value="3. kubeconfig ファイルの生成&#xa;（admin.conf, kubelet.conf, scheduler.conf 等）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAEEF3;strokeColor=#5B9BD5;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="400" height="45" as="geometry" />
        </mxCell>

        <!-- Phase 4: Static Pods -->
        <mxCell id="phase4" value="4. Static Pod マニフェスト生成&#xa;（kube-apiserver, kube-controller-manager, kube-scheduler, etcd）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#70AD47;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="400" height="50" as="geometry" />
        </mxCell>

        <!-- Phase 5: kubelet start -->
        <mxCell id="phase5" value="5. kubelet 起動&#xa;（Static Pod として Control Plane コンポーネントを起動）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#70AD47;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="405" width="400" height="45" as="geometry" />
        </mxCell>

        <!-- Phase 6: Addons -->
        <mxCell id="phase6" value="6. アドオンのインストール&#xa;（CoreDNS, kube-proxy）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#70AD47;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="475" width="400" height="45" as="geometry" />
        </mxCell>

        <!-- Phase 7: Bootstrap Token -->
        <mxCell id="phase7" value="7. Bootstrap Token 生成&#xa;（Worker Node の join 用トークン出力）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E57373;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="545" width="400" height="50" as="geometry" />
        </mxCell>

        <!-- 矢印: init フェーズ間 -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="phase1" target="phase2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="phase2" target="phase3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="phase3" target="phase4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="phase4" target="phase5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="phase5" target="phase6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="phase6" target="phase7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== 右側: kubeadm join フェーズ ===== -->
        <mxCell id="join-group" value="kubeadm join（Worker ノード）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#66BB6A;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=5;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="600" y="70" width="460" height="430" as="geometry" />
        </mxCell>

        <!-- Join Phase 1 -->
        <mxCell id="jphase1" value="1. Preflight Checks&#xa;（前提条件の検証）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAEEF3;strokeColor=#5B9BD5;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="120" width="380" height="45" as="geometry" />
        </mxCell>

        <!-- Join Phase 2 -->
        <mxCell id="jphase2" value="2. TLS Bootstrap&#xa;（Bootstrap Token で API Server に接続し証明書を取得）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAEEF3;strokeColor=#5B9BD5;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="195" width="380" height="50" as="geometry" />
        </mxCell>

        <!-- Join Phase 3 -->
        <mxCell id="jphase3" value="3. kubelet 設定の取得&#xa;（Control Plane から kubelet の設定を取得し適用）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#70AD47;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="275" width="380" height="50" as="geometry" />
        </mxCell>

        <!-- Join Phase 4 -->
        <mxCell id="jphase4" value="4. kubelet 起動&#xa;（Worker Node として kubelet を起動しクラスタに参加）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#70AD47;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="355" width="380" height="50" as="geometry" />
        </mxCell>

        <!-- 矢印: join フェーズ間 -->
        <mxCell id="ja1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="jphase1" target="jphase2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ja2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="jphase2" target="jphase3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ja3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="jphase3" target="jphase4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 矢印: init の token → join の TLS Bootstrap（x=575 で迂回し他要素と交差しない） -->
        <mxCell id="token-arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#E57373;strokeWidth=2;dashed=1;" edge="1" source="phase7" target="jphase2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="575" y="570" />
              <mxPoint x="575" y="220" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="token-label" value="Bootstrap Token" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#E57373;fontStyle=1;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="token-arrow">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint x="-20" y="0" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- ===== 下部: kubeadm の追加コマンド ===== -->
        <mxCell id="extra-group" value="その他の kubeadm コマンド" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#AB47BC;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=5;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="600" y="530" width="460" height="120" as="geometry" />
        </mxCell>

        <mxCell id="cmd-upgrade" value="kubeadm upgrade&#xa;クラスタのバージョンアップ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#CE93D8;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="620" y="570" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="cmd-reset" value="kubeadm reset&#xa;クラスタ設定の初期化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#CE93D8;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="840" y="570" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend-title" value="凡例" style="text;html=1;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAEEF3;strokeColor=#5B9BD5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="90" y="662" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg1t" value="検証・認証" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="110" y="660" width="70" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#70AD47;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="190" y="662" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg2t" value="コンポーネント起動" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="210" y="660" width="110" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E57373;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="330" y="662" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg3t" value="トークン連携" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="660" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#CE93D8;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="440" y="662" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg4t" value="運用コマンド" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="460" y="660" width="80" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>