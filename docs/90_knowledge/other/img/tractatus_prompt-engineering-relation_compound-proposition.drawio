          <mxGeometry x="610" y="90" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="&lt;b&gt;出力形式&lt;/b&gt;&#xa;構造・スキーマ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
