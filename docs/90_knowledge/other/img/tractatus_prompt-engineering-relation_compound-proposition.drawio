        <mxCell id="p" value="プロンプト = 要素命題の真理関数的結合（基本は論理積、場合分けは含意）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
