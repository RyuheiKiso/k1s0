        </mxCell>
        <mxCell id="e1" value="&lt;b&gt;システム指示&lt;/b&gt;&#xa;応答の基本方針" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
