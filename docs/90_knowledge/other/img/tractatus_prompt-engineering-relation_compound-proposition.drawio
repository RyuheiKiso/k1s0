<mxfile host="app.diagrams.net">
  <diagram id="prompt-compound-proposition" name="prompt-compound-proposition">
    <mxGraphModel dx="1000" dy="460" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="460" math="0" shadow="0">
      <root>
