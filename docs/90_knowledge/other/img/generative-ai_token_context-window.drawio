<mxfile host="app.diagrams.net">
  <diagram id="token-context-window" name="token-context-window">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="500" as="geometry" />
        </mxCell>

        <mxCell id="title" value="コンテキストウィンドウとトークン消費（例: 200,000 トークンのモデル）" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="50" y="15" width="800" height="30" as="geometry" />
        </mxCell>

        <mxCell id="ctx_label" value="コンテキストウィンドウ全体（200,000 トークン）" style="text;html=1;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="820" height="22" as="geometry" />
        </mxCell>

        <mxCell id="ctx_outer" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#333333;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="820" height="80" as="geometry" />
        </mxCell>

        <mxCell id="seg_sys" value="システム&#10;プロンプト&#10;~5K" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="42" y="87" width="80" height="76" as="geometry" />
        </mxCell>

        <mxCell id="seg_hist" value="会話履歴&#10;~80K" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="122" y="87" width="320" height="76" as="geometry" />
        </mxCell>

        <mxCell id="seg_user" value="ユーザー入力&#10;~30K" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="442" y="87" width="120" height="76" as="geometry" />
        </mxCell>

        <mxCell id="seg_out" value="アシスタント出力&#10;~25K" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="562" y="87" width="100" height="76" as="geometry" />
        </mxCell>

        <mxCell id="seg_empty" value="未使用&#10;~60K" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="662" y="87" width="196" height="76" as="geometry" />
        </mxCell>

        <mxCell id="bracket_in" value="←─── Input トークン（プロンプト課金、相対的に安価） ───→" style="text;html=1;align=center;fontSize=11;fontColor=#1f5582;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="42" y="180" width="520" height="24" as="geometry" />
        </mxCell>

        <mxCell id="bracket_out" value="←── Output（生成課金、Input の 3〜5 倍） ──→" style="text;html=1;align=center;fontSize=11;fontColor=#a02828;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="562" y="180" width="100" height="24" as="geometry" />
        </mxCell>

        <mxCell id="bracket_out2" value="" style="text;html=1;align=center;fontSize=11;fontColor=#a02828;" vertex="1" parent="1">
          <mxGeometry x="450" y="200" width="320" height="22" as="geometry" />
        </mxCell>

        <mxCell id="note1_title" value="重要な性質" style="text;html=1;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="200" height="20" as="geometry" />
        </mxCell>

        <mxCell id="note1" value="・コンテキストウィンドウは Input + Output の合計で計測される。生成中も枠を消費する。" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="262" width="820" height="20" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="・上限を超えると、古い会話履歴から切り詰められる（ホスト側の戦略はモデル/SDK ごとに異なる）。" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="284" width="820" height="20" as="geometry" />
        </mxCell>

        <mxCell id="note3" value="・同じ文字数でも言語によりトークン数が変わる（英文 1 単語 ≒ 1 トークン、日本語 1 文字 ≒ 1〜3 トークン）。" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="306" width="820" height="20" as="geometry" />
        </mxCell>

        <mxCell id="note4" value="・課金・速度・品質はすべてトークン量に支配される。プロンプト設計は「トークン経済」を意識する。" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="328" width="820" height="20" as="geometry" />
        </mxCell>

        <mxCell id="legend_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="820" height="110" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="凡例" style="text;html=1;fontSize=11;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="50" y="376" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend_sys" value="■ システムプロンプト（モデルへの恒久指示）" style="text;html=1;fontSize=10;align=left;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="55" y="400" width="380" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend_hist" value="■ 会話履歴（過去ターンの user/assistant ペア）" style="text;html=1;fontSize=10;align=left;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="55" y="420" width="380" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend_user" value="■ ユーザー入力（最新ターンの問い合わせ）" style="text;html=1;fontSize=10;align=left;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="55" y="440" width="380" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend_out" value="■ アシスタント出力（生成中／生成済み）" style="text;html=1;fontSize=10;align=left;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="445" y="400" width="380" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend_empty" value="■（破線）未使用領域" style="text;html=1;fontSize=10;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="445" y="420" width="380" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend_billing" value="課金: Input × 単価A + Output × 単価B（B ≒ 3〜5×A、モデル毎に異なる）" style="text;html=1;fontSize=10;align=left;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="445" y="440" width="400" height="18" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
