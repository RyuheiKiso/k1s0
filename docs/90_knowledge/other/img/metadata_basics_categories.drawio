        <mxCell id="root" value="メタデータ&#10;(Metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="345" y="50" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="desc" value="&lt;b&gt;記述的メタデータ&lt;/b&gt;&#10;(Descriptive)&#10;&#10;同定・検索・発見のため&#10;&#10;・タイトル&#10;・著者 / 作成者&#10;・件名 / キーワード&#10;・要約" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="220" height="220" as="geometry" />
        </mxCell>
        <mxCell id="struct" value="&lt;b&gt;構造的メタデータ&lt;/b&gt;&#10;(Structural)&#10;&#10;内部構成・関係を示す&#10;&#10;・章 / 節の順序&#10;・ページ番号&#10;・ファイル間の包含/参照&#10;・チャプター区切り" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="315" y="200" width="220" height="220" as="geometry" />
        </mxCell>
        <mxCell id="admin" value="&lt;b&gt;管理的メタデータ&lt;/b&gt;&#10;(Administrative)&#10;&#10;運用・保管に必要&#10;&#10;・技術: 形式 / サイズ&#10;・権利: 著作権 / ライセンス&#10;・保存: 作成日 / 保管期限&#10;・出所: 入手経路" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="590" y="200" width="220" height="220" as="geometry" />
