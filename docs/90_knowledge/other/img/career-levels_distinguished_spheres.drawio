<mxfile host="app.diagrams.net">
  <diagram id="distinguished-spheres" name="distinguished-spheres">
    <mxGraphModel dx="1000" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1000" height="720" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Distinguished / Fellow の影響圏（同心円モデル）" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="960" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ring4" value="&lt;b&gt;④ 国際標準 / 規格策定&lt;/b&gt;  ─ IETF・W3C・IEEE・ISO 等で仕様に直接寄与。業界の共通言語を形成" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacingLeft=20;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="90" width="940" height="580" as="geometry" />
        </mxCell>
        <mxCell id="ring3" value="&lt;b&gt;③ 学術・技術コミュニティ&lt;/b&gt;  ─ 論文・基調講演・書籍で新領域の概念を創出" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacingLeft=20;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="110" y="150" width="780" height="470" as="geometry" />
        </mxCell>
        <mxCell id="ring2" value="&lt;b&gt;② 業界・競合各社&lt;/b&gt;  ─ 技術ブログ・カンファレンス登壇・OSS リリースで業界を動かす" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacingLeft=20;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="210" y="210" width="580" height="360" as="geometry" />
        </mxCell>
        <mxCell id="ring1" value="&lt;b&gt;① 自社（Principal 兼務）&lt;/b&gt;&#xa;&#xa;組織の技術方向性に責任を持ち、CTO・役員と対話する。会社を対外的に代表する存在" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacingLeft=20;spacingRight=20;" vertex="1" parent="1">
          <mxGeometry x="320" y="290" width="360" height="200" as="geometry" />
        </mxCell>
        <mxCell id="note" value="多くの会社で Distinguished は全社で 10 名以下、Fellow は数名のみ任命される狭き門。Principal と比較し「会社を超えて業界を動かす活動」が職務記述に含まれる点が違い" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#999999;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="680" width="940" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
