<mxfile host="app.diagrams.net">
  <diagram id="sagen-vs-zeigen" name="sagen-vs-zeigen">
    <mxGraphModel dx="1000" dy="560" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1000" height="560" as="geometry" />
        </mxCell>
        <mxCell id="title" value="『語り（sagen）』と『示し（zeigen）』: 指示型プロンプトと例示型プロンプトの対比" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="960" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lh" value="&lt;b&gt;語り（sagen）／指示型&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rh" value="&lt;b&gt;示し（zeigen）／例示型&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="520" y="90" width="460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ld1" value="論考での定義: 命題が事態を写像し述べる。語りうる内容" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#D6B656;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rd1" value="論考での定義: 命題が自身の論理形式を持つという事実。語れず示されるのみ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F2E0;strokeColor=#82B366;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="150" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ld2" value="プロンプト対応: 明示的な指示・制約・手順を文として書く" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#D6B656;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rd2" value="プロンプト対応: 入出力ペアで形式を示す（few-shot）。パターンは名前を与えずに示す" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F2E0;strokeColor=#82B366;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="230" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ld3" value="例: 『以下を 3 点に要約せよ』『JSON で出力せよ』『敬体で書け』" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#D6B656;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="460" height="100" as="geometry" />
        </mxCell>
        <mxCell id="rd3" value="例: Input: &quot;apple&quot; → Output: &quot;果物&quot;&#xa;Input: &quot;car&quot; → Output: &quot;乗り物&quot;&#xa;Input: &quot;dog&quot; → Output: ?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F2E0;strokeColor=#82B366;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="310" width="460" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ld4" value="強み: 明示的で再現性が高い／弱み: 暗黙の形式を言語化しきれない" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#D6B656;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="460" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rd4" value="強み: 複雑な形式を例の類推で伝える／弱み: 例の選定バイアスが混入する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F2E0;strokeColor=#82B366;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="430" width="460" height="50" as="geometry" />
        </mxCell>
        <mxCell id="note" value="※ 両者は排他ではない。プロンプト設計は『語り』と『示し』の配分を状況に応じて調整する作業である。" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="20" y="500" width="960" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
