<mxfile host="app.diagrams.net">
  <diagram id="career-levels-dimensions" name="career-levels-dimensions">
    <mxGraphModel dx="1000" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1000" height="720" as="geometry" />
        </mxCell>
        <mxCell id="title" value="5 つの評価軸 × 4 レベルの成長マトリクス" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="960" height="40" as="geometry" />
        </mxCell>
        <mxCell id="hd_dim" value="&lt;b&gt;評価軸&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="hd_jr" value="&lt;b&gt;Junior&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="190" y="70" width="195" height="40" as="geometry" />
        </mxCell>
        <mxCell id="hd_sr" value="&lt;b&gt;Senior&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="390" y="70" width="195" height="40" as="geometry" />
        </mxCell>
        <mxCell id="hd_staff" value="&lt;b&gt;Staff&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="70" width="195" height="40" as="geometry" />
        </mxCell>
        <mxCell id="hd_pri" value="&lt;b&gt;Principal&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="790" y="70" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="&lt;b&gt;スコープ&lt;/b&gt;&#xa;どこまでの範囲に責任を持つか" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="120" width="160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d1_jr" value="個々のタスクやバグ修正。自分が書いたコードが責任範囲" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="190" y="120" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d1_sr" value="チームが担当する機能群。要件・設計・運用まで一貫して責任を持つ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="120" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d1_staff" value="複数チームにまたがる技術領域。組織図に属さない課題を自分で拾う" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="120" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d1_pri" value="組織全体・事業全体の技術的健全性。数年単位の投資判断を含む" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="790" y="120" width="190" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="&lt;b&gt;自律性&lt;/b&gt;&#xa;どの粒度の指示で動けるか" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d2_jr" value="「この関数を実装して」レベルの指示に従って動く。途中で質問できる" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="190" y="240" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d2_sr" value="「この機能を作って」レベルの指示から要件を分解し、設計・実装まで自力で推進する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="240" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d2_staff" value="「何に取り組むべきか」を自ら特定する。取り組む課題の選定そのものが仕事" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="240" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d2_pri" value="事業方針から技術課題を逆算する。課題を探索する方向性そのものを定義する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="790" y="240" width="190" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="&lt;b&gt;曖昧さへの対処&lt;/b&gt;&#xa;未定義状態での推進力" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="360" width="160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d3_jr" value="要件がある程度明確な作業で成果を出す。曖昧なものはシニアに相談する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="190" y="360" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d3_sr" value="仕様に抜けがあっても仮説を立てて前進させる。ステークホルダーに確認して固める" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="360" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d3_staff" value="問題そのものが曖昧な状況で、問題を切り分けて構造化する。解くべき問題を定義し直す" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="360" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d3_pri" value="何が問題かさえ未定義の状況から方針を示す。不確実性のまま数年判断を下す" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="790" y="360" width="190" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d4" value="&lt;b&gt;影響範囲&lt;/b&gt;&#xa;成果が何に届くか" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="480" width="160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d4_jr" value="自分のプルリクの品質。チーム内の小さな改善に貢献する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="190" y="480" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d4_sr" value="チームの成果物の品質と納期。チームの生産性を底上げする設計や仕組みを導入する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="480" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d4_staff" value="複数チームの意思決定を技術的に揃える。プラットフォーム化や規約整備で横展開する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="480" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d4_pri" value="組織の技術方向性、採用方針、投資配分に影響する。会社全体のアウトプットを動かす" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="790" y="480" width="190" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d5" value="&lt;b&gt;リーダーシップ&lt;/b&gt;&#xa;他者に対する責任" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="600" width="160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d5_jr" value="自分の成長と学習に集中する。レビューを受けることで学ぶ立場" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="190" y="600" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d5_sr" value="ジュニアのメンタリング、コードレビュー、技術共有を通じチームを育てる" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="600" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d5_staff" value="シニアを育成する。技術戦略を言語化し、複数チームを同じ方向に揃える" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="600" width="195" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d5_pri" value="組織の技術文化、採用水準、教育体系を形成する。会社の技術的評判に責任を持つ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="790" y="600" width="190" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
