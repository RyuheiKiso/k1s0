<mxfile host="app.diagrams.net">
  <diagram id="career-levels-hierarchy" name="career-levels-hierarchy">
    <mxGraphModel dx="1000" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1000" height="720" as="geometry" />
        </mxCell>
        <mxCell id="title" value="エンジニアキャリアレベル階層（IC トラック）" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="960" height="40" as="geometry" />
        </mxCell>
        <mxCell id="col_level" value="&lt;b&gt;レベル / 目安年数&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="col_desc" value="&lt;b&gt;中心的な責務&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="70" width="430" height="30" as="geometry" />
        </mxCell>
        <mxCell id="col_scope" value="&lt;b&gt;スコープ（影響の広がり）&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="70" width="310" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lv_jr" value="&lt;b&gt;Junior&lt;/b&gt;&#xa;L1–L2 / 0–3 年" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="110" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="desc_jr" value="指示された明確なタスクを完遂する。コードレビューで基礎を学び、チームの作法を吸収する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="110" width="430" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bar_jr" value="自分のタスク" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="110" width="70" height="70" as="geometry" />
        </mxCell>
        <mxCell id="lv_mid" value="&lt;b&gt;Mid&lt;/b&gt;&#xa;L3 / 2–5 年" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="190" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="desc_mid" value="曖昧さのある機能でも自力で分解し実装できる。他者のコードレビューで貢献する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="190" width="430" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bar_mid" value="チーム内の機能" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="190" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="lv_sr" value="&lt;b&gt;Senior&lt;/b&gt;&#xa;L4 / 5–8 年" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="270" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="desc_sr" value="重要機能の設計と納品責任を負う。ジュニアを育て、チームの技術水準を引き上げる" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="270" width="430" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bar_sr" value="チーム全体" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="270" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="lv_staff" value="&lt;b&gt;Staff&lt;/b&gt;&#xa;L5 / 8–12 年" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="350" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="desc_staff" value="複数チームを横断する課題を特定し、設計方針・技術投資を主導する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="350" width="430" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bar_staff" value="複数チーム横断" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="350" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="lv_pri" value="&lt;b&gt;Principal&lt;/b&gt;&#xa;L6 / 10–15 年+" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="430" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="desc_pri" value="組織全体の技術方向性を決定する。長期的・未定義な課題に責任を持ち、役員と対話する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="430" width="430" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bar_pri" value="組織全体" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="430" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="lv_dist" value="&lt;b&gt;Distinguished / Fellow&lt;/b&gt;&#xa;L7+ / 15 年+" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="510" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="desc_dist" value="業界・市場レベルの技術的影響を担う。新しい領域の創出や外部発信を通じ会社を代表する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="510" width="430" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bar_dist" value="業界全体" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="510" width="310" height="70" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="年数は業界平均の目安であり、到達条件ではない。レベルは「経験年数」ではなく「スコープと影響範囲」で定義される（Google, Amazon, Meta 等のラダーに共通）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#999999;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="600" width="940" height="40" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="Senior 以降で IC（Individual Contributor）トラックと EM（Engineering Manager）トラックに分岐する。本図は IC トラックを示す。EM 側では Engineering Manager → Director → VP のようなマネジメントの階層が並走する" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#999999;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="650" width="940" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
