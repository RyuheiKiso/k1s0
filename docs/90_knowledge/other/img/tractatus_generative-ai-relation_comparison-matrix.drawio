<mxfile host="app.diagrams.net">
  <diagram id="comparison-matrix" name="comparison-matrix">
    <mxGraphModel dx="960" dy="540" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="540" math="0" shadow="0">
      <root>
