        <mxCell id="theme1" value="&lt;b&gt;存在論&lt;/b&gt;&#xa;世界・事実・事態" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
