        </mxCell>
        <mxCell id="p1" value="1. 世界は成立している事柄の全体である" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="80" width="740" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="2. 事実とは諸事態の成立である" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="160" width="740" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="3. 事実の論理像が思考である" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="240" width="740" height="50" as="geometry" />
