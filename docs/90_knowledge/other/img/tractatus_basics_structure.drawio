        <mxCell id="theme2" value="&lt;b&gt;意味論&lt;/b&gt;&#xa;思考と命題" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
