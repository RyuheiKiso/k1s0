<mxfile>
  <diagram name="Swift の値型と参照型" id="value-vs-reference">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="380" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="820" height="380" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Swift の値型と参照型: ARC は参照型のみに効く" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="sep" value="" style="endArrow=none;html=1;strokeColor=#999999;dashed=1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="400" y="55" as="sourcePoint" />
            <mxPoint x="400" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lhead" value="値型 (struct / enum / tuple): 代入で複製" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="340" height="25" as="geometry" />
        </mxCell>
        <mxCell id="va" value="var a" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="80" height="36" as="geometry" />
        </mxCell>
        <mxCell id="ma" value="Point(x:1, y:2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="220" y="100" width="160" height="36" as="geometry" />
        </mxCell>
        <mxCell id="vb" value="var b = a" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="80" height="36" as="geometry" />
        </mxCell>
        <mxCell id="mb" value="Point(x:9, y:2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="220" y="170" width="160" height="36" as="geometry" />
        </mxCell>
        <mxCell id="ea" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="va" target="ma" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="vb" target="mb" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lnote" value="var b = a; b.x = 9 とすると b は a と別実体になり、&#xa;a.x は 1 のまま変わらない。&#xa;標準ライブラリの Array / Dictionary / String も値型で同じ挙動。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="340" height="100" as="geometry" />
        </mxCell>
        <mxCell id="rhead" value="参照型 (class / actor): ARC で参照を共有" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="440" y="60" width="340" height="25" as="geometry" />
        </mxCell>
        <mxCell id="rva" value="let a" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="450" y="100" width="80" height="36" as="geometry" />
        </mxCell>
        <mxCell id="rvb" value="let b = a" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="450" y="170" width="80" height="36" as="geometry" />
        </mxCell>
        <mxCell id="rm" value="Node(x:9)&#xa;ARC=2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="630" y="118" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rea" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;strokeColor=#333333;strokeWidth=2;" edge="1" source="rva" target="rm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="reb" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.7;strokeColor=#333333;strokeWidth=2;" edge="1" source="rvb" target="rm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rnote" value="let b = a; b.x = 9 とすると同じ実体を共有し、&#xa;a.x も 9 になる。&#xa;retain / release 命令は SIL 段階でコンパイラが挿入する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="440" y="240" width="340" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
