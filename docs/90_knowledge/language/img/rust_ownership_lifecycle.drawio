        <mxCell id="p3_free" value="メモリ自動解放" style="text;html=1;fontSize=10;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="748" y="185" width="90" height="18" as="geometry" />
        </mxCell>
        <mxCell id="flow1" style="strokeColor=#666666;strokeWidth=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p1_border" target="p2_border" parent="1">
