          <mxGeometry x="20" y="330" width="410" height="90" as="geometry" />
        </mxCell>
        <mxCell id="copy_title" value="Copy トレイト型（i32, f64, bool, char）" style="text;html=1;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="35" y="338" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="copy_desc" value="代入時にビットコピーが発生する。元の変数も引き続き使用可能。&#xa;スタック上の固定サイズデータのみが対象。" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="35" y="360" width="380" height="35" as="geometry" />
        </mxCell>
        <mxCell id="copy_ex" value="let x = 42; let y = x;  → x も y も有効" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="35" y="396" width="350" height="18" as="geometry" />
        </mxCell>
        <mxCell id="move_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="450" y="330" width="410" height="90" as="geometry" />
        </mxCell>
        <mxCell id="move_title" value="ヒープ型（String, Vec&lt;T&gt;, Box&lt;T&gt;）" style="text;html=1;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="465" y="338" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="move_desc" value="代入時にムーブが発生する。元の変数は無効になる。&#xa;同じデータを使いたい場合は clone() または借用を使用する。" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="465" y="360" width="380" height="35" as="geometry" />
        </mxCell>
        <mxCell id="move_ex" value="let s1 = String::from(&quot;hi&quot;); let s2 = s1;  → s1 は無効" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="465" y="396" width="380" height="18" as="geometry" />
        </mxCell>
        <mxCell id="note" value="所有権の 3 つのルール: ① 各値は 1 つの所有者を持つ  ② 所有者がスコープを抜けると値は解放される  ③ 同時に持てる参照は &amp;T 複数 or &amp;mut T 1 つ" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#333333;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="440" width="840" height="30" as="geometry" />
        </mxCell>
