        <mxCell id="p1_arrow" style="strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p1_s1" target="p1_heap" parent="1">
          <mxGeometry relative="1" as="geometry" />
