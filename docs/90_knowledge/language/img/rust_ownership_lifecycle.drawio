        <mxCell id="p1_code" value="let s1 = String::from(&quot;hello&quot;);" style="text;html=1;fontSize=10;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
