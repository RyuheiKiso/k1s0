          <mxGeometry x="660" y="140" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p3_heap" value="解放済み" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontSize=12;fontColor=#999999;dashed=1;" vertex="1" parent="1">
