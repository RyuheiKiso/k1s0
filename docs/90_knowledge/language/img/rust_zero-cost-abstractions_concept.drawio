        <mxCell id="asm" value="生成された機械語&#xa;（ループ・即値加算）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="340" y="420" width="220" height="55" as="geometry" />
