        <mxCell id="llvm2" value="LLVM 最適化&#xa;（ループ展開・ベクトル化）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="305" width="220" height="55" as="geometry" />
