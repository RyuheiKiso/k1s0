<mxfile>
  <diagram name="ゼロコスト抽象化の概念" id="zca-concept">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="540" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="540" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ゼロコスト抽象化: 高水準コードとハンドコードが同じ機械語に収束する" style="text;html=1;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="hi_label" value="高水準コード（抽象）" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hi_code" value="(0..n).map(|x| x * 2).sum::&lt;i32&gt;()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lo_label" value="ハンドコード（手書きループ）" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="55" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lo_code" value="let mut s = 0;&#xa;for x in 0..n { s += x * 2; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="85" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rustc" value="rustc&#xa;（型解決・モノモーフィゼーション）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="195" width="220" height="55" as="geometry" />
        </mxCell>
