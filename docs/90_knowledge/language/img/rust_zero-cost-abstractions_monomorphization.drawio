          <mxGeometry x="40" y="195" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="call1" value="add(1_i32, 2_i32)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="225" width="280" height="35" as="geometry" />
        </mxCell>
        <mxCell id="call2" value="add(1.5_f64, 2.5_f64)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="280" height="35" as="geometry" />
