        </mxCell>
        <mxCell id="title" value="モノモーフィゼーション: ジェネリック関数を使用された型ごとに実体化する" style="text;html=1;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="generic_label" value="ソース上の定義（1 個）" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="generic" value="fn add&lt;T: Add&gt;(a: T, b: T) -&gt; T {&#xa;    a + b&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontFamily=Courier New;fontColor=#333333;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="280" height="70" as="geometry" />
