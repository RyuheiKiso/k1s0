<mxfile>
  <diagram name="Swift コンパイルパイプライン" id="compilation">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1030" pageHeight="340" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1030" height="340" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Swift コンパイルパイプライン (LLVM ベースの 5 段階 + SIL)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="src" value=".swift ソースコード" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sema" value="Parser + Sema&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;AST 構築 / 型検査&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="80" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rawsil" value="Raw SIL&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Swift 固有の中間表現&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="80" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cansil" value="Canonical SIL&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;最適化 / ARC 命令挿入&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="80" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="llvm" value="LLVM IR&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;LLVM バックエンド最適化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="200" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="bin" value="ネイティブバイナリ&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Mach-O / ELF / PE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="200" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="src" target="sema" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="sema" target="rawsil" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="rawsil" target="cansil" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=block;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#333333;strokeWidth=2;" edge="1" source="cansil" target="llvm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="llvm" target="bin" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note" value="Swift は LLVM フロントエンドを持つ言語で、独自の中間表現 SIL (Swift Intermediate Language) を経由する。&#xa;ARC (Automatic Reference Counting) の retain/release 命令は Canonical SIL 段階でコンパイラが挿入し、LLVM バックエンドへ降ろす。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
