<mxfile>
  <diagram name="Dart コンパイルパイプライン" id="compilation">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="380" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="820" height="380" as="geometry" />
        </mxCell>
        <mxCell id="src" value=".dart ソースコード" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="analyzer" value="Dart Analyzer&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;型検査 / Null安全性検査&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="160" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="kernel" value="Kernel IR&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;中間表現 (.dill)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="160" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="jit" value="JIT&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;dart run / hot reload&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="40" width="80" height="60" as="geometry" />
        </mxCell>
        <mxCell id="aot" value="AOT&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ネイティブバイナリ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="160" width="80" height="60" as="geometry" />
        </mxCell>
        <mxCell id="js" value="dart2js&lt;br&gt;dart2wasm&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Web向け出力&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="280" width="80" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="src" target="analyzer" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="analyzer" target="kernel" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=block;endFill=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="kernel" target="jit" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="kernel" target="aot" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="endArrow=block;endFill=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5;strokeColor=#333333;strokeWidth=2;" edge="1" source="kernel" target="js" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Dart コンパイルパイプライン (3 系統の出力)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="note" value="開発時は JIT で hot reload を有効にし、リリース時は AOT でネイティブにビルドする。&#xa;Web 向けは dart2js (JavaScript) または dart2wasm (WebAssembly) で出力する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="640" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
