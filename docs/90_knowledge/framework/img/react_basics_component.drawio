          <mxGeometry x="600" y="340" width="140" height="55" as="geometry" />
        </mxCell>
        <mxCell id="usememo-box" value="&lt;b&gt;useMemo / useCallback&lt;/b&gt;&lt;br&gt;パフォーマンス最適化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="780" y="340" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="hook-arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="child-b" target="usestate-box" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
