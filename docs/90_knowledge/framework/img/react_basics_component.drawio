          </mxGeometry>
        </mxCell>
        <mxCell id="hook-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="child-b" target="useeffect-box" parent="1">
          <mxGeometry relative="1" as="geometry">
