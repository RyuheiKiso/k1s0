        </mxCell>
        <mxCell id="legend-hook" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="20" height="15" as="geometry" />
