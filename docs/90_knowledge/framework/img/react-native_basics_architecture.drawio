<mxfile>
  <diagram name="React Native New Architecture" id="rn-architecture">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="600" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="600" as="geometry" />
        </mxCell>
        <mxCell id="title" value="React Native 新アーキテクチャ（Bridgeless）" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="240" y="20" width="480" height="40" as="geometry" />
        </mxCell>
        <mxCell id="js-layer" value="&lt;b&gt;JavaScript スレッド（Hermes エンジン）&lt;/b&gt;&lt;br&gt;React コンポーネント / JSX / Hooks をここで実行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=13;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="85" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="jsi-layer" value="&lt;b&gt;JSI (JavaScript Interface)&lt;/b&gt;&lt;br&gt;C++ 実装の同期呼び出し層。旧来の Bridge を置換" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fabric" value="&lt;b&gt;Fabric Renderer&lt;/b&gt;&lt;br&gt;Shadow Tree を構築し&lt;br&gt;Native View Tree に同期反映" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="305" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="turbo" value="&lt;b&gt;TurboModules&lt;/b&gt;&lt;br&gt;ネイティブ機能（カメラ・位置情報等）への&lt;br&gt;型安全な遅延ロード型アクセス" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="520" y="305" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="native-platform" value="&lt;b&gt;ネイティブプラットフォーム&lt;/b&gt;&lt;br&gt;&lt;br&gt;iOS: UIView / UITextView / UIImageView 等&lt;br&gt;Android: ViewGroup / TextView / ImageView 等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="800" height="100" as="geometry" />
        </mxCell>
        <mxCell id="arrow-js-jsi" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="js-layer" target="jsi-layer" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-jsi-fabric" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333333;strokeWidth=2;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.9;entryY=0;entryDx=0;entryDy=0;" edge="1" source="jsi-layer" target="fabric" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow-jsi-turbo" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333333;strokeWidth=2;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.1;entryY=0;entryDx=0;entryDy=0;" edge="1" source="jsi-layer" target="turbo" parent="1">
          <mxGeometry relative="1" as="geometry" />
