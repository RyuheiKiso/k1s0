        <mxCell id="arrow-fabric-native" value="UI 描画" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.225;entryY=0;entryDx=0;entryDy=0;fontSize=11;fontColor=#333333;labelBackgroundColor=#FFFFFF;" edge="1" source="fabric" target="native-platform" parent="1">
