        <mxCell id="legend-app-text" value="JS / RN 抽象" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="485" y="562" width="100" height="20" as="geometry" />
