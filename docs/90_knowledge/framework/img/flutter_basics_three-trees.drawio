        <mxCell id="r-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#d6b656;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;" edge="1" source="r-row" target="r-image" parent="1">
          <mxGeometry relative="1" as="geometry" />
