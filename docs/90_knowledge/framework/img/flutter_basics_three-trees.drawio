<mxfile>
  <diagram name="Flutter Three Trees" id="trees">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="540" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="540" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Flutter の 3 ツリーモデル: Widget / Element / RenderObject" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="120" y="15" width="720" height="40" as="geometry" />
        </mxCell>

        <mxCell id="flow-text" value="Widget Tree   ──build()──▶   Element Tree   ──createRenderObject()──▶   RenderObject Tree" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="880" height="25" as="geometry" />
        </mxCell>

        <mxCell id="col1-title" value="① Widget Tree（不変／毎フレーム再生成）" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="20" y="100" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="col2-title" value="② Element Tree（可変／フレーム間で保持）" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="col3-title" value="③ RenderObject Tree（layout / paint）" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#a08a2c;" vertex="1" parent="1">
          <mxGeometry x="620" y="100" width="320" height="30" as="geometry" />
        </mxCell>

        <mxCell id="w-container" value="Container" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="145" width="120" height="40" as="geometry" />
