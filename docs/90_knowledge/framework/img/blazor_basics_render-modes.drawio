<mxfile>
  <diagram name="Blazor Render Modes" id="render-modes">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1080" pageHeight="640" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1080" height="640" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Blazor Web App のレンダーモード（.NET 10）" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="280" y="15" width="520" height="40" as="geometry" />
        </mxCell>

        <mxCell id="req" value="&lt;b&gt;ブラウザからの HTTP 要求&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="430" y="80" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="q1" value="そのコンポーネントは&lt;br&gt;ユーザー入力に応答するか？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="400" y="170" width="280" height="100" as="geometry" />
        </mxCell>

        <mxCell id="q1-no-edge" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=11;fontColor=#333333;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="q1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ssr" value="&lt;b&gt;Static SSR&lt;/b&gt;&lt;br&gt;サーバーで HTML 生成&lt;br&gt;対話なし・最軽量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ssr-note" value="例: ランディングページ / ブログ" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="405" width="200" height="20" as="geometry" />
        </mxCell>

        <mxCell id="q2" value="初回ロードを最速にしたい？&lt;br&gt;または接続前提でよい？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="q1-yes-edge" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=11;fontColor=#333333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="q1" target="q2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ias" value="&lt;b&gt;InteractiveServer&lt;/b&gt;&lt;br&gt;サーバー実行&lt;br&gt;SignalR で UI 同期" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ias-note" value="例: 社内管理画面 / 入力フォーム" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#7f6000;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="555" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="q2-yes-edge" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=11;fontColor=#333333;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="q2" target="ias" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="iauto" value="&lt;b&gt;InteractiveAuto&lt;/b&gt;&lt;br&gt;初回 Server / 以降 WASM&lt;br&gt;キャッシュ後はクライアント実行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="430" y="470" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="iauto-note" value="例: 利用頻度の高い汎用画面" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#5f3973;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="430" y="555" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="q2-no-edge" value="No (両立したい)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=11;fontColor=#333333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="q2" target="iauto" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="iwasm" value="&lt;b&gt;InteractiveWebAssembly&lt;/b&gt;&lt;br&gt;.NET WASM で実行&lt;br&gt;オフライン動作可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="820" y="470" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="iwasm-note" value="例: ダッシュボード / グラフ操作" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#3f6f23;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="820" y="555" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="q2-wasm-edge" value="No (オフライン優先)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=11;fontColor=#333333;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="q2" target="iwasm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="req-edge" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="req" target="q1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend-title" value="補足" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-line" value="同一アプリ内でページ単位・コンポーネント単位にレンダーモードを混在できる（.NET 8 以降）" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="600" width="900" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
