        <mxCell id="legend1" value="青＝開発者コード／緑＝MAUI 抽象／黄＝Handler／赤＝OS ネイティブ" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
