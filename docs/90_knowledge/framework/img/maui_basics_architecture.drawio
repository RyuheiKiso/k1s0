<mxfile>
  <diagram name="MAUI Architecture" id="maui-architecture">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="640" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="640" as="geometry" />
        </mxCell>
        <mxCell id="title" value=".NET MAUI アーキテクチャ" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="layer1-label" value="① 開発者が書くコード" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#6c8ebf;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="75" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="xaml" value="&lt;b&gt;XAML&lt;/b&gt;&lt;br&gt;UI を宣言的に記述" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="csharp" value="&lt;b&gt;C# コードビハインド&lt;/b&gt;&lt;br&gt;イベント処理 / ロジック / MVVM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="290" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="hybrid" value="&lt;b&gt;Blazor Hybrid（任意）&lt;/b&gt;&lt;br&gt;Razor コンポーネントを&lt;br&gt;BlazorWebView 経由で利用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="520" y="100" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="layer2-label" value="② MAUI が提供する抽象（共通）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#82b366;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="680" height="25" as="geometry" />
        </mxCell>
        <mxCell id="abstractions" value="&lt;b&gt;MAUI コントロール抽象&lt;/b&gt;&lt;br&gt;Page / Layout / View（Button・Label・Entry・CollectionView 等）&lt;br&gt;Resources / Bindings / Navigation / Lifecycle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="225" width="680" height="80" as="geometry" />
        </mxCell>
        <mxCell id="layer3-label" value="③ Handler 層（プラットフォーム差分の橋渡し）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#d6b656;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="335" width="680" height="25" as="geometry" />
        </mxCell>
        <mxCell id="handler" value="&lt;b&gt;Handler&lt;/b&gt;&lt;br&gt;ButtonHandler / LabelHandler / EntryHandler ...&lt;br&gt;抽象コントロールを各プラットフォームのネイティブビューに対応付ける" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="680" height="80" as="geometry" />
        </mxCell>
        <mxCell id="layer4-label" value="④ プラットフォームネイティブ（OS ごとの実装）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#b85450;fontStyle=2;" vertex="1" parent="1">
