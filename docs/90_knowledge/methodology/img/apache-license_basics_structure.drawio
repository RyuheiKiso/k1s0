        <mxCell id="note_perm" value="ソースコード公開義務なし&#xa;（非コピーレフト）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
