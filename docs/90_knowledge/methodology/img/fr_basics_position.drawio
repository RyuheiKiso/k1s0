        <mxCell id="br" value="&lt;b&gt;業務要件&lt;/b&gt;&lt;br&gt;(BR)&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;業務上の目標・課題&lt;br&gt;「何を達成したいか」&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
