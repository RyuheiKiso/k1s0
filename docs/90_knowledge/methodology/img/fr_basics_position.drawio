          <mxGeometry x="310" y="80" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="nfr" value="&lt;b&gt;非機能要件&lt;/b&gt;&lt;br&gt;(NFR)&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;品質・性能・セキュリティ&lt;br&gt;「どの水準で動くべきか」&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
