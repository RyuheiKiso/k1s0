<mxfile host="draw.io">
  <diagram name="テストピラミッドと E2E の位置" id="e2e-pyramid">
    <mxGraphModel dx="1000" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="560" as="geometry" />
        </mxCell>
        <mxCell id="title" value="テストピラミッドにおける E2E テストの位置づけ" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="15" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="unit" value="&lt;b&gt;単体テスト (Unit Test)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;関数・メソッド単位の検証&lt;br&gt;高速・安価・大量に実行&lt;/font&gt;" style="trapezoid;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;perimeter=trapezoidPerimeter;fixedSize=1;size=60;" vertex="1" parent="1">
          <mxGeometry x="130" y="350" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="integration" value="&lt;b&gt;結合テスト (Integration Test)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;複数コンポーネント間の連携検証&lt;br&gt;DB / API / 外部サービスとの接続&lt;/font&gt;" style="trapezoid;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;perimeter=trapezoidPerimeter;fixedSize=1;size=40;" vertex="1" parent="1">
          <mxGeometry x="180" y="220" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e2e" value="&lt;b&gt;E2E テスト&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ユーザー視点で&lt;br&gt;システム全体を検証&lt;/font&gt;" style="trapezoid;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;perimeter=trapezoidPerimeter;fixedSize=1;size=30;" vertex="1" parent="1">
          <mxGeometry x="225" y="100" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="arrow_speed" style="shape=flexArrow;endArrow=classic;startArrow=none;html=1;strokeColor=#666666;fillColor=#E6E6E6;width=8;endSize=6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="430" as="sourcePoint" />
            <mxPoint x="600" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="label_slow" value="&lt;font style=&quot;font-size:10px&quot;&gt;遅い・高コスト&lt;br&gt;少なく書く&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="620" y="110" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="label_fast" value="&lt;font style=&quot;font-size:10px&quot;&gt;速い・低コスト&lt;br&gt;多く書く&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="620" y="410" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="arrow_confidence" style="shape=flexArrow;endArrow=classic;startArrow=none;html=1;strokeColor=#666666;fillColor=#E6E6E6;width=8;endSize=6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="770" y="430" as="sourcePoint" />
            <mxPoint x="770" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="label_high_conf" value="&lt;font style=&quot;font-size:10px&quot;&gt;高い信頼性&lt;br&gt;実際の利用に近い&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="790" y="110" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="label_low_conf" value="&lt;font style=&quot;font-size:10px&quot;&gt;低い信頼性&lt;br&gt;部分的な検証&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="790" y="410" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ratio" value="&lt;font style=&quot;font-size:11px&quot;&gt;推奨比率の目安 (Google Testing Blog):&lt;br&gt;&lt;b&gt;Unit 70%&lt;/b&gt; : &lt;b&gt;Integration 20%&lt;/b&gt; : &lt;b&gt;E2E 10%&lt;/b&gt;&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontColor=#333333;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="350" height="55" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
