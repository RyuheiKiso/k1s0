<mxfile host="draw.io">
  <diagram name="E2E テストの実行フロー" id="e2e-flow">
    <mxGraphModel dx="1100" dy="550" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1060" pageHeight="440" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1060" height="440" as="geometry" />
        </mxCell>
        <mxCell id="title" value="E2E テストの実行フロー（Web アプリの例）" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="15" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="user_label" value="&lt;b&gt;テストランナー&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(ユーザー操作を&lt;br&gt;自動化する)&lt;/font&gt;" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="80" height="90" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="&lt;b&gt;ブラウザ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Chrome / Firefox&lt;br&gt;(ヘッドレス可)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="130" width="130" height="80" as="geometry" />
        </mxCell>
        <mxCell id="frontend" value="&lt;b&gt;フロントエンド&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;React / Vue 等&lt;br&gt;実際の UI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="410" y="130" width="130" height="80" as="geometry" />
        </mxCell>
        <mxCell id="api" value="&lt;b&gt;API サーバ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Go / C# 等&lt;br&gt;実際のバックエンド&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="130" height="80" as="geometry" />
        </mxCell>
        <mxCell id="db" value="&lt;b&gt;データベース&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PostgreSQL 等&lt;br&gt;実際の永続化層&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="120" width="120" height="90" as="geometry" />
        </mxCell>
        <mxCell id="a1" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="user_label" target="browser" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a1l" value="&lt;font style=&quot;font-size:9px&quot;&gt;① 操作を&lt;br&gt;送信&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#666666;" vertex="1" connectable="0" parent="a1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="a2" style="rounded=1;strokeColor=#D6B656;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="browser" target="frontend" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2l" value="&lt;font style=&quot;font-size:9px&quot;&gt;② 画面を&lt;br&gt;レンダリング&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#666666;" vertex="1" connectable="0" parent="a2">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="a3" style="rounded=1;strokeColor=#82B366;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="frontend" target="api" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3l" value="&lt;font style=&quot;font-size:9px&quot;&gt;③ API&lt;br&gt;呼び出し&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#666666;" vertex="1" connectable="0" parent="a3">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="a4" style="rounded=1;strokeColor=#D79B00;strokeWidth=2;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="api" target="db" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4l" value="&lt;font style=&quot;font-size:9px&quot;&gt;④ データ&lt;br&gt;読み書き&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#666666;" vertex="1" connectable="0" parent="a4">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="assert_box" value="&lt;b&gt;⑤ アサーション（検証）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;画面の表示内容・URL 遷移・&lt;br&gt;要素の存在・レスポンス値を確認&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="200" y="280" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a5" style="rounded=1;strokeColor=#9673A6;strokeWidth=1.5;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="browser" target="assert_box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="key_point" value="&lt;font style=&quot;font-size:11px&quot;&gt;E2E テストの核心:&lt;br&gt;ユーザーと同じ経路（ブラウザ → フロント → API → DB）を&lt;br&gt;全て通過させて、システム全体が正しく動作するかを検証する&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontColor=#333333;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="550" y="290" width="420" height="70" as="geometry" />
        </mxCell>
        <mxCell id="scope_line" value="" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;flipH=0;size=0.5;strokeColor=#B85450;strokeWidth=2;direction=south;" vertex="1" parent="1">
          <mxGeometry x="200" y="85" width="760" height="20" as="geometry" />
        </mxCell>
        <mxCell id="scope_label" value="&lt;font color=&quot;#B85450&quot; style=&quot;font-size:11px&quot;&gt;&lt;b&gt;E2E テストのスコープ: システム全体&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="370" y="60" width="300" height="25" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="凡例" style="text;html=1;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="40" y="405" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="l1t" value="テスト制御" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="65" y="402" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="160" y="405" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="l2t" value="クライアント層" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="185" y="402" width="90" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="290" y="405" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="l3t" value="プレゼンテーション層" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="315" y="402" width="120" height="20" as="geometry" />
