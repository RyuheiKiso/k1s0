        <mxCell id="l4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1">
          <mxGeometry x="450" y="405" width="20" height="14" as="geometry" />
        </mxCell>
        <mxCell id="l4t" value="ビジネスロジック層" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="475" y="402" width="110" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l5" value="" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=4;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="600" y="402" width="20" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l5t" value="永続化層" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="625" y="402" width="60" height="20" as="geometry" />
