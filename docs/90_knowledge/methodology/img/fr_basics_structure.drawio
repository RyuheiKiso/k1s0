<mxfile host="draw.io">
  <diagram name="FR の記述構成要素" id="fr-structure">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="520" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="520" as="geometry" />
        </mxCell>
        <mxCell id="title" value="FR (機能要件) の記述構成要素" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="15" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="center" value="&lt;b style=&quot;font-size:14px&quot;&gt;FR-xxx&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;機能要件&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="200" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="id" value="&lt;b&gt;一意の ID&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;FR-001 形式&lt;br&gt;欠番は再利用しない&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="stmt" value="&lt;b&gt;要件文&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;「〜できること」形式&lt;br&gt;曖昧な形容詞を使わない&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="365" y="60" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="prio" value="&lt;b&gt;優先度&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;MUST / SHOULD&lt;br&gt;/ COULD / WON'T&lt;br&gt;(MoSCoW 分析)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="60" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="accept" value="&lt;b&gt;受け入れ基準&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;検証可能な条件&lt;br&gt;数値 / E2E テスト&lt;br&gt;/ CI ガード等で判定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="380" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rel" value="&lt;b&gt;関連要件&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;関連 BR (業務目的)&lt;br&gt;関連 NFR (品質水準)&lt;br&gt;関連 CON (制約)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="365" y="390" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="phase" value="&lt;b&gt;提供層 / 適用段階&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;tier1 / tier2 / operation&lt;br&gt;リリース時点 / 採用初期 / 運用拡大時 / 全社展開期&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="390" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="context" value="&lt;b&gt;根拠・背景&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;なぜこの機能が必要か&lt;br&gt;現状の課題は何か&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="210" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="scope" value="&lt;b&gt;機能概要&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;この FR が何をするか&lt;br&gt;tier2/tier3 から見た姿&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="210" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" edge="1" source="id" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="stmt" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.8;entryY=0;entryDx=0;entryDy=0;" edge="1" source="prio" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.2;entryY=1;entryDx=0;entryDy=0;" edge="1" source="accept" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="rel" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.8;entryY=1;entryDx=0;entryDy=0;" edge="1" source="phase" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="context" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="rounded=1;strokeColor=#6C8EBF;strokeWidth=1.5;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="scope" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note_good" value="&lt;font style=&quot;font-size:10px&quot;&gt;良い FR:&lt;br&gt;✓ 検証可能（数値や条件で判定できる）&lt;br&gt;✓ 1 つの FR に 1 つの機能&lt;br&gt;✓ BR との紐付けが明確&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#E6FFE6;strokeColor=#82B366;fontColor=#333333;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="60" width="0" height="0" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
