        <mxCell id="lg_box" value="凡例（責務レイヤ）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="510" width="480" height="100" as="geometry" />
