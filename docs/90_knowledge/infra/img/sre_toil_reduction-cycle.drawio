<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="Toil 削減サイクル" id="toil-cycle">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="750" pageHeight="480" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="750" height="480" as="geometry"/>
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;1. 計測&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Toil の量と種類を&lt;br&gt;定量的に記録する&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="275" y="25" width="180" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;2. 分類&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;カテゴリ別に&lt;br&gt;整理・可視化する&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="530" y="145" width="180" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;3. 優先順位付け&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;ROI を基に&lt;br&gt;自動化対象を選定する&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="470" y="355" width="200" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;4. 自動化&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;ツール・スクリプトで&lt;br&gt;自動化を実施する&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="355" width="180" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="&lt;b&gt;5. 検証&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;削減効果を&lt;br&gt;計測・評価する&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="145" width="180" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="center" value="&lt;b&gt;継続的な&lt;br&gt;Toil 削減サイクル&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="270" y="220" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a12" style="rounded=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.6;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a23" style="rounded=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a34" style="rounded=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;endFill=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a45" style="rounded=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;endFill=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a51" style="rounded=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.6;entryDx=0;entryDy=0;" edge="1" source="s5" target="s1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
