        <mxCell id="t1" value="&lt;b&gt;カオスエンジニアリング 実験サイクル&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
