        </mxCell>
        <mxCell id="client" value="&lt;b&gt;クライアント（CLI / HTTP API）&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
