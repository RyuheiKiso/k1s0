<mxfile host="draw.io">
  <diagram name="Kubernetes Resources" id="k8s-resources">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 白背景（GitHub ダークテーマ対応） -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1100" height="700" as="geometry" />
        </mxCell>

        <!-- タイトル -->
        <mxCell id="title" value="Kubernetes 主要リソースの関係" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Service -->
        <mxCell id="service" value="Service&#xa;（サービス）&#xa;&#xa;安定したエンドポイントを提供&#xa;ロードバランシング" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BDD7EE;strokeColor=#6C8EBF;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Deployment -->
        <mxCell id="deployment" value="Deployment&#xa;（デプロイメント）&#xa;&#xa;宣言的な Pod 管理&#xa;ローリングアップデート" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- ReplicaSet -->
        <mxCell id="replicaset" value="ReplicaSet&#xa;（レプリカセット）&#xa;&#xa;指定数の Pod レプリカを維持" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="270" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Pod 群 -->
        <mxCell id="pod-group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="120" y="400" width="600" height="130" as="geometry" />
        </mxCell>
        <mxCell id="pod-group-label" value="Pod 群（label: app=my-app）" style="text;html=1;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="405" width="250" height="20" as="geometry" />
        </mxCell>

        <!-- Pod 1 -->
        <mxCell id="pod1" value="Pod&#xa;(replica 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="440" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="Container" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6B8AF;strokeColor=#B85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="165" y="462" width="100" height="28" as="geometry" />
        </mxCell>

        <!-- Pod 2 -->
        <mxCell id="pod2" value="Pod&#xa;(replica 2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="440" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="Container" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6B8AF;strokeColor=#B85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="365" y="462" width="100" height="28" as="geometry" />
        </mxCell>

        <!-- Pod 3 -->
        <mxCell id="pod3" value="Pod&#xa;(replica 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="440" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="Container" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6B8AF;strokeColor=#B85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="565" y="462" width="100" height="28" as="geometry" />
        </mxCell>

        <!-- ConfigMap -->
        <mxCell id="configmap" value="ConfigMap&#xa;（設定情報）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="270" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Secret -->
        <mxCell id="secret" value="Secret&#xa;（機密情報）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="340" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Namespace -->
        <mxCell id="namespace" value="Namespace&#xa;（名前空間）&#xa;&#xa;リソースの論理的な分離" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="770" y="100" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- 外部トラフィック -->
        <mxCell id="external" value="外部トラフィック" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- 矢印: 外部 → Service -->
        <mxCell id="e-ext-svc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" source="external" target="service" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-ext-svc-label" value="アクセス" style="edgeLabel;html=1;fontSize=10;fontColor=#333333;" vertex="1" connectable="0" parent="e-ext-svc">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- 矢印: Service → Pod群 (label selector) -->
        <mxCell id="e-svc-pods" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.2;entryY=0;" edge="1" source="service" target="pod-group" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="370" />
              <mxPoint x="240" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-svc-pods-label" value="Label Selector で振り分け" style="edgeLabel;html=1;fontSize=10;fontColor=#333333;" vertex="1" connectable="0" parent="e-svc-pods">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="30" y="-10" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- 矢印: Deployment → ReplicaSet -->
        <mxCell id="e-dep-rs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="deployment" target="replicaset" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-dep-rs-label" value="管理" style="edgeLabel;html=1;fontSize=10;fontColor=#333333;" vertex="1" connectable="0" parent="e-dep-rs">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- 矢印: ReplicaSet → Pod群 -->
        <mxCell id="e-rs-pods" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="replicaset" target="pod-group" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-rs-pods-label" value="レプリカ数を維持" style="edgeLabel;html=1;fontSize=10;fontColor=#333333;" vertex="1" connectable="0" parent="e-rs-pods">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="45" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- 矢印: Pod → ConfigMap -->
        <mxCell id="e-pod-cm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=1;dashed=1;exitX=1;exitY=0;entryX=0;entryY=1;" edge="1" source="pod3" target="configmap" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="730" y="440" />
              <mxPoint x="730" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-pod-cm-label" value="参照" style="edgeLabel;html=1;fontSize=10;fontColor=#333333;" vertex="1" connectable="0" parent="e-pod-cm">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-15" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- 矢印: Pod → Secret -->
        <mxCell id="e-pod-sec" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=1;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="pod3" target="secret" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="740" y="470" />
              <mxPoint x="740" y="365" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-pod-sec-label" value="参照" style="edgeLabel;html=1;fontSize=10;fontColor=#333333;" vertex="1" connectable="0" parent="e-pod-sec">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-15" y="10" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="60" y="570" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="凡例:" style="text;html=1;fontSize=11;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="577" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l1" value="" style="rounded=1;fillColor=#BDD7EE;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="115" y="580" width="15" height="15" as="geometry" />
        </mxCell>
        <mxCell id="l1t" value="ネットワーク" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="133" y="578" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="" style="rounded=1;fillColor=#E1D5E7;strokeColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="220" y="580" width="15" height="15" as="geometry" />
        </mxCell>
        <mxCell id="l2t" value="ワークロード管理" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="238" y="578" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="" style="rounded=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="350" y="580" width="15" height="15" as="geometry" />
        </mxCell>
        <mxCell id="l3t" value="Pod" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="368" y="578" width="30" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l4" value="" style="rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="410" y="580" width="15" height="15" as="geometry" />
        </mxCell>
        <mxCell id="l4t" value="構成・機密" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="428" y="578" width="70" height="20" as="geometry" />
        </mxCell>
        <mxCell id="l5" value="" style="rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="510" y="580" width="15" height="15" as="geometry" />
        </mxCell>
        <mxCell id="l5t" value="論理分離" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="528" y="578" width="60" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
