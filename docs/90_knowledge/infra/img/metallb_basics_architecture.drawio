            <mxPoint x="420" y="95" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="cluster" value="Kubernetes Cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontStyle=1;fontSize=14;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;fontColor=#333333;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="15" y="180" width="810" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="sp1" value="Speaker (DaemonSet)&#xa;Node 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
