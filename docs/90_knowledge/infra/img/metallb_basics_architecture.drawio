          <mxGeometry x="560" y="305" width="240" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="anno" value="Controller が Service を監視し、IPAddressPool から外部 IP を割り当てる。Speaker が外部ネットワークに IP を通知する。" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="760" height="25" as="geometry"/>
