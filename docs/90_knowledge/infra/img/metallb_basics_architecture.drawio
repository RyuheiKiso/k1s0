        <mxCell id="pod1" value="Service / Pod" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="305" width="240" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="pod2" value="Service / Pod" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="305" width="240" height="45" as="geometry"/>
        </mxCell>
