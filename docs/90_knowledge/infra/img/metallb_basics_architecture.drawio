<mxfile host="draw.io">
  <diagram name="MetalLB Architecture" id="arch">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="840" pageHeight="510" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="840" height="510" as="geometry"/>
        </mxCell>
        <mxCell id="client" value="外部クライアント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="330" y="15" width="180" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="router" value="ネットワーク（ルーター / スイッチ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="275" y="95" width="290" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a1" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
