        <mxCell id="sp3" value="Speaker (DaemonSet)&#xa;Node 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="225" width="240" height="50" as="geometry"/>
