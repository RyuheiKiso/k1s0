<mxfile host="draw.io">
  <diagram name="Kubeshark Architecture" id="kubeshark-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="640" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- 白背景 -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="640" as="geometry" />
        </mxCell>
        <!-- タイトル -->
        <mxCell id="title" value="Kubeshark アーキテクチャ" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="330" y="15" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- Kubernetes Cluster 外枠 -->
        <mxCell id="cluster" value="Kubernetes Cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#333333;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="880" height="520" as="geometry" />
        </mxCell>

        <!-- kubeshark namespace 枠 -->
        <mxCell id="ns" value="namespace: kubeshark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#4285F4;strokeWidth=2;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#4285F4;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="530" height="460" as="geometry" />
        </mxCell>

        <!-- Hub (Deployment) -->
        <mxCell id="hub" value="Hub&#xa;（Deployment）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="240" y="150" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="hub_desc" value="トラフィックデータの集約・&#xa;インデックス化・KFL クエリ処理" style="text;html=1;fontSize=10;align=center;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="220" y="210" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- Front (Deployment) -->
        <mxCell id="front" value="Front&#xa;（Deployment）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="240" y="280" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="front_desc" value="Web UI ダッシュボード&#xa;（React ベース）" style="text;html=1;fontSize=10;align=center;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="240" y="340" width="160" height="30" as="geometry" />
        </mxCell>

        <!-- Node 1 -->
        <mxCell id="node1_box" value="Node 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;dashed=1;verticalAlign=top;fontStyle=1;fontSize=11;fontColor=#388E3C;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="230" height="140" as="geometry" />
        </mxCell>

        <!-- Worker (DaemonSet) - Node 1 -->
        <mxCell id="worker1" value="Worker（DaemonSet）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=1;fontStyle=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="95" y="430" width="200" height="35" as="geometry" />
        </mxCell>
        <!-- Sniffer - Node 1 -->
        <mxCell id="sniffer1" value="Sniffer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#689F38;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="95" y="480" width="90" height="35" as="geometry" />
        </mxCell>
        <!-- Tracer (eBPF) - Node 1 -->
        <mxCell id="tracer1" value="Tracer (eBPF)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="205" y="480" width="90" height="35" as="geometry" />
        </mxCell>

        <!-- Node 2 -->
        <mxCell id="node2_box" value="Node 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;dashed=1;verticalAlign=top;fontStyle=1;fontSize=11;fontColor=#388E3C;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="400" width="230" height="140" as="geometry" />
        </mxCell>

        <!-- Worker (DaemonSet) - Node 2 -->
        <mxCell id="worker2" value="Worker（DaemonSet）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=1;fontStyle=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="355" y="430" width="200" height="35" as="geometry" />
        </mxCell>
        <!-- Sniffer - Node 2 -->
        <mxCell id="sniffer2" value="Sniffer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#689F38;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="355" y="480" width="90" height="35" as="geometry" />
        </mxCell>
        <!-- Tracer (eBPF) - Node 2 -->
        <mxCell id="tracer2" value="Tracer (eBPF)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="465" y="480" width="90" height="35" as="geometry" />
        </mxCell>

        <!-- CLI / ユーザー -->
        <mxCell id="cli" value="kubeshark CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- ブラウザ -->
        <mxCell id="browser" value="ブラウザ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="700" y="280" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- App Pods -->
        <mxCell id="app_pods" value="アプリケーション Pod 群" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="700" y="440" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="app_desc" value="HTTP / gRPC / Kafka /&#xa;Redis / DNS 等の通信" style="text;html=1;fontSize=10;align=center;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="710" y="500" width="160" height="30" as="geometry" />
        </mxCell>

        <!-- 矢印: CLI → Hub -->
        <mxCell id="e1" value="tap / proxy&#xa;コマンド" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#E65100;strokeWidth=2;fontColor=#E65100;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="cli" target="hub" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 矢印: Hub → Front -->
        <mxCell id="e2" value="API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#1976D2;strokeWidth=2;fontColor=#1976D2;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="hub" target="front" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 矢印: Front ← ブラウザ -->
        <mxCell id="e3" value="port-forward&#xa;(8899)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#E65100;strokeWidth=2;fontColor=#E65100;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="browser" target="front" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 矢印: Worker1 → Hub -->
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;strokeColor=#388E3C;strokeWidth=2;fontSize=9;" edge="1" source="worker1" target="hub" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="195" y="380" />
              <mxPoint x="195" y="250" />
              <mxPoint x="280" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 矢印: Worker2 → Hub -->
        <mxCell id="e5" value="キャプチャデータ送信" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=1;entryDx=0;entryDy=0;strokeColor=#388E3C;strokeWidth=2;fontColor=#388E3C;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="worker2" target="hub" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="455" y="380" />
              <mxPoint x="455" y="250" />
              <mxPoint x="360" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 矢印: App Pods ← Tracer (eBPF) -->
        <mxCell id="e6" value="eBPF フック" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#7B1FA2;strokeWidth=2;fontColor=#7B1FA2;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" source="tracer2" target="app_pods" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="620" y="497" />
              <mxPoint x="620" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="540" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="630" y="550" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg1t" value="Hub" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="648" y="548" width="30" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="685" y="550" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg2t" value="Worker" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="703" y="548" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="550" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg3t" value="eBPF" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="768" y="548" width="32" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="807" y="550" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg4t" value="Front" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="825" y="548" width="32" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="864" y="550" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg5t" value="App Pod" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="882" y="548" width="45" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
