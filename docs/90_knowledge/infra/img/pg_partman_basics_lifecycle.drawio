<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io">
  <diagram name="pg_partman Lifecycle" id="lifecycle">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="640" pageHeight="480" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="640" height="480" as="geometry"/>
        </mxCell>
        <mxCell id="step1" value="① 親テーブル作成&#xa;CREATE TABLE ... PARTITION BY RANGE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="170" y="20" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a12" value="" style="edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="② create_parent() 実行&#xa;初期パーティション・テンプレート・デフォルト作成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="170" y="100" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a23" value="" style="edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="③ 運用開始&#xa;INSERT → PostgreSQL が子パーティションへ自動ルーティング" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="170" y="180" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a34" value="" style="edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" source="step3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="step4" value="④ run_maintenance() 定期実行&#xa;pg_cron または BGW でスケジュール" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="170" y="260" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a4r" value="" style="edgeStyle=none;exitX=0.17;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#b85450;strokeWidth=2;" edge="1" source="step4" target="retention" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4p" value="" style="edgeStyle=none;exitX=0.83;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#82b366;strokeWidth=2;" edge="1" source="step4" target="premake" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="retention" value="retention 処理&#xa;保持期間を超えたパーティションを&#xa;削除 / 別スキーマへ退避" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="10" y="370" width="210" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="premake" value="premake 処理&#xa;将来のパーティションを&#xa;事前作成（デフォルト 4 つ先）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
