<mxfile host="draw.io">
  <diagram name="Kubeshark Capture Flow" id="kubeshark-flow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- 白背景 -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="960" height="500" as="geometry" />
        </mxCell>
        <!-- タイトル -->
        <mxCell id="title" value="Kubeshark トラフィックキャプチャフロー" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="280" y="15" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1: kubeshark tap -->
        <mxCell id="s1" value="1. kubeshark tap&#xa;コマンド実行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- Step 2: Deploy -->
        <mxCell id="s2" value="2. Hub / Worker&#xa;を自動デプロイ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="240" y="70" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- Step 3: eBPF attach -->
        <mxCell id="s3" value="3. eBPF プログラムを&#xa;カーネルにアタッチ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="440" y="70" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- Step 4: Capture -->
        <mxCell id="s4" value="4. カーネルレベルで&#xa;パケットキャプチャ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="650" y="70" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- Step 5: Parse -->
        <mxCell id="s5" value="5. L7 プロトコル&#xa;パース・解析" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="650" y="200" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- Step 6: Hub集約 -->
        <mxCell id="s6" value="6. Hub がデータを&#xa;集約・インデックス化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="440" y="200" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- Step 7: KFLクエリ -->
        <mxCell id="s7" value="7. KFL クエリで&#xa;トラフィック検索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- Step 8: Dashboard -->
        <mxCell id="s8" value="8. ダッシュボードで&#xa;リアルタイム可視化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=2;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- 矢印 s1→s2 -->
        <mxCell id="a1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;strokeColor=#333333;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 矢印 s2→s3 -->
        <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;strokeColor=#333333;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 矢印 s3→s4 -->
        <mxCell id="a3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;strokeColor=#333333;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 矢印 s4→s5 -->
        <mxCell id="a4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 矢印 s5→s6 -->
        <mxCell id="a5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;strokeColor=#333333;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s5" target="s6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 矢印 s6→s7 -->
        <mxCell id="a6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;strokeColor=#333333;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s6" target="s7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 矢印 s7→s8 -->
        <mxCell id="a7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;strokeColor=#333333;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s7" target="s8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 対応プロトコル一覧 -->
        <mxCell id="proto_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="760" height="160" as="geometry" />
        </mxCell>
        <mxCell id="proto_title" value="対応プロトコル" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="55" y="320" width="150" height="25" as="geometry" />
        </mxCell>

        <!-- HTTP -->
        <mxCell id="p1" value="HTTP/1.1&#xa;HTTP/2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="55" y="355" width="90" height="45" as="geometry" />
        </mxCell>
        <!-- gRPC -->
        <mxCell id="p2" value="gRPC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="160" y="355" width="90" height="45" as="geometry" />
        </mxCell>
        <!-- GraphQL -->
        <mxCell id="p3" value="GraphQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="265" y="355" width="90" height="45" as="geometry" />
        </mxCell>
        <!-- Kafka -->
        <mxCell id="p4" value="Kafka" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="370" y="355" width="90" height="45" as="geometry" />
        </mxCell>
        <!-- Redis -->
        <mxCell id="p5" value="Redis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="475" y="355" width="90" height="45" as="geometry" />
        </mxCell>
        <!-- DNS -->
        <mxCell id="p6" value="DNS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="580" y="355" width="90" height="45" as="geometry" />
        </mxCell>
        <!-- AMQP -->
        <mxCell id="p7" value="AMQP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="685" y="355" width="90" height="45" as="geometry" />
        </mxCell>

        <!-- TLS 復号 -->
        <mxCell id="tls" value="TLS 復号対応: eBPF を使用してカーネルレベルで TLS トラフィックを復号する（サイドカー不要）" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="55" y="415" width="720" height="25" as="geometry" />
        </mxCell>
        <mxCell id="pcap" value="PCAP エクスポート: キャプチャしたパケットを Wireshark 互換の PCAP 形式でダウンロード可能" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="55" y="440" width="720" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
