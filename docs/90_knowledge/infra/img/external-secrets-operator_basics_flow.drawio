        <mxCell id="a23" value="" style="endArrow=classic;html=1;strokeColor=#D6B656;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
