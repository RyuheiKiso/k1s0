<mxfile>
  <diagram name="flow" id="flow">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="870" pageHeight="340" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="870" height="340" as="geometry" />
        </mxCell>

        <mxCell id="title" value="External Secrets Operator 同期フロー" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="235" y="5" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="phase_manual" value="手動（ユーザー操作）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="100" y="42" width="160" height="20" as="geometry" />
        </mxCell>

        <mxCell id="phase_auto" value="自動（ESO Controller）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="500" y="42" width="170" height="20" as="geometry" />
        </mxCell>

        <mxCell id="divider" value="" style="endArrow=none;html=1;strokeColor=#CCCCCC;dashed=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="40" as="sourcePoint" />
            <mxPoint x="410" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;1. SecretStore を定義&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;外部プロバイダの&lt;br&gt;認証情報を設定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="25" y="80" width="170" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="&lt;b&gt;2. ExternalSecret を定義&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;同期対象の&lt;br&gt;シークレットを指定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="225" y="80" width="170" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="&lt;b&gt;3. Controller が同期&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;外部プロバイダから&lt;br&gt;シークレット値を取得&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="440" y="80" width="170" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="&lt;b&gt;4. K8s Secret 作成&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Pod から env や&lt;br&gt;volume で利用可能&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="650" y="80" width="170" height="100" as="geometry" />
        </mxCell>

        <mxCell id="a12" value="" style="endArrow=classic;html=1;strokeColor=#6C8EBF;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s1" target="s2" parent="1">
