        <mxCell id="loop" value="refreshInterval で自動再同期" style="endArrow=classic;html=1;strokeColor=#D6B656;strokeWidth=2;dashed=1;fontSize=10;fontColor=#D6B656;fontStyle=1;curved=0;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="s4" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="840" y="260" />
              <mxPoint x="525" y="260" />
            </Array>
          </mxGeometry>
