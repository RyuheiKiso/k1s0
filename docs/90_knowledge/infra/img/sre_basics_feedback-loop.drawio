<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="Error Budget フィードバックループ" id="sre-loop">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="550" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="700" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="sli" value="&lt;b&gt;SLI 計測&lt;/b&gt;&lt;br&gt;可用性 / レイテンシ / エラー率" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="230" y="30" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="slo" value="&lt;b&gt;SLO 判定&lt;/b&gt;&lt;br&gt;目標値（例: 99.9%）と比較" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="230" y="150" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="eb" value="&lt;b&gt;Error Budget 算出&lt;/b&gt;&lt;br&gt;100% − SLO = 許容障害量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="230" y="270" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="decision" value="Budget&lt;br&gt;残量を判定" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="285" y="395" width="130" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="feature" value="&lt;b&gt;機能開発を加速&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="50" y="425" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="reliability" value="&lt;b&gt;信頼性改善を優先&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="490" y="425" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="rounded=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="sli" target="slo" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="rounded=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="slo" target="eb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="rounded=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="eb" target="decision" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="十分" style="rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontSize=12;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="decision" target="feature" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="不足" style="rounded=1;strokeColor=#b85450;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=12;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" source="decision" target="reliability" parent="1">
          <mxGeometry relative="1" as="geometry"/>
