<mxfile>
  <diagram name="CNCF Maturity Model">
    <mxGraphModel dx="900" dy="400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="400" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="900" height="400" as="geometry" />
        </mxCell>
        <mxCell id="title" value="CNCF プロジェクト成熟度モデル" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="早期段階 ────────────────────── 成熟" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="200" y="45" width="500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sandbox" value="&lt;b style=&apos;font-size:14px&apos;&gt;Sandbox&lt;/b&gt;&lt;br&gt;（サンドボックス）&lt;hr style=&apos;border:1px solid #CCCCCC&apos;&gt;&lt;div style=&apos;text-align:left;padding:0 10px&apos;&gt;初期段階のプロジェクト&lt;br&gt;&lt;br&gt;・実験的で急速に変化&lt;br&gt;・本番利用は非推奨&lt;br&gt;・TOC スポンサーが必要&lt;br&gt;・最小限のガバナンス&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;align=center;verticalAlign=top;spacingTop=10;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="240" height="300" as="geometry" />
        </mxCell>
        <mxCell id="incubating" value="&lt;b style=&apos;font-size:14px&apos;&gt;Incubating&lt;/b&gt;&lt;br&gt;（インキュベーティング）&lt;hr style=&apos;border:1px solid #D6B656&apos;&gt;&lt;div style=&apos;text-align:left;padding:0 10px&apos;&gt;成長段階のプロジェクト&lt;br&gt;&lt;br&gt;・本番採用の実績あり&lt;br&gt;・コミュニティが活発&lt;br&gt;・明確なガバナンス&lt;br&gt;・セキュリティ監査済み&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=top;spacingTop=10;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="80" width="240" height="300" as="geometry" />
        </mxCell>
        <mxCell id="graduated" value="&lt;b style=&apos;font-size:14px&apos;&gt;Graduated&lt;/b&gt;&lt;br&gt;（グラデュエーテッド）&lt;hr style=&apos;border:1px solid #82B366&apos;&gt;&lt;div style=&apos;text-align:left;padding:0 10px&apos;&gt;成熟したプロジェクト&lt;br&gt;&lt;br&gt;・広範な本番採用実績&lt;br&gt;・厳格なガバナンス&lt;br&gt;・コミッターが複数組織&lt;br&gt;・CII ベストプラクティス準拠&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=top;spacingTop=10;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="630" y="80" width="240" height="300" as="geometry" />
        </mxCell>
        <mxCell id="arrow1" value="" style="endArrow=block;endSize=10;endFill=1;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="270" y="230" as="sourcePoint" />
            <mxPoint x="330" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow2" value="" style="endArrow=block;endSize=10;endFill=1;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="570" y="230" as="sourcePoint" />
            <mxPoint x="630" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
