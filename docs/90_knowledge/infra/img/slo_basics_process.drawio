<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="SLO 定義プロセス" id="slo-process">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="720" pageHeight="500" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
