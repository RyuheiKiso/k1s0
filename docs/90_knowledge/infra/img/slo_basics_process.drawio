        <mxCell id="n5" value="バーンレートアラートを設定し&lt;br&gt;Grafana でダッシュボードを構築" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;fontSize=10;fontColor=#666666;align=left;spacingLeft=8;" vertex="1" parent="1">
