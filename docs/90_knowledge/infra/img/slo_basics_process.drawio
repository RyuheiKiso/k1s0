        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;① CUJ を特定する&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="160" y="30" width="240" height="50" as="geometry"/>
