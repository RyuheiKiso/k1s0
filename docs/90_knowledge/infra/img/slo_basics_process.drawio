        <mxCell id="n3" value="SLI の目標値を設定する&lt;br&gt;例: 可用性 99.9%、p99 &amp;lt; 300ms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;dashed=1;fontSize=10;fontColor=#666666;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="430" y="210" width="260" height="50" as="geometry"/>
