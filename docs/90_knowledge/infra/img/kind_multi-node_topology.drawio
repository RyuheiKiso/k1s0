        <mxCell id="legend" value="凡例: 黄=control-plane / 緑=worker / 青=外部接続 / 破線=クラスタ内通信" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=#FFFFFF;strokeColor=#888888;spacingLeft=8;" vertex="1" parent="1">
