        <mxCell id="el3" value="kubelet → apiserver (LB 経由) / kindnet で Pod 間ルーティング" style="text;html=1;fontSize=10;fontStyle=2;fillColor=#FFFFFF;strokeColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="120" y="450" width="500" height="20" as="geometry" />
