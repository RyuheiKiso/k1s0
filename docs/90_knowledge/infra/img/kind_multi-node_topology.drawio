        <mxCell id="e6" style="endArrow=classic;startArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#B58900;dashed=1;" edge="1" parent="1" source="cp2" target="cp3">
