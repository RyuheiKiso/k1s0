<mxfile host="app.diagrams.net">
  <diagram name="kind-multi-node-topology" id="topo">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="kind マルチノード クラスタ トポロジ (control-plane 3 + worker 3 / HA 例)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1020" height="30" as="geometry" />
        </mxCell>

        <mxCell id="host" value="Host OS (Linux / macOS / Windows + Docker Engine)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#444444;dashed=0;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1020" height="600" as="geometry" />
        </mxCell>

        <mxCell id="kubectl" value="kubectl (host バイナリ)&#10;kind-&lt;name&gt; context" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F6FB2;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dockernet" value="Docker bridge network: kind&#10;(各 node container が join)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#888888;dashed=1;fontSize=12;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="940" height="430" as="geometry" />
        </mxCell>

        <mxCell id="cp1" value="control-plane #1&#10;(Static Pods: apiserver / etcd /&#10;scheduler / controller-manager)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B58900;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="260" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="cp2" value="control-plane #2&#10;(Static Pods, etcd member)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B58900;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="260" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="cp3" value="control-plane #3&#10;(Static Pods, etcd member)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B58900;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="260" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="lb" value="external-load-balancer&#10;(haproxy / 自動生成 node container)&#10;Listen :6443 → cp#1/2/3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F6FB2;fontSize=11;align=center;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="380" y="380" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="w1" value="worker #1&#10;(kubelet / containerd / kindnet /&#10;kube-proxy / User Pods)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="490" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="w2" value="worker #2&#10;(同上 / User Pods)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="490" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="w3" value="worker #3&#10;(同上 / User Pods)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="490" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#1F6FB2;" edge="1" parent="1" source="kubectl" target="lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
