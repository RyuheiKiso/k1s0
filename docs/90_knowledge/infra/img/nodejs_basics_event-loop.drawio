        <mxCell id="d1" value="setTimeout / setInterval の&lt;br&gt;コールバックを実行" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
