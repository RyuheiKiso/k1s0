<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="Event Loop">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="620" pageHeight="570" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
