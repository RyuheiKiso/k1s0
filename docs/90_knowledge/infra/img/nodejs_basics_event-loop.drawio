        <mxCell id="title" value="Node.js イベントループのフェーズ" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
