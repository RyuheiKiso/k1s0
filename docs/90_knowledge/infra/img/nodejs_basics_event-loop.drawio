          <mxGeometry x="200" y="195" width="220" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="d3" value="Node.js の内部処理&lt;br&gt;（開発者は直接使わない）" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="10" y="195" width="180" height="45" as="geometry"/>
