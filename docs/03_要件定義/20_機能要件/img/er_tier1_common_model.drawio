<mxfile host="app.diagrams.net" modified="2026-04-20T00:00:00.000Z" agent="claude" version="28.0.6">
  <diagram id="er-tier1" name="tier1 共通データモデル ER 図">
    <mxGraphModel dx="1600" dy="1000" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1600" height="1000" as="geometry" />
        </mxCell>
        <mxCell id="title" value="tier1 共通データモデル (ER 図 / PostgreSQL 論理スキーマ)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1000" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="tier1 が管理する共通エンティティ。業務固有エンティティは tier2 が所有し、tenant_id で論理分割する" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="250" y="56" width="1100" height="22" as="geometry" />
        </mxCell>
        <mxCell id="tenant" value="&lt;b&gt;Tenant&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK tenant_id (uuid)&lt;br&gt;tenant_code (business)&lt;br&gt;display_name&lt;br&gt;status (active/suspended/terminated)&lt;br&gt;tier (free/standard/enterprise)&lt;br&gt;parent_tenant_id (FK self)&lt;br&gt;created_at / updated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="260" height="180" as="geometry" />
        </mxCell>
        <mxCell id="user" value="&lt;b&gt;User (Keycloak 同期)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK user_id (uuid)&lt;br&gt;FK tenant_id&lt;br&gt;keycloak_sub (unique)&lt;br&gt;email&lt;br&gt;display_name&lt;br&gt;status&lt;br&gt;last_login_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="110" width="260" height="170" as="geometry" />
        </mxCell>
        <mxCell id="role" value="&lt;b&gt;Role&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK role_id (uuid)&lt;br&gt;FK tenant_id (null=global)&lt;br&gt;role_code&lt;br&gt;permissions (jsonb)&lt;br&gt;created_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="user_role" value="&lt;b&gt;UserRole&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK (user_id, role_id)&lt;br&gt;granted_by (FK user)&lt;br&gt;granted_at&lt;br&gt;expires_at (nullable)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="110" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="audit" value="&lt;b&gt;AuditLog (WORM / 長期保存)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK audit_id (uuid v7)&lt;br&gt;FK tenant_id&lt;br&gt;FK actor_user_id&lt;br&gt;event_type&lt;br&gt;resource_type / resource_id&lt;br&gt;action (create/update/delete/read)&lt;br&gt;payload (jsonb, PII マスク済)&lt;br&gt;trace_id / span_id&lt;br&gt;occurred_at (immutable)&lt;br&gt;hash_chain (前レコードハッシュ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="280" height="240" as="geometry" />
        </mxCell>
        <mxCell id="workflow" value="&lt;b&gt;WorkflowExecution (Temporal 管理)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK workflow_id (uuid)&lt;br&gt;FK tenant_id&lt;br&gt;workflow_type&lt;br&gt;run_id (Temporal)&lt;br&gt;status (running/completed/failed)&lt;br&gt;started_at / closed_at&lt;br&gt;history_location (S3 path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="330" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="decision_rule" value="&lt;b&gt;DecisionRule (JDM)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK rule_id (uuid)&lt;br&gt;FK tenant_id&lt;br&gt;rule_code&lt;br&gt;version (semver)&lt;br&gt;jdm_definition (jsonb)&lt;br&gt;status (draft/published/deprecated)&lt;br&gt;published_by / published_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="330" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="feature_flag" value="&lt;b&gt;FeatureFlag (flagd 同期)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK flag_id (uuid)&lt;br&gt;FK tenant_id (null=global)&lt;br&gt;flag_key&lt;br&gt;kind (release/experiment/ops/permission)&lt;br&gt;variants (jsonb)&lt;br&gt;targeting (jsonb)&lt;br&gt;updated_by / updated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="330" width="280" height="210" as="geometry" />
        </mxCell>
        <mxCell id="state_entry" value="&lt;b&gt;StateEntry (KV 汎用)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK (tenant_id, store, key)&lt;br&gt;value (jsonb)&lt;br&gt;etag (uuid v7 / 楽観排他)&lt;br&gt;ttl_at (nullable)&lt;br&gt;updated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="280" height="160" as="geometry" />
        </mxCell>
        <mxCell id="outbox" value="&lt;b&gt;OutboxEvent (Transactional Outbox)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK event_id (uuid v7)&lt;br&gt;FK tenant_id&lt;br&gt;aggregate_type / aggregate_id&lt;br&gt;event_type&lt;br&gt;payload (jsonb)&lt;br&gt;status (pending/published/failed)&lt;br&gt;created_at / published_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="620" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="pii_catalog" value="&lt;b&gt;PiiCatalog (PII 分類辞書)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK pii_type_id (uuid)&lt;br&gt;code (個人番号/氏名/メール/電話 等)&lt;br&gt;sensitivity (low/medium/high/critical)&lt;br&gt;masking_strategy (hash/partial/redact)&lt;br&gt;legal_basis (個情法/GDPR)&lt;br&gt;retention_days" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="620" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="secret_ref" value="&lt;b&gt;SecretReference (OpenBao メタ)&lt;/b&gt;&lt;br&gt;---&lt;br&gt;PK secret_id (uuid)&lt;br&gt;FK tenant_id&lt;br&gt;secret_path (OpenBao KV パス)&lt;br&gt;secret_type (api_key/db/cert)&lt;br&gt;owner_service_id&lt;br&gt;rotation_interval_days&lt;br&gt;last_rotated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="620" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="rel-tenant-user" value="1..N" style="endArrow=ERmany;html=1;startArrow=ERone;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="170" as="sourcePoint" />
            <mxPoint x="380" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel-tenant-role" value="1..N" style="endArrow=ERmany;html=1;startArrow=ERone;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="200" as="sourcePoint" />
            <mxPoint x="700" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel-user-ur" value="1..N" style="endArrow=ERmany;html=1;startArrow=ERone;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="170" as="sourcePoint" />
            <mxPoint x="1020" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel-role-ur" value="1..N" style="endArrow=ERmany;html=1;startArrow=ERone;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="960" y="210" as="sourcePoint" />
