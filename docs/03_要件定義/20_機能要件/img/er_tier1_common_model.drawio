        <mxCell id="rel-tenant-audit" value="1..N" style="endArrow=ERmany;html=1;startArrow=ERone;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="190" y="290" as="sourcePoint" />
            <mxPoint x="190" y="330" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rel-user-audit" value="actor" style="endArrow=ERmany;html=1;startArrow=ERone;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="280" as="sourcePoint" />
