        <mxCell id="cHH" value="&lt;b&gt;P1 最優先&lt;/b&gt;&#xa;OPS-001 bus factor&#xa;(運用 少数名依存)&#xa;→ 採用 + Runbook 化で&#xa;& Medium 側へ移動目標" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8b7b3;strokeColor=#8b3a36;fontSize=10;fontColor=#FFFFFF;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontStyle=1" vertex="1" parent="1">
