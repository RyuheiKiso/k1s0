        <mxCell id="cHL" value="&lt;b&gt;該当なし&lt;/b&gt;&#xa;(High × Low 出現時は&#xa;Runbook 対応化を&#xa;優先)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=10;fontColor=#999999;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6" vertex="1" parent="1">
