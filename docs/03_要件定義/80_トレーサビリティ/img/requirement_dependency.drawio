        <mxCell id="title" value="要件 ID 依存グラフ（Phase 1b パイロット合格チェーン ＋ コンプライアンス連鎖）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="1140" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="要件は独立ではなく相互に前提・支援関係を持つ。本図は稟議審査と Phase 1b ゲート評価で問われる主要依存を可視化し、ある要件を外したときに連鎖的に何が崩れるかを判定する用途に使う。" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#555555;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="180" y="58" width="1340" height="32" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="凡例" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="60" height="22" as="geometry" />
        </mxCell>
        <mxCell id="legend-root" value="ハブ要件（章別ゲート）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="98" width="170" height="22" as="geometry" />
        </mxCell>
        <mxCell id="legend-nfr" value="非機能要件 NFR-*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="98" width="150" height="22" as="geometry" />
