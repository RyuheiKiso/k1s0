          <mxGeometry x="1360" y="148" width="240" height="32" as="geometry" />
        </mxCell>
        <mxCell id="phase-1a-label" value="Phase 1a&lt;br&gt;&lt;span style='font-size:10px;color:#555'&gt;MVP-0 / 稟議通過直後&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="1110" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="phase-1b-label" value="Phase 1b&lt;br&gt;&lt;span style='font-size:10px;color:#555'&gt;MVP-1a / パイロット投入&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="1110" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="phase-1c-label" value="Phase 1c&lt;br&gt;&lt;span style='font-size:10px;color:#555'&gt;MVP-1b / 運用定着&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="1110" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="phase-2p-label" value="Phase 2+&lt;br&gt;&lt;span style='font-size:10px;color:#555'&gt;拡大 / A-B 等の高度化&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1360" y="1110" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="gate-1a" value="&lt;b&gt;ゲート通過条件&lt;/b&gt;: tier2 アプリが 1 つ動く最小条件。同期呼出・状態管理・ログ・計装・JDM PoC・改ざん不可監査・AD 認証・データモデル基盤の 17 件 MUST 全件達成。&lt;br&gt;&lt;b&gt;ゲート審査者&lt;/b&gt;: Architecture Council&lt;br&gt;&lt;b&gt;主な達成証跡&lt;/b&gt;: 稟議デモ環境のスモークテスト pass、構造化ログの取得、JDM 評価デモ動画。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffaf0;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="180" y="1170" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="gate-1b" value="&lt;b&gt;ゲート通過条件&lt;/b&gt;: パイロット 1 チームが業務投入できる条件。Phase 1a 17 件に加え、PubSub 4 件・Secrets 1 件・Workflow 2 件・Binding 1 件・PII 1 件・Audit 連携 1 件・Feature Flag 1 件・.NET サイドカー 1 件・既存監視連携 1 件・Decision Audit 連携 1 件 = 累計 51 件達成、達成率 100%。&lt;br&gt;&lt;b&gt;ゲート審査者&lt;/b&gt;: Product Council ＋ パイロットチーム&lt;br&gt;&lt;b&gt;主な達成証跡&lt;/b&gt;: パイロット業務 SLO の 30 日連続観測、p99 500ms 達成、RTO 4h 復旧訓練。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5faff;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="1170" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="gate-1c" value="&lt;b&gt;ゲート通過条件&lt;/b&gt;: SRE オンコール体制で継続運用できる条件。新規 MUST は AUDIT-003（7 年保存）の 1 件のみ。NFR 側は HA 化・カオス試験・自動 Secret ローテーション・.NET サイドカー成熟・PII 仮名化が SHOULD/COULD として進む。&lt;br&gt;&lt;b&gt;ゲート審査者&lt;/b&gt;: SRE Lead ＋ コンプライアンス&lt;br&gt;&lt;b&gt;主な達成証跡&lt;/b&gt;: 監査ログ 7 年保存設定の運用記録、カオス試験 Runbook の演習結果。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f6fbf3;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="1170" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="gate-2p" value="&lt;b&gt;ゲート通過条件&lt;/b&gt;: Phase 1c で運用定着した上で、業務分析・品質高度化を扱う。新規 MUST は無し（既存要件の改善が主）。新機能 COULD は A/B テスト機構（FEATURE-004）の 1 件。&lt;br&gt;&lt;b&gt;ゲート審査者&lt;/b&gt;: Product Council&lt;br&gt;&lt;b&gt;主な達成証跡&lt;/b&gt;: A/B テスト基盤 PoC、テナント別コスト可視化、既存 EOL 製品の撤退記録。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5fc;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1170" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="note" value="解釈上の注: 本図は機能要件（FR-T1-* / FR-EXT-* / FR-INFO-*）の合計 59 件を対象とする。NFR・OR・DX・BC は別軸の Phase 進捗で管理しており本図には含まない。Phase ゲート通過判定は累計達成率 95% 以上を基準とする（02_機能一覧.md「要件総数と優先度分布」節）。Phase 1a → 1b の急増（17 → 51）は、パイロット投入で必要な API 基盤がほぼ全て立ち上がる構造を示す。" style="text;html=1;strokeColor=#888;fillColor=#fafafa;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=10;fontColor=#555555;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="160" y="1378" width="1480" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
