          <mxGeometry x="100" y="60" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="syft" value="Syft&#10;SBOM 生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="320" y="60" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sbom" value="SBOM 成果物&#10;(依存コンポーネント一覧)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="540" y="60" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="license" value="ライセンス分類&#10;(ポリシー照合: allow / label / forbid)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="170" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="grype" value="Grype&#10;CVE スキャン (Critical / High / Low)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="640" y="170" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="decide" value="統合判定&#10;ライセンス結果 + CVE 重大度 → 最終判断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="allow" value="許可 (PR 通過)&#10;Apache / MIT / BSD / MPL-2.0 / PostgreSQL&#10;Low CVE のみ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="390" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="label" value="ラベル付与 (通知のみ)&#10;AGPL 新規 / LGPL / High CVE&#10;→ 法務レビュー起票" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="440" y="390" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="block" value="PR ブロック (マージ拒否)&#10;GPL-2.0/3.0 / SSPL / BUSL / Critical CVE&#10;→ 代替 OSS 検討に差し戻し" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="800" y="390" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="kafka" value="Kafka 監査ログ&#10;(全判定イベントを追記)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="510" width="400" height="70" as="geometry" />
        </mxCell>
        <mxCell id="harbor" value="Harbor&#10;SBOM 保管" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="630" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="quarter" value="四半期レポート&#10;(法務レビュー向け)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="360" y="630" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="external" value="外部監査応答&#10;(SOC2 / ISO 27001)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="660" y="630" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="dashboard" value="法務ダッシュボード&#10;(Grafana 可視化)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="960" y="630" width="320" height="70" as="geometry" />
        </mxCell>
        <mxCell id="legAllow" value="許可 (即通過)&#10;&#10;Apache-2.0 / MIT / BSD-2-Clause / BSD-3-Clause&#10;MPL-2.0 (ファイル単位 copyleft, 隔離で対応可)&#10;PostgreSQL License&#10;ISC / Zlib" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F4E6;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="750" width="420" height="130" as="geometry" />
        </mxCell>
        <mxCell id="legLabel" value="ラベル (通知必須 / 改変時は配布条件注意)&#10;&#10;AGPL-3.0 (無改変 + 社内利用 + プロセス分離で義務発動なし)&#10;LGPL-2.1 / LGPL-3.0 (動的リンクで回避)&#10;EPL / CDDL (弱 copyleft)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7D5;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="750" width="420" height="130" as="geometry" />
        </mxCell>
        <mxCell id="legForbid" value="禁止 (PR ブロック)&#10;&#10;GPL-2.0 / GPL-3.0 (強 copyleft, 配布時に感染)&#10;SSPL (MongoDB 系, サービス提供時に全スタック公開義務)&#10;BUSL (Business Source, 時限的非商用制限)&#10;Commons Clause (再販禁止条項)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE5E5;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
