                    <mxGeometry x="1080" y="3535" width="500" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="iotDMZnote" value="※ OpenBao / Argo CD / Harbor は既存拡張。EMQX / Mender が新規追加。" style="text;html=1;align=left;fontSize=10;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="1080" y="3625" width="500" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="iotFrameT1" value="tier1 ファサードによる infra 隠蔽 + tier2 / tier3 接点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999999;verticalAlign=top;fontSize=12;fontStyle=1;arcSize=4;" parent="1" vertex="1">
                    <mxGeometry x="1620" y="3060" width="700" height="620" as="geometry"/>
                </mxCell>
                <mxCell id="iotT1Boundary" value="tier1 facade 境界 — 下記 Ingress / Dispatcher / Kafka は tier1 が内包 (tier2 / tier3 からは不可視)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#b8941d;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;arcSize=5;" parent="1" vertex="1">
                    <mxGeometry x="1635" y="3085" width="670" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="iotIngress" value="k1s0.Edge.Ingress (上り / Rust 自作)&#xa;━━━━━━━━━━━&#xa;EMQX を subscribe&#xa;→ CN allowlist / schema 検証&#xa;→ 単位正規化 + 重複排除&#xa;→ Dapr PubSub で Kafka 投入" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b8941d;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="1650" y="3115" width="280" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="iotDispatcher" value="k1s0.Edge.Dispatcher (下り / Rust 自作)&#xa;━━━━━━━━━━━&#xa;Dapr PubSub で Kafka subscribe&#xa;→ ポリシー検証 (ACL / rate limit)&#xa;→ EMQX へ MQTT Publish&#xa;   factory/{site}/device/{id}/cmd" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6a1b9a;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="1650" y="3215" width="280" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="iotKafkaTopics" value="Kafka topics (tier1 所有 / Strimzi 拡張 / RF=3)&#xa;━━━━━━━━━━━━━━━&#xa;上り telemetry :&#xa;  • edge.device.measurement (1〜10 Hz)&#xa;  • edge.device.alarm (閾値超過)&#xa;  • edge.device.heartbeat (1 min)&#xa;下り command :&#xa;  • edge.device.command&#xa;  • edge.device.command.ack&#xa;※ tier2 / tier3 は Kafka を直接参照しない" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#b85450;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="1940" y="3115" width="350" height="275" as="geometry"/>
                </mxCell>
                <mxCell id="iotT1FacadeExpose" value="▼ tier1 公開 API (この接点のみ tier2 / tier3 から可視)&#xa;上り : k1s0.PubSub.Subscribe(&quot;edge.device.measurement | alarm | heartbeat&quot;)&#xa;下り : k1s0.PubSub.Publish(&quot;edge.device.command&quot;, cmd)  /  Subscribe(&quot;edge.device.command.ack&quot;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8d0;strokeColor=#d6b656;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#8a6d00;align=center" parent="1" vertex="1">
                    <mxGeometry x="1640" y="3425" width="660" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="iotT2sub" value="tier2 ドメインサービス (k1s0.PubSub のみ使用 / Kafka は不可視)&#xa;━━━━━━━━━━━━━━━&#xa;上り : 品質管理 Service → alarm 購読  /  稼働分析 Service → measurement 購読&#xa;下り : 操業制御 Service → command 発行 (認可 + 監査 + 冪等化)&#xa;※ tier2 / tier3 のコード変更は不要 (案 C の最重要不変条件)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="1640" y="3495" width="660" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="iotT3obs" value="tier3 UI / 可視化 (既存 LGTM+P に統合)&#xa;Grafana 「エッジデバイス」ダッシュボード (Prometheus scrape / Loki は edge-agent ログ — Kafka 非経由)&#xa;操作 UI → tier2 操業制御 Service へ Service.Invoke → 下り command を tier2 から発行" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="1640" y="3615" width="660" height="60" as="geometry"/>
