                <mxCell id="podTmp" value="TemporalWorker Pod&#xa;[Go 1.25]&#xa;&#xa;• Deployment&#xa;• 3 replica (固定)&#xa;• Saga 実行専用&#xa;  Worker プロセス&#xa;&#xa;task queue:&#xa;k1s0-workflows" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=9;fontStyle=1;align=center;verticalAlign=top;spacingTop=4" vertex="1" parent="1">
