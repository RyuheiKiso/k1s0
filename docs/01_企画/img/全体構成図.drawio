                    <mxGeometry x="1080" y="3220" width="500" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="iotBao" value="OpenBao PKI secrets engine&#xa;(既存 OpenBao を機能拡張)&#xa;AppRole 認証 + TTL 24h 証明書署名&#xa;ATECC608B 連携で秘密鍵不持出" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1080" y="3325" width="500" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="iotArgoEdge" value="Argo CD ApplicationSet (edge)&#xa;既存 operation の Argo CD を拡張&#xa;GitOps pull 型 → k3s エッジ同期&#xa;argocd.ops.k1s0.internal" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="1080" y="3430" width="500" height="90" as="geometry"/>
                </mxCell>
