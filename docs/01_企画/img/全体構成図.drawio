                <mxCell id="podDec" value="DecisionEngine Pod&#xa;[Rust Edition 2024]&#xa;&#xa;• Deployment&#xa;• HPA 2–8 replica&#xa;• in-mem ZEN cache&#xa;  (ルール LRU 1GB)&#xa;&#xa;ConfigMap watch:&#xa;ルール JDM hot-reload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=9;fontStyle=1;align=center;verticalAlign=top;spacingTop=4" vertex="1" parent="1">
