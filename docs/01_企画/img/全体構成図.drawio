                <mxCell id="rpcLegend" value="&lt;b&gt;色別 gRPC (k1s0.internal.v1.* / mTLS via ztunnel / retry+deadline):&lt;/b&gt;  &lt;span style='color:#424242'&gt;■&lt;/span&gt; State→Audit.AppendHash   &lt;span style='color:#d32f2f'&gt;■&lt;/span&gt; Secret→Audit.AppendAccess   &lt;span style='color:#1565c0'&gt;■&lt;/span&gt; Tmp→Decision.Evaluate   &lt;span style='color:#7b1fa2'&gt;■&lt;/span&gt; State→PII.Mask   &lt;span style='color:#2e7d32'&gt;■&lt;/span&gt; Tmp→State.Batch" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;strokeWidth=1;fontSize=9;align=left;verticalAlign=middle;spacingLeft=8" vertex="1" parent="1">
