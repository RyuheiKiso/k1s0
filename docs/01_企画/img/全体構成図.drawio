                <mxCell id="iotFrameT1" value="tier1 / infra 追加 + tier2 / tier3 既存への流入ルート" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8d0;strokeColor=#d6b656;verticalAlign=top;fontSize=12;fontStyle=1;arcSize=4;" parent="1" vertex="1">
