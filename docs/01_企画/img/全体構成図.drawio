                <mxCell id="nsTier1" value="namespace: tier1 (共通基盤 / アーキテクト級チーム — Dapr を隠蔽)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=12;fontStyle=1;arcSize=4;" parent="1" vertex="1">
