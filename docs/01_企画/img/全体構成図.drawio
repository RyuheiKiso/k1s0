                <mxCell id="iotIngress" value="k1s0.Edge.Ingress (tier1 Go ファサード 新規追加)&#xa;━━━━━━━━━━━━━━━&#xa;Dapr MQTT binding で EMQX を subscribe&#xa;→ JSON schema 検証 + 単位正規化&#xa;→ k1s0.PubSub.Publish で infra Kafka へ&#xa;※ tier1 Go サービス群 (nsTier1) に crate として組込" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8d0;strokeColor=#d6b656;fontSize=11;fontStyle=1" parent="1" vertex="1">
