                <mxCell id="t1r6Head" value="ROW 6 — 失敗ドメイン境界 (Stateful vs Stateless) + CI / Admission ガード (tier2/3 の逸脱を強制検出)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbea;strokeColor=#d79b00;fontSize=10;fontStyle=1;fontColor=#8b6508" vertex="1" parent="1">
