                <mxCell id="admFrame" value="Admission フック順序 (Pod 作成シーケンス) — GitOps 起点 → 入退室 webhook チェーン → etcd 永続 → Node 配置 → 実行 (Dapr / Kyverno / kubelet の関係)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#37474f;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#263238" parent="1" vertex="1">
                    <mxGeometry x="60" y="4559" width="2280" height="250" as="geometry" />
                </mxCell>
                <mxCell id="adm1" value="① GitOps 起点&#10;━━━━━&#10;git push (開発者)&#10;→ Argo CD pull 型 sync&#10;→ Kyverno / Dapr の Helm Chart も含め reconcile" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="80" y="4599" width="260" height="120" as="geometry" />
                </mxCell>
                <mxCell id="adm2" value="② kube-apiserver&#10;━━━━━&#10;REST 受信 / 認証 / RBAC&#10;Admission webhook chain&#10;起動 (MutatingAdmission&#10;→ ValidatingAdmission)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="360" y="4599" width="260" height="120" as="geometry" />
                </mxCell>
                <mxCell id="adm3" value="③ Kyverno Mutating&#10;━━━━━&#10;dapr.io/* 未設定を&#10;拒否 (app-id 必須)&#10;CPU/memory limit 強制&#10;runAsNonRoot 強制" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="640" y="4599" width="260" height="120" as="geometry" />
                </mxCell>
                <mxCell id="adm4" value="④ Dapr sidecar-injector&#10;━━━━━&#10;MutatingWebhook&#10;app Pod に daprd container&#10;を注入 (app-id / app-port&#10;/ log-level 自動設定)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;verticalAlign=middle;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="920" y="4599" width="260" height="120" as="geometry" />
                </mxCell>
                <mxCell id="adm5" value="⑤ Kyverno Validating&#10;━━━━━&#10;PSS Restricted 違反拒否&#10;Pull 元 Harbor 限定&#10;Cosign 署名必須" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1200" y="4599" width="260" height="120" as="geometry" />
                </mxCell>
                <mxCell id="adm6" value="⑥ etcd 永続 + scheduler&#10;━━━━━&#10;apiserver が etcd 書込&#10;kube-scheduler が&#10;nodeSelector / taint で&#10;Worker Node 選択" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1480" y="4599" width="260" height="120" as="geometry" />
                </mxCell>
                <mxCell id="adm7" value="⑦ kubelet + containerd&#10;━━━━━&#10;Harbor から image pull&#10;(Cosign 検証)&#10;container 起動 / cgroup&#10;/ runAsNonRoot 適用" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
