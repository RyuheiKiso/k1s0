                <mxCell id="as_subs_cluster" value="4 subscriber (tier3 アプリ Pod 並列起動 / daprd が Kafka consumer group 管理)&#10;━━━━━━&#10;A inventory-svc : 在庫引当 reserve&#10;B credit-svc : 与信照会&#10;C payment-svc : 決済実行 (外部 API 連携)&#10;D notify-svc : メール / 社内 Slack 通知&#10;アプリ層 (tier3)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbea;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10" parent="1" vertex="1">
