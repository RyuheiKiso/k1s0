                    <mxGeometry x="80" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="adm2" value="② kube-apiserver&#xa;━━━━━&#xa;REST 受信 / 認証 / RBAC&#xa;Admission webhook chain&#xa;起動 (MutatingAdmission&#xa;→ ValidatingAdmission)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="360" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="adm3" value="③ Kyverno Mutating&#xa;━━━━━&#xa;dapr.io/* 未設定を&#xa;拒否 (app-id 必須)&#xa;CPU/memory limit 強制&#xa;runAsNonRoot 強制" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="640" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="adm4" value="④ Dapr sidecar-injector&#xa;━━━━━&#xa;MutatingWebhook&#xa;app Pod に daprd container&#xa;を注入 (app-id / app-port&#xa;/ log-level 自動設定)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;verticalAlign=middle;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="920" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="adm5" value="⑤ Kyverno Validating&#xa;━━━━━&#xa;PSS Restricted 違反拒否&#xa;Pull 元 Harbor 限定&#xa;Cosign 署名必須&#xa;(Phase 2 以降)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1200" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="adm6" value="⑥ etcd 永続 + scheduler&#xa;━━━━━&#xa;apiserver が etcd 書込&#xa;kube-scheduler が&#xa;nodeSelector / taint で&#xa;Worker Node 選択" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1480" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="adm7" value="⑦ kubelet + containerd&#xa;━━━━━&#xa;Harbor から image pull&#xa;(Cosign 検証)&#xa;container 起動 / cgroup&#xa;/ runAsNonRoot 適用" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;verticalAlign=middle" parent="1" vertex="1">
                    <mxGeometry x="1760" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="adm8" value="⑧ Pod Running&#xa;━━━━━&#xa;app + daprd 並行起動&#xa;readinessProbe 合格&#xa;ztunnel (Node 上) が&#xa;iptables で透過捕捉開始" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;verticalAlign=middle;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="2040" y="4740" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="admA1" style="endArrow=classic;html=1;rounded=0;edgeStyle=none;strokeColor=#37474f;strokeWidth=1.5" parent="1" edge="1">
