                <mxCell id="t1Api" value="k1s0 公開 API (多言語クライアントライブラリ Go / C# / TS) — tier2/tier3 から見える唯一の接点&#xa;k1s0.Log │ Telemetry │ State │ PubSub │ Secrets │ Workflow │ Auth │ Audit │ Decision │ Settings │ Feature" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8d0;strokeColor=#d6b656;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="110" y="1050" width="1590" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="t1Dapr" value="Dapr Control Plane (dapr-system)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="110" y="1160" width="360" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="t1DaprBody" value="• dapr-operator&#xa;• dapr-sidecar-injector&#xa;• dapr-sentry (mTLS CA)&#xa;• dapr-placement&#xa;• Component CRDs:&#xa;  statestore.valkey / pubsub.kafka /&#xa;  secretstore.openbao /&#xa;  bindings.postgres" style="text;html=1;align=left;verticalAlign=top;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="125" y="1185" width="335" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="t1Go" value="tier1 Go サービス群 (Go 1.25 / Dapr SDK 1.17 + Temporal SDK 1.35)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="490" y="1160" width="580" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="t1GoBody" value="• Dapr ファサード (state / pubsub / secrets / bindings)&#xa;• 認証プロキシ (oauth2-proxy → Keycloak)&#xa;• Saga ワークフローオーケストレータ (Temporal Worker)&#xa;  例: OrderSaga = 在庫確保 → 与信 → 決済 → 通知&#xa;• OTel 集約 / Loki クライアント&#xa;• 管理 Dapr Components YAML 一式" style="text;html=1;align=left;verticalAlign=top;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="505" y="1185" width="555" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="t1Rust" value="tier1 Rust サービス群 (Rust Edition 2024 / 高安全性・高性能)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="1090" y="1160" width="610" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="t1RustBody" value="• ZEN Engine 1.x 統合 (k1s0.Decision — 単発ルール評価)&#xa;  例: 承認者決定, 割引率判定, 与信ランク判定&#xa;• 暗号 (AES-256-GCM / Ed25519) / 監査改ざん防止ハッシュ (SHA-256 Merkle)&#xa;• 個人情報マスキング (正規表現 + 辞書ベース)&#xa;• Dapr Component YAML バリデータ (雛形 CLI と共通 crate)" style="text;html=1;align=left;verticalAlign=top;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="1105" y="1185" width="585" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="t1Cli" value="雛形生成 CLI `k1s0-init` (Rust 単一バイナリ): tier1 公開 API / Dapr annotation (dapr.io/enabled, app-id, app-port) / CI ガード (禁止 import 検出) を自動付与&#xa;→ tier2 / tier3 開発者は Dapr / OSS の存在を意識しない" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=11;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="110" y="1340" width="1590" height="70" as="geometry"/>
