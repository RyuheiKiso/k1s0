                <mxCell id="iotEMQX" value="EMQX MQTT Broker (3 ノード HA)&#xa;:8883 mTLS / ACL 強制&#xa;topic: factory/+/device/+/*&#xa;→ infra namespace の新規コンポーネント" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;fontStyle=1" parent="1" vertex="1">
