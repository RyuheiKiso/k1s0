                <mxCell id="netIstiod" value="istiod (control plane)&#xa;namespace: istio-system&#xa;Pilot / Citadel 統合&#xa;mTLS CA (Istio 側)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="95" y="1955" width="300" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="netZtunnel" value="ztunnel (DaemonSet / Node 単位)&#xa;L4 データプレーン / HBONE :15008&#xa;mTLS (spiffe:// identity)&#xa;iptables/eBPF で Pod トラフィックを透過捕捉" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="405" y="1955" width="430" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="netWaypoint" value="waypoint proxy (namespace/service 単位)&#xa;L7 データプレーン (HTTP ルーティング / Authorization Policy / リトライ / 負荷分散)&#xa;必要な namespace にのみ配置 (tier3 等 / L4 のみで足りる tier1 内部では非配置)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="845" y="1955" width="620" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="netDaprCP" value="Dapr Control Plane (dapr-system)&#xa;• dapr-operator • dapr-sidecar-injector • dapr-sentry (Dapr 側 mTLS CA)&#xa;• dapr-placement • Component CRDs: state.valkey / pubsub.kafka / secret.openbao / binding.postgres" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="1475" y="1955" width="830" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="netKedaHpa" value="KEDA ScaledObject — 例: kafka-lag-order.created &gt; 100 → 注文処理 Pod replicas +2 (max=10) / HPA も併用" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" parent="1" vertex="1">
                    <mxGeometry x="95" y="2055" width="1290" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="netMeshNote" value="透過捕捉の仕組み: Pod は自分のトラフィックが ztunnel 経由で流れることを知らない。アプリは通常の HTTP/gRPC 呼び出しをするだけで、ノード上の ztunnel が iptables/eBPF で捕捉し HBONE (L4 mTLS) トンネル経由で相手ノードに届ける。L7 必要時は waypoint 経由で迂回。" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="95" y="2105" width="2210" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="netDaprCpNote" value="※ Dapr サイドカー (daprd) 本体はアプリ層 lane (各 Pod 内) に在る。ここは Dapr の Control Plane のみ。" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=2;fontColor=#1a4c80" parent="1" vertex="1">
                    <mxGeometry x="1475" y="2055" width="830" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="netDistinction" value="重要なレイヤ対比: Dapr (アプリ層) = アプリが `k1s0.State.Save()` のような SDK で明示的に呼び出す / Istio Ambient (本 lane) = アプリから見えず、ノード上の ztunnel が透過的に mTLS を適用する。両者は同じ Pod 近傍に在るが責務レイヤが異なる (ADR-0001 / 0002 参照)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#e65100;fontSize=10;fontStyle=1;fontColor=#5d4037" parent="1" vertex="1">
                    <mxGeometry x="95" y="2170" width="2210" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="netKyvernoRef" value="ネットワーク層で適用される Admission ポリシー (実体は インフラ層 lane の Kyverno / dapr.io/app-id 必須 / Pod Security Standard Restricted / イメージ Pull 元制限 Harbor のみ)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="95" y="2245" width="2210" height="40" as="geometry"/>
