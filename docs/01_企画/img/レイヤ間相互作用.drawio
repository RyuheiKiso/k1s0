        <mxCell id="sb_layer" value="【レイヤ色の読み方】&#xa;暖色=アプリ層 (明示呼び出し) / 寒色=ネット層 (透過的) / 灰=インフラ層 (前提) / 紫=データ層 (状態)。同色内の箱は同じ責務レイヤに属する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;spacingTop=4;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1190" y="215" width="285" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sb_a1" value="① ユーザー → Edge Gateway (黒実線太)&#xa;外部トラフィックの入口。アプリコードはまだ登場しない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;spacingTop=2;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1190" y="290" width="285" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sb_a2" value="② Edge → tier3 (点線細寒色)&#xa;Ambient が iptables で透過配送。tier3 Pod には「直接来た」ように見え、アプリコードには経路が一切現れない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;spacingTop=2;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1190" y="345" width="285" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sb_a3" value="③ tier3 → tier2 → tier1 (実線太暖色)&#xa;明示呼び出し。tier1 が Go ファサード / Rust 自作 / daprd を内部で隠蔽し、tier2/3 からは同じ k1s0 API 面しか見えない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;spacingTop=2;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1190" y="410" width="285" height="75" as="geometry" />
        </mxCell>
        <mxCell id="sb_a4" value="④ tier1 → データ層 (実線太暖色)&#xa;k1s0.State.Save() 等の SDK 呼び出しが daprd → Dapr Component → RDB/Kafka 等に伝播。アプリはデータ製品名を知らない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;spacingTop=2;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1190" y="490" width="285" height="75" as="geometry" />
        </mxCell>
        <mxCell id="sb_a5" value="⑤ tier Pod → Ambient (点線細寒色)&#xa;Pod 間の全通信は ztunnel/waypoint が iptables で透過捕捉し mTLS + 認可を付与。アプリはこの挙動を認識しない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;spacingTop=2;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1190" y="570" width="285" height="75" as="geometry" />
        </mxCell>
        <mxCell id="sb_extra" value="【tier と責務レイヤは直交】&#xa;tier1/2/3 は「アプリ組織上の階層」で全てアプリ層内。4 レイヤは「責務区分」。両者を混同しないこと。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;spacingTop=2;whiteSpace=wrap;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1190" y="650" width="285" height="65" as="geometry" />
