        <mxCell id="c2Body" value="事件: Phobos 系ランサムウェア&#xa;業種: 公立医療機関 (電子カルテ停止)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDEAE8;strokeColor=#B85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
