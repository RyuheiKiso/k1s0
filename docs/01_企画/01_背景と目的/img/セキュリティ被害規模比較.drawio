        <mxCell id="c1Body" value="事件: Emotet 経由のランサムウェア&#xa;業種: 自動車部品サプライチェーン" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDEAE8;strokeColor=#B85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
