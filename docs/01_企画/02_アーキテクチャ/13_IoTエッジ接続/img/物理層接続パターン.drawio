        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1500" height="820" as="geometry" />
        </mxCell>
        <mxCell id="title" value="RS-232C / RS-485 / GPIO UART 物理層接続パターン" style="text;html=1;align=center;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="0" y="10" width="1500" height="30" as="geometry" />
        </mxCell>

