        </mxCell>
        <mxCell id="labelA" value="パターン 1&#xa;RS-232C&#xa;(単点・全二重)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontStyle=1;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="30" y="90" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="piA" value="Raspberry Pi&#xa;(USB 2.0)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="180" y="150" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="convA" value="USB-Serial 変換&#xa;(FTDI / SiLabs / CH340)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="450" y="150" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="devA" value="RS-232C 機器&#xa;(DB-9 / DB-25)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555" vertex="1" parent="1">
          <mxGeometry x="790" y="150" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="noteA" value="&#x2022; 全二重 / 1:1 / ケーブル長 ≤ 15 m&#xa;&#x2022; 電気仕様: ±3〜±15 V、シングルエンド (シールド推奨)&#xa;&#x2022; 産業環境ではフォトカプラ・パルストランスによるアイソレーション必須&#xa;&#x2022; チップ選定基準: Linux kernel の ftdi_sio / cp210x / ch341 ドライバ対応" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
          <mxGeometry x="980" y="90" width="500" height="170" as="geometry" />
        </mxCell>
        <mxCell id="eA1" value="USB" style="endArrow=classic;html=1;strokeColor=#333333;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="piA" target="convA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eA2" value="RS-232C" style="endArrow=classic;html=1;strokeColor=#333333;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="convA" target="devA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="laneB" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#d6a24f;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="10" y="310" width="1480" height="240" as="geometry" />
        </mxCell>
        <mxCell id="labelB" value="パターン 2&#xa;RS-485&#xa;(差動・マルチドロップ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6a24f;fontStyle=1;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="30" y="340" width="130" height="180" as="geometry" />
        </mxCell>
        <mxCell id="piB" value="Raspberry Pi&#xa;(USB 2.0)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6a24f" vertex="1" parent="1">
          <mxGeometry x="180" y="410" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="convB" value="USB-RS485 変換&#xa;(アイソレータ + 終端抵抗)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6a24f" vertex="1" parent="1">
          <mxGeometry x="450" y="410" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="devB1" value="機器 #1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555" vertex="1" parent="1">
          <mxGeometry x="790" y="340" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="devB2" value="機器 #2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555" vertex="1" parent="1">
          <mxGeometry x="790" y="415" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="devB3" value="機器 #N (最大 32 / 250 kbps時)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555" vertex="1" parent="1">
          <mxGeometry x="790" y="490" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="noteB" value="&#x2022; 半二重 (2 線式) / マスタ (Pi) が順次ポーリング&#xa;&#x2022; 電気仕様: 差動 (A/B ペア) / ケーブル長 ≤ 1200 m&#xa;&#x2022; 両端に終端抵抗 120 Ω、バイアス抵抗が必要&#xa;&#x2022; 太線は RS-485 マルチドロップバス (A/B 差動ペア)&#xa;&#x2022; Modbus RTU / BACnet MS/TP / PROFIBUS DP 等が載る&#xa;&#x2022; 機器 GND 間の電位差対策でガルバニックアイソレーション必須" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6a24f;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
          <mxGeometry x="980" y="340" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="eB1" value="USB" style="endArrow=classic;html=1;strokeColor=#333333;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="piB" target="convB">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
