        <mxCell id="laneC" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#6c8ebf;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="10" y="570" width="1480" height="230" as="geometry" />
        </mxCell>
        <mxCell id="labelC" value="パターン 3&#xa;GPIO UART 直結&#xa;(非推奨・検証用)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="30" y="600" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="piC" value="Raspberry Pi GPIO&#xa;(3.3 V TTL UART)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="180" y="660" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="convC" value="MAX3232 IC&#xa;(3.3 V TTL ⇔ ±12 V 変換)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="450" y="660" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="devC" value="RS-232C 機器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555" vertex="1" parent="1">
          <mxGeometry x="790" y="660" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="noteC" value="&#x2022; Pi 単体で GPIO から UART を取り出す構成&#xa;&#x2022; 3.3 V TTL のままでは RS-232C 機器に接続不可、MAX3232 等のレベル変換 IC 必須&#xa;&#x2022; アイソレーション無しでは Pi の GPIO が焼損するリスクあり&#xa;&#x2022; シリアルコンソール用途と競合しがち、/boot/config.txt の設定変更必要&#xa;&#x2022; 本番配線では USB-Serial (パターン 1) を推奨" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
          <mxGeometry x="980" y="600" width="500" height="170" as="geometry" />
