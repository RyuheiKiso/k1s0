<mxfile host="draw.io">
  <diagram name="cert-rotation" id="cert-rotation">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1500" height="780" as="geometry" />
        </mxCell>
        <mxCell id="title" value="mTLS 短命証明書 (TTL 24h) の自動ローテーションフロー" style="text;html=1;align=center;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="0" y="10" width="1500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="laneEdge" value="Edge Agent (Pi)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontStyle=1;verticalAlign=top;align=center" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="280" height="680" as="geometry" />
        </mxCell>
        <mxCell id="laneATECC" value="ATECC608B&#xa;(セキュアエレメント)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c0578f;fontStyle=1;verticalAlign=top;align=center" vertex="1" parent="1">
          <mxGeometry x="360" y="60" width="280" height="680" as="geometry" />
        </mxCell>
        <mxCell id="laneBao" value="OpenBao PKI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#d6a24f;fontStyle=1;verticalAlign=top;align=center" vertex="1" parent="1">
          <mxGeometry x="680" y="60" width="280" height="680" as="geometry" />
        </mxCell>
        <mxCell id="laneBroker" value="MQTT Broker (EMQX)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;verticalAlign=top;align=center" vertex="1" parent="1">
          <mxGeometry x="1000" y="60" width="280" height="680" as="geometry" />
        </mxCell>
        <mxCell id="laneNote" value="メモ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontStyle=1;verticalAlign=top;align=center" vertex="1" parent="1">
          <mxGeometry x="1300" y="60" width="180" height="680" as="geometry" />
        </mxCell>

        <mxCell id="step1" value="① boot 時&#xa;CSR 生成要求" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="② slot0 で ECDSA P-256 鍵生成&#xa;CSR を返す" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c0578f" vertex="1" parent="1">
          <mxGeometry x="380" y="180" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="③ AppRole 認証&#xa;CSR 提出" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="④ TTL=24h で署名&#xa;証明書 + CA chain 返却" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6a24f" vertex="1" parent="1">
          <mxGeometry x="700" y="340" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="⑤ MQTT CONNECT&#xa;mTLS handshake (TLS 1.3)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="60" y="430" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="⑥ CN allowlist 検証&#xa;CRL チェック → 通信開始" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565c0" vertex="1" parent="1">
          <mxGeometry x="1020" y="500" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step7" value="⑦ 残存 TTL ≤ 8h を検出&#xa;再発行サイクルへ&#xa;(③ に戻る)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="60" y="600" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="note1" value="• 秘密鍵は ATECC&#xa;  内部から出ない&#xa;• 漏えい不可" style="text;html=1;align=left;fontSize=11;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="1310" y="180" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="• AppRole の secret_id&#xa;  は 10 分 TTL&#xa;  使い捨て" style="text;html=1;align=left;fontSize=11;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="1310" y="270" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="• 失敗 3 回で alert&#xa;• 残存 4h で CRITICAL&#xa;• 残存 1h で publish&#xa;  停止フェイルセーフ" style="text;html=1;align=left;fontSize=11;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="1310" y="600" width="170" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e12" value="" style="endArrow=classic;html=1;strokeColor=#333333" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
