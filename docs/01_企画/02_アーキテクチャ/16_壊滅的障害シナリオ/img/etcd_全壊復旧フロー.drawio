<mxfile host="draw.io">
  <diagram name="etcd_recovery" id="er">
    <mxGraphModel dx="1100" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1100" height="760" as="geometry" />
        </mxCell>
        <mxCell id="title" value="etcd 全ノード障害 - Runbook (kubeadm メイン / k3s サブプラン)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="既存 Pod は kubelet で実行継続&#xa;(static manifest と PLEG キャッシュ)&#xa;業務トラフィックは縮退で継続" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="T+0: kube-apiserver が 503&#xa;新規 Pod 起動・Job スケジュール不能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="直近 24h 以内のスナップショット&#xa;が MinIO 上に存在するか?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="400" y="200" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="b4a" value="経路 A (RTO 30 分): 健全な制御ノードで&#xa;etcdctl snapshot restore&#xa;→ kube-apiserver / scheduler を再起動" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b4b" value="経路 B (RTO 4 時間): 全ノード再構築&#xa;tofu apply で VM 再作成&#xa;→ kubeadm init で空クラスタ生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="720" y="360" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b5b" value="T+2h: Argo CD インストール&#xa;Git から全マニフェストを同期" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="720" y="470" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b6b" value="T+3h: PostgreSQL を barman-cloud から復元&#xa;(Keycloak / Backstage / Harbor が起動)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="720" y="560" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b7" value="動作確認 (Keycloak SSO → Argo CD → サンプル業務)&#xa;業務完全復旧" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="390" y="660" width="340" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e13" value="" style="endArrow=classic;html=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="b1" target="b3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3a" value="Yes" style="endArrow=classic;html=1;strokeWidth=2;exitX=0;exitY=0.5;entryX=0.5;entryY=0;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="b3" target="b4a">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="220" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e3b" value="No" style="endArrow=classic;html=1;strokeWidth=2;exitX=1;exitY=0.5;entryX=0.5;entryY=0;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="b3" target="b4b">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="880" y="250" />
