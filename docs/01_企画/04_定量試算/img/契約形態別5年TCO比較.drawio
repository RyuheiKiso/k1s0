        <mxCell id="bF" value="フリーランス&#xa;&#xa;◎ 契約柔軟性&#xa;◎ 5 年 TCO 最安&#xa;△ ノウハウ蓄積弱&#xa;△ 離脱耐性弱" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFBE4;strokeColor=#82B366;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
