        </mxCell>
        <mxCell id="bE" value="SES&#xa;&#xa;◎ 短期増員対応&#xa;◎ 固定コストにならない&#xa;△ 5 年 TCO 最高&#xa;△ 知財流出リスク (OSS 公開前提に不適合)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D79B00;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
