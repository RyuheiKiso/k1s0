        </mxCell>

        <mxCell id="open" value="Open (遮断)&#xa;全リクエスト即時失敗&#xa;(503 / Unavailable)&#xa;下流への負荷停止" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;fontColor=#000000;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="1180" y="400" width="280" height="180" as="geometry" />
        </mxCell>

        <mxCell id="halfopen" value="HalfOpen (試行)&#xa;少数リクエストのみ通過&#xa;下流の回復を探る" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;fontColor=#000000;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="660" y="400" width="280" height="180" as="geometry" />
        </mxCell>

        <mxCell id="metrics" value="Prometheus メトリクス&#xa;circuit_breaker_state{dependency, state}&#xa;  Closed=0 / Open=1 / HalfOpen=2&#xa;circuit_breaker_transitions_total{dependency, from, to}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontColor=#000000;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="720" width="520" height="100" as="geometry" />
        </mxCell>

        <mxCell id="trigger_close_open" value="直近 1 分で失敗 10 回以上&#xa;かつ失敗率 50% 以上" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="500" y="180" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="trigger_open_half" value="Open 遷移から 30 秒経過&#xa;(Kubernetes Pod 再起動&#xa;+ Readiness 典型値)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#6c8ebf;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
