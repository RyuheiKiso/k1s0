        </mxCell>

        <mxCell id="title" value="k1s0 呼び出し経路のタイムアウト階層 (Client 10s → Gateway 8s → Istio 7s → tier1 6s → Dapr 5s → Backend 4s)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="1460" height="40" as="geometry" />
        </mxCell>

        <mxCell id="subtitle" value="上位ほど長く下位ほど短い「ピラミッド構造」で、一次タイムアウトを必ず下位層で発生させる (差分 1〜2 秒)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="60" width="1460" height="24" as="geometry" />
        </mxCell>

        <mxCell id="client" value="クライアント側 SDK (tier2 / tier3)&#xa;タイムアウト 10 秒&#xa;業務要件上の許容待ち時間の上限" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="1300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="gateway" value="Envoy Gateway&#xa;タイムアウト 8 秒&#xa;外部境界での最終防衛線 / JWT 検証含む" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="280" y="230" width="1140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="istio" value="Istio Ambient waypoint proxy&#xa;タイムアウト 7 秒&#xa;tier1 サービス到達前のネットワーク層制限 (Istio 側 retries.attempts=0 固定)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="360" y="340" width="980" height="60" as="geometry" />
        </mxCell>

        <mxCell id="tier1api" value="tier1 公開 API (Go Dapr ファサード / Rust 自作領域)&#xa;タイムアウト 6 秒&#xa;業務ロジックの最大処理時間 / context.Context / tokio::timeout で伝搬" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="440" y="450" width="820" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dapr" value="Dapr Building Block (daprd sidecar)&#xa;タイムアウト 5 秒&#xa;SDK 呼び出し完了までの制限" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="520" y="560" width="660" height="60" as="geometry" />
        </mxCell>

        <mxCell id="backend" value="バックエンド OSS (Valkey / Kafka / PostgreSQL / OpenBao)&#xa;タイムアウト 4 秒&#xa;データ層への最終呼び出し" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
