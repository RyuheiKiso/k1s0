        <mxCell id="axis_label" value="↓ 呼び出し方向 (上位 → 下位)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="140" height="30" as="geometry" />
        </mxCell>

        <mxCell id="axis_rev" value="↑ エラー応答方向 (下位 → 上位)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1470" y="400" width="180" height="30" as="geometry" />
        </mxCell>

        <mxCell id="api_header" value="API 別個別タイムアウト (層別と min() で適用)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;fontColor=#000000;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="780" width="1540" height="30" as="geometry" />
        </mxCell>

        <mxCell id="api1" value="Decision.Evaluate&#xa;100ms&#xa;(p99 1ms の 100 倍)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="80" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api2" value="State.Get&#xa;500ms&#xa;(p99 10ms の 50 倍)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="275" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api3" value="State.Set&#xa;1 秒" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="470" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api4" value="State.BulkTransaction&#xa;2 秒" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="665" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api5" value="PubSub.Publish&#xa;1 秒&#xa;(p99 50ms の 20 倍)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="860" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api6" value="Secrets.Get&#xa;1 秒" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1055" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api7" value="Workflow.Start&#xa;5 秒" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1250" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api8" value="Binding.Invoke&#xa;10 秒&#xa;(外部依存吸収)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1445" y="820" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="basis_box" value="階層差分 1〜2 秒の数値根拠&#xa;・差分が小さすぎる: 下位で一次タイムアウトする前に上位が先に切れる事故&#xa;・差分が大きすぎる: 上位層で長時間滞留してリソースを浪費する逆問題&#xa;・1〜2 秒: goroutine/task スケジューリング遅延・gRPC RTT 変動・Node 間遅延を吸収できる最低値&#xa;・tier1 API p99 500ms (正常時) の 12 倍マージンを異常時上限 6 秒で確保" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontColor=#000000;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="910" width="760" height="110" as="geometry" />
        </mxCell>

        <mxCell id="context_box" value="コンテキスト伝搬&#xa;・gRPC Deadline Propagation (grpc-timeout ヘッダ) 必須&#xa;・Go: context.WithTimeout / WithDeadline / WithCancel&#xa;・Rust: tokio::time::timeout + #[instrument] で OTel Span 連携&#xa;・下流側は min(own_limit, deadline - processing_time) で動的計算&#xa;・CI で ctx.Done() 監視漏れを go vet + カスタム linter で検出" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontColor=#000000;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="860" y="910" width="760" height="110" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="凡例" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;verticalAlign=top;fontColor=#000000;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="1040" width="1540" height="50" as="geometry" />
        </mxCell>

        <mxCell id="legend_app" value="■ アプリ層 (暖色): tier1 公開 API / Dapr / クライアント SDK   ■ ネットワーク層 (寒色): Envoy Gateway / Istio Ambient   ■ データ層 (薄紫): バックエンド OSS   ■ インフラ層 (中性灰): 根拠・補足" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#000000;align=left;" vertex="1" parent="1">
