        </mxCell>

        <mxCell id="orchestrator_compensation" value="Temporal Workflow (Compensation フェーズに遷移)&#xa;失敗検出後 10 秒以内に補償開始 / 逆順で Compensation Activity を呼び出し" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
