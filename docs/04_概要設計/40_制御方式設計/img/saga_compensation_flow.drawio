        </mxCell>

        <mxCell id="step1_normal" value="ステップ 1: 在庫引当&#xa;State.BulkTransaction&#xa;stock:SKU-001 -= 1&#xa;stock log 追記 (原子)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="270" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="step2_normal" value="ステップ 2: 決済&#xa;Binding.Invoke&#xa;外部決済ゲートウェイ&#xa;(timeout 10s, retry 5)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="410" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="step3_normal" value="ステップ 3: 出荷手配&#xa;PubSub.Publish&#xa;ShipmentRequested&#xa;(at-least-once)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="550" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="step4_normal" value="ステップ 4: 通知&#xa;PubSub.Publish&#xa;OrderConfirmed&#xa;(軽微、3 回 retry 許容)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
