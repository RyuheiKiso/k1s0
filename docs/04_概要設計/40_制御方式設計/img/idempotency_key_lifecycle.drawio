<mxfile host="app.diagrams.net" modified="2026-04-21T00:00:00.000Z" agent="k1s0" version="24.7.17">
  <diagram id="idempotency-key-lifecycle" name="IdempotencyKeyLifecycle">
    <mxGraphModel dx="1600" dy="1000" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1360" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1700" height="1360" as="geometry" />
        </mxCell>

        <mxCell id="title" value="冪等性キーのライフサイクル (クライアント送信 → tier1 受信 → Valkey 重複チェック → 応答分岐)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="1400" height="40" as="geometry" />
        </mxCell>

        <mxCell id="client" value="tier2 / tier3 クライアント&#xa;UUIDv7 生成 + X-Idempotency-Key 付与&#xa;SDK: k1s0.StateClient.Set(..., WithIdempotencyKey(uuid.NewV7()))" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="610" y="90" width="480" height="70" as="geometry" />
        </mxCell>

        <mxCell id="tier1" value="tier1 公開 API (Dapr ファサード / Go)&#xa;X-Idempotency-Key ヘッダ抽出 + スコープ判定 (tenant default)&#xa;未指定時は 400 Bad Request (IDEMPOTENCY_REQUIRED)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="570" y="210" width="560" height="80" as="geometry" />
        </mxCell>

        <mxCell id="valkey_check" value="Valkey SET NX EX 86400&#xa;key: idempotency:{scope}:{tenant}:{api}:{uuid}&#xa;value: {status:processing, request_hash:sha256(body), started_at:...}&#xa;TTL 24 時間 (86400 秒)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="570" y="340" width="560" height="100" as="geometry" />
        </mxCell>

        <mxCell id="decision" value="NX 成否で分岐&#xa;(Valkey 原子操作、10ms 以内)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="670" y="490" width="360" height="100" as="geometry" />
        </mxCell>

        <mxCell id="branch_new" value="NX 成功 (初回リクエスト)&#xa;キーを新規作成&#xa;業務処理を実行可" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="160" y="650" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="branch_exists" value="NX 失敗 (既存キー検出)&#xa;既存 status を読み出して分岐" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=11;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1220" y="650" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="execute" value="業務処理実行&#xa;(State.Set / PubSub.Publish / Workflow.Start 等)&#xa;処理後に Valkey を UPDATE&#xa;status:completed + response_body 保存" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="140" y="770" width="360" height="90" as="geometry" />
        </mxCell>

        <mxCell id="response_fresh" value="200 OK + 処理結果応答&#xa;X-Idempotent-Replay: false" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;fontStyle=1;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="140" y="910" width="360" height="70" as="geometry" />
        </mxCell>

        <mxCell id="check_hash" value="request_hash 照合 (衝突対策)&#xa;SHA-256(body) が一致するか確認" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1210" y="770" width="340" height="90" as="geometry" />
        </mxCell>

        <mxCell id="branch_status" value="status 分岐&#xa;processing / completed / failed" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="690" y="770" width="360" height="90" as="geometry" />
        </mxCell>

        <mxCell id="resp_processing" value="409 Conflict&#xa;Retry-After: 5s&#xa;processing 状態&#xa;(5 分超過時は強制 failed 遷移)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="550" y="910" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="resp_completed" value="前回応答をリプレイ&#xa;X-Idempotent-Replay: true&#xa;業務処理は再実行しない" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="800" y="910" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="resp_failed" value="前回失敗応答を返却&#xa;クライアントは新キーで再発行&#xa;またはリトライポリシー適用" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fdf3f3;strokeColor=#c62828;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1050" y="910" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="resp_mismatch" value="409 Conflict&#xa;IDEMPOTENCY_MISMATCH&#xa;(ボディ不一致、早期バグ検出)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fdf3f3;strokeColor=#c62828;fontSize=11;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1320" y="910" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="valkey_gc" value="Valkey 組込 TTL GC&#xa;24h 経過で自動 expire&#xa;別スイーププロセス不要" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="140" y="1040" width="360" height="70" as="geometry" />
        </mxCell>

        <mxCell id="metrics_note" value="オーバーヘッド / 数値仕様&#xa;Valkey SET NX EX: 10ms タイムアウト&#xa;冪等化オーバーヘッド: 1ms 未満 (p99)&#xa;tier1 API p99 予算 500ms のうち 0.2% 消費" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;fontColor=#000000;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="1040" width="330" height="110" as="geometry" />
        </mxCell>

        <mxCell id="scope_note" value="キーのスコープ&#xa;idempotency:tenant:{tenant}:{api}:{uuid} (default)&#xa;global / user スコープも指定可&#xa;マルチテナント衝突を構造的に排除" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;fontColor=#000000;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="910" y="1040" width="330" height="110" as="geometry" />
        </mxCell>

        <mxCell id="hash_note" value="ハッシュ衝突対策&#xa;SHA-256(request body) を保存&#xa;同一キーで異なるボディ = クライアントバグ&#xa;IDEMPOTENCY_MISMATCH で即座に検出" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;fontColor=#000000;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1280" y="1040" width="330" height="110" as="geometry" />
        </mxCell>

        <mxCell id="e_client_tier1" value="HTTP / gRPC" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#d79b00;strokeWidth=2;fontSize=11;fontColor=#000000;" edge="1" parent="1" source="client" target="tier1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_tier1_valkey" value="SET NX EX 86400" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=2;fontSize=11;fontColor=#000000;" edge="1" parent="1" source="tier1" target="valkey_check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_valkey_decision" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1" source="valkey_check" target="decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_dec_new" value="新規キー作成成功" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#2e7d32;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#2e7d32;" edge="1" parent="1" source="decision" target="branch_new">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="540" />
              <mxPoint x="320" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_dec_exists" value="既存キー検出" style="edgeStyle=none;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#ef6c00;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#ef6c00;" edge="1" parent="1" source="decision" target="branch_exists">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1090" y="540" />
              <mxPoint x="1380" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_new_exec" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#2e7d32;strokeWidth=2;" edge="1" parent="1" source="branch_new" target="execute">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_exec_resp" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#2e7d32;strokeWidth=2;" edge="1" parent="1" source="execute" target="response_fresh">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_exists_hash" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#ef6c00;strokeWidth=2;" edge="1" parent="1" source="branch_exists" target="check_hash">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_hash_status" value="一致" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#ef6c00;strokeWidth=2;fontSize=11;fontColor=#ef6c00;" edge="1" parent="1" source="check_hash" target="branch_status">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_hash_mismatch" value="不一致" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#c62828;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#c62828;" edge="1" parent="1" source="check_hash" target="resp_mismatch">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1440" y="880" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_status_processing" value="processing" style="edgeStyle=none;rounded=0;html=1;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#ef6c00;strokeWidth=2;fontSize=10;fontColor=#ef6c00;" edge="1" parent="1" source="branch_status" target="resp_processing">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_status_completed" value="completed" style="edgeStyle=none;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#2e7d32;strokeWidth=2;fontSize=10;fontColor=#2e7d32;" edge="1" parent="1" source="branch_status" target="resp_completed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_status_failed" value="failed" style="edgeStyle=none;rounded=0;html=1;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#c62828;strokeWidth=2;fontSize=10;fontColor=#c62828;" edge="1" parent="1" source="branch_status" target="resp_failed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_gc" value="24h 経過で自動削除" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=1.5;fontSize=10;fontColor=#9673a6;dashed=1;" edge="1" parent="1" source="valkey_check" target="valkey_gc">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="390" />
              <mxPoint x="520" y="1075" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="legend" value="凡例" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;verticalAlign=top;fontColor=#000000;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="140" y="1190" width="1470" height="140" as="geometry" />
        </mxCell>

        <mxCell id="legend_app" value="■ アプリ層 (暖色): クライアント / tier1 ファサード / 判定ノード" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#d79b00;align=left;" vertex="1" parent="1">
          <mxGeometry x="160" y="1214" width="600" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_data" value="■ データ層 (薄紫): Valkey 冪等キーストア / TTL GC" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#9673a6;align=left;" vertex="1" parent="1">
          <mxGeometry x="160" y="1234" width="600" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_ok" value="■ 成功状態 (緑): 初回処理成功 / completed リプレイ" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#2e7d32;align=left;" vertex="1" parent="1">
          <mxGeometry x="160" y="1254" width="600" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_warn" value="■ 警告状態 (橙): 処理中 409 / 既存キー検出" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#ef6c00;align=left;" vertex="1" parent="1">
          <mxGeometry x="160" y="1274" width="600" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_fail" value="■ 失敗状態 (赤): failed リプレイ / ボディ不一致 409" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#c62828;align=left;" vertex="1" parent="1">
          <mxGeometry x="160" y="1294" width="600" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_solid" value="― 実線太: 明示呼び出し (HTTP / gRPC / Valkey コマンド)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#000000;align=left;" vertex="1" parent="1">
          <mxGeometry x="780" y="1214" width="820" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_dashed" value="--- 紫破線細: Valkey 組込 TTL GC (自動 expire、別プロセス不要)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#000000;align=left;" vertex="1" parent="1">
          <mxGeometry x="780" y="1234" width="820" height="18" as="geometry" />
        </mxCell>

        <mxCell id="legend_note_block" value="■ 補足ブロック (薄黄、枠 #d6b656): 数値仕様 / スコープ / ハッシュ衝突対策" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#d6b656;align=left;" vertex="1" parent="1">
          <mxGeometry x="780" y="1254" width="820" height="18" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
