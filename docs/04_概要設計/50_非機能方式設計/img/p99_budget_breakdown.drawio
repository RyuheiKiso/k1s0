        </mxCell>
        <mxCell id="note_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="1000" height="240" as="geometry" />
        </mxCell>
        <mxCell id="note_title" value="予算超過時のアクション（DS-NFR-PERF-013）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note_1" value="・業務 200ms 超過  →  Rust 実装プロファイリング。ZEN Engine / Decision API では LRU ヒット率 95% 死守。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="670" width="960" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note_2" value="・Dapr 80ms 超過  →  Go ファサードの middleware 順序と mTLS ハンドシェイク（Istio Ambient）を再計測。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="698" width="960" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note_3" value="・OTel 20ms 超過  →  tail-based sampling 保存率を 10% → 5% へ絞込み、Collector サイドカーのキュー上限見直し。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="726" width="960" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note_4" value="・監査 50ms 超過  →  Kafka producer の linger.ms / batch.size を再調整、acks=1 固定、同期 flush の誤設定を除去。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="754" width="960" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note_5" value="・NW/DB 150ms 超過  →  Connection Pool の再利用率、Valkey Sentinel の Replica 分散、PG EXPLAIN を確認。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="782" width="960" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note_6" value="・p99 が 80% (400ms) で Warning、100% (500ms) で SEV2、3 週連続超過で容量計画レビュー強制起動。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="820" width="960" height="24" as="geometry" />
        </mxCell>
