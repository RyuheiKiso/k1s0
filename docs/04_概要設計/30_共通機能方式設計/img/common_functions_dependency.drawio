        </mxCell>

        <mxCell id="lg_arrow_title" value="矢印の意味（線の太さ・色・実線点線の組合せ）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1080" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_arrow1" value="暖色実線太：アプリ層内の明示的な依存呼出（例：認証 → 認可 への JWT claims 伝搬）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1105" width="780" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_arrow2" value="寒色実線細：観測性系の透過的なシグナル結合（例：分散トレーシング → ログ への trace_id 自動注入）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1125" width="780" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_arrow3" value="紫実線細：データ層への永続化（例：認可判定 → 監査証跡 への記録、暗号化 → 監査証跡 へのハッシュチェーン署名）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1145" width="780" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_arrow4" value="寒色点線細：間接的・条件付の透過捕捉（例：Feature Management → ログ への評価結果非同期送信）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1165" width="780" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lg_read1" value="読み方：監査証跡（④）が単独でデータ層に置かれているのは、上位 8 機構すべての実行記録が最終的に監査証跡へ集約される構造を可視化するためである。J-SOX / 個人情報保護法 / GDPR の即時提出要件は監査証跡の改ざん防止性能で担保され、その鍵管理を暗号化（⑧）が、その記録経路をログ出力（③）が支える依存関係になる。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1195" width="1580" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lg_read2" value="執筆順の根拠：認証系 → 観測性系 → エラー系 → 暗号系 → Feature Management の順は、上位機構（認証 / 認可）が下位機構（監査 / ログ）へ依存を流す向きと整合する。図中の矢印が「上から下」「左から右」へ流れるよう配置することで、執筆順序のままレビューしても依存関係の前提が崩れない。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1245" width="1580" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
