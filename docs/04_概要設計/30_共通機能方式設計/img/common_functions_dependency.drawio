        <mxCell id="lg_app" value="アプリ層（#fff2cc / #d79b00）：tier1 API から明示的に呼び出すセキュリティ系・エラー系 — 認証 / 認可 / 暗号化 / エラーハンドリング" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="955" width="1580" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lg_net" value="ネットワーク層（#dae8fc / #6c8ebf）：アプリから透過的に効く観測性系・宣言系 — ログ / トレース / メトリクス / Feature Management" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
