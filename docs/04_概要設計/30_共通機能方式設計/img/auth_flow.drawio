        <mxCell id="lane_tier2" value="tier2 / tier3&#10;クライアント" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="180" height="48" as="geometry" />
        </mxCell>
        <mxCell id="lane_envoy" value="Envoy Gateway&#10;(ext_authz)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="180" height="48" as="geometry" />
