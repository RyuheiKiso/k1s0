        <mxCell id="lane_kc" value="Keycloak 25.x&#10;(OIDC / JWKS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="180" height="48" as="geometry" />
        </mxCell>
        <mxCell id="lane_facade" value="tier1 Dapr ファサード&#10;(Go Interceptor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
