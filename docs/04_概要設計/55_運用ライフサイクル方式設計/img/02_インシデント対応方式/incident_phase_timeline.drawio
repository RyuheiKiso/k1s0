        <mxCell id="detail_title" value="SEV1 各フェーズの内訳（担当 Tier / 主要アクション / 所要時間目標）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;" vertex="1" parent="1">
