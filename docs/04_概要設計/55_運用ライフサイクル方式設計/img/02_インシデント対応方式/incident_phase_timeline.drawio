        <mxCell id="det_ph1" value="Phase 1 検知 / トリアージ&#10;&#10;所要: 0 〜 15 分&#10;主担当: Tier1 (L1)&#10;&#10;主要アクション&#10;・Alertmanager / 問合せ受領&#10;・インシデント ID 発番&#10;・影響範囲確認&#10;・Severity 暫定判定&#10;・#k1s0-incident-active 宣言&#10;・SEV1 時は役員 30 分通知" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="575" width="280" height="220" as="geometry" />
        </mxCell>
        <mxCell id="det_ph2" value="Phase 2 一次対応 / 暫定復旧&#10;&#10;所要: 15 分 〜 4 h&#10;主担当: Tier2 (L2) + Tier3 並行&#10;&#10;主要アクション&#10;・Runbook 選定（runbook_url）&#10;・failover 実行&#10;・Pod 強制再起動&#10;・トラフィック迂回&#10;・flagd 機能フラグオフ&#10;・2 h 未復旧で Tier3 強制召集&#10;・3 h 超で DR Runbook 検討" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="340" y="575" width="280" height="220" as="geometry" />
        </mxCell>
        <mxCell id="det_ph3" value="Phase 3 根本原因特定&#10;&#10;所要: 4 h 〜 24 h&#10;主担当: Tier3 (L3)&#10;&#10;主要アクション&#10;・Loki（ログ集約）&#10;・Tempo（分散トレース）&#10;・Pyroscope（プロファイル）&#10;・Git blame（コード履歴）&#10;・why を 5 回繰り返す&#10;・ドラフト 24 h 以内&#10;・1 週間超は別 Issue 化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="640" y="575" width="280" height="220" as="geometry" />
        </mxCell>
        <mxCell id="det_ph4" value="Phase 4 恒久対策実装&#10;&#10;所要: 24 h 〜 1 週間&#10;主担当: Tier3 (L3)&#10;&#10;主要アクション&#10;・PR 作成 / レビュー&#10;・ステージング検証&#10;・本番デプロイ&#10;・Runbook 更新&#10;・監視強化（閾値 / 追加 Alert）&#10;・SEV1/2 は 1 週間内デプロイ&#10;・SEV3 は次 Sprint 許容" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="940" y="575" width="280" height="220" as="geometry" />
        </mxCell>
        <mxCell id="det_ph5" value="Phase 5 ポストモーテム / 学習&#10;&#10;所要: 〜 1 週間&#10;主担当: Tier3 + Product Council&#10;&#10;主要アクション&#10;・Blameless Postmortem 執筆&#10;・ドラフト ≤ 24 h&#10;・公開 ≤ 1 週間&#10;・Jira アクション登録&#10;・FAQ / Runbook 追加 PR&#10;・Product Council レビュー&#10;・SEV1/2 全件、SEV3 任意" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
