        <mxCell id="p1_d" value="・Alertmanager 受領&#10;・インシデント ID 発番&#10;・#k1s0-incident-active 宣言&#10;・SEV1 時は役員 30 分以内通知" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
