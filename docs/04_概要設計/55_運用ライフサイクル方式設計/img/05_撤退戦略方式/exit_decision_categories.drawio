          <mxGeometry x="80" y="540" width="470" height="24" as="geometry" />
        </mxCell>
        <mxCell id="org_rev" value="四半期：人事部門＋起案者＋協力者のアンケート突合&#10;随時：バス係数 1 以下で即時 Product Council 招集" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
