          <mxGeometry x="1150" y="540" width="470" height="24" as="geometry" />
        </mxCell>
        <mxCell id="biz_rev" value="年次：TCO レビュー（CFO ＋ 起案者）&#10;四半期：テナント数 KPI レビュー（情シス部長 ＋ 起案者）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
