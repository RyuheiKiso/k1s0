          <mxGeometry x="615" y="540" width="470" height="24" as="geometry" />
        </mxCell>
        <mxCell id="tec_rev" value="四半期：起案者＋協力者＋CTO が Grafana ダッシュボード精査&#10;随時：SEV1 2 件以上 / Critical CVE 遵守率破綻で即時招集" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
