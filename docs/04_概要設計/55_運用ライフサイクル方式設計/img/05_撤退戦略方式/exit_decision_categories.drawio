        </mxCell>
        <mxCell id="org_m1" value="バス係数：常に 2 以上を維持&#10;→ 1 以下に低下した時点で要 Alert（Backstage ownership で自動検知）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
