        <mxCell id="biz_metric_lbl" value="判定基準（企画書数値との乖離）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="370" width="470" height="24" as="geometry" />
        </mxCell>
        <mxCell id="biz_m1" value="年次 TCO レビュー：採用検討時の試算と実績の乖離率 ≥ 30%&#10;→ CFO 起票で Product Council 撤退判定レビュー必須化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1150" y="400" width="470" height="60" as="geometry" />
        </mxCell>
        <mxCell id="biz_m2" value="テナント数：計画比 30% 未満が 8 四半期（2 年）連続&#10;→ 事業計画改定または撤退を Product Council で択一判断" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1150" y="470" width="470" height="60" as="geometry" />
        </mxCell>

