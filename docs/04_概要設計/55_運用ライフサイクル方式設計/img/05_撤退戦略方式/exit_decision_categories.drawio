        <mxCell id="tec_t1" value="設計構造欠陥の判明&#10;tier1 公開 API の抜本的再設計が必要で修復不能" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="615" y="180" width="470" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tec_t2" value="主要 OSS の長期メンテ停止＋代替不在&#10;Dapr / Istio / Argo CD いずれかが fork 不可な衰退へ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="615" y="240" width="470" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tec_t3" value="重大セキュリティインシデントで信頼回復不能&#10;SEV1 複数回＋監督官庁の指導＋テナント離脱ドミノ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="615" y="300" width="470" height="50" as="geometry" />
        </mxCell>

        <mxCell id="tec_metric_lbl" value="判定基準（監視指標の定量閾値）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="615" y="370" width="470" height="24" as="geometry" />
        </mxCell>
        <mxCell id="tec_m1" value="SLO 違反率：2 四半期連続で MonthlyBudget の 200% 超過&#10;→ 99% 採用検討で約束した値の根拠が崩壊、Grafana SLO ボードで月次可視化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="615" y="400" width="470" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tec_m2" value="Critical CVE 48 時間ルール遵守率：50% 未満が 2 四半期継続&#10;→ NFR-C-MNT-002 の運用契約破綻、セキュリティ信頼消滅" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="615" y="470" width="470" height="60" as="geometry" />
        </mxCell>

