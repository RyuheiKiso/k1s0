        <mxCell id="org_t1" value="内製化方針の撤回&#10;経営層の方針転換で情シス内製が外部委託に戻る" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="470" height="50" as="geometry" />
        </mxCell>
        <mxCell id="org_t2" value="情シス部門の解体 / 外部委託化&#10;部門再編で k1s0 保守主体が消失" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="470" height="50" as="geometry" />
        </mxCell>
        <mxCell id="org_t3" value="起案者・協力者の同時離職（バス係数 = 0）&#10;技術継承が途絶え Backstage の運用知識を誰も持たない" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
