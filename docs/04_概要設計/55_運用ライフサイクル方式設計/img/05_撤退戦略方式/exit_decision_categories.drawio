        <mxCell id="biz_t1" value="ROI 3 年連続未達&#10;企画書の TCO 削減目標と実績の乖離が 30% 超過" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1150" y="180" width="470" height="50" as="geometry" />
        </mxCell>
        <mxCell id="biz_t2" value="利用テナント数 が計画の 30% 未満（2 年継続）&#10;収益 / 運用分母が縮小して固定費が賄えない" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1150" y="240" width="470" height="50" as="geometry" />
        </mxCell>
        <mxCell id="biz_t3" value="予算削減 / 親会社の戦略変更&#10;採用検討で約束した要員 / 投資が恒常的に確保不能" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1150" y="300" width="470" height="50" as="geometry" />
