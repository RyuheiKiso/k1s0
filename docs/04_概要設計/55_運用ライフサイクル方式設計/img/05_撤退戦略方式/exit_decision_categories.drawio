        </mxCell>
        <mxCell id="org_m2" value="組織変更告知：人事部門からの正式発令（四半期ごと確認）&#10;→ 情シス内製方針の変更は Product Council 議題として必ず上程" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="470" height="60" as="geometry" />
        </mxCell>

