  <diagram name="exit_gate_three_layers" id="exit-gate-three-layers">
    <mxGraphModel dx="1700" dy="1200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
