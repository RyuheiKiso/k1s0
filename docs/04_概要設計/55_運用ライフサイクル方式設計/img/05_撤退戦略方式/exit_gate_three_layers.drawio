        <mxCell id="title" value="k1s0 撤退ゲート 3 層構造（段階ゲート / KPI 常時監視 / 即時撤退トリガー）— 性格の異なる 3 層を独立に発動し、判定会議へ集約" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1620" height="30" as="geometry" />
        </mxCell>

        <mxCell id="l1_lane" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="1620" height="220" as="geometry" />
        </mxCell>
        <mxCell id="l1_title" value="第 1 層：段階ゲート（DS-OPS-EXIT-007）— 計画的に発生する判定機会、段階完了時に判定者が撤退提案書起票の要否を判定" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="78" width="1590" height="24" as="geometry" />
        </mxCell>
        <mxCell id="l1_p1a" value="リリース時点&#10;（採用初期 デモ後 2 週間）&#10;撤退コスト 15 万円&#10;判定者：情シス部長 + 起案者" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="115" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l1_p1b" value="リリース時点&#10;（採用初期 完了判定）&#10;撤退コスト 121 万円&#10;判定者：情シス部長 + アーキテクト + 起案者" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="115" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l1_p1c" value="リリース時点&#10;（採用初期 完了判定）&#10;撤退コスト 230 万円&#10;判定者：情シス部長 + 運用責任者 + アーキテクト" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="115" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l1_p2" value="採用後の運用拡大時（拡張）&#10;（四半期 Council レビュー）&#10;撤退コスト 518 万円&#10;判定者：CTO + 情シス部長 + Council 全員" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="115" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l1_p3" value="採用側のマルチクラスタ移行時&#10;（年次レビュー / 取締役会）&#10;撤退コスト 1,200〜2,240 万円&#10;判定者：CTO + CFO + 取締役会" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1340" y="115" width="300" height="160" as="geometry" />
        </mxCell>

        <mxCell id="l2_lane" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef4fb;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="1620" height="220" as="geometry" />
        </mxCell>
        <mxCell id="l2_title" value="第 2 層：KPI 常時監視ゲート（DS-OPS-EXIT-008）— 月次の数値実績で異常を検出、撤退検討しきい値抵触で翌月内に臨時判定会議を強制招集" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="318" width="1590" height="24" as="geometry" />
        </mxCell>
        <mxCell id="l2_k1" value="tier1 API SLO 達成率&#10;目標 99.9% 以上&#10;警告：99.5% を 1 か月下回る&#10;検討：99.0% を 3 か月連続" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="355" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l2_k2" value="月次運用コスト&#10;目標 575 万円以下&#10;警告：690 万円（+20%）を 1 か月&#10;検討：805 万円（+40%）を 2 か月連続" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="355" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l2_k3" value="バス係数&#10;目標 複数名以上&#10;警告：1 名（協力者離脱）&#10;検討：1 名のまま 6 か月継続" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="355" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l2_k4" value="テナント採用数&#10;目標 1c 後 5 社 / 2 後 10 社&#10;警告：計画 70% を 3 か月後も下回る&#10;検討：計画 30% を 6 か月継続" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="355" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l2_k5" value="Critical CVE 対応遵守率&#10;目標 100%（48h 以内）&#10;警告：1 件遅延（48h 超過）&#10;検討：3 か月で 3 件以上の SLA 違反" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1340" y="355" width="300" height="160" as="geometry" />
        </mxCell>

        <mxCell id="l3_lane" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0e8f5;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="1620" height="220" as="geometry" />
        </mxCell>
        <mxCell id="l3_title" value="第 3 層：即時撤退トリガー（DS-OPS-EXIT-009）— 想定外イベントへの即応、検出から 2 週間以内に判定会議を強制招集" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="558" width="1590" height="24" as="geometry" />
        </mxCell>
        <mxCell id="l3_a" value="A. OSS ライセンス複数同時変更&#10;依存 OSS 3 本以上が同一四半期に non-permissive 化&#10;検出：Renovate + Syft 四半期レポート&#10;招集：Slack → 起案者 → 情シス部長 → Council" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="595" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l3_b" value="B. 初期構築費 50% 超過&#10;採用初期 の累計実績が 2,775 万円超過&#10;検出：月次工数集約（3 ゲート）&#10;招集：レポート → 情シス部長 → Council → CFO" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="460" y="595" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l3_c" value="C. バス係数 1 名が 6 か月継続&#10;起案者または協力者のみで 180 日連続運用&#10;検出：月次体制レビュー&#10;招集：レポート → 情シス部長 → CTO → Council" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="860" y="595" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l3_d" value="D. 経営方針転換&#10;取締役会で内製化撤回 / 部門解体 / 外部委託全面切替を決議&#10;検出：取締役会議事録の起案者・情シス部長配布&#10;招集：取締役会決議 → 情シス部長 → Council 緊急" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1260" y="595" width="380" height="160" as="geometry" />
        </mxCell>

        <mxCell id="council" value="判定会議（Product Council ＋ 各層判定者）&#10;議事録・撤退提案書・最終決議は Confluence『k1s0-exit-decisions』に集約（5 年保管）&#10;3 択：撤退承認 / 撤退延期（3 か月後再審議）/ 撤退却下（継続）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="820" width="1000" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e_l1_council" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="l1_lane" target="council">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="850" y="295" />
              <mxPoint x="550" y="295" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_l2_council" style="html=1;strokeWidth=2;strokeColor=#6c8ebf;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="l2_lane" target="council">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="850" y="535" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_l3_council" style="html=1;strokeWidth=2;strokeColor=#9673a6;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.8;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="l3_lane" target="council">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="850" y="775" />
              <mxPoint x="1150" y="775" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_l1_lbl" value="段階ゲート発動：段階完了時に予定起票" style="text;html=1;strokeColor=none;fillColor=#ffffff;fillOpacity=95;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="780" width="280" height="24" as="geometry" />
        </mxCell>
        <mxCell id="e_l2_lbl" value="月次しきい値抵触：翌月内に臨時招集" style="text;html=1;strokeColor=none;fillColor=#ffffff;fillOpacity=95;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="780" width="280" height="24" as="geometry" />
        </mxCell>
        <mxCell id="e_l3_lbl" value="トリガー検出：2 週間以内に強制招集" style="text;html=1;strokeColor=none;fillColor=#ffffff;fillOpacity=95;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="780" width="280" height="24" as="geometry" />
        </mxCell>

        <mxCell id="next_step" value="判定会議の議決：撤退承認 → 6 ステップ意思決定プロセス（提案書起案 → Council レビュー → 採用検討 → 利用者通知 → 段階縮退 → 停止後始末）へ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="950" width="1620" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_council_next" style="html=1;strokeWidth=2;strokeColor=#ef6c00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="council" target="next_step">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="1020" width="1620" height="280" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="凡例（drawio 4 レイヤ記法規約 — 撤退判定ゲートの性格を色で示す）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="1025" width="600" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lg_l1" value="アプリ層（#fff2cc）：第 1 層 段階ゲート — 人による予定された判定機会、段階完了タイミングで起動" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1055" width="780" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lg_l2" value="ネットワーク層（#dae8fc）：第 2 層 KPI 常時監視 — 自動収集される数値で異常を透過的に検出" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="1055" width="780" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lg_l3" value="データ層（#e1d5e7）：第 3 層 即時撤退トリガー — 想定外イベントの事実検出、4 トリガーは独立に発動" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1095" width="780" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lg_council" value="判定会議（#fff2cc + 太枠）：3 層からの起票を集約する単一の議決機関、議事録は Confluence『k1s0-exit-decisions』に 5 年保管" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="1095" width="780" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule1" value="判定ルール：3 層は独立に発動可能（OR）。例：リリース時点 進行中にトリガー B 成立 → リリース時点を待たず 2 週間以内に判定会議を招集。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1140" width="1580" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule2" value="情報引継ぎ：第 2 層の警告しきい値抵触は次回段階ゲート判定材料として記録、第 3 層トリガー成立時は第 2 層の直近 6 か月実績を判定会議資料に必ず添付。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1170" width="1580" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule3" value="同時発動の優先順位：第 1 層と第 3 層が同時発動した場合（例：リリース時点判定中にトリガー B 成立）は、第 3 層を優先して 2 週間以内に判定会議を開催し、段階完了判定を当該会議に統合する（結論遅延の防止）。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1200" width="1580" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule4" value="矢印：暖色実線＝第 1 層からの起票、寒色実線＝第 2 層からの起票、紫実線＝第 3 層からの起票、橙実線＝判定会議承認後の後続プロセス起動。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1230" width="1580" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule5" value="判定会議の 3 択結果：撤退承認 → 6 ステップ意思決定プロセスへ。撤退延期 → 3 か月後に再審議、その間は是正計画を Council が並行レビュー。撤退却下 → 通常運用継続だが警告履歴は Confluence に永続記録。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1260" width="1580" height="24" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
