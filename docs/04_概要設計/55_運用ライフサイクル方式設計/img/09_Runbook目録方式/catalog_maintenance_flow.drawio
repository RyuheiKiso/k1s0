  <diagram name="catalog_maintenance_flow" id="cat-flow">
    <mxGraphModel dx="1600" dy="1100" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1600" height="1100" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Runbook 目録維持フロー（四半期レビュー → 陳腐化検出 → 更新 PR → 自動リンクチェック → 監査）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="目録は書いた瞬間から陳腐化する。OSS バージョンアップ・機能追加・インシデント教訓を継続反映する循環フローを制度化し、「常時利用可能な 15 本」を維持する。" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="1520" height="24" as="geometry" />
        </mxCell>
        <mxCell id="input_src" value="インプット源（複数チャネル）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=12;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="1480" height="120" as="geometry" />
        </mxCell>
        <mxCell id="in_incident" value="インシデント対応ログ&#10;（Jira + ポストモーテム）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="in_oss" value="OSS バージョンアップ通知&#10;（Renovate / Dependabot）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="in_fmea" value="FMEA 四半期レビュー&#10;（O / D 実測値更新）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="610" y="150" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="in_chaos" value="Chaos Drill 検証結果&#10;（四半期 3〜4 本）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="870" y="150" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="in_feature" value="新機能追加 PR&#10;（PR テンプレート Runbook 欄）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1130" y="150" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="① 四半期レビュー（Product Council）&#10;月次レビューを起案者が主催、四半期で Product Council へ昇格。新規追加 / 廃止 / 棚卸し対象の判定、品質指標（カバー率 90% / 実行成功率 80%）確認。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="② 陳腐化検出（自動 + 手動）&#10;6 か月以上未更新 Runbook / runbook_url に TBD が残るアラート / OSS バージョン差分を Backstage 自動集計。所有者へ棚卸し依頼を自動起票。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="290" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="③ 更新 PR 作成（所有者責任）&#10;staging で手順実行 → 差分を Markdown で反映。YAML front-matter（owner / automation / last_drill）を同 PR で更新。レビュア 2 名必須（緊急時 1 名 + 事後 1 名）。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="290" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="④ 自動リンクチェック（CI）&#10;GitHub Actions で（a）Alertmanager runbook_url と実 Runbook の存在検証、（b）FMEA 対応表との整合検証、（c）Backstage TechDocs ビルド成功を 3 ゲートで強制。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="990" y="290" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="⑤ 監査（5 年保管）&#10;廃止 Runbook はアーカイブフォルダへ移動し監査証跡として 5 年保管。発動実績は Jira の runbook フィールドで月次集計、自動化候補（月 3 回以上）を識別。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="1300" y="290" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="artifact_git" value="k1s0/runbooks Git リポジトリ&#10;全社閲覧可・運用 + 起案者 + 協力者のみ Write" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="90" y="530" width="450" height="70" as="geometry" />
        </mxCell>
        <mxCell id="artifact_back" value="Backstage TechDocs（全社ポータル）&#10;Runbook / 目録ビュー / 最終更新日 / 発動実績（6 か月）/ Chaos Drill 日" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="580" y="530" width="460" height="70" as="geometry" />
