<mxfile host="app.diagrams.net" modified="2026-04-21T00:00:00.000Z" agent="k1s0" version="22.1.16">
  <diagram name="runbook_structure" id="rb-struct">
    <mxGraphModel dx="1600" dy="1100" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1600" height="1100" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Runbook 構造: 6 ライフサイクル節（Precondition / Detect / Mitigate / Verify / Escalate / Close）と粒度基準" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Runbook は「採用側の小規模運用で成立する」ための機械的手順書。形式・粒度・順序を固定することで新規執筆の迷いを減らし、夜間単独対応でも判断要素を最小化する。" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="1520" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lane_struct" value="Runbook 6 ライフサイクル節（実行順に並ぶ）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=13;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="900" height="840" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="① Precondition（前提条件）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="860" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s1b" value="実行者の権限（k1s0-operator ロール / OpenBao ポリシー）、必要ツール（kubectl / psql / argocd CLI）、対象環境（prod か staging か）を明記する。前提未達での実行は禁止。対応セクション: md 必須セクション 1（前提条件）。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="860" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="② Detect（対象事象の特定）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="275" width="860" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s2b" value="対応する Alertmanager ルール ID / 観測症状 / 分岐条件を具体記述する。Alertmanager の runbook_url ラベルから自動提示される導線を前提とし、対応 FMEA エントリと 1:1 または 1:n 対応を明示。対応セクション: md 必須セクション 2（対象事象）。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="315" width="860" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="③ Mitigate（初動 5 分 + 復旧手順 1 時間以内）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="410" width="860" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s3b" value="初動は 5 分以内に影響範囲確認・ステークホルダ通知・暫定復旧判断を完了。復旧は「暫定（failover / Pod 再起動）」と「恒久（設定変更 / コード修正デプロイ）」を分離記述。1 ステップ = コマンド 1 回 or 確認 1 項目 = 3 分以内 / 全体 1 時間以内を粒度基準とする。対応セクション: md 必須セクション 3（初動）・5（復旧）。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="860" height="100" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="④ Verify（復旧検証）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="565" width="860" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s4b" value="復旧後の正常稼働を具体的確認項目で検証する。例: 「p99 レイテンシが 500ms 以内に戻っている（Grafana 参照）」「Loki クエリ {app=&quot;k1s0-tier1&quot;} |= &quot;ERROR&quot; でエラーなし」。「問題なし」等の曖昧表現は禁止。対応セクション: md 必須セクション 6（検証手順）。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="605" width="860" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="⑤ Escalate（原因特定とエスカレーション）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="860" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s5b" value="根本原因を特定するための調査手順（ログ確認コマンド / メトリクス参照先 / 関連コンポーネント確認順序）を明記。特定不能時のエスカレーション先（L3 コア開発者 / ベンダサポート）を指定する。SEV1 で 3 時間未解決なら RB-DR-001（DR 発動）へエスカレート。対応セクション: md 必須セクション 4（原因特定）。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="740" width="860" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="⑥ Close（予防策 + 関連 Runbook + 記録）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="845" width="860" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s6b" value="予防策は Jira チケット化しポストモーテムで追跡。関連 Runbook を列挙し連鎖事象（DB → API → 監査）の導線を提供。発動実績は Jira の runbook フィールドで記録、月次集計で発動回数管理。対応セクション: md 必須セクション 7・8。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="885" width="860" height="45" as="geometry" />
        </mxCell>
        <mxCell id="lane_gran" value="粒度基準（DS-OPS-RB-003）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=13;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1000" y="100" width="540" height="420" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="1 Runbook = 1 事象" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="140" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g1b" value="1 Runbook は 1 つのアラート or 1 つの症状に対応。複数原因事象のカバーは禁止。読み手が分岐判断に迷う構成を排除する。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="180" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="1 手順 = 3 分以内" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="250" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g2b" value="1 ステップ = コマンド 1 回 or 確認 1 項目。3 分を超える手順は複数ステップへ分割。対応者が進捗を常に可視化できる状態を保つ。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="290" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="1 Runbook 全体 = 1 時間以内の復旧" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="360" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g3b" value="初動〜検証まで合計 1 時間以内。これを超える場合は Runbook を分割する。RTO 4h の内訳（検知 15 + 初動 15 + 対応 60 + 検証 30 + 報告 30 + バッファ 120）に整合。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="400" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lane_total" value="総数計画（NFR-A-REC-002）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=13;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1000" y="540" width="540" height="400" as="geometry" />
        </mxCell>
        <mxCell id="p1a" value="採用初期 (デモ): 5 本&#10;FMEA 上位 5 事象をプロトタイプとして整備" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="585" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p1b" value="採用初期 (パイロット): 15 本（本章コミット）&#10;目録は 09_Runbook目録方式.md で確定" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="660" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p1c" value="採用初期 (運用体制確立): 20 本&#10;運用経験で発見した追加事象を反映" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="735" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="採用後の運用拡大時: 30 本（廃止 1 本に対し追加 1.5 本まで）&#10;DR / Temporal / Backstage 等の拡張分を追加" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="810" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p_note" value="採用初期 (デモ→パイロット→運用体制確立) → 採用後の運用拡大時 → 採用側のマルチクラスタ移行時 の階段的整備。無制限拡張を避けるリミットあり。" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1020" y="890" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e12" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s1b" target="s2">
          <mxGeometry relative="1" as="geometry" />
