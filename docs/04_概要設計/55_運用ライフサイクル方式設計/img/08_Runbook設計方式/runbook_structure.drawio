        </mxCell>
        <mxCell id="lg_detail_t" value="詳細パネル（節の内容 / 粒度の根拠）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="112" y="1020" width="540" height="24" as="geometry" />
        </mxCell>
