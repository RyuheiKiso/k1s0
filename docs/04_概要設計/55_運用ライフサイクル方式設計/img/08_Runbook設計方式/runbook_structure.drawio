        <mxCell id="lg_line_seq_t" value="節の実行順序（Precondition → Detect → Mitigate → Verify → Escalate → Close）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
