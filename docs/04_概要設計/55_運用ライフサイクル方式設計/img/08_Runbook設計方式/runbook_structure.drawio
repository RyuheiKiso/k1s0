        <mxCell id="lg_app_t" value="アプリ層（Runbook セクション見出し・粒度項目・段階別本数）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
