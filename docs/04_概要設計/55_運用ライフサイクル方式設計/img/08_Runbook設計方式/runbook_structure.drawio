        <mxCell id="e23" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s2b" target="s3">
          <mxGeometry relative="1" as="geometry" />
