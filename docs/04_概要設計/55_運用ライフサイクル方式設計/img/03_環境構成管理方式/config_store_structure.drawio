        <mxCell id="a_cm_pod" style="html=1;strokeWidth=2;strokeColor=#666666;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.15;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="rt_configmap" target="pod_body">
          <mxGeometry relative="1" as="geometry" />
