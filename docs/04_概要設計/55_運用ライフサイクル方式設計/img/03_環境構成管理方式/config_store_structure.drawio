        <mxCell id="a_jdm_load_lbl" value="git clone / watch" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="1190" y="240" width="120" height="16" as="geometry" />
