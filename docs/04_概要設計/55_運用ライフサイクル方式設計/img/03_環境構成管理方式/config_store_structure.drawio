        <mxCell id="a_argo_cm" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="argocd" target="rt_configmap">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_argo_cm_lbl" value="kubectl apply" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="100" y="450" width="110" height="16" as="geometry" />
        </mxCell>

        <mxCell id="a_eso_sec" style="html=1;strokeWidth=2;strokeColor=#9673a6;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="eso" target="rt_secret">
          <mxGeometry relative="1" as="geometry" />
