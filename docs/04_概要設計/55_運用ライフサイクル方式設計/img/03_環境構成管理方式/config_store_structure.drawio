          <mxGeometry x="150" y="660" width="60" height="16" as="geometry" />
        </mxCell>

        <mxCell id="a_sec_pod" style="html=1;strokeWidth=2;strokeColor=#9673a6;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.4;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="rt_secret" target="pod_body">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_sec_pod_lbl" value="volume mount" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="500" y="660" width="110" height="16" as="geometry" />
        </mxCell>

        <mxCell id="a_flagd_pod" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.6;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="rt_flagd" target="pod_body">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_flagd_pod_lbl" value="flag eval API" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="870" y="660" width="110" height="16" as="geometry" />
        </mxCell>

        <mxCell id="a_dec_pod" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.85;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="rt_decision" target="pod_body">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_dec_pod_lbl" value="Decision API" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="1230" y="660" width="110" height="16" as="geometry" />
        </mxCell>

        <mxCell id="legend_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="870" width="1390" height="220" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="凡例と格納ルール（性質による分離）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="95" y="875" width="400" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lg_app2" value="アプリ層（#fff2cc）：GitOps / flagd / Decision など、tier2/tier3 Pod から明示的に参照される抽象" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="905" width="1200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_inf2" value="インフラ層（#f5f5f5）：k8s ConfigMap（非機密設定の標準注入先）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="930" width="1200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_dat2" value="データ層（#e1d5e7）：OpenBao 正本 + k8s Secret（機密情報の正本と注入先）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="955" width="1200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule1" value="ルール 1: 機密は OpenBao のみ / 非機密は ConfigMap のみ / 動的は flagd のみ（クロスストア禁止）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="985" width="1300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule2" value="ルール 2: 書込は運用チームのみ（開発者は read-only）、Git 以外のルート（手動 kubectl / Vault CLI 直接）は監査時以外禁止" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="1010" width="1300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_rule3" value="ルール 3: flagd 管理 API 直 Patch は緊急時限定。24h 以内に Git に事後 PR を戻し、Argo CD 次回 Sync での上書きを防ぐ。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="1035" width="1300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg_line" value="矢印：橙実線＝GitOps 同期経路、紫実線＝Secret 経路、橙破線＝Git → Argo CD Pull（非同期 reconcile）、灰実線＝ConfigMap の Pod 注入" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1060" width="1360" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
