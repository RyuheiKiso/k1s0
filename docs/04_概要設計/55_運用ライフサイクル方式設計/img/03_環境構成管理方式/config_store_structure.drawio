        <mxCell id="a_eso_sec_lbl" value="Secret CRD" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="470" y="450" width="100" height="16" as="geometry" />
        </mxCell>

        <mxCell id="a_flag_flagd" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="flagd_sync" target="rt_flagd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_flag_flagd_lbl" value="ConfigMap patch" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="830" y="450" width="130" height="16" as="geometry" />
        </mxCell>

        <mxCell id="a_jdm_dec" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="jdm_loader" target="rt_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_jdm_dec_lbl" value="in-memory eval" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=90;" vertex="1" parent="1">
          <mxGeometry x="1190" y="450" width="130" height="16" as="geometry" />
