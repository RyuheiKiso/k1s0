        <mxCell id="a_flag_sync" style="html=1;strokeWidth=2;strokeColor=#d79b00;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="flagd_src" target="flagd_sync">
