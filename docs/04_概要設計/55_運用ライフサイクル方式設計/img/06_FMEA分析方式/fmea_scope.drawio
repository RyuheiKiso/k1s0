          <mxGeometry x="580" y="320" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="oss_note" value="OSS は責務レイヤ（アプリ / ネットワーク / インフラ / データ）で色分けする。同一の故障モード名でも、レイヤが異なれば影響範囲と検知経路が異なる。レイヤ認識を誤ると FMEA の重要度スコアリング（S）が歪む。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="580" y="390" width="440" height="200" as="geometry" />
