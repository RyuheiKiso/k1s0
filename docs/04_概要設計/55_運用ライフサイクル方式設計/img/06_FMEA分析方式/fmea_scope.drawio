        <mxCell id="flow_auth" value="認証フロー&#10;Keycloak → tier1 API" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
