          <mxGeometry x="1100" y="200" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="flow_audit" value="監査書込フロー&#10;tier1 → AUDIT DB" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="200" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="flow_backup" value="バックアップフロー&#10;CNPG / Velero" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="260" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="flow_restore" value="リストアフロー&#10;DR 発動時" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="260" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="flow_note" value="業務クリティカルパス。フロー停止は業務停止に直結するため、単一コンポーネントではなく一連の呼び出し経路を FMEA 対象とする。連鎖故障（例: DB 障害 → 監査書込失敗 → 完整性違反）を抽出する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1100" y="330" width="420" height="250" as="geometry" />
        </mxCell>
        <mxCell id="fmea_box" value="FMEA 分析（S × O × D = RPN）&#10;テンプレート 8 項目でエントリ化 / RPN 60 超は最優先対策 / RPN 100 超は対策計画必達" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="680" width="800" height="70" as="geometry" />
        </mxCell>
