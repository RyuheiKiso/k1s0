        <mxCell id="s_active" value="Active&#10;（正常稼働）&#10;利用推奨" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
