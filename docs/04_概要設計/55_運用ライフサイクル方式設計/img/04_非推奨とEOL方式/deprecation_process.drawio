        <mxCell id="s1" value="段階 1: Announced&#10;（D-Day）&#10;Backstage バナー / Slack /&#10; メール 3 経路配信&#10;代替案・移行ガイド同時公開" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="320" y="160" width="220" height="110" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="段階 2: Warning Emitted&#10;（D+1 か月）&#10;API: Deprecation Header +&#10; Sunset RFC 8594&#10;OSS: 運用アラート&#10;内部: @deprecated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="160" width="220" height="130" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="段階 3: Migration Assist&#10;（D+3 か月）&#10;自動変換スクリプト提供&#10;データ変換バッチ提供&#10;重要テナント個別相談" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="880" y="160" width="220" height="130" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="段階 4: Final Warning&#10;（D+猶予-3 か月）&#10;ログ ERROR 格上げ&#10;Backstage 赤バナー&#10;個別電話連絡" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1160" y="160" width="220" height="130" as="geometry" />
        </mxCell>

        <mxCell id="s5" value="段階 5: EOL Executed&#10;（D+猶予）&#10;API: HTTP 410 Gone&#10;OSS: Pod / PVC 削除&#10;内部: コード削除&#10;Runbook: archive 移動" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1440" y="160" width="200" height="130" as="geometry" />
        </mxCell>

        <mxCell id="s_rollback" value="緊急ロールバック期間&#10;（D+猶予 〜 +1 か月）&#10;重大漏れ判明時のみ&#10;Product Council 承認で復旧&#10;1 か月経過で不可逆削除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;dashed=1;dashPattern=4 4;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1420" y="350" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="s_removed" value="Removed（完全削除）&#10;Git 履歴のみ残存&#10;監査ログ 10 年 / archive 5 年" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
