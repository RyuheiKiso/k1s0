        <mxCell id="e_extended_s4_lbl" value="3 か月後に再猶予" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fillColor=#ffffff;fillOpacity=95;" vertex="1" parent="1">
          <mxGeometry x="970" y="310" width="130" height="20" as="geometry" />
        </mxCell>

        <mxCell id="trigger_panel" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="1620" height="300" as="geometry" />
        </mxCell>
        <mxCell id="trigger_title" value="各遷移トリガー条件と責任者" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="548" width="400" height="24" as="geometry" />
        </mxCell>
        <mxCell id="t_r1" value="Active → 段階 1：Product Council（起案者・協力者・CTO・情シス部長・法務代表）の決議。決議理由（技術負債 / ライセンス / セキュリティ / コミュニティ衰退）を申請起票と共に Backstage へ記録。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="580" width="1590" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_r2" value="段階 1 → 2：D-Day から 30 日経過で自動遷移。Warning 発出は CI/CD で配備物に組み込み、遷移操作は Argo CD の sync タグで記録。Warning 発出漏れがあった場合は段階 1 へ差し戻し。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="615" width="1590" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_r3" value="段階 2 → 3：Deprecation 統計（Backstage ダッシュボード）で 50% 未満のテナントしか検知していない場合に移行支援を前倒し起動。自動変換スクリプトと個別相談会を並走。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="650" width="1590" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_r4" value="段階 3 → 4：EOL の 3 か月前に自動格上げ。未移行テナントの残件数が閾値（5 テナント）を超える場合、段階 4 発出前に Product Council で状況レビューを行い、延長の前倒し判定を検討する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="685" width="1590" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_r5" value="段階 4 → 5：EOL 当日、Argo Rollouts Canary（10%→50%→100%）で 410 Gone 切替、異常検知（エラー率 1% 超 / レイテンシ 2 倍超）で自動ロールバックし翌週再実行。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="720" width="1590" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_r6" value="段階 5 → 緊急ロールバック：重大漏れ発覚時のみ Product Council 承認で暫定復旧（Argo CD Manual Sync で旧版再配備）。起票は必ず Jira Incident チケットに紐付ける。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="755" width="1590" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_r7" value="緊急ロールバック → Removed：+1 か月経過で不可逆削除。削除 PR は削除理由と削除日を本文必須、監査ログ 10 年保存・ドキュメント archive 5 年保存で切り替える。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="790" width="1590" height="30" as="geometry" />
        </mxCell>

