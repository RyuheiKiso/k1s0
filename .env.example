# =============================================================================
# .env.example — 開発者ローカル `.env` の雛形
#
# 設計: docs/05_実装/85_Identity設計/30_OpenBao/secrets-matrix.md
# 関連: plan/02_開発環境整備/08_secret_management.md
#
# 利用方法:
#   cp .env.example .env
#   ローカル開発に必要な値を埋める（特に OpenBao dev token / Keycloak 等）
#
# 重要:
#   - 本ファイル（.env.example）は git にコミットされる「雛形」であり、実 secret を含めない。
#   - .env（実体）は .gitignore 済（`.env` / `.env.local` / `.env.*.local`）。
#   - 本番値を .env に入れるのは禁止。本番は OpenBao + Workload Identity 経由が default。
#   - 値は dev/staging/prod の境界を越えないこと（dev fixture を prod に流用しない）。
# =============================================================================

# -----------------------------------------------------------------------------
# OpenBao（dev mode）
# -----------------------------------------------------------------------------
# dev mode の root token は固定値 "root"。本番では絶対に使わない。
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root
VAULT_DEV_ROOT_TOKEN_ID=root

# -----------------------------------------------------------------------------
# Keycloak（dev realm）
# -----------------------------------------------------------------------------
# tools/local-stack/manifests/keycloak/realm-import.json の dev 固定値と整合
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=k1s0
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# tier1 facade 用 client（dev 専用 secret、prod では OpenBao 経由で取得）
KEYCLOAK_CLIENT_ID=tier1-facade
KEYCLOAK_CLIENT_SECRET=dev-client-secret-change-me

# -----------------------------------------------------------------------------
# CloudNativePG（dev cluster）
# -----------------------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=k1s0
PG_PASSWORD=dev-password-change-me
PG_DATABASE=k1s0_dev

# -----------------------------------------------------------------------------
# Strimzi Kafka（dev cluster）
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SASL_USERNAME=k1s0-dev
KAFKA_SASL_PASSWORD=dev-kafka-password-change-me

# -----------------------------------------------------------------------------
# MinIO（dev tenant）
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# OTLP / 観測性
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=tier1-facade-dev

# -----------------------------------------------------------------------------
# Dev Container 切替（オプション）
# -----------------------------------------------------------------------------
# postCreate.sh が参照する。デフォルト: docs-writer
# 値: docs-writer / tier1-rust-dev / tier1-go-dev / tier2-dev / tier3-web-dev /
#     tier3-native-dev / platform-cli-dev / sdk-dev / infra-ops / full
K1S0_DEV_ROLE=docs-writer

# local-stack の起動制御
# 1: スキップ / 0 or 未設定: foreground 起動
K1S0_SKIP_LOCAL_STACK=0
# 1: バックグラウンド起動（log は .devcontainer/.log/local-stack-up.log へ）
K1S0_LOCAL_STACK_BG=0

# -----------------------------------------------------------------------------
# SOPS（オプション、values 暗号解除に必要な開発者）
# -----------------------------------------------------------------------------
# age recipient のローカル鍵パス。リポジトリ外を指す。
# SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
