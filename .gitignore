# ============================================================
# k1s0 セットアップツール .gitignore
# 対象: Rust workspace / Tauri / React / Node.js / Windows
# ============================================================

# ------------------------------------------------------------
# Rust ビルド成果物
# ------------------------------------------------------------
# Cargoのビルド出力ディレクトリ（全 workspace 共通）
target/
# Cargo のロックファイル（lib のみの crate では .gitignore する慣習だが、本リポジトリは
# モノレポで bin / lib 両方を含むため、各 workspace の Cargo.lock はそれぞれの
# 既存方針に従う。新規生成は examples/ 配下のみ）
examples/tier1-rust-service/Cargo.lock
src/platform/scaffold/Cargo.lock
# レガシーで残されたパス（互換のため重複記載）
setup/target/

# ------------------------------------------------------------
# .NET ビルド成果物
# ------------------------------------------------------------
# csproj 配下の bin / obj
**/bin/
**/obj/
# Visual Studio ローカル設定
.vs/

# ------------------------------------------------------------
# Go ビルド成果物
# ------------------------------------------------------------
# 例 main package を `go build` で生成した実行ファイル
examples/tier1-go-facade/example-facade
examples/tier3-bff-graphql/example-bff
examples/tier2-go-service/example-service

# ------------------------------------------------------------
# Node.js / npm
# ------------------------------------------------------------
# npmパッケージのインストールディレクトリ
node_modules/
# npmのデバッグログ
npm-debug.log*
# yarnのデバッグログ
yarn-debug.log*
# yarnのエラーログ
yarn-error.log*
# pnpmのログ
pnpm-debug.log*

# ------------------------------------------------------------
# フロントエンド ビルド成果物
# ------------------------------------------------------------
# Viteのプロダクションビルド出力（setup gui / tier3 web 全般）
setup/gui/dist/
src/tier3/web/apps/*/dist/
src/tier3/web/packages/*/dist/
# 例外: src/sdk/typescript/dist/ は npm 配布物として意図的にコミットする
# Vitestのカバレッジレポート
setup/gui/coverage/
**/coverage/

# ------------------------------------------------------------
# Tauri 固有
# ------------------------------------------------------------
# Tauriのバンドル時に自動ダウンロードされるWiXツール（Windows）
setup/gui/src-tauri/WixTools/
# Tauriのモバイル向け自動生成コード（Android/iOS）
setup/gui/src-tauri/gen/
# Tauriのバンドル成果物
setup/gui/src-tauri/target/

# ------------------------------------------------------------
# 環境変数・シークレット
# ------------------------------------------------------------
# ローカル環境変数ファイル
.env
# 環境別ローカル環境変数ファイル
.env.local
.env.*.local
# Dev Container ローカル環境変数（OpenBao dev token 等）
.devcontainer/.env.local
# postCreate / local-stack 起動ログ
.devcontainer/.log/

# ------------------------------------------------------------
# OS 生成ファイル
# ------------------------------------------------------------
# macOS のメタデータファイル
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows のサムネイルキャッシュ
Thumbs.db
ehthumbs.db
desktop.ini
# Windows のショートカットファイル
*.lnk

# ------------------------------------------------------------
# IDE・エディタ
# ------------------------------------------------------------
# JetBrains IDE（IntelliJ / CLion / RustRover など）
.idea/
*.iml
# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
# Visual Studio Code（個人設定は除外、共有設定は含める）
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
# Claude Code（個人設定は除外、共有設定・skill・command・hook は含める）
.claude/settings.local.json
# /audit コマンドの生証跡（肥大化するためコミット対象外、AUDIT.md に集計のみ反映）
.claude/audit-evidence/
# Vim / Neovim のスワップファイル
*.swp
*.swo
*~

# ------------------------------------------------------------
# Python 系生成物
# ------------------------------------------------------------
# Python のバイトコードキャッシュ
__pycache__/
*.py[cod]
*$py.class
# Python の型チェッカ・テストキャッシュ
.mypy_cache/
.ruff_cache/
.pytest_cache/
# Python venv（ローカル開発用、コミット対象外）
.venv/
venv/

# ------------------------------------------------------------
# ログ・一時ファイル
# ------------------------------------------------------------
# 汎用ログファイル
*.log
# 一時ファイル
*.tmp
*.temp
docs/99_壁打ち/*
plan/*
