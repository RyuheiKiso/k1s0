# ============================================================
# k1s0 セットアップツール .gitignore
# 対象: Rust workspace / Tauri / React / Node.js / Windows
# ============================================================

# ------------------------------------------------------------
# Rust ビルド成果物
# ------------------------------------------------------------
# Cargoのビルド出力ディレクトリ（ワークスペース共有）
setup/target/

# ------------------------------------------------------------
# Node.js / npm
# ------------------------------------------------------------
# npmパッケージのインストールディレクトリ
node_modules/
# npmのデバッグログ
npm-debug.log*
# yarnのデバッグログ
yarn-debug.log*
# yarnのエラーログ
yarn-error.log*
# pnpmのログ
pnpm-debug.log*

# ------------------------------------------------------------
# フロントエンド ビルド成果物
# ------------------------------------------------------------
# Viteのプロダクションビルド出力
setup/gui/dist/
# Vitestのカバレッジレポート
setup/gui/coverage/

# ------------------------------------------------------------
# Tauri 固有
# ------------------------------------------------------------
# Tauriのバンドル時に自動ダウンロードされるWiXツール（Windows）
setup/gui/src-tauri/WixTools/
# Tauriのモバイル向け自動生成コード（Android/iOS）
setup/gui/src-tauri/gen/
# Tauriのバンドル成果物
setup/gui/src-tauri/target/

# ------------------------------------------------------------
# 環境変数・シークレット
# ------------------------------------------------------------
# ローカル環境変数ファイル
.env
# 環境別ローカル環境変数ファイル
.env.local
.env.*.local

# ------------------------------------------------------------
# OS 生成ファイル
# ------------------------------------------------------------
# macOS のメタデータファイル
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows のサムネイルキャッシュ
Thumbs.db
ehthumbs.db
desktop.ini
# Windows のショートカットファイル
*.lnk

# ------------------------------------------------------------
# IDE・エディタ
# ------------------------------------------------------------
# JetBrains IDE（IntelliJ / CLion / RustRover など）
.idea/
*.iml
# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
# Visual Studio Code（個人設定は除外、共有設定は含める）
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
# Vim / Neovim のスワップファイル
*.swp
*.swo
*~

# ------------------------------------------------------------
# ログ・一時ファイル
# ------------------------------------------------------------
# 汎用ログファイル
*.log
# 一時ファイル
*.tmp
*.temp
docs/99_壁打ち/*
