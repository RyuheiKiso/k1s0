{
  "uid": "k1s0-consensus-alerts",
  "title": "k1s0 Consensus Alerts",
  "description": "Alert rules for consensus monitoring: leader absence, lock timeout rate, saga dead letters, heartbeat failures",
  "tags": ["k1s0", "consensus", "alerts"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Alert: No Leader Elected",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k1s0_leader_is_leader) by (lease_key)",
          "legendFormat": "{{lease_key}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "No Leader Elected",
        "conditions": [
          {
            "evaluator": { "params": [1], "type": "lt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "2m",
        "frequency": "30s",
        "noDataState": "alerting",
        "notifications": [],
        "message": "No leader is elected for the given lease key. All nodes report is_leader=0. Singleton tasks may not be running."
      }
    },
    {
      "id": 2,
      "title": "Alert: Lock Acquisition Timeout Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k1s0_lock_acquisitions_total{result=\"timeout\"}[5m])) / (sum(rate(k1s0_lock_acquisitions_total[5m])) + 1)",
          "legendFormat": "Timeout Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.3 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "Lock Timeout Rate High",
        "conditions": [
          {
            "evaluator": { "params": [0.1], "type": "gt" },
            "operator": { "type": "or" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [],
        "message": "Lock acquisition timeout rate exceeds 10%. Possible contention or deadlock."
      }
    },
    {
      "id": 3,
      "title": "Alert: Saga Dead Letter Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(k1s0_saga_dead_letter_count) by (saga_type)",
          "legendFormat": "{{saga_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "Saga Dead Letter Count High",
        "conditions": [
          {
            "evaluator": { "params": [5], "type": "gt" },
            "operator": { "type": "or" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [],
        "message": "Saga dead letter count exceeds threshold. Compensation failures require manual investigation."
      }
    },
    {
      "id": 4,
      "title": "Alert: Heartbeat Failure Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k1s0_leader_heartbeat_failures_total[5m])) by (lease_key)",
          "legendFormat": "{{lease_key}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "Heartbeat Failure Rate High",
        "conditions": [
          {
            "evaluator": { "params": [1], "type": "gt" },
            "operator": { "type": "or" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "2m",
        "frequency": "30s",
        "noDataState": "no_data",
        "notifications": [],
        "message": "Leader heartbeat failure rate is elevated. Leader may lose lease and failover could occur."
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
