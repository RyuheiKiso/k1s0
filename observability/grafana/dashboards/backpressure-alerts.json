{
  "uid": "k1s0-backpressure-alerts",
  "title": "k1s0 Backpressure Alerts",
  "description": "Alert rules for backpressure monitoring: queue depth, rejection rate, event bus lag, DB pool saturation",
  "tags": ["k1s0", "backpressure", "alerts"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Alert: Queue Depth > 80% Capacity (Warning)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "k1s0_cache_write_behind_queue_depth / k1s0_cache_write_behind_queue_capacity",
          "legendFormat": "{{cache_name}}"
        },
        {
          "refId": "B",
          "expr": "k1s0_event_bus_queue_depth / 1024",
          "legendFormat": "event_bus:{{bus_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "Queue Depth High",
        "conditions": [
          {
            "evaluator": { "params": [0.8], "type": "gt" },
            "operator": { "type": "or" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [],
        "message": "Queue depth exceeds 80% capacity. Warning threshold reached."
      }
    },
    {
      "id": 2,
      "title": "Alert: Rejection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k1s0_rate_limit_requests_total{result=\"rejected\"}[5m])) / sum(rate(k1s0_rate_limit_requests_total[5m]))",
          "legendFormat": "Rate Limit Rejection Rate"
        },
        {
          "refId": "B",
          "expr": "sum(rate(k1s0_event_bus_rejected_total[5m])) / (sum(rate(k1s0_event_bus_rejected_total[5m])) + sum(rate(k1s0_event_bus_queue_depth[5m])) + 1)",
          "legendFormat": "Event Bus Rejection Rate"
        },
        {
          "refId": "C",
          "expr": "sum(rate(k1s0_cache_write_behind_rejected_total[5m])) / (sum(rate(k1s0_cache_write_behind_enqueue_total[5m])) + 1)",
          "legendFormat": "Cache Write-Behind Rejection Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "Rejection Rate High",
        "conditions": [
          {
            "evaluator": { "params": [0.1], "type": "gt" },
            "operator": { "type": "or" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [],
        "message": "Rejection rate exceeds 10%. Warning: system is rejecting requests."
      }
    },
    {
      "id": 3,
      "title": "Alert: Event Bus Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(k1s0_event_bus_lagged_total[5m])) by (bus_name)",
          "legendFormat": "lag:{{bus_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "Event Bus Lag High",
        "conditions": [
          {
            "evaluator": { "params": [100], "type": "gt" },
            "operator": { "type": "or" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [],
        "message": "Event bus lag exceeds 100 events. Consumers may be falling behind."
      }
    },
    {
      "id": 4,
      "title": "Alert: DB Pool Waiting Saturation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "k1s0_db_pool_waiting_count / (k1s0_db_pool_active_connections + k1s0_db_pool_idle_connections + k1s0_db_pool_waiting_count + 1)",
          "legendFormat": "waiting_ratio:{{pool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "alert": {
        "name": "DB Pool Waiting High",
        "conditions": [
          {
            "evaluator": { "params": [0.8], "type": "gt" },
            "operator": { "type": "or" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [],
        "message": "DB pool waiting ratio exceeds 80%. Connection pool may be saturated."
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
