      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(k1s0_leader_lease_duration_seconds_bucket[5m])) by (le, lease_key))",
