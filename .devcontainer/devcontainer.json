{
    "name": "k1s0 dev (tier1-rust-dev profile, Phase 1 bootstrap)",
    "build": {
        "dockerfile": "../tools/devcontainer/profiles/tier1-rust-dev/Dockerfile",
        "context": ".."
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/go:1": {
            "version": "1.24"
        },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "latest",
            "helm": "latest",
            "minikube": "none"
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "bash tools/devcontainer/postCreate.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "vadimcn.vscode-lldb",
                "tamasfe.even-better-toml",
                "fill-labs.dependi",
                "zxh404.vscode-proto3",
                "bufbuild.vscode-buf",
                "golang.go",
                "ms-azuretools.vscode-docker",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "redhat.vscode-yaml",
                "EditorConfig.EditorConfig"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.rulers": [100],
                "files.insertFinalNewline": true,
                "files.trimTrailingWhitespace": true,
                "rust-analyzer.check.command": "clippy",
                "[rust]": {
                    "editor.defaultFormatter": "rust-lang.rust-analyzer"
                }
            }
        }
    },
    "mounts": [
        "source=k1s0-cargo-registry,target=/usr/local/cargo/registry,type=volume",
        "source=k1s0-cargo-git,target=/usr/local/cargo/git,type=volume",
        "source=k1s0-target,target=${containerWorkspaceFolder}/target,type=volume"
    ]
}
