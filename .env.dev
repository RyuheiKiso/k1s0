# .env.dev — ローカル開発環境専用の環境変数
#
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# !! WARNING: このファイルはローカル開発専用です。             !!
# !! 本番環境・CI では絶対に使用しないでください。             !!
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#
# 【重要】docker-compose.dev.yaml との役割分担
#
#   docker-compose.yaml 内の ${VAR:?error} 構文は「ホスト環境変数の interpolation」として
#   Docker Compose がファイルを読み込む時点で評価されます。
#   docker-compose.dev.yaml の environment セクションは「コンテナ環境変数」を設定するものであり、
#   上記の interpolation タイミングより後に処理されるため、:? エラーを抑制できません。
#
#   そのため、docker-compose.dev.yaml だけでは起動できない問題が発生していました。
#   このファイル (.env.dev) を --env-file オプションで渡すことで、
#   Docker Compose がファイル読み込み前にホスト環境変数として展開し、正しく動作します。
#
# 使用方法:
#   just local-up          # 自動で --env-file .env.dev が適用される
#   または:
#   docker compose --env-file .env.dev -f docker-compose.yaml -f docker-compose.dev.yaml \
#     --profile infra --profile system up -d
#
# このファイルはリポジトリに含めています（開発専用の固定値のみ記載）。
# 実際の秘密情報は Vault / Kubernetes Secrets で管理してください。

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_PASSWORD=dev
# INFRA-HIGH-003 対応: dev スーパーユーザーの認証情報を変数として一元管理する
# docker-compose.dev.yaml の DATABASE_URL から直接パスワードを除去し、この変数を参照する
DEV_DB_USER=dev
DEV_DB_PASSWORD=dev
# k1s0 アプリケーションユーザーのパスワード（infra/docker/init-db/00-create-app-user.sh で参照）
K1S0_DB_PASSWORD=dev-k1s0-local

# ============================================================
# Redis（キャッシュ用）
# ============================================================
REDIS_PASSWORD=dev

# ============================================================
# Redis（セッション用）
# ============================================================
REDIS_SESSION_PASSWORD=dev

# ============================================================
# Keycloak
# ============================================================
KC_DB_PASSWORD=dev
KEYCLOAK_ADMIN_PASSWORD=dev
KC_BFF_CLIENT_SECRET=dev-bff-secret
KC_SERVICE_CLIENT_SECRET=dev-service-secret
# H-015 監査対応: auth-rust-admin クライアントのシークレット変数を追加
# realm-k1s0.json の ${KC_AUTH_ADMIN_SECRET:-dev-service-secret} で参照される
KC_AUTH_ADMIN_SECRET=dev-service-secret
KC_TEST_ADMIN_PASSWORD=admin123
KC_TEST_USER_PASSWORD=user123
KC_TEST_TASK_MGR_PASSWORD=task123

# ============================================================
# Vault（dev モード: インメモリ。本番では絶対使用不可）
# ============================================================
VAULT_DEV_ROOT_TOKEN_ID=dev-token

# ============================================================
# Grafana
# ============================================================
GF_SECURITY_ADMIN_PASSWORD=dev

# ============================================================
# Prometheus（CRIT-004 対応: Basic Auth ヘルスチェック用）
# ============================================================
# web.yml に設定した prometheus_admin ユーザーのパスワード（開発環境専用固定値）
# healthcheck コマンドが /-/healthy に認証付きでアクセスするために使用する
# 本番環境では Vault から注入し、必ず強力なパスワードを使用すること
PROMETHEUS_ADMIN_PASSWORD=prometheus_admin

# ============================================================
# DEV_ENV_GUARD（LOW-002 対応: --env-file 省略検出用ガード変数）
# ============================================================
# この変数は docker-compose.dev.yaml のパース時に評価される。
# --env-file .env.dev を指定せずに docker-compose.dev.yaml を使用した場合、
# Docker Compose は「DEV_ENV_GUARD が設定されていません」エラーで即時終了する。
# この変数の値自体に意味はなく、存在確認のためのみに使用する。
DEV_ENV_GUARD=true

# ============================================================
# Docker Compose ビルド設定（C-7 監査対応）
# ============================================================
# Docker 並列ビルド数を制限してメモリ不足（OOM）によるクラッシュを防ぐ
# デフォルトでは CPU コア数に比例するが、大規模モノリポでは OOM になりやすいため制限する
# 注意: COMPOSE_PARALLEL_LIMIT は `up` のみに効果があり `build` には効果がない（HIGH-2 監査対応）
#      ビルド時は `just docker-build-safe` (--parallel 2) を使用すること
COMPOSE_PARALLEL_LIMIT=4

# ============================================================
# BFF セッション暗号化設定（MED-8 監査対応）
# ============================================================
# bff-proxy はこの値が設定されていない場合、セッションデータを Redis に平文で保存する。
# 本番環境では必ず openssl rand -hex 32 で生成したランダム値に変更すること
# 生成コマンド: openssl rand -hex 32
# H-06 監査対応: オールゼロキーを開発用固定値に変更（本番では必ずランダム値を使用すること）
# L-01 監査対応: パターン値から openssl rand -hex 32 生成のランダム値に変更する
SESSION_ENCRYPTION_KEY=e29fee9b9d9fef45b65e6265b11fb2bb6b1e34c301e0e929e2917a5344c20f28

# ============================================================
# notification ポート設定（MED-15 監査対応）
# ============================================================
# デフォルト 8100 は macOS の XGRID サービス（ポート 8100）と衝突する可能性があるため、
# ローカル開発では 8122 に明示設定してポート競合を解消する。
NOTIFICATION_REST_HOST_PORT=8122

# ============================================================
# API Key ペッパー（HIGH-02 監査対応）
# ============================================================
# auth-rust の API キー HMAC-SHA256 ハッシュに使用するペッパー値。
# 本番環境では Vault から注入し、openssl rand -hex 32 で生成した値を使用すること。
# 以下はローカル開発専用の固定値であり、本番環境では絶対に使用しないこと。
API_KEY_PEPPER=k1s0-dev-pepper-do-not-use-in-production

# ============================================================
# gRPC ポート上書き（Hyper-V 動的除外範囲 50165-50264 回避）
# ============================================================
# デフォルトの 50200-50205 が Windows 除外ポート範囲に含まれるため 50300 番台に移動する
EVENT_MONITOR_GRPC_HOST_PORT=50300
MASTER_MAINTENANCE_GRPC_HOST_PORT=50301
NAVIGATION_GRPC_HOST_PORT=50302
POLICY_GRPC_HOST_PORT=50303
RULE_ENGINE_GRPC_HOST_PORT=50304
SESSION_GRPC_HOST_PORT=50305
