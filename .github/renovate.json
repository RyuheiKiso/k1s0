{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate 依存自動更新設定。Docker・Rust・GitHub Actions・Node.js の依存を自動更新し、patch/minor は自動マージする。",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "group:allNonMajor"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": ["every weekend"],
  "labels": ["dependencies"],
  "assignAutomerge": true,
  "packageRules": [
    {
      "description": "Docker base image の自動更新（digest pinning によるセキュアな固定）",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["digest", "patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "docker base images"
    },
    {
      "description": "Rust クレートの週次自動更新（patch・minor のみ自動マージ）",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "schedule": ["every weekend"],
      "groupName": "rust crates (non-major)"
    },
    {
      "description": "Rust major バージョン更新は自動マージしない（破壊的変更の可能性があるため手動レビューを要求）",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "groupName": "rust crates (major)"
    },
    {
      "description": "GitHub Actions の自動更新（patch・minor のみ自動マージ）",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "github actions"
    },
    {
      "description": "Node.js パッケージの patch 更新は自動マージ（依存関係の安定性を維持）",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "npm patch updates"
    },
    {
      "description": "Node.js パッケージの minor 更新は自動マージ（後方互換性を持つ機能追加）",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "npm minor updates"
    },
    {
      "description": "Node.js major バージョン更新は手動レビューが必要（破壊的変更の可能性があるため）",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "groupName": "npm major updates"
    },
    {
      "description": "Go モジュールの patch・minor 更新は自動マージ",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "go modules (non-major)"
    },
    {
      "description": "Go モジュールの major 更新は手動レビューが必要",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "groupName": "go modules (major)"
    },
    {
      "description": "Dart/Flutter パッケージの patch・minor 更新は自動マージ",
      "matchManagers": ["pub"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "dart/flutter packages (non-major)"
    },
    {
      "description": "Dart/Flutter パッケージの major 更新は手動レビューが必要",
      "matchManagers": ["pub"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "groupName": "dart/flutter packages (major)"
    },
    {
      "description": "セキュリティ脆弱性修正は即時自動マージ（スケジュールを無視して適用）",
      "matchUpdateTypes": ["patch"],
      "isVulnerabilityAlert": true,
      "automerge": true,
      "schedule": ["at any time"],
      "labels": ["dependencies", "security"]
    }
  ],
  "vulnerabilityAlerts": {
    "description": "セキュリティ脆弱性アラートは即時対応するため自動マージを有効化",
    "automerge": true,
    "schedule": ["at any time"],
    "labels": ["dependencies", "security"]
  },
  "docker": {
    "description": "Docker イメージは digest pinning を有効化してセキュアなイメージ固定を行う",
    "pinDigests": true
  },
  "cargo": {
    "description": "Cargo.lock の更新も追跡してセキュリティ修正を確実に取り込む",
    "rangeStrategy": "update-lockfile"
  },
  "npm": {
    "description": "package-lock.json または pnpm-lock.yaml の更新も追跡する",
    "rangeStrategy": "update-lockfile"
  },
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "rebaseWhen": "behind-base-branch",
  "reviewers": [],
  "baseBranches": ["main"]
}
