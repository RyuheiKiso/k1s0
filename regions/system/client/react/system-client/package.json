{
  "name": "system-client",
  "version": "0.1.0",
  "description": "System-tier shared client SDK for authentication, API client, routing guard, and common components.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/system-client.umd.js",
  "module": "./dist/system-client.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/system-client.js",
      "require": "./dist/system-client.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.57.15",
    "axios": "^1.7.7",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "axios-mock-adapter": "^2.0.0",
    "eslint": "^9.10.0",
    "globals": "^15.0.0",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "msw": "^2.4.9",
    "prettier": "^3.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.5.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.0.0"
  }
}
