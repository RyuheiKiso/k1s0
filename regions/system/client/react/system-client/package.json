{
  "name": "system-client",
  "version": "0.1.0",
  "description": "System-tier shared client SDK for authentication, API client, routing guard, and common components.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/system-client.umd.js",
  "module": "./dist/system-client.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/system-client.js",
      "require": "./dist/system-client.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.167.5",
    "axios": "^1.13.6",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.28.0",
    "globals": "^17.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.0",
    "msw": "^2.12.13",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
