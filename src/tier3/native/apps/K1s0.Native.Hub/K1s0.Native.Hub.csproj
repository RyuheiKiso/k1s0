<!--
  K1s0.Native.Hub: 配信ハブ MAUI アプリ。

  docs 正典:
    docs/05_実装/00_ディレクトリ設計/40_tier3レイアウト/03_maui_native配置.md

  scope（リリース時点 minimum）:
    TargetFrameworks に net8.0-android / net8.0-ios の 2 platform のみ。
    Windows / MacCatalyst は採用初期 で追加する（multi-target 拡張）。
-->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0-android;net8.0-ios</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>K1s0.Native.Hub</RootNamespace>
    <AssemblyName>K1s0.Native.Hub</AssemblyName>
    <ApplicationTitle>k1s0 Hub</ApplicationTitle>
    <ApplicationId>io.k1s0.native.hub</ApplicationId>
    <ApplicationIdGuid>2e5f8a14-0001-0000-0000-000000000001</ApplicationIdGuid>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationDisplayVersion>0.1.0</ApplicationDisplayVersion>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <SupportedOSPlatformVersion Condition="'$(TargetFramework)' == 'net8.0-ios'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="'$(TargetFramework)' == 'net8.0-android'">21.0</SupportedOSPlatformVersion>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" />
    <PackageReference Include="Microsoft.Maui.Controls.Compatibility" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" />
    <PackageReference Include="CommunityToolkit.Maui" />
    <PackageReference Include="CommunityToolkit.Mvvm" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\shared\K1s0.Native.Shared\K1s0.Native.Shared.csproj" />
  </ItemGroup>
</Project>
