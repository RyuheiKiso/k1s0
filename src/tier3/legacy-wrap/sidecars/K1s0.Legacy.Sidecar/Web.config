<?xml version="1.0" encoding="utf-8"?>
<!--
  K1s0.Legacy.Sidecar の Web.config。

  docs 正典:
    docs/05_実装/00_ディレクトリ設計/40_tier3レイアウト/05_レガシーラップ配置.md
-->
<configuration>
  <appSettings>
    <!-- Dapr sidecar の HTTP API endpoint（Pod 内 localhost）。 -->
    <add key="DaprHttpEndpoint" value="http://localhost:3500" />
    <!-- k1s0 State の Component 名（Dapr Component CRD の metadata.name）。 -->
    <add key="K1s0StateStore" value="postgres" />
    <!-- ログレベル（Trace / Information / Warning / Error）。 -->
    <add key="LogLevel" value="Information" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" />
  </system.web>
  <system.webServer>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
