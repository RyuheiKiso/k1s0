<!--
  k1s0 依存方向 Roslyn Analyzer 本体。
  netstandard2.0 で build し、Microsoft.CodeAnalysis.CSharp 経由で
  個別 `using` 文 / SimpleNameSyntax を解析する。

  本 csproj 自体は library であり、NuGet 配布は K1s0.DependencyDirection.Analyzer.Package
  csproj から analyzers/dotnet/cs/ にコピーする形で行う。
-->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>K1s0.DependencyDirection.Analyzer</RootNamespace>
    <AssemblyName>K1s0.DependencyDirection.Analyzer</AssemblyName>
    <!-- analyzer は実行時 DLL ではなく Roslyn host が ロードする -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <DevelopmentDependency>true</DevelopmentDependency>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <!--
      NuGet パッケージング自体は K1s0.DependencyDirection.Analyzer.Package が担当する。
      本 csproj は内部 assembly 提供のみで、Package 側と PackageId が衝突しないよう
      明示的に別 ID（.AssemblyOnly）を割り当て、IsPackable=false で pack 自体を抑止する。
      これにより NuGet restore の "Ambiguous project name" を回避する。
    -->
    <PackageId>K1s0.DependencyDirection.Analyzer.AssemblyOnly</PackageId>
    <IsPackable>false</IsPackable>
    <!-- Roslyn analyzer プロジェクト用の拡張ルール（RS1036 等）を有効化 -->
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.11.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.11.0" PrivateAssets="all" />
  </ItemGroup>

  <!-- Analyzer Release Tracking 必須ファイル（RS2008 / RS2009） -->
  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>
</Project>
