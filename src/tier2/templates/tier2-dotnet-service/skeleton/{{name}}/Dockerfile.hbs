# {{name}} multi-stage Dockerfile（ASP.NET Core 8.0 runtime）。
# k1s0-scaffold が生成。distroless 化は採用初期 で検討（ASP.NET runtime image でも nonroot 可）。

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY . .
RUN dotnet restore "{{namespace}}.csproj" && \
    dotnet publish "{{namespace}}.csproj" -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 8080
ENTRYPOINT ["dotnet", "{{namespace}}.dll"]
