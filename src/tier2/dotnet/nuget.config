<?xml version="1.0" encoding="utf-8"?>
<!--
  tier2 .NET 用 NuGet ソース定義。

  docs 正典:
    docs/05_実装/00_ディレクトリ設計/30_tier2レイアウト/02_dotnet_solution配置.md

  運用:
    - リリース時点 では nuget.org のみ。社内パッケージ（K1s0.Sdk）は ProjectReference で参照
    - 運用蓄積後 で GitHub Packages / 社内プライベートに移行（K1s0.Sdk を NuGet 取得に切替）
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
